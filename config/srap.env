# Self-Report Alignment Protocol Configuration
# Phase B Shadow Mode

# Enable SRAP checking (1 = enabled, 0 = disabled)
SRAP_ENABLED=1

# Mode: shadow (log only) or enforced (block ERRORs)
SRAP_MODE=shadow

# Shadow log path (default: artifacts/self_report/shadow_log.jsonl)
# SRAP_SHADOW_LOG=/path/to/custom/log.jsonl

# Manual review sample rate (default: 0.1 = 10%)
# SRAP_SAMPLE_RATE=0.1
