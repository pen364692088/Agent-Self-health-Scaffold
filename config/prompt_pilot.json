{
  "pilot_enabled": false,
  "pilot_mode": "shadow",
  "allowed_events": [
    "recovery_success",
    "task_ready_to_close",
    "gate_completed"
  ],
  "blocked_events": [
    "subagent_spawn",
    "external_api_call",
    "user_message"
  ],
  "authority_chain": {
    "prompt": "main_chain",
    "recovery": "main_chain"
  },
  "fallback_on_error": true,
  
  "_comment": "=== DUAL GATE CONFIGURATION ===",
  "dual_gate": {
    "shadow_to_pilot": {
      "min_samples": 20,
      "max_days": 7,
      "required_conditions": [
        "all_stop_conditions_pass",
        "conflict_rate_ok",
        "match_rate_ok",
        "fallback_rate_ok"
      ]
    },
    "pilot_to_decision": {
      "min_samples": 30,
      "max_days": 14,
      "possible_decisions": [
        "expand_prompt_pilot",
        "continue_pilot_and_patch_gaps",
        "escalate_to_phase_3"
      ]
    }
  },
  
  "_comment_stop_conditions": "=== STOP CONDITIONS (violations trigger auto-disable) ===",
  "stop_conditions": {
    "max_conflict_rate": 0.05,
    "max_missing_rate": 0.05,
    "min_match_rate": 0.80,
    "max_token_overhead": 0.30,
    "max_fallback_rate": 0.10,
    "max_manual_override_rate": 0.05,
    "min_provenance_completeness": 0.95
  },
  
  "_comment_rollback": "=== ROLLBACK TRIGGERS ===",
  "rollback_trigger": {
    "manual": true,
    "auto_on_violation": true,
    "auto_on_error_spike": true
  },
  
  "_comment_scope": "=== PILOT SCOPE CONSTRAINTS (cannot be changed without code review) ===",
  "pilot_scope": {
    "can_influence_prompt_assembly": true,
    "can_influence_context_selection": true,
    "cannot_decide_task_close": true,
    "cannot_decide_gate_pass": true,
    "final_authority": "main_chain"
  },
  
  "pilot_start_time": null,
  
  "_comment_metrics": "=== METRICS (AUTHORITATIVE SOURCE) ===",
  "_comment_metrics_note": "metrics.effective_samples is the AUTHORITATIVE count for gate decisions",
  "_comment_display_note": "effective_sample_count at root level is DERIVED from metrics.effective_samples for display only",
  
  "metrics": {
    "total_calls": 0,
    "effective_samples": 0,
    "successful_calls": 0,
    "fallback_calls": 0,
    "error_calls": 0,
    "manual_overrides": 0,
    "user_visible_anomalies": 0,
    "avg_match_rate": 0.0,
    "avg_conflict_rate": 0.0,
    "avg_missing_rate": 0.0,
    "avg_token_overhead": 0.0,
    "avg_fallback_rate": 0.0,
    "avg_manual_override_rate": 0.0,
    "avg_provenance_completeness": 0.0,
    "recent_stop_condition_hits": []
  },
  
  "_comment_derived": "=== DERIVED FIELDS (for display/convenience, not authoritative) ===",
  "effective_sample_count": 0
}
