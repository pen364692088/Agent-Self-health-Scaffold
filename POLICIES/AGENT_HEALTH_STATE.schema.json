{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/agent-health-state.v1.json",
  "title": "Agent Health State",
  "description": "Unified health state for OpenClaw agent health governance",
  "type": "object",
  "required": ["timestamp", "overall_status", "components"],
  "properties": {
    "timestamp": { "type": "string", "format": "date-time" },
    "session_key": { "type": "string" },
    "overall_status": { "type": "string", "enum": ["GREEN", "YELLOW", "ORANGE", "RED"] },
    "mode": { "type": "string", "enum": ["quick", "deep", "gate"] },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["component", "status", "severity", "last_ok_at", "fail_count", "recovery_attempts", "recommended_action"],
        "properties": {
          "component": { "type": "string" },
          "status": { "type": "string", "enum": ["ok", "warning", "error", "unknown"] },
          "severity": { "type": "string", "enum": ["INFO", "WARN", "ERROR", "CRITICAL"] },
          "last_ok_at": { "type": ["string", "null"], "format": "date-time" },
          "last_fail_at": { "type": ["string", "null"], "format": "date-time" },
          "fail_count": { "type": "integer", "minimum": 0 },
          "recovery_attempts": { "type": "integer", "minimum": 0 },
          "latest_evidence": { "type": ["object", "string", "null"] },
          "recommended_action": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "context_usage_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "memory_usage_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "disk_usage_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "active_subagents": { "type": "integer", "minimum": 0 },
        "failed_subagents_last_hour": { "type": "integer", "minimum": 0 },
        "pending_inbox_items": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "previous_level": { "type": "string", "enum": ["GREEN", "YELLOW", "ORANGE", "RED"] },
    "active_incidents": { "type": "array", "items": { "type": "string" } },
    "last_heal_action": { "type": ["object", "null"] }
  }
}
