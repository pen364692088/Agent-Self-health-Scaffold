{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "execution_policy_rules.v1.schema.json",
  "title": "Execution Policy Rules Schema",
  "description": "Schema for validating execution policy rules",
  "type": "object",
  "required": ["metadata", "rules"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version", "created", "status"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "created": {
          "type": "string",
          "format": "date"
        },
        "status": {
          "type": "string",
          "enum": ["active", "deprecated", "testing"]
        },
        "description": {
          "type": "string"
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/rule"
      }
    },
    "path_patterns": {
      "type": "object",
      "properties": {
        "sensitive_paths": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/path_definition"
          }
        },
        "safe_tools_for_sensitive_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unsafe_tools_for_sensitive_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "decision_matrix": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/decision_config"
      }
    },
    "audit": {
      "$ref": "#/definitions/audit_config"
    },
    "gate_requirements": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/gate_config"
      }
    }
  },
  "definitions": {
    "rule": {
      "type": "object",
      "required": ["id", "status", "priority", "scope", "trigger", "action", "reason"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "status": {
          "type": "string",
          "enum": ["active", "deprecated", "testing"]
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2"]
        },
        "scope": {
          "type": "string",
          "enum": ["path", "action", "state", "operation"]
        },
        "trigger": {
          "$ref": "#/definitions/trigger"
        },
        "action": {
          "type": "string",
          "enum": ["deny", "reroute", "warn", "allow"]
        },
        "fallback": {
          "type": "string"
        },
        "reason": {
          "type": "string",
          "minLength": 10
        },
        "gate": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["A", "B", "C"]
          }
        },
        "audit": {
          "type": "boolean",
          "default": true
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "escalation": {
          "$ref": "#/definitions/escalation"
        }
      }
    },
    "trigger": {
      "type": "object",
      "properties": {
        "path_pattern": {
          "type": "string"
        },
        "operation": {
          "type": "string",
          "enum": ["read", "write", "replace", "delete"]
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tool": {
          "type": "string"
        },
        "action": {
          "type": "string"
        },
        "state": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "event": {
          "type": "string"
        },
        "state_changed": {
          "type": "boolean"
        },
        "persisted": {
          "type": "boolean"
        },
        "gate_passed": {
          "type": "boolean"
        },
        "content_type": {
          "type": "string"
        },
        "verify_and_close_called": {
          "type": "boolean"
        },
        "estimated_size_mb": {
          "type": "number"
        }
      }
    },
    "escalation": {
      "type": "object",
      "required": ["threshold", "action"],
      "properties": {
        "threshold": {
          "type": "integer",
          "minimum": 1
        },
        "action": {
          "type": "string",
          "enum": ["deny", "log", "notify"]
        }
      }
    },
    "path_definition": {
      "type": "object",
      "required": ["pattern", "description", "protection_level"],
      "properties": {
        "pattern": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "protection_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        }
      }
    },
    "decision_config": {
      "type": "object",
      "required": ["description", "log_level"],
      "properties": {
        "description": {
          "type": "string"
        },
        "log_level": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"]
        },
        "notify": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "audit_config": {
      "type": "object",
      "required": ["log_path", "retention_days", "format", "fields"],
      "properties": {
        "log_path": {
          "type": "string"
        },
        "retention_days": {
          "type": "integer",
          "minimum": 1
        },
        "format": {
          "type": "string",
          "enum": ["jsonl", "json", "csv"]
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "gate_config": {
      "type": "object",
      "required": ["description", "checks"],
      "properties": {
        "description": {
          "type": "string"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
