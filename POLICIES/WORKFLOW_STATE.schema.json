{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/workflow-state.v1.json",
  "title": "Workflow State",
  "description": "状态机真相源 - 工作流推进状态",
  "type": "object",
  "required": ["active", "workflow_type", "workflow_id", "steps", "created_at", "updated_at"],
  "properties": {
    "active": {
      "type": "boolean",
      "description": "工作流是否活跃"
    },
    "workflow_type": {
      "type": "string",
      "enum": ["serial", "parallel"],
      "description": "工作流类型"
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$",
      "maxLength": 100,
      "description": "工作流唯一标识"
    },
    "rev": {
      "type": "integer",
      "minimum": 0,
      "description": "版本号，每次更新递增"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/step"
      }
    },
    "notify_on_done": {
      "type": "string",
      "description": "完成时通知消息"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "创建时间 (ISO8601)"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "更新时间 (ISO8601)"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "完成时间 (ISO8601)"
    }
  },
  "definitions": {
    "step": {
      "type": "object",
      "required": ["id", "task", "model", "status"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$",
          "maxLength": 100,
          "description": "步骤唯一标识"
        },
        "task": {
          "type": "string",
          "description": "任务描述"
        },
        "model": {
          "type": "string",
          "description": "执行模型"
        },
        "run_id": {
          "type": ["string", "null"],
          "pattern": "^[a-zA-Z0-9_-]+$",
          "maxLength": 100,
          "description": "运行 ID"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "running", "done", "failed", "timeout"],
          "description": "步骤状态"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "spawned_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "advance_inflight": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "required": ["nonce", "at", "by"],
              "properties": {
                "nonce": {"type": "string"},
                "at": {"type": "string", "format": "date-time"},
                "by": {"type": "string"}
              }
            }
          ],
          "description": "推进中标记"
        },
        "advance_processed": {
          "type": "boolean",
          "description": "是否已推进"
        },
        "attempts": {
          "type": "integer",
          "minimum": 0,
          "description": "尝试次数"
        },
        "last_error": {
          "type": ["string", "null"],
          "description": "最后错误信息"
        },
        "backoff_until": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "format": "date-time"}
          ],
          "description": "退避到期时间"
        }
      }
    }
  }
}
