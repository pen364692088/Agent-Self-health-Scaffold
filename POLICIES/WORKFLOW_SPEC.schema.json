{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.ai/schemas/workflow-spec.v1.json",
  "title": "Workflow Spec",
  "description": "工作流规范 - 定义如何执行工作流",
  "type": "object",
  "required": ["workflow_id", "steps"],
  "properties": {
    "workflow_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$",
      "maxLength": 100,
      "description": "工作流唯一标识"
    },
    "workflow_type": {
      "type": "string",
      "enum": ["serial", "parallel"],
      "default": "serial",
      "description": "工作流类型"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/step"
      }
    },
    "limits": {
      "$ref": "#/definitions/limits"
    },
    "hooks": {
      "$ref": "#/definitions/hooks"
    }
  },
  "definitions": {
    "step": {
      "type": "object",
      "required": ["id", "payload"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$",
          "maxLength": 100
        },
        "kind": {
          "type": "string",
          "default": "spawn",
          "description": "步骤类型"
        },
        "payload": {
          "type": "object",
          "description": "Spawn 参数 (model, task, cwd, timeout, etc.)",
          "properties": {
            "model": {"type": "string"},
            "task": {"type": "string"},
            "cwd": {"type": "string"},
            "timeout": {"type": "integer"},
            "tags": {"type": "array", "items": {"type": "string"}}
          }
        },
        "depends_on": {
          "type": "array",
          "items": {"type": "string"},
          "description": "依赖的步骤 ID（用于并行工作流）"
        }
      }
    },
    "limits": {
      "type": "object",
      "description": "覆盖默认限制",
      "properties": {
        "max_advances_per_hour": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 100
        },
        "max_advances_per_workflow": {
          "type": "integer",
          "minimum": 1,
          "maximum": 500,
          "default": 50
        },
        "max_global_inflight": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 10
        },
        "rate_limit_per_sec": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 5
        }
      }
    },
    "hooks": {
      "type": "object",
      "description": "钩子配置",
      "properties": {
        "on_done": {
          "type": "object",
          "properties": {
            "notify": {
              "type": "object",
              "properties": {
                "channel": {"type": "string"},
                "message": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
