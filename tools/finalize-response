#!/usr/bin/env python3
"""
finalize-response v1.1 - Auto-wrap completion output with done-guard

遵循 OPENCLAW_EXECUTION_POLICY.md:
- 任何"完成总结"输出前，自动先过一遍 done-guard
- 不靠 agent 自己决定何时检查
- 把"发最终总结"这个动作本身包起来

v1.1: 支持环境变量配置工作区路径（CI 兼容）

Usage:
  finalize-response --task-id <id> --summary "..."
  finalize-response --task-id <id> --file output.md
  
Exit codes:
  0 - ALLOW: safe to output
  1 - BLOCK: must repair first
  2 - ERROR: invalid usage
"""

import argparse
import json
import sys
import os
import re
from pathlib import Path
from datetime import datetime
from typing import Tuple, List

# 动态检测工作区路径
def _detect_workspace() -> Path:
    """Detect workspace path from environment or script location."""
    env_workspace = os.environ.get("OPENCLAW_WORKSPACE")
    if env_workspace:
        return Path(env_workspace)
    
    script_path = Path(__file__).resolve()
    possible_workspace = script_path.parent.parent
    if (possible_workspace / "tools").exists():
        return possible_workspace
    
    cwd = Path.cwd()
    if (cwd / "tools").exists():
        return cwd
    
    default = Path("/home/moonlight/.openclaw/workspace")
    if default.exists():
        return default
    
    return possible_workspace

WORKSPACE = _detect_workspace()
DONE_GUARD = WORKSPACE / "tools" / "done-guard"
ARTIFACTS_DIR = WORKSPACE / "artifacts" / "receipts"
FINALIZE_LOG = WORKSPACE / "reports" / "finalize_log.jsonl"

# 伪完成模式 (复用 done-guard)
FAKE_COMPLETION_PATTERNS = [
    r"已完成", r"全部完成", r"可以交付", r"已可合并",
    r"已准备好关闭", r"所有阶段通过", r"基本完成",
    r"大体完成", r"核心已完成", r"主要功能完成"
]


def check_fake_completion(text: str) -> Tuple[bool, List[str]]:
    """Check if text contains fake completion phrases."""
    matches = []
    for pattern in FAKE_COMPLETION_PATTERNS:
        if re.search(pattern, text):
            matches.append(pattern)
    return len(matches) > 0, matches


def check_receipts_exist(task_id: str) -> Tuple[bool, List[str]]:
    """Check if all required receipts exist."""
    required = ["contract", "e2e", "preflight", "final"]
    missing = []
    
    for rtype in required:
        path = ARTIFACTS_DIR / f"{task_id}_{rtype}_receipt.json"
        if not path.exists():
            missing.append(rtype)
    
    return len(missing) == 0, missing


def log_finalize(task_id: str, allowed: bool, reason: str, details: dict = None):
    """Log finalize event."""
    try:
        FINALIZE_LOG.parent.mkdir(parents=True, exist_ok=True)
        
        entry = {
            "timestamp": datetime.now().isoformat(),
            "task_id": task_id,
            "allowed": allowed,
            "reason": reason
        }
        if details:
            entry["details"] = details
        
        with open(FINALIZE_LOG, "a") as f:
            f.write(json.dumps(entry) + "\n")
    except Exception:
        pass


def main():
    parser = argparse.ArgumentParser(description="finalize-response v1.1")
    parser.add_argument("--task-id", required=True, help="Task identifier")
    parser.add_argument("--summary", help="Summary text to check")
    parser.add_argument("--file", help="File containing summary")
    parser.add_argument("--json", action="store_true", help="JSON output")
    
    args = parser.parse_args()
    
    result = {
        "task_id": args.task_id,
        "action": "ALLOW"
    }
    
    # Get summary text
    text = ""
    if args.summary:
        text = args.summary
    elif args.file:
        try:
            text = Path(args.file).read_text()
        except Exception as e:
            result = {"action": "error", "message": str(e)}
            if args.json:
                print(json.dumps(result, indent=2))
            return 2
    
    # Check receipts
    receipts_ok, missing = check_receipts_exist(args.task_id)
    result["has_receipts"] = receipts_ok
    
    if not receipts_ok:
        result["action"] = "BLOCK"
        result["reason"] = "missing_receipts"
        result["missing"] = missing
    
    # Check fake completion
    if text and receipts_ok:
        has_fake, patterns = check_fake_completion(text)
        if has_fake:
            result["action"] = "BLOCK"
            result["reason"] = "fake_completion_detected"
            result["patterns"] = patterns
    
    # Log
    log_finalize(
        args.task_id,
        result["action"] == "ALLOW",
        result.get("reason", "passed"),
        {"has_receipts": receipts_ok}
    )
    
    if args.json:
        print(json.dumps(result, indent=2))
    else:
        if result["action"] == "ALLOW":
            print(f"✅ ALLOW: {args.task_id}")
            if text:
                print(f"\n{text}")
        else:
            print(f"❌ BLOCK: {result.get('reason', 'unknown')}")
    
    return 0 if result["action"] == "ALLOW" else 1


if __name__ == "__main__":
    sys.exit(main())
