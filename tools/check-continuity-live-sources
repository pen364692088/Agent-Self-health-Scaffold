#!/usr/bin/env python3
import json
import sys
from pathlib import Path

REPO = Path('/home/moonlight/Project/Github/MyProject/Agent-Self-health-Scaffold')
TOOLS = REPO / 'tools'
FORBIDDEN = ['memory/working-buffer.md', 'memory/SESSION-STATE.md']
IGNORE_SUFFIXES = {'.bak'}

hits = []
SELF_NAME = 'check-continuity-live-sources'

for path in sorted(TOOLS.iterdir()):
    if not path.is_file():
        continue
    if path.suffix in IGNORE_SUFFIXES:
        continue
    if path.name == SELF_NAME:
        continue
    try:
        text = path.read_text(encoding='utf-8', errors='ignore')
    except Exception:
        continue
    for needle in FORBIDDEN:
        if needle in text:
            hits.append({'file': str(path.relative_to(REPO)), 'forbidden_ref': needle})

result = {
    'status': 'ok' if not hits else 'fail',
    'forbidden_refs': FORBIDDEN,
    'hits': hits,
}
print(json.dumps(result, ensure_ascii=False, indent=2))
sys.exit(0 if not hits else 1)
