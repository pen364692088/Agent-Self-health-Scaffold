def save_config(config: dict) -> None:
    """Save pilot configuration."""
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_PATH, 'w') as f:
        json.dump(config, f, indent=2)


def log_event(event_type: str, details: dict) -> None:
    """Log a pilot event."""
    METRICS_PATH.parent.mkdir(parents=True, exist_ok=True)
    
    event = {
        "timestamp": datetime.now().isoformat(),
        "event_type": event_type,
        **details
    }
    
    with open(METRICS_PATH, 'a') as f:
        f.write(json.dumps(event) + '\n')


def get_effective_sample_count(config: dict) -> int:
    """
    Get count of effective samples from metrics log.
    
    An effective sample must meet ALL conditions:
    1. event_type == "prompt_pilot_call"
    2. task_type in allowed_events
    3. success == True
    4. is_effective_sample == True (added 2026-03-14, fixes gate calculation bug)
    5. no error
    """
    if not METRICS_PATH.exists():
        return 0
    
    count = 0
    allowed_events = config.get("allowed_events", [])
    
    with open(METRICS_PATH) as f:
        for line in f:
            try:
                event = json.loads(line)
                # Effective sample: ALL conditions must be met
                if (event.get("event_type") == "prompt_pilot_call" and
                    event.get("task_type") in allowed_events and
                    not event.get("error") and
                    event.get("success") and
                    event.get("is_effective_sample")):  # CRITICAL: must check this field
                    count += 1
            except:
                pass
    
    return count


def check_stop_conditions(config: dict) -> Tuple[List[str], List[str]]:
    """Check stop conditions. Returns (violations, warnings)."""
    violations = []
    warnings = []
    
    metrics = config.get("metrics", {})
    stop = config.get("stop_conditions", {})
    
    # Need at least 5 calls to check conditions meaningfully
    if metrics.get("effective_samples", 0) < 5:
        return violations, warnings
    
    # Check each stop condition
    if metrics.get("avg_conflict_rate", 0) > stop.get("max_conflict_rate", 0.05):
        violations.append(
            f"Conflict rate {metrics['avg_conflict_rate']:.1%} > {stop['max_conflict_rate']:.1%}"
        )
    
    if metrics.get("avg_missing_rate", 0) > stop.get("max_missing_rate", 0.05):
        violations.append(
            f"Missing rate {metrics['avg_missing_rate']:.1%} > {stop['max_missing_rate']:.1%}"
        )
    
    if metrics.get("avg_match_rate", 0) < stop.get("min_match_rate", 0.80):
        violations.append(
            f"Match rate {metrics['avg_match_rate']:.1%} < {stop['min_match_rate']:.1%}"
        )
    
    if metrics.get("avg_token_overhead", 0) > stop.get("max_token_overhead", 0.30):
        violations.append(
            f"Token overhead {metrics['avg_token_overhead']:.1%} > {stop['max_token_overhead']:.1%}"
        )
    
    # Check new conditions (warning level)
    if metrics.get("avg_fallback_rate", 0) > stop.get("max_fallback_rate", 0.10):
        violations.append(
            f"Fallback rate {metrics['avg_fallback_rate']:.1%} > {stop['max_fallback_rate']:.1%}"
        )
    
    if metrics.get("avg_manual_override_rate", 0) > stop.get("max_manual_override_rate", 0.05):
        violations.append(
            f"Manual override rate {metrics['avg_manual_override_rate']:.1%} > {stop['max_manual_override_rate']:.1%}"
        )
    
    if metrics.get("avg_provenance_completeness", 1.0) < stop.get("min_provenance_completeness", 0.95):
        warnings.append(
            f"Provenance completeness {metrics['avg_provenance_completeness']:.1%} < {stop['min_provenance_completeness']:.1%}"
        )
    
    return violations, warnings


def get_gate_status(config: dict) -> Dict[str, Any]:
    """Get gate status for shadow->pilot transition."""
    dual_gate = config.get("dual_gate", {})
    shadow_gate = dual_gate.get("shadow_to_pilot", {})
    
    min_samples = shadow_gate.get("min_samples", 20)
    max_days = shadow_gate.get("max_days", 7)
    
    effective_samples = get_effective_sample_count(config)
    
    # Check time elapsed
    start_time = config.get("pilot_start_time")
    days_elapsed = 0
    time_ok = True
    
    if start_time:
        start_dt = datetime.fromisoformat(start_time)
        days_elapsed = (datetime.now() - start_dt).days
        time_ok = days_elapsed <= max_days
    
    # Check stop conditions
    violations, warnings = check_stop_conditions(config)
    
    # Check key metrics
    metrics = config.get("metrics", {})
    conflict_ok = metrics.get("avg_conflict_rate", 0) <= 0.05
    match_ok = metrics.get("avg_match_rate", 1) >= 0.80
    fallback_ok = metrics.get("avg_fallback_rate", 0) <= 0.10
    
    # Determine eligibility
    samples_ok = effective_samples >= min_samples
    all_conditions_ok = len(violations) == 0 and conflict_ok and match_ok and fallback_ok
    
    eligible = samples_ok and time_ok and all_conditions_ok
    
    return {
        "min_samples_required": min_samples,
        "effective_samples": effective_samples,
        "samples_ok": samples_ok,
        "max_days": max_days,
        "days_elapsed": days_elapsed,
        "time_ok": time_ok,
        "violations": violations,
        "warnings": warnings,
        "conflict_ok": conflict_ok,
        "match_ok": match_ok,
        "fallback_ok": fallback_ok,
        "eligible_for_pilot": eligible
    }


def get_recommendation(config: dict, gate_status: Dict[str, Any]) -> str:
    """Get recommendation for next action."""
    if not config.get("pilot_enabled"):
        return "disabled"
    
    mode = config.get("pilot_mode", "shadow")
    
    if mode == "shadow":
        if gate_status["eligible_for_pilot"]:
            return "eligible_for_pilot"
        elif gate_status["violations"]:
            return "stay_shadow_fix_violations"
        elif not gate_status["samples_ok"]:
            return "stay_shadow_collect_samples"
        else:
            return "stay_shadow"
    
    elif mode == "pilot":
        # Check pilot->decision gate
        dual_gate = config.get("dual_gate", {})
        pilot_gate = dual_gate.get("pilot_to_decision", {})
        min_samples = pilot_gate.get("min_samples", 30)
        effective_samples = get_effective_sample_count(config)
        
        if effective_samples >= min_samples and not gate_status["violations"]:
            return "ready_for_decision"
        elif gate_status["violations"]:
            return "rollback_recommended"
        else:
            return "continue_pilot"
    
    return "unknown"


