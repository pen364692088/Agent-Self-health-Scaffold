        print(f"\n⚠️  STOP CONDITION VIOLATIONS:")
        for v in violations:
            print(f"  ❌ {v}")
    elif warnings:
        print(f"\n⚠️  WARNINGS:")
        for w in warnings:
            print(f"  ⚠️  {w}")
    else:
        print(f"\n✅ No stop condition violations")
    
    # Recommendation
    recommendation = get_recommendation(config, gate)
    
    print(f"\n--- Recommendation ---")
    if recommendation == "disabled":
        print("Status: DISABLED")
        print("Action: Run preflight, then enable shadow mode")
    elif recommendation == "stay_shadow":
        print("Status: SHADOW - collecting samples")
        print(f"Action: Continue shadow until {gate['min_samples_required']} samples collected")
    elif recommendation == "stay_shadow_collect_samples":
        print(f"Status: SHADOW - need more samples ({gate['effective_samples']}/{gate['min_samples_required']})")
        print("Action: Continue shadow mode")
    elif recommendation == "stay_shadow_fix_violations":
        print("Status: SHADOW - violations detected")
        print("Action: Fix violations before switching to pilot")
    elif recommendation == "eligible_for_pilot":
        print("Status: ✅ ELIGIBLE FOR PILOT")
        print("Action: Can switch to pilot mode with: --set-mode pilot")
    elif recommendation == "continue_pilot":
        print("Status: PILOT - continuing")
        print("Action: Monitor metrics, wait for decision gate")
    elif recommendation == "ready_for_decision":
        print("Status: PILOT - ready for decision")
        print("Action: Review metrics and make post-pilot decision")
    elif recommendation == "rollback_recommended":
        print("Status: ❌ ROLLBACK RECOMMENDED")
        print("Action: Disable pilot and investigate violations")
    else:
        print(f"Status: {recommendation}")


def check_gate() -> None:
    """Check if gate conditions are met for transition."""
    config = load_config()
    gate = get_gate_status(config)
    
    print("=== Gate Check: Shadow -> Pilot ===\n")
    
    print(f"Samples: {gate['effective_samples']} / {gate['min_samples_required']} required")
    print(f"  Status: {'✅ OK' if gate['samples_ok'] else '❌ INSUFFICIENT'}")
    
    print(f"\nTime: {gate['days_elapsed']} / {gate['max_days']} days max")
    print(f"  Status: {'✅ OK' if gate['time_ok'] else '⚠️ EXCEEDED'}")
    
    print(f"\nConflict Rate: {'✅ OK' if gate['conflict_ok'] else '❌ EXCEEDED'}")
    print(f"Match Rate: {'✅ OK' if gate['match_ok'] else '❌ BELOW THRESHOLD'}")
    print(f"Fallback Rate: {'✅ OK' if gate['fallback_ok'] else '❌ EXCEEDED'}")
    
    if gate['violations']:
        print(f"\n❌ Violations:")
        for v in gate['violations']:
            print(f"  - {v}")
    
    if gate['warnings']:
        print(f"\n⚠️ Warnings:")
        for w in gate['warnings']:
            print(f"  - {w}")
    
    print(f"\n{'='*40}")
    if gate['eligible_for_pilot']:
        print("✅ ELIGIBLE FOR PILOT")
        print("\nYou can now run:")
        print("  tools/prompt-pilot-control --set-mode pilot")
    else:
        print("❌ NOT ELIGIBLE FOR PILOT")
        print("\nContinue shadow mode until all conditions are met.")


def enable_pilot(mode: str = "shadow") -> None:
    """Enable the pilot."""
    config = load_config()
    
    if config.get("pilot_enabled"):
        print("Pilot already enabled")
        return
    
    # Pre-flight checks
    print("Running pre-flight checks...")
    
    # Check if shadow systems are available
    try:
        sys.path.insert(0, str(Path(__file__).parent.parent))
        from core.prompt_preview import MaterializedStatePromptAssembler
        from core.materialized_state_v0 import MaterializedState
        print("  ✅ Shadow systems available")
    except ImportError as e:
        print(f"  ❌ Shadow systems not available: {e}")
        print("Cannot enable pilot")
        return
    
    # Check if trying to enable pilot mode directly
    if mode == "pilot":
        gate = get_gate_status(config)
        if not gate["eligible_for_pilot"]:
            print(f"\n❌ Cannot enable pilot mode directly")
            print(f"   Effective samples: {gate['effective_samples']}/{gate['min_samples_required']}")
            print(f"   Enable shadow mode first:")
            print(f"     tools/prompt-pilot-control --enable --mode shadow")
            return
    
    # Enable pilot
    config["pilot_enabled"] = True
    config["pilot_mode"] = mode
    config["pilot_start_time"] = datetime.now().isoformat()
    config["effective_sample_count"] = 0
    
    # Reset metrics
    config["metrics"] = {
        "total_calls": 0,
        "effective_samples": 0,
        "successful_calls": 0,
        "fallback_calls": 0,
        "error_calls": 0,
        "manual_overrides": 0,
        "user_visible_anomalies": 0,
        "avg_match_rate": 0.0,
        "avg_conflict_rate": 0.0,
        "avg_missing_rate": 0.0,
        "avg_token_overhead": 0.0,
        "avg_fallback_rate": 0.0,
        "avg_manual_override_rate": 0.0,
        "avg_provenance_completeness": 0.0,
        "recent_stop_condition_hits": []
    }
    
    save_config(config)
    
    log_event("pilot_enabled", {
        "mode": mode,
        "config": config
    })
    
    print(f"\n✅ Pilot ENABLED in {mode} mode")
    print(f"   Authority chain: main_chain (shadow will not replace)")
    print(f"   Fallback on error: {config.get('fallback_on_error', True)}")
    
    if mode == "shadow":
        print(f"\n   Collecting samples for gate check...")
        print(f"   Need {config.get('dual_gate', {}).get('shadow_to_pilot', {}).get('min_samples', 20)} effective samples")
        print(f"   Run --check-gate to see progress")


def disable_pilot(reason: str = None) -> None:
    """Disable the pilot."""
    config = load_config()
    
    if not config.get("pilot_enabled"):
        print("Pilot already disabled")
        return
    
    config["pilot_enabled"] = False
    config["pilot_mode"] = "shadow"
    
    save_config(config)
    
    log_event("pilot_disabled", {
        "reason": reason or "manual",
        "final_metrics": config.get("metrics", {})
    })
    
    print(f"✅ Pilot DISABLED")
    if reason:
        print(f"   Reason: {reason}")


def set_mode(mode: str) -> None:
    """Set the pilot mode."""
    if mode not in ("shadow", "pilot"):
        print(f"Invalid mode: {mode}. Must be 'shadow' or 'pilot'")
        return
    
    config = load_config()
    
    if not config.get("pilot_enabled"):
        print("Pilot is not enabled. Enable it first:")
        print("  tools/prompt-pilot-control --enable --mode shadow")
        return
    
    old_mode = config.get("pilot_mode", "shadow")
    
    # Check gate if switching to pilot
    if mode == "pilot" and old_mode != "pilot":
        gate = get_gate_status(config)
        if not gate["eligible_for_pilot"]:
            print(f"❌ Cannot switch to pilot mode:")
            print(f"   Effective samples: {gate['effective_samples']}/{gate['min_samples_required']}")
            if gate["violations"]:
                print(f"   Violations: {gate['violations']}")
            print(f"\n   Continue shadow mode and collect more samples.")
            return
    
    config["pilot_mode"] = mode
    save_config(config)
    
    log_event("pilot_mode_changed", {
        "old_mode": old_mode,
        "new_mode": mode
    })
    
    print(f"✅ Mode changed: {old_mode} → {mode}")


def reset_metrics() -> None:
    """Reset pilot metrics."""
    config = load_config()
    
    config["metrics"] = {
        "total_calls": 0,
        "effective_samples": 0,
        "successful_calls": 0,
        "fallback_calls": 0,
        "error_calls": 0,
        "manual_overrides": 0,
        "user_visible_anomalies": 0,
        "avg_match_rate": 0.0,
        "avg_conflict_rate": 0.0,
        "avg_missing_rate": 0.0,
        "avg_token_overhead": 0.0,
        "avg_fallback_rate": 0.0,
        "avg_manual_override_rate": 0.0,
        "avg_provenance_completeness": 0.0,
        "recent_stop_condition_hits": []
    }
    config["effective_sample_count"] = 0
    
    save_config(config)
    
    log_event("metrics_reset", {})
    
    print("✅ Metrics reset")


def main():
    parser = argparse.ArgumentParser(description='Prompt Pilot Control')
    
    parser.add_argument('--status', action='store_true', help='Show current status')
    parser.add_argument('--enable', action='store_true', help='Enable pilot')
    parser.add_argument('--disable', action='store_true', help='Disable pilot')
    parser.add_argument('--set-mode', dest='set_mode', choices=['shadow', 'pilot'],
                        help='Set pilot mode')
    parser.add_argument('--mode', default='shadow', choices=['shadow', 'pilot'],
                        help='Mode when enabling')
    parser.add_argument('--reason', help='Reason for disabling')
    parser.add_argument('--reset-metrics', action='store_true', help='Reset metrics')
    parser.add_argument('--check-gate', action='store_true', help='Check gate conditions')
    
    args = parser.parse_args()
    
    if args.check_gate:
        check_gate()
    elif args.status or (not any([args.enable, args.disable, args.set_mode, args.reset_metrics, args.check_gate])):
        show_status()
    elif args.enable:
        enable_pilot(args.mode)
    elif args.disable:
        disable_pilot(args.reason)
    elif args.set_mode:
        set_mode(args.set_mode)
    elif args.reset_metrics:
        reset_metrics()


if __name__ == '__main__':
    main()
