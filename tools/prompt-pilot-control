    # Basic status
    status = "ENABLED" if config.get("pilot_enabled") else "DISABLED"
    mode = config.get("pilot_mode", "shadow")
    
    print(f"Status: {status}")
    print(f"Mode: {mode}")
    print(f"Authority: {config.get('authority_chain', {}).get('prompt', 'main_chain')}")
    
    if config.get("pilot_start_time"):
        start_dt = datetime.fromisoformat(config["pilot_start_time"])
        elapsed = datetime.now() - start_dt
        print(f"Started: {config['pilot_start_time']} ({elapsed.days} days ago)")
    
    print(f"\nAllowed Events: {', '.join(config.get('allowed_events', []))}")
    print(f"Blocked Events: {', '.join(config.get('blocked_events', []))}")
    
    # Gate status
    gate = get_gate_status(config)
    
    print(f"\n--- Gate Status ---")
    print(f"Effective Samples: {gate['effective_samples']} / {gate['min_samples_required']} required")
    print(f"Days Elapsed: {gate['days_elapsed']} / {gate['max_days']} max")
    
    # Core metrics
    metrics = config.get("metrics", {})
    
    print(f"\n--- Core Metrics ---")
    print(f"Total Calls: {metrics.get('total_calls', 0)}")
    print(f"Effective Samples: {metrics.get('effective_samples', 0)}")
    print(f"Successful: {metrics.get('successful_calls', 0)}")
    print(f"Fallbacks: {metrics.get('fallback_calls', 0)}")
    print(f"Errors: {metrics.get('error_calls', 0)}")
    print(f"Manual Overrides: {metrics.get('manual_overrides', 0)}")
    print(f"User Visible Anomalies: {metrics.get('user_visible_anomalies', 0)}")
    
    print(f"\n--- Quality Metrics ---")
    print(f"Avg Match Rate: {metrics.get('avg_match_rate', 0):.1%}")
    print(f"Avg Conflict Rate: {metrics.get('avg_conflict_rate', 0):.1%}")
    print(f"Avg Missing Rate: {metrics.get('avg_missing_rate', 0):.1%}")
    print(f"Avg Token Overhead: {metrics.get('avg_token_overhead', 0):.1%}")
    print(f"Avg Fallback Rate: {metrics.get('avg_fallback_rate', 0):.1%}")
    print(f"Avg Manual Override Rate: {metrics.get('avg_manual_override_rate', 0):.1%}")
    print(f"Avg Provenance Completeness: {metrics.get('avg_provenance_completeness', 0):.1%}")
    
    # Stop conditions
    violations, warnings = check_stop_conditions(config)
    
