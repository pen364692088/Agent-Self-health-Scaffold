#!/usr/bin/env python3
"""
Spawn with Callback v2.2 - 硬化的邮箱模式

子代理完成后使用 subagent-inbox 写入回执：
- 原子写入（.tmp → rename）
- 完整状态字段
- 支持 completed/failed/timeout

Usage:
  spawn-with-callback "<task>" --model <model> [--timeout 300]
  spawn-with-callback --health
"""

import json
import sys
import uuid
from datetime import datetime
from pathlib import Path

WORKSPACE = Path.home() / ".openclaw" / "workspace"
INBOX_TOOL = WORKSPACE / "tools" / "subagent-inbox"

CALLBACK_TEMPLATE = '''
**元信息**：
- task_id: {task_id}
- run_id: {run_id}
- parent_session_key: {parent_session_key}

**完成要求（邮箱模式 v2.2）**：

成功时：
```bash
~/.openclaw/workspace/tools/subagent-inbox write \\
  --task-id {task_id} \\
  --run-id {run_id} \\
  --status completed \\
  --summary "任务摘要" \\
  --session-key "$SESSION_KEY" \\
  --parent-session-key "{parent_session_key}"
```

失败时：
```bash
~/.openclaw/workspace/tools/subagent-inbox write \\
  --task-id {task_id} \\
  --run-id {run_id} \\
  --status failed \\
  --summary "错误描述" \\
  --session-key "$SESSION_KEY"
```

超时时：
```bash
~/.openclaw/workspace/tools/subagent-inbox write \\
  --task-id {task_id} \\
  --run-id {run_id} \\
  --status timeout \\
  --summary "任务超时"
```

最后输出：
```
ANNOUNCE_SKIP: true
```

**任务内容**：
{task_content}
'''


def generate_task_id():
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    short_uuid = uuid.uuid4().hex[:8]
    return f"task_{timestamp}_{short_uuid}"


def generate_run_id():
    return f"run_{uuid.uuid4().hex[:8]}"


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)
    
    if sys.argv[1] == "--health":
        print(json.dumps({"status": "healthy", "version": "2.2", "mode": "inbox"}))
        sys.exit(0)
    
    # 解析参数
    task = ""
    model = "baiduqianfancodingplan/qianfan-code-latest"
    timeout = 300
    parent_session_key = "agent:main:telegram:direct:unknown"
    
    i = 1
    while i < len(sys.argv):
        arg = sys.argv[i]
        if arg == "-m" or arg == "--model":
            model = sys.argv[i + 1]
            i += 2
        elif arg == "-t" or arg == "--timeout":
            timeout = int(sys.argv[i + 1])
            i += 2
        elif arg == "--parent":
            parent_session_key = sys.argv[i + 1]
            i += 2
        elif not arg.startswith("-"):
            task = arg
            i += 1
        else:
            i += 1
    
    if not task:
        print("Error: task description required", file=sys.stderr)
        sys.exit(1)
    
    # 生成 ID
    task_id = generate_task_id()
    run_id = generate_run_id()
    
    # 生成任务内容
    task_content = CALLBACK_TEMPLATE.format(
        task_id=task_id,
        run_id=run_id,
        parent_session_key=parent_session_key,
        task_content=task
    )
    
    # 输出
    output = {
        "task_id": task_id,
        "run_id": run_id,
        "model": model,
        "timeout": timeout,
        "mode": "inbox",
        "parent_session_key": parent_session_key,
        "spawn_args": {
            "runtime": "subagent",
            "model": model,
            "task": task_content,
            "timeoutSeconds": timeout
        },
        "check_command": f"~/.openclaw/workspace/tools/subagent-inbox check --once"
    }
    
    print(json.dumps(output, indent=2))


if __name__ == "__main__":
    main()
