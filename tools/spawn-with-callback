#!/usr/bin/env python3
# LAYER: debug
# PURPOSE: 调试用底层 spawn
# WARNING: 不推荐直接使用，请用 subtask-orchestrate
"""
Spawn with Callback v3.0 - 双通道回调

v3.0 新增：
- sessions_send 实时回调（主通道）
- subagent-inbox 回执（备份通道）
- 自动识别 parent_session_key

Usage:
  spawn-with-callback "<task>" --model <model> [--timeout 300]
  spawn-with-callback --health
"""

import json
import os
import sys
import uuid
from datetime import datetime
from pathlib import Path

WORKSPACE = Path.home() / ".openclaw" / "workspace"

CALLBACK_TEMPLATE = '''
**元信息**：
- task_id: {task_id}
- run_id: {run_id}
- parent_session_key: {parent_session_key}
- parentSessionKey: {parent_session_key}

**完成要求（双通道回调 v3.0）**：

完成时，你必须执行以下两步：

**Step 1: 写入回执（备份通道）**
```bash
~/.openclaw/workspace/tools/subagent-inbox write \\
  --task-id {task_id} \\
  --run-id {run_id} \\
  --status completed \\
  --summary "任务摘要" \\
  --session-key "$SESSION_KEY"
```

**Step 2: 发送实时回调（主通道）**
使用 sessions_send 工具，发送以下 JSON 给父代理：
```json
{{
  "type": "subagent_done",
  "task_id": "{task_id}",
  "run_id": "{run_id}",
  "child_session_key": "$SESSION_KEY",
  "status": "completed",
  "summary": "任务摘要（1-2句话）",
  "artifacts": []
}}
```

发送命令：
```
sessions_send(sessionKey="{parent_session_key}", message=<上述JSON>)
```

**失败时**：status 改为 "failed"，添加 error 字段。

**最后输出**：
```
ANNOUNCE_SKIP: true
```

**任务内容**：
{task_content}
'''


def get_parent_session_key():
    """从环境变量获取 parent session key"""
    # 尝试从环境变量获取
    parent_key = os.environ.get("PARENT_SESSION_KEY", "")
    if parent_key:
        return parent_key
    
    # 尝试从 SESSION_STATE 获取
    state_file = WORKSPACE / "SESSION_STATE.md"
    if state_file.exists():
        try:
            import re
            content = state_file.read_text()
            match = re.search(r'parent_session_key:\s*(\S+)', content)
            if match:
                return match.group(1)
        except:
            pass
    
    # 默认值
    return "agent:main:telegram:direct:unknown"


def generate_task_id():
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    short_uuid = uuid.uuid4().hex[:8]
    return f"task_{timestamp}_{short_uuid}"


def generate_run_id():
    return f"run_{uuid.uuid4().hex[:8]}"


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)
    
    if sys.argv[1] == "--health":
        print(json.dumps({"status": "healthy", "version": "3.0", "mode": "dual_channel"}))
        sys.exit(0)
    
    # 解析参数
    task = ""
    model = "baiduqianfancodingplan/qianfan-code-latest"
    timeout = 300
    parent_session_key = get_parent_session_key()
    
    i = 1
    while i < len(sys.argv):
        arg = sys.argv[i]
        if arg == "-m" or arg == "--model":
            model = sys.argv[i + 1]
            i += 2
        elif arg == "-t" or arg == "--timeout":
            timeout = int(sys.argv[i + 1])
            i += 2
        elif arg == '-p' or arg == "--parent":
            parent_session_key = sys.argv[i + 1]
            i += 2
        elif not arg.startswith("-"):
            task = arg
            i += 1
        else:
            i += 1
    
    if not task:
        print("Error: task description required", file=sys.stderr)
        sys.exit(1)
    
    # 生成 ID
    task_id = generate_task_id()
    run_id = generate_run_id()
    
    # 生成任务内容
    task_content = CALLBACK_TEMPLATE.format(
        task_id=task_id,
        run_id=run_id,
        parent_session_key=parent_session_key,
        task_content=task
    )
    
    # 输出
    output = {
        "task_id": task_id,
        "run_id": run_id,
        "model": model,
        "timeout": timeout,
        "mode": "dual_channel",
        "parent_session_key": parent_session_key,
        "spawn_args": {
            "runtime": "subagent",
            "model": model,
            "task": task_content,
            "timeoutSeconds": timeout
        },
        "callback": {
            "inbox_command": f"~/.openclaw/workspace/tools/subagent-inbox check --once",
            "sessions_send": f"sessions_send(sessionKey=\"{parent_session_key}\", message=<subagent_done JSON>)"
        }
    }
    
    print(json.dumps(output, indent=2))


if __name__ == "__main__":
    main()
