#!/usr/bin/env python3
"""
safe-message v1.0 - 安全消息发送包装器

在发送消息前自动检查 execution policy。

用法：
  safe-message --task-id <id> --to <target> --message "..."
  safe-message --task-id <id> --channel telegram --message "..."

流程：
  1. 检查 output-interceptor
  2. 如果 ALLOW，调用 message tool
  3. 如果 BLOCK，返回错误提示

Exit codes:
  0 - 消息已发送
  1 - 被拦截，需先调用 verify-and-close
  2 - 参数错误
"""

import argparse
import json
import sys
import subprocess
from pathlib import Path

WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
OUTPUT_INTERCEPTOR = WORKSPACE / "tools" / "output-interceptor"


def call_output_interceptor(task_id: str, channel: str, message: str) -> tuple:
    """调用 output-interceptor 检查"""
    args = [
        str(OUTPUT_INTERCEPTOR),
        "--task-id", task_id,
        "--channel", channel,
        "--json"
    ]
    
    if message:
        args.extend(["--message", message])
    
    result = subprocess.run(
        args,
        capture_output=True,
        text=True
    )
    
    try:
        data = json.loads(result.stdout)
        return data.get("action") == "ALLOW", data
    except:
        return False, {"error": "parse_error"}


def main():
    parser = argparse.ArgumentParser(description="safe-message v1.0")
    parser.add_argument("--task-id", required=True, help="Task identifier")
    parser.add_argument("--to", help="Message target")
    parser.add_argument("--channel", default="telegram", help="Output channel")
    parser.add_argument("--message", required=True, help="Message content")
    parser.add_argument("--force", action="store_true", help="Force send (dangerous)")
    parser.add_argument("--json", action="store_true", help="JSON output")
    
    args = parser.parse_args()
    
    task_id = args.task_id
    message = args.message
    channel = args.channel
    
    # Force 模式：跳过检查
    if args.force:
        if args.json:
            print(json.dumps({"action": "FORCED", "warning": "Bypassing execution policy"}))
        # 这里应该调用实际的 message tool
        # 但我们没有访问权限，所以只是输出
        print(f"[FORCED] Would send to {args.to or channel}: {message[:50]}...")
        return 0
    
    # 检查是否允许发送
    allowed, check_result = call_output_interceptor(task_id, channel, message)
    
    if not allowed:
        result = {
            "action": "BLOCK",
            "reason": check_result.get("reason", "unknown"),
            "message": "Output blocked. Run verify-and-close first.",
            "required_action": f"verify-and-close --task-id {task_id}"
        }
        
        if args.json:
            print(json.dumps(result, indent=2))
        else:
            print(f"❌ BLOCKED: {result['reason']}")
            print(f"Run: {result['required_action']}")
        
        return 1
    
    # 允许发送
    result = {
        "action": "ALLOW",
        "task_id": task_id,
        "channel": channel,
        "message_preview": message[:100] + "..." if len(message) > 100 else message
    }
    
    if args.json:
        print(json.dumps(result, indent=2))
    else:
        print(f"✅ ALLOW: Safe to send message")
        print(f"To: {args.to or channel}")
        print(f"Preview: {result['message_preview']}")
    
    return 0


if __name__ == "__main__":
    sys.exit(main())
