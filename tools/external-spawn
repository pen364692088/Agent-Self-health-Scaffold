#!/usr/bin/env python3
"""
External Spawn v1.0 - 通过 OpenClaw CLI spawn 子代理

Usage:
  external-spawn --task "<task>" --model <model> --task-id <id> --run-id <id>
"""

import json
import subprocess
import sys
from pathlib import Path

WORKSPACE = Path.home() / ".openclaw" / "workspace"
SPAWN_TOOL = WORKSPACE / "tools" / "spawn-with-callback"
ACTIVATOR = WORKSPACE / "tools" / "callback-handler"
TRIGGER_FILE = WORKSPACE / "reports" / "pending_spawns.jsonl"


def spawn_subagent(task, model, step_id):
    """Spawn 子代理并返回 task_id 和 run_id"""
    try:
        result = subprocess.run(
            [str(SPAWN_TOOL), task, "--model", model, "--timeout", "300"],
            capture_output=True, text=True
        )
        
        if result.returncode != 0:
            return {"error": result.stderr}
        
        data = json.loads(result.stdout)
        task_id = data.get("task_id", "")
        run_id = data.get("run_id", "")
        
        # 激活步骤
        subprocess.run(
            [str(ACTIVATOR), "--activate", step_id, run_id],
            capture_output=True, text=True
        )
        
        # 写入触发文件（让主代理执行实际的 sessions_spawn）
        trigger = {
            "step_id": step_id,
            "task_id": task_id,
            "run_id": run_id,
            "task": task,
            "model": model,
            "spawn_args": data.get("spawn_args", {})
        }
        
        with open(TRIGGER_FILE, 'a') as f:
            f.write(json.dumps(trigger) + '\n')
        
        return {
            "status": "triggered",
            "task_id": task_id,
            "run_id": run_id,
            "step_id": step_id
        }
    except Exception as e:
        return {"error": str(e)}


def main():
    args = {}
    i = 1
    while i < len(sys.argv):
        arg = sys.argv[i]
        if arg.startswith("--"):
            key = arg[2:].replace("-", "_")
            if i + 1 < len(sys.argv) and not sys.argv[i + 1].startswith("--"):
                args[key] = sys.argv[i + 1]
                i += 2
            else:
                args[key] = True
                i += 1
        else:
            i += 1
    
    task = args.get("task", "")
    model = args.get("model", "iflow/glm-4.6")
    step_id = args.get("step_id", "")
    
    if not task:
        print("Error: --task required", file=sys.stderr)
        sys.exit(1)
    
    result = spawn_subagent(task, model, step_id)
    print(json.dumps(result, indent=2))


if __name__ == "__main__":
    main()
