#!/usr/bin/env python3
import argparse, json, os, subprocess, time
from datetime import datetime, timezone, timedelta
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
LOCK_DIR = REPO / 'artifacts' / 'self_health' / 'locks'
STATE_DIR = REPO / 'artifacts' / 'self_health' / 'state'
LOG_DIR = REPO / 'artifacts' / 'self_health' / 'pilot'

FREQUENCIES = {
    'capability_check_quick': 60,
    'recovery_apply': 60,
    'capability_check_full': 360,
    'forgetting_guard': 720,
    'capability_summary': 3600,
    'proposal_summary': 3600,
    'recovery_summary': 3600,
    'gate_check': 21600,
}

BUDGETS = {'quick': 30, 'full': 120}

def get_lock_file(task):
    LOCK_DIR.mkdir(parents=True, exist_ok=True)
    return LOCK_DIR / f'{task}.lock'

def acquire_lock(task):
    lock_file = get_lock_file(task)
    if lock_file.exists():
        try:
            data = json.loads(lock_file.read_text())
            started = datetime.fromisoformat(data['started_at'].replace('Z', '+00:00'))
            age = (datetime.now(timezone.utc) - started).total_seconds()
            if age < 300:
                return False
        except Exception:
            pass
    lock_file.write_text(json.dumps({
        'task': task,
        'started_at': datetime.now(timezone.utc).isoformat(),
        'pid': os.getpid(),
    }))
    return True

def release_lock(task):
    lock_file = get_lock_file(task)
    if lock_file.exists():
        lock_file.unlink()

def should_run(task, last_run_file):
    if not last_run_file.exists():
        return True
    try:
        last = datetime.fromisoformat(last_run_file.read_text().strip().replace('Z', '+00:00'))
        interval = FREQUENCIES.get(task, 3600)
        return (datetime.now(timezone.utc) - last).total_seconds() >= interval
    except Exception:
        return True

def record_run(task):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    (STATE_DIR / f'{task}.last_run').write_text(datetime.now(timezone.utc).isoformat())

def log_run(task, result):
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    log_file = LOG_DIR / 'scheduler_runs.jsonl'
    entry = {
        'task': task,
        'timestamp': datetime.now(timezone.utc).isoformat(),
        'exit_code': result.get('exit_code', 'N/A'),
        'error': result.get('error'),
    }
    with open(log_file, 'a') as f:
        f.write(json.dumps(entry, ensure_ascii=False) + '\n')

def run_tool(tool_name, args, budget):
    tool_path = REPO / 'tools' / tool_name
    if not tool_path.exists():
        return {'error': f'tool not found: {tool_name}'}
    try:
        start = time.time()
        r = subprocess.run([str(tool_path)] + args, capture_output=True, text=True, timeout=budget)
        elapsed = time.time() - start
        return {
            'exit_code': r.returncode,
            'stdout': r.stdout[:500] if r.stdout else '',
            'stderr': r.stderr[:200] if r.stderr else '',
            'elapsed_seconds': round(elapsed, 2),
        }
    except subprocess.TimeoutExpired:
        return {'error': 'timeout', 'budget': budget}
    except Exception as e:
        return {'error': str(e)}

def run_quick_check():
    return run_tool('agent-capability-check', ['--all', '--json'], BUDGETS['quick'])

def run_recovery_apply():
    try:
        start = time.time()
        r = subprocess.run(
            ['python3', str(REPO / 'runtime' / 'recovery-orchestrator' / 'recovery_apply.py'), '--root', str(REPO), '--json'],
            capture_output=True,
            text=True,
            timeout=BUDGETS['quick'],
        )
        elapsed = time.time() - start
        return {
            'exit_code': r.returncode,
            'stdout': r.stdout[:500] if r.stdout else '',
            'stderr': r.stderr[:200] if r.stderr else '',
            'elapsed_seconds': round(elapsed, 2),
        }
    except subprocess.TimeoutExpired:
        return {'error': 'timeout', 'budget': BUDGETS['quick']}
    except Exception as e:
        return {'error': str(e)}

def run_full_cycle():
    results = {}
    tasks = [
        ('agent-capability-check', ['--all', '--json']),
        ('agent-forgetting-guard', ['--all', '--json']),
        ('agent-capability-summary', ['--write']),
        ('agent-proposal-summary', ['--write']),
        ('agent-recovery-summary', ['--write']),
    ]
    for tool, args in tasks:
        task_name = tool.replace('agent-', '').replace('-', '_')
        r = run_tool(tool, args, BUDGETS['full'])
        results[task_name] = r
    return results

def run_gate_check():
    return run_tool('gate-self-health-check', ['--write', '--json'], BUDGETS['full'])

parser = argparse.ArgumentParser()
parser.add_argument('--mode', choices=['quick', 'full', 'gate'], default='quick')
parser.add_argument('--json', action='store_true')
parser.add_argument('--force', action='store_true', help='Force run even if cooldown not expired')
args = parser.parse_args()

results = {
    'mode': args.mode,
    'tasks': {},
    'started_at': datetime.now(timezone.utc).isoformat(),
}

if args.mode == 'quick':
    for task in ['capability_check_quick', 'recovery_apply']:
        if args.force or (acquire_lock(task) and should_run(task, STATE_DIR / f'{task}.last_run')):
            if task == 'capability_check_quick':
                r = run_quick_check()
                results['tasks']['capability_check'] = r
            elif task == 'recovery_apply':
                r = run_recovery_apply()
                results['tasks']['recovery_apply'] = r
            else:
                r = {'error': 'unknown task'}
            record_run(task)
            log_run(task, r)
            release_lock(task)

elif args.mode == 'full':
    for task in ['recovery_apply', 'capability_check_full', 'forgetting_guard', 'capability_summary', 'proposal_summary', 'recovery_summary']:
        if args.force or (acquire_lock(task) and should_run(task, STATE_DIR / f'{task}.last_run')):
            if task == 'recovery_apply':
                r = run_recovery_apply()
            elif task == 'capability_check_full':
                r = run_tool('agent-capability-check', ['--all', '--json'], BUDGETS['full'])
            elif task == 'forgetting_guard':
                r = run_tool('agent-forgetting-guard', ['--all', '--json'], BUDGETS['full'])
            elif task == 'capability_summary':
                r = run_tool('agent-capability-summary', ['--write'], BUDGETS['full'])
            elif task == 'proposal_summary':
                r = run_tool('agent-proposal-summary', ['--write'], BUDGETS['full'])
            elif task == 'recovery_summary':
                r = run_tool('agent-recovery-summary', ['--write'], BUDGETS['full'])
            else:
                r = {'error': 'unknown task'}
            results['tasks'][task] = r
            record_run(task)
            log_run(task, r)
            release_lock(task)

elif args.mode == 'gate':
    task = 'gate_check'
    if args.force or (acquire_lock(task) and should_run(task, STATE_DIR / f'{task}.last_run')):
        r = run_gate_check()
        results['tasks']['gate_check'] = r
        record_run(task)
        log_run(task, r)
        release_lock(task)

results['completed_at'] = datetime.now(timezone.utc).isoformat()

if args.json:
    print(json.dumps(results, ensure_ascii=False, indent=2))
else:
    print(f"Mode: {args.mode}")
    print(f"Tasks run: {len(results['tasks'])}")
    for task, r in results['tasks'].items():
        status = 'ok' if r.get('exit_code') == 0 else 'error'
        print(f"  {task}: {status}")
