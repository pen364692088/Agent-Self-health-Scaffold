def now_iso():
    return datetime.now(timezone.utc).isoformat()


def read_json(path, default):
    try:
        return json.loads(Path(path).read_text())
    except Exception:
        return default


def write_json(path, obj):
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + '.tmp')
    tmp.write_text(json.dumps(obj, ensure_ascii=False, indent=2))
    tmp.replace(path)


def append_jsonl(path, obj):
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open('a', encoding='utf-8') as f:
        f.write(json.dumps(obj, ensure_ascii=False) + '\n')


def run(cmd, timeout=None):
    p = subprocess.run(cmd, cwd=WORKSPACE, capture_output=True, text=True, timeout=timeout)
    return p.returncode, p.stdout, p.stderr


def file_age_seconds(path):
    p = Path(path)
    if not p.exists():
        return None
    return max(0, time.time() - p.stat().st_mtime)


def parse_json(stdout, fallback=None):
    try:
        return json.loads(stdout)
    except Exception:
        return fallback if fallback is not None else {'raw_stdout': stdout[:1000]}


def run_all_probes():
    """Run all P0 probes and collect results."""
    results = {}
    failed_probes = []
    
    for probe_name in ALL_PROBES:
        probe_path = WORKSPACE / 'tools' / probe_name
        if not probe_path.exists():
            results[probe_name] = {'status': 'error', 'message': f'Probe not found: {probe_name}'}
            continue
        
        try:
            rc, out, err = run(['python3', str(probe_path), '--json'], timeout=30)
            result = parse_json(out, {'raw_stdout': out[:500], 'error': err[:200]})
            results[probe_name] = result
            
            # Write individual probe result
            write_json(PROBES_DIR / f'{probe_name}.json', result)
            
            if result.get('status') in ('fail', 'error'):
                failed_probes.append({
                    'probe': probe_name,
                    'status': result.get('status'),
                    'message': result.get('message', 'Unknown failure')
                })
        except Exception as e:
            results[probe_name] = {'status': 'error', 'message': str(e)}
            failed_probes.append({
                'probe': probe_name,
                'status': 'error',
                'message': str(e)
            })
    
    # Write combined probe status
    probe_summary = {
        'timestamp': now_iso(),
        'total_probes': len(ALL_PROBES),
        'passed': len(ALL_PROBES) - len(failed_probes),
        'failed': len(failed_probes),
        'failed_probes': failed_probes,
        'results': results
    }
    write_json(PROBES_DIR / 'probe_summary.json', probe_summary)
    
    return probe_summary, failed_probes


def component_snapshot(mode, health_result=None, gate_result=None, probe_summary=None):
    ts = now_iso()
    hb = read_json(RUNTIME / 'heartbeat_status.json', {})
    cb = read_json(RUNTIME / 'callback_worker_status.json', {})
    mb = read_json(RUNTIME / 'mailbox_worker_status.json', {})
    sm = read_json(RUNTIME / 'summary_status.json', {})
    metrics = read_json(ALWAYS_ON / 'always_on_metrics.json', {
        'scheduler_runs_total': 0, 'quick_runs_total': 0, 'full_runs_total': 0, 'gate_runs_total': 0,
        'skipped_runs_total': 0, 'lock_contention_count': 0, 'execution_budget_hit_count': 0,
        'incident_total': 0, 'deduped_incident_count': 0, 'proposal_total': 0, 'deduped_proposal_count': 0,
        'cooldown_blocked_count': 0, 'repeated_same_alert_count': 0, 'gate_inconsistency_count': 0,
        'probe_runs_total': 0, 'probe_failures_total': 0,
    })
    metrics['scheduler_runs_total'] += 1
    metrics[f'{mode}_runs_total'] = metrics.get(f'{mode}_runs_total', 0) + 1
    if probe_summary:
        metrics['probe_runs_total'] = metrics.get('probe_runs_total', 0) + 1
        metrics['probe_failures_total'] = metrics.get('probe_failures_total', 0) + probe_summary.get('failed', 0)
    write_json(ALWAYS_ON / 'always_on_metrics.json', metrics)

    last_hist_age = file_age_seconds(STATE / 'health_history.jsonl')
    hb.update({
        'last_heartbeat_at': ts,
        'heartbeat_lag_seconds': 0,
        'heartbeat_cycle_ok': True,
        'last_cycle_duration_ms': health_result.get('duration_ms') if health_result else hb.get('last_cycle_duration_ms'),
        'last_quick_check_at': ts if mode == 'quick' else hb.get('last_quick_check_at'),
        'last_full_check_at': ts if mode == 'full' else hb.get('last_full_check_at'),
        'heartbeat_status': 'healthy' if (health_result or {}).get('ok', True) else 'degraded',
        'health_history_age_seconds': last_hist_age,
        'last_probe_summary': probe_summary,
    })
    write_json(RUNTIME / 'heartbeat_status.json', hb)

    code, out, err = run(['python3', str(WORKSPACE / 'tools' / 'callback-worker-doctor')], timeout=20)
    
    service_state = 'unknown'
    if '✅ Service state: OK (idle, no pending work)' in out:
        service_state = 'idle_expected'
    elif '✅ Service state: OK (service running)' in out:
        service_state = 'active'
    elif '❌ Service state: Inactive with' in out:
        service_state = 'degraded'
    
    worker_status = 'healthy' if code == 0 or service_state == 'idle_expected' else 'degraded'
    
    cb.update({
        'worker_name': 'callback-worker',
        'alive': service_state in ('active', 'idle_expected'),
        'last_progress_at': ts if ('可以上线' in out or '不能上线' in out) else cb.get('last_progress_at'),
        'last_output_at': ts,
        'pending_count': None,
        'stuck_suspected': service_state == 'degraded',
        'last_error_at': ts if service_state == 'degraded' else cb.get('last_error_at'),
        'last_error_type': 'doctor_failed' if service_state == 'degraded' else None,
        'worker_status': worker_status,
        'service_state': service_state,
        'doctor_excerpt': '\n'.join(out.splitlines()[:8])[:500]
    })
    write_json(RUNTIME / 'callback_worker_status.json', cb)

    inbox = WORKSPACE / 'mailbox' / 'inbox.jsonl'
    done = WORKSPACE / 'mailbox' / 'done.jsonl'
    backlog = 0
    if inbox.exists():
        try:
            backlog = sum(1 for _ in inbox.open('r', encoding='utf-8'))
        except Exception:
            backlog = 0
    mb.update({
        'worker_name': 'mailbox-worker',
        'alive': True if (WORKSPACE / 'flows' / 'mailbox-worker.prose').exists() else False,
        'last_poll_at': ts,
        'last_progress_at': datetime.fromtimestamp(done.stat().st_mtime, timezone.utc).isoformat() if done.exists() else None,
        'backlog_count': backlog,
        'stuck_suspected': backlog > 20,
        'mailbox_status': 'healthy' if backlog <= 20 else 'degraded',
        'source': 'mailbox files + flow definition'
    })
    write_json(RUNTIME / 'mailbox_worker_status.json', mb)

    sm.update({
        'last_health_summary_at': sm.get('last_health_summary_at'),
        'last_recovery_summary_at': sm.get('last_recovery_summary_at'),
        'last_capability_summary_at': sm.get('last_capability_summary_at'),
        'last_proposal_summary_at': sm.get('last_proposal_summary_at'),
        'last_incident_recorded_at': datetime.fromtimestamp(INCIDENTS.stat().st_mtime, timezone.utc).isoformat() if INCIDENTS.exists() else None,
        'summary_pipeline_status': 'healthy' if health_result or gate_result else sm.get('summary_pipeline_status', 'unknown')
    })
    write_json(RUNTIME / 'summary_status.json', sm)


def should_dedup(kind, fingerprint, seconds):
    ledger = read_json(RUNTIME / 'dedup_ledger.json', {})
    now = time.time()
    entry = ledger.get(kind, {}).get(fingerprint)
    if entry and now - entry.get('epoch', 0) < seconds:
        return True, entry
    ledger.setdefault(kind, {})[fingerprint] = {'epoch': now, 'timestamp': now_iso()}
    write_json(RUNTIME / 'dedup_ledger.json', ledger)
    return False, None


def maybe_generate_incident_and_proposal(health_payload, probe_failures=None):
    metrics = read_json(ALWAYS_ON / 'always_on_metrics.json', {})
    overall = health_payload.get('overall_status', 'GREEN') if health_payload else 'GREEN'
    components = health_payload.get('components', []) if health_payload else []
    bad = [c for c in components if c.get('status') in ('warning', 'error', 'unknown') and c.get('component') != 'network']
    
    # Add probe failures to bad list
    if probe_failures:
        for pf in probe_failures:
            bad.append({
                'component': f'probe:{pf["probe"]}',
                'status': pf['status'],
                'message': pf['message']
            })
        if probe_failures:
            overall = 'ORANGE' if overall == 'GREEN' else overall
    
    created = {'incident': None, 'proposal': None}

    if overall in ('YELLOW', 'ORANGE', 'RED') or bad:
        summary = '; '.join(f"{c.get('component')}={c.get('status')}" for c in bad) or f'overall={overall}'
        fp = hashlib.sha1(summary.encode()).hexdigest()[:16]
        deduped, _ = should_dedup('incident', fp, INCIDENT_DEDUP_SECONDS)
        if deduped:
            metrics['deduped_incident_count'] = metrics.get('deduped_incident_count', 0) + 1
            metrics['repeated_same_alert_count'] = metrics.get('repeated_same_alert_count', 0) + 1
        else:
            level_map = {'YELLOW': 'YELLOW', 'ORANGE': 'ORANGE', 'RED': 'RED'}
            rc, out, err = run([
                str(WORKSPACE / 'tools' / 'agent-incident-report'),
                '--level', level_map.get(overall, 'YELLOW'),
                '--category', 'always_on_health',
                '--summary', summary,
                '--context', json.dumps({'source': 'agent-self-health-scheduler', 'overall_status': overall, 'probe_failures': probe_failures}),
                '--json'
            ], timeout=20)
            created['incident'] = parse_json(out, {'raw_stdout': out[:500], 'error': err[:200]})
            metrics['incident_total'] = metrics.get('incident_total', 0) + 1

    if overall in ('ORANGE', 'RED'):
        action = 'retry_subagent' if any(c.get('component') == 'subagents' for c in bad) else 'restart_subsystem'
        fp = hashlib.sha1(f'{overall}:{action}'.encode()).hexdigest()[:16]
        deduped, _ = should_dedup('proposal', fp, PROPOSAL_DEDUP_SECONDS)
        if deduped:
            metrics['deduped_proposal_count'] = metrics.get('deduped_proposal_count', 0) + 1
        else:
            rc, out, err = run([
                str(WORKSPACE / 'tools' / 'agent-self-heal'),
                '--proposal-only', '--action', action, '--level', 'B', '--json'
            ], timeout=20)
            created['proposal'] = parse_json(out, {'raw_stdout': out[:500], 'error': err[:200]})
            metrics['proposal_total'] = metrics.get('proposal_total', 0) + 1

    write_json(ALWAYS_ON / 'always_on_metrics.json', metrics)
    return created


def maybe_generate_summaries(mode, health_payload=None):
    sm = read_json(RUNTIME / 'summary_status.json', {})
    generated = {}
    now = time.time()
    last_health = sm.get('last_health_summary_epoch', 0) or 0
    if mode == 'full' or now - last_health >= SUMMARY_MIN_INTERVAL_SECONDS:
        rc, out, err = run([str(WORKSPACE / 'tools' / 'agent-health-summary'), '--json'], timeout=20)
        payload = parse_json(out, {'raw_stdout': out[:500], 'error': err[:200]})
        write_json(ALWAYS_ON / 'health_summary_latest.json', payload)
        generated['health_summary'] = payload
        sm['last_health_summary_at'] = now_iso()
        sm['last_health_summary_epoch'] = now
        sm['last_capability_summary_at'] = sm['last_health_summary_at']
    if generated:
        write_json(RUNTIME / 'summary_status.json', sm)
    return generated


def gate_consistency_metrics(gate_payload):
    metrics = read_json(ALWAYS_ON / 'always_on_metrics.json', {})
    if gate_payload.get('verdict') != 'PASS':
        metrics['gate_inconsistency_count'] = metrics.get('gate_inconsistency_count', 0) + 1
        write_json(ALWAYS_ON / 'always_on_metrics.json', metrics)


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument('--mode', choices=['quick','full','gate'], default='quick')
    ap.add_argument('--force', action='store_true')
    ap.add_argument('--json', action='store_true')
    ap.add_argument('--health', action='store_true')
    ap.add_argument('--no-probes', action='store_true', help='Skip P0 probes')
    args = ap.parse_args()
    if args.health:
        print(json.dumps({'status':'healthy','tool':'agent-self-health-scheduler','version':'1.2.0'}))
        return 0

    cfg = CONFIG[args.mode]
    lock_path = LOCKS / f'{args.mode}.lock'
    state_path = RUNTIME / f'{args.mode}_scheduler_state.json'
    history_path = RUNTIME / 'run_history.jsonl'
    state = read_json(state_path, {})
    start = time.time()
    ts = now_iso()

    with open(lock_path, 'w') as lockf:
        try:
            fcntl.flock(lockf, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            metrics = read_json(ALWAYS_ON / 'always_on_metrics.json', {})
            metrics['lock_contention_count'] = metrics.get('lock_contention_count', 0) + 1
            write_json(ALWAYS_ON / 'always_on_metrics.json', metrics)
            result = {'mode': args.mode, 'status': 'skipped', 'reason': 'lock_contended', 'timestamp': ts}
            append_jsonl(history_path, result)
            print(json.dumps(result, ensure_ascii=False, indent=2) if args.json else 'lock_contended')
            return 0

        last_run = state.get('last_run_epoch')
        if not args.force and last_run and time.time() - last_run < cfg['cooldown']:
            metrics = read_json(ALWAYS_ON / 'always_on_metrics.json', {})
            metrics['skipped_runs_total'] = metrics.get('skipped_runs_total', 0) + 1
            metrics['cooldown_blocked_count'] = metrics.get('cooldown_blocked_count', 0) + 1
            write_json(ALWAYS_ON / 'always_on_metrics.json', metrics)
            result = {'mode': args.mode, 'status': 'skipped', 'reason': 'cooldown', 'cooldown_seconds': cfg['cooldown'], 'timestamp': ts}
            state.update({'last_skipped_reason': 'cooldown', 'last_skipped_at': ts})
            write_json(state_path, state)
            append_jsonl(history_path, result)
            print(json.dumps(result, ensure_ascii=False, indent=2) if args.json else 'cooldown')
            return 0

        extras = {}
        probe_summary = None
        probe_failures = None
        
        # Run P0 probes if configured
        if cfg.get('run_probes') and not args.no_probes:
            probe_summary, probe_failures = run_all_probes()
            extras['probes'] = probe_summary
        
        if args.mode in ('quick','full'):
            cmd = [str(WORKSPACE / 'tools' / 'agent-health-check')] + cfg['health_args']
            rc, out, err = run(cmd, timeout=cfg['budget'])
            payload = parse_json(out, {'raw_stdout': out[:1000], 'raw_stderr': err[:500]})
            ok = rc in (0,1,2,3)
            duration_ms = int((time.time() - start) * 1000)
            result = {'mode': args.mode, 'status': 'ok' if ok else 'failed', 'exit_code': rc, 'timestamp': ts, 'duration_ms': duration_ms, 'health': payload}
            if duration_ms > cfg['budget'] * 1000:
                metrics = read_json(ALWAYS_ON / 'always_on_metrics.json', {})
                metrics['execution_budget_hit_count'] = metrics.get('execution_budget_hit_count', 0) + 1
                write_json(ALWAYS_ON / 'always_on_metrics.json', metrics)
                result['budget_hit'] = True
            component_snapshot(args.mode, {'ok': ok, 'duration_ms': duration_ms}, probe_summary=probe_summary)
            extras['auto_flow'] = maybe_generate_incident_and_proposal(payload, probe_failures)
            extras['summaries'] = maybe_generate_summaries(args.mode, payload)
        else:
            rc, out, err = run(['python3', str(WORKSPACE / 'tools' / 'gate-self-health-check'), '--json'], timeout=cfg['budget'])
            payload = parse_json(out, {'raw_stdout': out[:1000], 'raw_stderr': err[:500]})
            ok = rc == 0
            duration_ms = int((time.time() - start) * 1000)
            result = {'mode': args.mode, 'status': 'ok' if ok else 'failed', 'exit_code': rc, 'timestamp': ts, 'duration_ms': duration_ms, 'gate': payload}
            if duration_ms > cfg['budget'] * 1000:
                metrics = read_json(ALWAYS_ON / 'always_on_metrics.json', {})
                metrics['execution_budget_hit_count'] = metrics.get('execution_budget_hit_count', 0) + 1
                write_json(ALWAYS_ON / 'always_on_metrics.json', metrics)
                result['budget_hit'] = True
            component_snapshot(args.mode, None, payload)
            gate_consistency_metrics(payload)
            extras['summaries'] = maybe_generate_summaries(args.mode)

        if extras:
            result.update(extras)
        state.update({'last_run_at': ts, 'last_run_epoch': time.time(), 'last_run_result': result['status'], 'last_run_duration_ms': result['duration_ms']})
        write_json(state_path, state)
        append_jsonl(history_path, result)
        print(json.dumps(result, ensure_ascii=False, indent=2) if args.json else result['status'])
        return 0 if ok else 1

if __name__ == '__main__':
    sys.exit(main())
