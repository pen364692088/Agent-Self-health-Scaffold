def main():
    print("=" * 60)
    print("6 个关键护栏验证")
    print("=" * 60)
    
    tests = [
        ("状态文件原子写入", test_atomic_write),
        ("队列注入与权限", test_queue_permissions),
        ("全局并发上限", test_global_concurrent_limit),
        ("紧急刹车开关", test_kill_switch),
        ("可观测指标", test_observability_metrics),
        ("死循环护栏", test_deadloop_guard),
    ]
    
    passed = 0
    failed = 0
    
    for name, test_fn in tests:
        try:
            if test_fn():
                passed += 1
            else:
                failed += 1
        except Exception as e:
            print(f"❌ {name}: Exception - {e}")
            import traceback
            traceback.print_exc()
            failed += 1
    
    print("\n" + "=" * 60)
    print(f"结果: {passed} passed, {failed} failed")
    print("=" * 60)
    
    if failed == 0:
        print("\n✅ 所有护栏已实现，可以上线")
    else:
        print("\n⚠️  有护栏未通过，建议修复后再上线")
    
    return 0 if failed == 0 else 1


if __name__ == "__main__":
    sys.exit(main())
