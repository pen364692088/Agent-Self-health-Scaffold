def test_queue_permissions():
    """测试 2: 队列注入与权限"""
    print("\n" + "=" * 60)
    print("测试 2: 队列注入与权限")
    print("=" * 60)
    
    # 检查 events 目录权限
    if EVENTS_DIR.exists():
        mode = EVENTS_DIR.stat().st_mode
        perm = stat.S_IMODE(mode)
        print(f"  events/ 权限: {oct(perm)}")
        
        # 检查是否只有用户可读写执行
        if perm == 0o700:
            print("  ✅ 权限正确 (700)")
        else:
            print("  ⚠️  权限建议设为 700")
    else:
        print("  ❌ events/ 目录不存在")
        return False
    
    # 检查 event-queue 的白名单校验
    queue_file = WORKSPACE / "tools" / "event-queue"
    
    if queue_file.exists():
        content = queue_file.read_text()
        
        checks = {
            "run_id_validation": "validate_run_id" in content,
            "whitelist": "a-zA-Z0-9" in content,
            "max_length": "len(run_id) > 100" in content or "len(" in content
        }
        
        print(f"  run_id 校验: {'✅' if checks['run_id_validation'] else '❌'}")
        print(f"  白名单: {'✅' if checks['whitelist'] else '❌'}")
        print(f"  长度限制: {'✅' if checks['max_length'] else '❌'}")
        
        if checks['run_id_validation'] and checks['whitelist']:
            print("  ✅ 注入校验实现正确")
            return True
        else:
            print("  ❌ 注入校验不完整")
            return False
    else:
        print("  ❌ event-queue 不存在")
        return False


