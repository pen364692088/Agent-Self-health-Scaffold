#!/usr/bin/env python3
"""
Parse continuity events log and output metrics.
Handles multi-line JSON format.
Supports metric_semantics_version filtering.
"""

import json
import sys
from pathlib import Path
from collections import defaultdict
from datetime import datetime

def main():
    events_file = Path.home() / ".openclaw/workspace/state/session_continuity_events.jsonl"
    output_file = Path.home() / ".openclaw/workspace/state/daily_metrics.json"
    
    if not events_file.exists():
        print("No events file")
        metrics = {
            "raw": {},
            "unique_sessions": {},
            "unique_handoff_ids": 0,
            "unique_conflict_ids": 0,
            "unique_recovery_ids": 0,
            "unique_gate_ids": 0,
            "total_events": 0,
            "by_semantics_version": {},
            "generated_at": datetime.now().isoformat()
        }
        with open(output_file, 'w') as f:
            json.dump(metrics, f, indent=2)
        return
    
    # Read events
    events = []
    with open(events_file, 'r') as f:
        content = f.read()
    
    # Parse concatenated JSON objects
    decoder = json.JSONDecoder()
    idx = 0
    while idx < len(content):
        while idx < len(content) and content[idx] in ' \t\n\r':
            idx += 1
        if idx >= len(content):
            break
        try:
            obj, end = decoder.raw_decode(content, idx)
            events.append(obj)
            idx = end
        except:
            idx += 1
    
    # Count raw events by type
    raw_counts = defaultdict(int)
    for event in events:
        event_type = event.get("event_type", "unknown")
        raw_counts[event_type] += 1
    
    # Count unique sessions per event type
    unique_sessions = defaultdict(set)
    for event in events:
        event_type = event.get("event_type", "unknown")
        session_id = event.get("session_id", "unknown")
        unique_sessions[event_type].add(session_id)
    
    # Count unique identity fields
    unique_handoff_ids = set()
    unique_conflict_ids = set()
    unique_recovery_ids = set()
    unique_gate_ids = set()
    
    for event in events:
        meta = event.get("meta", {})
        event_type = event.get("event_type", "")
        
        if event_type == "handoff_created" and "handoff_id" in meta:
            unique_handoff_ids.add(meta["handoff_id"])
        if event_type == "conflict_resolution_applied" and "conflict_id" in meta:
            unique_conflict_ids.add(meta["conflict_id"])
        if event_type == "recovery_success" and "recovery_id" in meta:
            unique_recovery_ids.add(meta["recovery_id"])
        if event_type == "gate_completed" and "gate_id" in meta:
            unique_gate_ids.add(meta["gate_id"])
    
    # Group by semantics version
    by_semantics = defaultdict(int)
    for event in events:
        version = event.get("metric_semantics_version", "unknown")
        by_semantics[version] += 1
    
    # Output metrics
    metrics = {
        "raw": dict(raw_counts),
        "unique_sessions": {k: len(v) for k, v in unique_sessions.items()},
        "unique_handoff_ids": len(unique_handoff_ids),
        "unique_conflict_ids": len(unique_conflict_ids),
        "unique_recovery_ids": len(unique_recovery_ids),
        "unique_gate_ids": len(unique_gate_ids),
        "total_events": len(events),
        "by_semantics_version": dict(by_semantics),
        "generated_at": datetime.now().isoformat()
    }
    
    with open(output_file, 'w') as f:
        json.dump(metrics, f, indent=2)
    
    print(f"Parsed {len(events)} events (semantics: {dict(by_semantics)})")

if __name__ == "__main__":
    main()
