#!/usr/bin/env python3
"""
Session Continuity Deep Audit

Performs diagnostic audits beyond simple counts:
1. Recovery actual usability
2. Event/File consistency
3. Deduplication correctness
4. Cross-entry consistency
"""

import json
import sys
from pathlib import Path
from collections import defaultdict
from datetime import datetime

WORKSPACE = Path.home() / ".openclaw/workspace"
EVENTS_FILE = WORKSPACE / "state/session_continuity_events.jsonl"
SUMMARY_FILE = WORKSPACE / "artifacts/session_recovery/latest_recovery_summary.json"
HANDOFF_FILE = WORKSPACE / "handoff.md"
SESSION_STATE = WORKSPACE / "SESSION-STATE.md"
WORKING_BUFFER = WORKSPACE / "memory/working-buffer.md"

def parse_events():
    """Parse all events from log."""
    if not EVENTS_FILE.exists():
        return []
    
    events = []
    with open(EVENTS_FILE, 'r') as f:
        content = f.read()
    
    decoder = json.JSONDecoder()
    idx = 0
    while idx < len(content):
        while idx < len(content) and content[idx] in ' \t\n\r':
            idx += 1
        if idx >= len(content):
            break
        try:
            obj, end = decoder.raw_decode(content, idx)
            events.append(obj)
            idx = end
        except:
            idx += 1
    
    return events

def check_recovery_usability(events):
    """
    A. Recovery 真正可用率
    Check if recovery actually provided usable state.
    """
    recovery_events = [e for e in events if e.get("event_type") == "recovery_success"]
    
    results = {
        "total": len(recovery_events),
        "with_objective": 0,
        "with_phase": 0,
        "with_next_actions": 0,
        "fully_usable": 0
    }
    
    for event in recovery_events:
        meta = event.get("meta", {})
        has_obj = bool(meta.get("objective") and meta.get("objective") != "N/A")
        has_phase = bool(meta.get("phase") and meta.get("phase") != "N/A")
        
        if has_obj:
            results["with_objective"] += 1
        if has_phase:
            results["with_phase"] += 1
        if has_obj and has_phase:
            results["fully_usable"] += 1
    
    if results["total"] > 0:
        results["usable_rate"] = f"{results['fully_usable'] * 100 / results['total']:.1f}%"
    else:
        results["usable_rate"] = "N/A"
    
    return results

def check_event_file_consistency(events):
    """
    B. Event/File Consistency
    Check if events have corresponding files.
    """
    results = {
        "recovery_events": 0,
        "recovery_summaries": 0,
        "handoff_events": 0,
        "handoff_files": 0,
        "inconsistencies": []
    }
    
    # Recovery events vs summaries
    recovery_events = [e for e in events if e.get("event_type") == "recovery_success"]
    results["recovery_events"] = len(recovery_events)
    results["recovery_summaries"] = 1 if SUMMARY_FILE.exists() else 0
    
    if results["recovery_events"] > 0 and results["recovery_summaries"] == 0:
        results["inconsistencies"].append({
            "type": "recovery_no_summary",
            "detail": f"{results['recovery_events']} recovery events but no summary file"
        })
    
    # Handoff events vs files
    handoff_events = [e for e in events if e.get("event_type") == "handoff_created"]
    results["handoff_events"] = len(handoff_events)
    results["handoff_files"] = 1 if HANDOFF_FILE.exists() else 0
    
    if results["handoff_events"] > 0 and results["handoff_files"] == 0:
        results["inconsistencies"].append({
            "type": "handoff_no_file",
            "detail": f"{results['handoff_events']} handoff events but no handoff file"
        })
    
    # Gate events vs results
    gate_events = [e for e in events if e.get("event_type") == "gate_completed"]
    results["gate_events"] = len(gate_events)
    
    return results

def check_dedup_correctness(events):
    """
    C. Dedup Correctness
    Check if deduplication is working correctly.
    """
    results = {
        "total_events": len(events),
        "unique_dedupe_keys": 0,
        "duplicates_found": 0,
        "issues": []
    }
    
    dedupe_keys = defaultdict(int)
    for event in events:
        key = event.get("dedupe_key", "")
        dedupe_keys[key] += 1
    
    results["unique_dedupe_keys"] = len(dedupe_keys)
    
    for key, count in dedupe_keys.items():
        if count > 1:
            results["duplicates_found"] += 1
            results["issues"].append({
                "type": "duplicate_dedupe_key",
                "key": key,
                "count": count
            })
    
    return results

def check_cross_entry_consistency(events):
    """
    D. Cross-Entry Consistency
    Check if same logic works across different entry points.
    """
    results = {
        "by_source": defaultdict(int),
        "by_semantics": defaultdict(int),
        "issues": []
    }
    
    for event in events:
        source = event.get("source_tool", "unknown")
        semantics = event.get("metric_semantics_version", "unknown")
        results["by_source"][source] += 1
        results["by_semantics"][semantics] += 1
    
    # Check if all events have semantics version
    unknown_semantics = results["by_semantics"].get("unknown", 0)
    if unknown_semantics > 0:
        results["issues"].append({
            "type": "missing_semantics_version",
            "count": unknown_semantics
        })
    
    return results

def main():
    print("=== Session Continuity Deep Audit ===\n")
    
    events = parse_events()
    
    print(f"Total events: {len(events)}\n")
    
    # A. Recovery Usability
    print("A. Recovery Actual Usability:")
    usability = check_recovery_usability(events)
    print(f"  Total recoveries: {usability['total']}")
    print(f"  With objective: {usability['with_objective']}")
    print(f"  With phase: {usability['with_phase']}")
    print(f"  Fully usable: {usability['fully_usable']}")
    print(f"  Usable rate: {usability['usable_rate']}")
    print()
    
    # B. Event/File Consistency
    print("B. Event/File Consistency:")
    consistency = check_event_file_consistency(events)
    print(f"  Recovery events: {consistency['recovery_events']}")
    print(f"  Recovery summaries: {consistency['recovery_summaries']}")
    print(f"  Handoff events: {consistency['handoff_events']}")
    print(f"  Handoff files: {consistency['handoff_files']}")
    if consistency["inconsistencies"]:
        print("  ⚠️ Inconsistencies:")
        for inc in consistency["inconsistencies"]:
            print(f"    - {inc['detail']}")
    print()
    
    # C. Dedup Correctness
    print("C. Deduplication Correctness:")
    dedup = check_dedup_correctness(events)
    print(f"  Total events: {dedup['total_events']}")
    print(f"  Unique dedupe_keys: {dedup['unique_dedupe_keys']}")
    print(f"  Duplicates found: {dedup['duplicates_found']}")
    if dedup["issues"]:
        print("  ⚠️ Issues:")
        for issue in dedup["issues"]:
            print(f"    - Key: {issue['key']} (count: {issue['count']})")
    print()
    
    # D. Cross-Entry Consistency
    print("D. Cross-Entry Consistency:")
    cross = check_cross_entry_consistency(events)
    print(f"  By source tool:")
    for source, count in sorted(cross["by_source"].items()):
        print(f"    - {source}: {count}")
    print(f"  By semantics version:")
    for ver, count in sorted(cross["by_semantics"].items()):
        print(f"    - {ver}: {count}")
    if cross["issues"]:
        print("  ⚠️ Issues:")
        for issue in cross["issues"]:
            print(f"    - {issue['type']}: {issue['count']}")
    
    # Overall assessment
    print("\n=== Overall Assessment ===")
    issues_count = (
        len(consistency["inconsistencies"]) +
        len(dedup["issues"]) +
        len(cross["issues"])
    )
    
    if issues_count == 0:
        print("✅ No anomalies detected")
    else:
        print(f"⚠️ {issues_count} issue(s) found - check details above")

if __name__ == "__main__":
    main()
