#!/usr/bin/env python3
"""
子代理完成处理器 v2.2

v2.2 修复：
- 幂等处理：已完成的步骤不再重复处理
- 多维度匹配：task_id / run_id / orchestrator 映射

Usage:
  subagent-completion-handler --payload '<json>'
  subagent-completion-handler <run_id>
  subagent-completion-handler --health
  subagent-completion-handler --status
"""

import json
import sys
import uuid
from datetime import datetime
from pathlib import Path

WORKSPACE = Path.home() / ".openclaw" / "workspace"
WORKFLOW_FILE = WORKSPACE / "WORKFLOW_STATE.json"
ORCHESTRATOR_FILE = WORKSPACE / "tools" / "orchestrator" / "pending_subtasks.json"
LEDGER_TOOL = WORKSPACE / "tools" / "task-ledger"
RUN_STATE_TOOL = WORKSPACE / "tools" / "run-state"
HARD_BLOCK_POLICY_TOOL = WORKSPACE / "tools" / "hard-block-policy"


def load_workflow():
    """加载工作流状态"""
    if not WORKFLOW_FILE.exists():
        return None
    try:
        with open(WORKFLOW_FILE, 'r') as f:
            return json.load(f)
    except Exception as e:
        print(f"Error loading workflow: {e}", file=sys.stderr)
        return None


def save_workflow(state: dict):
    """保存工作流状态"""
    state['updated_at'] = datetime.now().isoformat()
    with open(WORKFLOW_FILE, 'w') as f:
        json.dump(state, f, indent=2, ensure_ascii=False)


def load_orchestrator():
    """加载 orchestrator 状态"""
    if not ORCHESTRATOR_FILE.exists():
        return None
    try:
        with open(ORCHESTRATOR_FILE, 'r') as f:
            return json.load(f)
    except Exception:
        return None


def find_step_by_task_id(state: dict, task_id: str, exclude_done: bool = False) -> tuple:
    """根据 task_id 找到对应步骤及其索引"""
    steps = state.get('steps', [])
    for i, step in enumerate(steps):
        if step.get('id') == task_id or step.get('task_id') == task_id:
            if exclude_done and step.get('status') == 'done':
                continue
            return step, i
    return None, -1


def find_step_by_run_id(state: dict, run_id: str, exclude_done: bool = False) -> tuple:
    """根据 run_id 找到对应步骤"""
    steps = state.get('steps', [])
    for i, step in enumerate(steps):
        if exclude_done and step.get('status') == 'done':
            continue
        step_run_id = step.get('run_id') or ''
        if step_run_id and (step_run_id == run_id or run_id in step_run_id or step_run_id in run_id):
            return step, i
    return None, -1


def find_task_in_orchestrator(task_id: str) -> dict:
    """在 orchestrator 中查找任务"""
    orch = load_orchestrator()
    if not orch:
        return None
    return orch.get('pending', {}).get(task_id)


def try_match_step(state: dict, payload: dict, exclude_done: bool = True) -> tuple:
    """
    多维度匹配步骤
    
    Args:
        state: 工作流状态
        payload: 回调 payload
        exclude_done: 是否排除已完成的步骤（幂等）
    
    Returns:
        (step, index, match_method) 或 (None, -1, None)
    """
    task_id = payload.get('task_id', '')
    run_id = payload.get('run_id', '')  # 直接从 payload 获取
    child_session_key = payload.get('child_session_key', '')
    
    # 方法 1: task_id 匹配
    step, idx = find_step_by_task_id(state, task_id, exclude_done)
    if step:
        return step, idx, 'task_id'
    
    # 方法 2: run_id 匹配
    if run_id:
        step, idx = find_step_by_run_id(state, run_id, exclude_done)
        if step:
            return step, idx, 'run_id'
    
    # 方法 3: orchestrator 映射
    orch_task = find_task_in_orchestrator(task_id)
    if orch_task:
        orch_run_id = orch_task.get('run_id', '')
        if orch_run_id:
            step, idx = find_step_by_run_id(state, orch_run_id, exclude_done)
            if step:
                return step, idx, 'orchestrator_mapping'
    
    # 方法 4: 尝试匹配已完成的步骤（用于检测重复回调）
    if exclude_done:
        step, idx, method = try_match_step(state, payload, exclude_done=False)
        if step and step.get('status') == 'done':
            return step, idx, 'already_done'
    
    return None, -1, None




def classify_hard_block(error_type: str | None):
    try:
        import subprocess, json
        if not error_type:
            return False, None
        r = subprocess.run([str(HARD_BLOCK_POLICY_TOOL), 'classify', '--error-type', error_type], capture_output=True, text=True, timeout=5)
        if r.returncode == 0:
            data = json.loads(r.stdout or '{}')
            return bool(data.get('hard_block')), data.get('reason')
    except Exception:
        pass
    return False, None

def write_checkpoint(label: str, summary: str = "", next_step: str = "", status: str = "running", hard_block: bool = False, error_type: str = None):
    """Persist a durable checkpoint without breaking main flow."""
    try:
        cmd = [str(RUN_STATE_TOOL), 'checkpoint', label, '--status', status]
        if summary:
            cmd.extend(['--summary', summary])
        if next_step:
            cmd.extend(['--next-step', next_step])
        if hard_block:
            cmd.append('--hard-block')
        if error_type:
            cmd.extend(['--error-type', error_type])
        import subprocess
        subprocess.run(cmd, capture_output=True, text=True, timeout=10)
    except Exception:
        pass

def handle_structured_payload(payload: dict) -> dict:
    """处理结构化 payload"""
    task_id = payload.get('task_id')
    status = payload.get('status', 'completed')
    summary = payload.get('summary', '')
    artifacts = payload.get('artifacts', [])
    
    # 加载工作流
    state = load_workflow()
    
    if not state or not state.get('active'):
        write_checkpoint('callback_no_active_workflow', summary=summary, next_step='', status='running')
        return {
            "action": "notify_user",
            "message": f"✅ 子任务完成: {task_id}\n{summary}",
            "should_silence": False,
            "artifacts": artifacts
        }
    
    # 多维度匹配（排除已完成）
    step, idx, match_method = try_match_step(state, payload, exclude_done=True)
    
    if match_method == 'already_done':
        # 幂等：步骤已完成，忽略重复回调
        write_checkpoint('duplicate_callback', summary=summary, status='running')
        return {
            "action": "ignore",
            "reason": "duplicate_callback",
            "task_id": task_id,
            "step_id": step.get('id'),
            "should_silence": True
        }
    
    if not step:
        # 没找到匹配步骤
        write_checkpoint('callback_step_not_found', summary=summary or task_id, status='running')
        return {
            "action": "ignore",
            "reason": "step_not_found",
            "task_id": task_id,
            "should_silence": False
        }
    
    # 更新步骤状态
    step['status'] = 'done' if status == 'completed' else 'failed'
    if status != 'completed':
        err = payload.get('error', {}) if isinstance(payload.get('error'), dict) else {}
        err_type = err.get('type') or 'subagent_failed'
        hard_block, hard_reason = classify_hard_block(err_type)
        write_checkpoint('step_failed', summary=summary or task_id, next_step=step.get('id') or '', status='hard_blocked' if hard_block else 'repairing', hard_block=hard_block, error_type=hard_reason or err_type)
    step['completed_at'] = datetime.now().isoformat()
    step['summary'] = summary
    step['artifacts'] = artifacts
    step['match_method'] = match_method
    
    # 检查是否还有待处理步骤
    steps = state.get('steps', [])
    pending_steps = [
        (i, s) for i, s in enumerate(steps)
        if s.get('status') in ('pending', 'running') and s.get('id') != step.get('id')
    ]
    
    if pending_steps:
        next_idx, next_step = pending_steps[0]
        depends_on = next_step.get('depends_on', [])
        completed_ids = [s.get('id') for s in steps if s.get('status') == 'done']
        
        if all(d in completed_ids for d in depends_on):
            save_workflow(state)
            write_checkpoint('step_completed', summary=summary or task_id, next_step=next_step.get('id') or '', status='running')
            return {
                "action": "spawn_next",
                "next_step": next_step,
                "workflow": state,
                "should_silence": True
            }
        else:
            save_workflow(state)
            write_checkpoint('wait_for_dependencies', summary=summary or task_id, next_step=next_step.get('id') or '', status='running')
            return {
                "action": "wait_for_dependencies",
                "waiting_for": [d for d in depends_on if d not in completed_ids],
                "should_silence": True
            }
    else:
        # 全部完成
        state['active'] = False
        state['completed_at'] = datetime.now().isoformat()
        save_workflow(state)
        write_checkpoint('workflow_completed', summary=summary or task_id, status='completed')
        
        return {
            "action": "notify_user",
            "message": state.get("notify_on_done", f"✅ 流程完成: {task_id}"),
            "should_silence": False
        }


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)
    
    if sys.argv[1] == "--health":
        print(json.dumps({"status": "healthy", "version": "2.2"}))
        sys.exit(0)
    
    if sys.argv[1] == "--status":
        state = load_workflow()
        if state:
            print(json.dumps(state, indent=2, ensure_ascii=False))
        else:
            print(json.dumps({"active": False, "message": "No active workflow"}))
        sys.exit(0)
    
    if sys.argv[1] == "--payload":
        if len(sys.argv) < 3:
            print("Error: --payload requires JSON argument", file=sys.stderr)
            sys.exit(1)
        try:
            payload = json.loads(sys.argv[2])
            result = handle_structured_payload(payload)
            print(json.dumps(result, indent=2, ensure_ascii=False))
        except json.JSONDecodeError as e:
            print(f"Error parsing JSON: {e}", file=sys.stderr)
            sys.exit(1)
        sys.exit(0)
    
    # 传统 run_id 模式
    run_id = sys.argv[1]
    state = load_workflow()
    
    if not state or not state.get('active'):
        print(json.dumps({"action": "ignore", "reason": "workflow_inactive", "should_silence": False}))
        sys.exit(0)
    
    step, idx = find_step_by_run_id(state, run_id, exclude_done=True)
    
    if step:
        step['status'] = 'done'
        step['completed_at'] = datetime.now().isoformat()
        
        # 检查下一步
        steps = state.get('steps', [])
        pending = [(i, s) for i, s in enumerate(steps) if s.get('status') in ('pending', 'running')]
        
        if pending:
            save_workflow(state)
            print(json.dumps({"action": "spawn_next", "next_step": pending[0][1], "should_silence": True}))
        else:
            state['active'] = False
            state['completed_at'] = datetime.now().isoformat()
            save_workflow(state)
            print(json.dumps({"action": "notify_user", "message": state.get("notify_on_done", "完成"), "should_silence": False}))
    else:
        # 检查是否已完成（幂等）
        step, idx = find_step_by_run_id(state, run_id, exclude_done=False)
        if step and step.get('status') == 'done':
            print(json.dumps({"action": "ignore", "reason": "duplicate_callback", "should_silence": True}))
        else:
            print(json.dumps({"action": "ignore", "reason": "run_id_not_found", "should_silence": False}))


if __name__ == "__main__":
    main()
