def compute_file_hash(file_path: str) -> str:
    """Compute SHA256 hash of a file."""
    if not Path(file_path).exists():
        return "file_not_found"
    
    with open(file_path, "rb") as f:
        return hashlib.sha256(f.read()).hexdigest()[:16]


def get_tool_versions() -> dict:
    """Get versions of key tools."""
    versions = {}
    
    for tool in ["subtask-orchestrate", "done-guard", "tool_doctor"]:
        tool_path = WORKSPACE / "tools" / tool
        if tool_path.exists():
            content = tool_path.read_text()
            # 提取版本号
            import re
            match = re.search(r'v(\d+\.\d+(?:\.\d+)?)', content)
            versions[tool] = match.group(0) if match else "unknown"
        else:
            versions[tool] = "not_found"
    
    return versions


def log_gates_bypass(reason: str, task_id: str = None, user: str = None):
    """
    Log GATES_DISABLE usage for audit with config hash.
    
    v2.3 补丁: 包含 gates_config_hash, schema_version, tool_versions
    """
    import getpass
    timestamp = datetime.now().isoformat()
    user = user or os.environ.get("USER") or getpass.getuser()
    
    # 计算配置文件 hash
    gates_config_hash = compute_file_hash(GATES_CONFIG)
    schema_hash = compute_file_hash(DOCTOR_SCHEMA)
    
    # 获取 schema version
    schema_version = "unknown"
    if DOCTOR_SCHEMA.exists():
        try:
            schema_data = json.loads(DOCTOR_SCHEMA.read_text())
            schema_version = schema_data.get("$id", "unknown")
        except:
            pass
    
    # 获取工具版本
    tool_versions = get_tool_versions()
    
    audit_entry = {
        "timestamp": timestamp,
        "event": "GATES_BYPASS",
        "reason": reason or os.environ.get("GATES_DISABLE_REASON", "No reason provided"),
        "task_id": task_id,
        "user": user,
        "env_gates_disable": os.environ.get("GATES_DISABLE", "0"),
        
        # v2.3 补丁: 新增字段
        "gates_config_hash": gates_config_hash,
        "schema_version": schema_version,
        "schema_hash": schema_hash,
        "tool_versions": tool_versions
    }
    
    # 追加审计日志
    with open(AUDIT_LOG, "a") as f:
        f.write(json.dumps(audit_entry) + "\n")
    
    return audit_entry


def is_tool_task(task_description: str, changed_paths: list = None) -> tuple:
    """Detect if task is tool-related."""
    # 路径触发 (最优先)
    if changed_paths:
        for path in changed_paths:
            for force_path in TOOL_PATHS_FORCE:
                if force_path in path:
                    return True, f"Path trigger: {path} matches {force_path}"
    
    # 关键词检测
    task_lower = task_description.lower()
    for kw in TOOL_TASK_KEYWORDS:
        if kw in task_lower:
            return True, f"Keyword match: {kw}"
    
    return False, "Not a tool task"


