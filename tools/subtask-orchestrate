#!/usr/bin/env python3
"""
Subagent Orchestrate v3.0 - 唯一正式入口

强制流程：
1. 先检查邮箱 (subagent-inbox check)
2. 处理所有待处理回执
3. 再决定是否 spawn 新任务
4. 返回简洁的下一步

主 agent 只需调用此工具，不需要记得"先查邮箱"。

Usage:
  subtask-orchestrate run "<task>" -m <model> --timeout 300
  subtask-orchestrate status
  subtask-orchestrate resume
  subtask-orchestrate list
"""

import argparse
import json
import sys
import subprocess
from datetime import datetime
from pathlib import Path

WORKSPACE = Path.home() / ".openclaw" / "workspace"
INBOX_TOOL = WORKSPACE / "tools" / "subagent-inbox"
SPAWN_TOOL = WORKSPACE / "tools" / "spawn-with-callback"
HANDLER_TOOL = WORKSPACE / "tools" / "subagent-completion-handler"
ORCHESTRATOR_DIR = WORKSPACE / "tools" / "orchestrator"
PENDING_FILE = ORCHESTRATOR_DIR / "pending_subtasks.json"
WORKFLOW_FILE = WORKSPACE / "WORKFLOW_STATE.json"


def run_command(cmd: list, capture: bool = True) -> tuple:
    """运行命令，返回 (success, output)"""
    result = subprocess.run(
        cmd,
        capture_output=capture,
        text=True
    )
    return result.returncode == 0, result.stdout if capture else ""


def check_and_process_inbox() -> dict:
    """
    检查并处理邮箱中的回执
    
    这是强制的第一步，不允许跳过。
    """
    # 1. 检查待处理
    success, output = run_command([str(INBOX_TOOL), "check", "--once"])
    
    if not success:
        return {"error": "inbox_check_failed", "output": output}
    
    # 解析 pending 数量
    pending_count = 0
    if "pending" in output:
        try:
            pending_count = int(output.split()[1])
        except:
            pass
    
    if pending_count == 0:
        return {"pending_count": 0, "processed": []}
    
    # 2. 处理每个回执
    processed = []
    
    # 获取 pending 列表
    success, output = run_command([
        str(INBOX_TOOL), "check", "--once", "--json"
    ])
    
    if success and output:
        try:
            data = json.loads(output.split('\n')[0])
            for item in data.get("pending", []):
                task_id = item.get("task_id", "").replace(".done", "")
                if task_id:
                    # 处理
                    proc_success, proc_output = run_command([
                        str(INBOX_TOOL), "process", task_id
                    ])
                    
                    processed.append({
                        "task_id": task_id,
                        "success": proc_success
                    })
        except:
            pass
    
    return {
        "pending_count": pending_count,
        "processed": processed
    }


def get_workflow_status() -> dict:
    """获取工作流状态"""
    if not WORKFLOW_FILE.exists():
        return {"active": False}
    
    try:
        with open(WORKFLOW_FILE) as f:
            return json.load(f)
    except:
        return {"active": False}


def has_pending_work() -> bool:
    """检查是否有待处理的工作"""
    # 检查工作流
    workflow = get_workflow_status()
    if workflow.get("active"):
        for step in workflow.get("steps", []):
            if step.get("status") in ("pending", "running"):
                return True
    
    # 检查 orchestrator
    if PENDING_FILE.exists():
        try:
            with open(PENDING_FILE) as f:
                data = json.load(f)
            if data.get("pending"):
                return True
        except:
            pass
    
    return False


def run_task(task: str, model: str, timeout: int) -> dict:
    """
    运行任务（唯一入口）
    
    强制流程：
    1. 先检查邮箱
    2. 处理待处理回执
    3. 检查是否有进行中的工作
    4. 如果需要，spawn 新任务
    """
    result = {
        "step": "preflight",
        "inbox": None,
        "existing_work": None,
        "spawn": None
    }
    
    # Step 1: 检查邮箱（强制）
    result["inbox"] = check_and_process_inbox()
    
    if result["inbox"].get("processed"):
        result["step"] = "processed_receipts"
        result["message"] = f"处理了 {len(result['inbox']['processed'])} 个回执，请检查是否需要继续"
        return result
    
    # Step 2: 检查现有工作
    result["existing_work"] = has_pending_work()
    
    if result["existing_work"]:
        result["step"] = "has_pending"
        result["message"] = "有进行中的工作，请先完成或检查状态"
        return result
    
    # Step 3: Spawn 新任务
    success, output = run_command([
        str(SPAWN_TOOL), task, "-m", model, "-t", str(timeout)
    ])
    
    if success and output:
        try:
            spawn_data = json.loads(output)
            result["spawn"] = spawn_data
            result["step"] = "ready_to_spawn"
            result["message"] = "任务已准备，请执行 spawn"
            result["spawn_args"] = spawn_data.get("spawn_args")
        except:
            result["error"] = "parse_spawn_output_failed"
    else:
        result["error"] = "spawn_failed"
    
    return result


def show_status() -> dict:
    """显示状态（强制先检查邮箱）"""
    result = {
        "inbox": check_and_process_inbox(),
        "workflow": get_workflow_status(),
        "pending_tasks": []
    }
    
    if PENDING_FILE.exists():
        try:
            with open(PENDING_FILE) as f:
                data = json.load(f)
            result["pending_tasks"] = list(data.get("pending", {}).keys())
        except:
            pass
    
    return result


def resume_work() -> dict:
    """恢复工作（强制先检查邮箱）"""
    result = {
        "inbox": check_and_process_inbox(),
        "action": None
    }
    
    # 检查是否有待恢复的工作
    workflow = get_workflow_status()
    
    if workflow.get("active"):
        for step in workflow.get("steps", []):
            if step.get("status") == "running":
                result["action"] = "wait_for_running"
                result["message"] = f"步骤 {step.get('id')} 正在运行"
                return result
    
    # 检查邮箱是否有新回执
    if result["inbox"].get("processed"):
        result["action"] = "processed"
        result["message"] = "已处理新回执"
    else:
        result["action"] = "nothing_to_do"
        result["message"] = "没有待处理的工作"
    
    return result


def main():
    parser = argparse.ArgumentParser(
        description="Subagent Orchestrate v3.0 - 唯一入口",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  # 运行新任务（自动检查邮箱）
  subtask-orchestrate run "修复 bug" -m qianfan-code-latest

  # 查看状态（自动检查邮箱）
  subtask-orchestrate status

  # 恢复工作（自动检查邮箱）
  subtask-orchestrate resume

强制流程:
  1. 检查邮箱 (subagent-inbox check)
  2. 处理待处理回执
  3. 决定下一步
"""
    )
    
    subparsers = parser.add_subparsers(dest="command")
    
    # run
    run_parser = subparsers.add_parser("run", help="运行任务")
    run_parser.add_argument("task", help="任务描述")
    run_parser.add_argument("-m", "--model", default="baiduqianfancodingplan/qianfan-code-latest")
    run_parser.add_argument("-t", "--timeout", type=int, default=300)
    
    # status
    subparsers.add_parser("status", help="显示状态")
    
    # resume
    subparsers.add_parser("resume", help="恢复工作")
    
    # list
    subparsers.add_parser("list", help="列出待处理任务")
    
    # health
    subparsers.add_parser("health", help="健康检查")
    
    args = parser.parse_args()
    
    if args.command == "health":
        print(json.dumps({"status": "healthy", "version": "3.0"}))
        sys.exit(0)
    
    if args.command == "run":
        result = run_task(args.task, args.model, args.timeout)
        print(json.dumps(result, indent=2, ensure_ascii=False))
        sys.exit(0)
    
    if args.command == "status":
        result = show_status()
        print(json.dumps(result, indent=2, ensure_ascii=False))
        sys.exit(0)
    
    if args.command == "resume":
        result = resume_work()
        print(json.dumps(result, indent=2, ensure_ascii=False))
        sys.exit(0)
    
    if args.command == "list":
        success, output = run_command([str(INBOX_TOOL), "check", "--once"])
        print(output)
        sys.exit(0)
    
    parser.print_help()
    sys.exit(1)


if __name__ == "__main__":
    main()
