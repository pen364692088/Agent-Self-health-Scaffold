def cmd_run(args):
    """One-shot subagent execution."""
    from orchestrator import Orchestrator
    
    # 先检查是否有 pending 任务
    if PENDING_FILE.exists():
        with open(PENDING_FILE) as f:
            data = json.load(f)
        pending_count = len(data.get('pending', {}))
        if pending_count > 0 and args.auto_resume:
            print(f"⚠️  Found {pending_count} pending tasks, auto-resuming...")
            print()
            args_resume = argparse.Namespace(
                timeout=args.timeout,
                per_task=args.per_task,
                max_poll=args.max_poll,
                report=None
            )
            cmd_resume(args_resume)
            print()
    
    # Step 1: 注册任务
    orch = Orchestrator()
    task_id, run_id, session_key = orch.spawn_task(
        description=args.task,
        model=args.model,
        max_retries=args.retries
    )
    
    # Step 1.5: 检测是否为工具任务，注入 Gate 协议
    is_tool, tool_reason = is_tool_task(args.task)
    gates_disabled = os.environ.get('GATES_DISABLE', '0') == '1' or args.no_gates
    
    # 审计绕过 (v2.3 包含 config hash)
    if gates_disabled and is_tool:
        audit = log_gates_bypass(
            reason=os.environ.get("GATES_DISABLE_REASON", "CLI flag"),
            task_id=task_id
        )
        if not args.json:
            print(f"📝 GATES_DISABLE audit logged: {audit['timestamp']}")
            print(f"   config_hash: {audit['gates_config_hash']}")
            print(f"   schema_version: {audit['schema_version']}")
    
    # Step 2: 输出 sessions_spawn 命令
    if args.json:
        result = {
            "action": "spawn_and_join",
            "task_id": task_id,
            "run_id": run_id,
            "session_key": session_key,
            "model": args.model,
            "is_tool_task": is_tool,
            "tool_detection_reason": tool_reason,
            "gates_enabled": not gates_disabled,
            "spawn_command": f"sessions_spawn runtime=subagent model={args.model} task='{args.task[:60]}'",
            "join_command": f"subtask-orchestrate join -t {args.timeout} --task-id {task_id}"
        }
        if is_tool and not gates_disabled:
            result["gates_protocol"] = "See POLICIES/TOOL_DELIVERY.md"
        if gates_disabled and is_tool:
            result["gates_bypass_audit"] = audit
        print(json.dumps(result, indent=2))
    else:
        print("=" * 60)
        print("ONE-SHOT SUBAGENT EXECUTION")
        print("=" * 60)
        print()
        print(f"Task ID:    {task_id}")
        print(f"Run ID:     {run_id}")
        print(f"Model:      {args.model}")
        
        if is_tool:
            print(f"Tool Detection: {tool_reason}")
            if gates_disabled:
                print()
                print("⚠️  TOOL TASK DETECTED (GATES DISABLED)")
                print("   GATES_DISABLE=1 is set - gates bypassed")
                print(f"   Audit logged: {AUDIT_LOG}")
            else:
                print()
                print("🔧 TOOL TASK DETECTED - DELIVERY GATES REQUIRED")
                print("-" * 60)
                print(get_gates_injection())
        
        print()
        print("Step 1: Execute this command to spawn the subagent:")
        print("-" * 60)
        print(f"sessions_spawn runtime=subagent model={args.model} task='{args.task[:60]}...'")
        print("-" * 60)
        print()
        print("Step 2: After spawn completes, run this to join:")
        print("-" * 60)
        print(f"subtask-orchestrate join -t {args.timeout} --task-id {task_id}")
        print("-" * 60)
        print()
        print("⚠️  CRITICAL: Both steps are mandatory!")
        print("   Missing Step 2 = task stuck in pending forever.")
    
    return True


