def cmd_gc(args):
    """Garbage collect old tasks and clean up zombie tasks."""
    from orchestrator import Orchestrator
    orch = Orchestrator()
    
    results = {
        "gc": None,
        "zombie_cleanup": None
    }
    
    # 1. Clean up zombie tasks
    if args.zombie or args.all:
        zombie_result = orch.cleanup_zombie_tasks()
        results["zombie_cleanup"] = zombie_result
        if not args.json:
            print(f"🧹 Cleaned {zombie_result['cleaned_count']} zombie tasks")
    
    # 2. Regular GC of old completed tasks
    if args.old or args.all:
        old_count = orch.gc(keep_days=args.days)
        results["gc"] = {"old_tasks_removed": old_count}
        if not args.json:
            print(f"🗑️  Removed {old_count} old completed tasks (older than {args.days} days)")
    
    # If no specific flag, do both
    if not args.zombie and not args.old and not args.all:
        zombie_result = orch.cleanup_zombie_tasks()
        results["zombie_cleanup"] = zombie_result
        if not args.json:
            print(f"🧹 Cleaned {zombie_result['cleaned_count']} zombie tasks")
    
    if args.json:
        print(json.dumps(results, indent=2))
    
    return True


def cmd_stuck(args):
    """List stuck/pending tasks for diagnostics."""
    from orchestrator import Orchestrator
    orch = Orchestrator()
    
    stuck_tasks = orch.get_stuck_tasks()
    
    if args.json:
        print(json.dumps({"stuck_tasks": stuck_tasks}, indent=2))
    else:
        if stuck_tasks:
            print(f"⚠️  Found {len(stuck_tasks)} stuck tasks:")
            print("-" * 60)
            for task in stuck_tasks:
                overdue_min = task['overdue_seconds'] / 60
                print(f"  {task['task_id']}: {task['description']}...")
                print(f"    Deadline: {task['deadline']}")
                print(f"    Overdue: {overdue_min:.1f} minutes")
            print("-" * 60)
            print("\nRun 'subtask-orchestrate gc --zombie' to clean these up.")
        else:
            print("✅ No stuck tasks found")
    
    return True


def cmd_list(args):
    """List all pending and recent completed tasks."""
    from orchestrator import Orchestrator
    orch = Orchestrator()
    
    # 获取 pending 任务
    pending = {}
    with orch.lock:
        for task_id, task in orch.pending_subtasks.items():
            pending[task_id] = task.to_dict()
    
    if args.json:
        print(json.dumps({"pending": pending}, indent=2))
    else:
        if pending:
            print(f"📋 {len(pending)} pending tasks:")
            for task_id, task in pending.items():
                print(f"  - {task_id}: {task.get('description', 'N/A')[:40]}...")
        else:
            print("✅ No pending tasks")
    
    return True


