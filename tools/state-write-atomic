#!/usr/bin/env python3
"""
state-write-atomic v1.1 - Atomic State File Writer

Writes state files atomically using temp file + rename pattern.

Usage:
  state-write-atomic <file> "<content>"
  state-write-atomic --file <path> --content "<content>"
  state-write-atomic --json
"""

from __future__ import annotations

import argparse
import json
import sys
import os
import tempfile
import hashlib
from pathlib import Path
from datetime import datetime
from typing import Any, Dict

WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
WAL_FILE = WORKSPACE / "state" / "wal" / "session_state_wal.jsonl"


def compute_hash(content: str) -> str:
    """Compute SHA256 hash of content."""
    return hashlib.sha256(content.encode()).hexdigest()[:16]


def atomic_write(filepath: Path, content: str) -> Dict[str, Any]:
    """Write content to file atomically."""
    filepath = Path(filepath).resolve()
    
    # Create parent directories if needed
    filepath.parent.mkdir(parents=True, exist_ok=True)
    
    # Write to temp file first
    temp_fd = None
    temp_path = None
    
    try:
        # Create temp file in same directory (for same filesystem rename)
        temp_fd, temp_path = tempfile.mkstemp(
            dir=filepath.parent,
            prefix=f".{filepath.name}.tmp."
        )
        
        # Write content
        os.write(temp_fd, content.encode('utf-8'))
        os.fsync(temp_fd)  # Ensure data is on disk
        os.close(temp_fd)
        temp_fd = None
        
        # Atomic rename
        os.rename(temp_path, filepath)
        
        return {
            "success": True,
            "path": str(filepath),
            "hash": compute_hash(content),
            "timestamp": datetime.now().isoformat()
        }
        
    except Exception as e:
        # Cleanup temp file on failure
        if temp_fd is not None:
            try:
                os.close(temp_fd)
            except:
                pass
        if temp_path and os.path.exists(temp_path):
            os.unlink(temp_path)
        
        return {
            "success": False,
            "path": str(filepath),
            "error": str(e)
        }


def append_wal(entry: Dict[str, Any]) -> bool:
    """Append entry to WAL journal."""
    try:
        WAL_FILE.parent.mkdir(parents=True, exist_ok=True)
        
        entry["timestamp"] = datetime.now().isoformat()
        
        with open(WAL_FILE, "a") as f:
            f.write(json.dumps(entry) + "\n")
            f.flush()
            os.fsync(f.fileno())
        
        return True
    except Exception as e:
        print(f"WAL append failed: {e}", file=sys.stderr)
        return False


def main():
    parser = argparse.ArgumentParser(description="Atomic State Writer")
    parser.add_argument("file", nargs="?", help="File path to write")
    parser.add_argument("content", nargs="?", help="Content to write")
    parser.add_argument("--file", "-f", help="File path to write")
    parser.add_argument("--content", "-c", help="Content to write")
    parser.add_argument("--json", action="store_true", help="JSON output")
    parser.add_argument("--no-wal", action="store_true", help="Skip WAL append")
    parser.add_argument("--session-id", help="Session ID for WAL")
    parser.add_argument("--action-type", default="state_update", help="Action type for WAL")
    args = parser.parse_args()
    
    # Determine file path
    filepath = args.file
    if not filepath and args.file:
        filepath = args.file
    
    # Determine content
    content = args.content
    if not content and len(sys.argv) > 2:
        content = sys.argv[-1]
    
    if not filepath or content is None:
        parser.print_help()
        sys.exit(1)
    
    # Perform atomic write
    result = atomic_write(filepath, content)
    
    # Append to WAL
    if result["success"] and not args.no_wal:
        wal_entry = {
            "file": str(filepath),
            "hash": result["hash"],
            "session_id": args.session_id or os.environ.get("OPENCLAW_SESSION_ID", "unknown"),
            "action_type": args.action_type,
            "summary": content[:100] + "..." if len(content) > 100 else content
        }
        append_wal(wal_entry)
    
    if args.json:
        print(json.dumps(result, indent=2))
    else:
        if result["success"]:
            print(f"✅ Written to {filepath}")
        else:
            print(f"❌ Write failed: {result.get('error')}")
            sys.exit(1)


if __name__ == "__main__":
    main()