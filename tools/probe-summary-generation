#!/usr/bin/env python3
"""
probe-summary-generation - Summary Generation Verification Probe

Verification Mode: artifact_output_check

检查逻辑:
1. 检查 agent-health-summary 工具存在
2. 检查 latest summary 文件存在
3. 检查 summary 格式正确
4. 检查关键字段存在 (overall_status, components, timestamp)

Usage:
  probe-summary-generation
  probe-summary-generation --json

Exit codes:
  0 - PASS (all checks passed)
  1 - FAIL (one or more checks failed)
  2 - ERROR (unexpected error)
"""

import argparse
import json
import sys
import subprocess
from pathlib import Path
from datetime import datetime, timezone
from typing import Dict, List, Any, Optional

WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
TOOLS_DIR = WORKSPACE / "tools"
PROBES_DIR = WORKSPACE / "artifacts" / "self_health" / "probes"

# Summary-related paths
SUMMARY_TOOL = TOOLS_DIR / "agent-health-summary"
HEALTH_STATE_DIR = WORKSPACE / "artifacts" / "self_health" / "state"
CURRENT_HEALTH_FILE = HEALTH_STATE_DIR / "current_health.json"
HEALTH_HISTORY_FILE = HEALTH_STATE_DIR / "health_history.jsonl"

# Required fields in summary
REQUIRED_FIELDS = ["overall_status", "timestamp"]
OPTIONAL_FIELDS = ["components", "incidents", "metrics", "generated_at"]

TIMEOUT_SECONDS = 30


def now_iso():
    return datetime.now(timezone.utc).isoformat()


def write_evidence(probe_name: str, evidence: Dict):
    """Write probe evidence to artifacts directory."""
    PROBES_DIR.mkdir(parents=True, exist_ok=True)
    evidence_file = PROBES_DIR / f"{probe_name}_evidence.json"
    evidence["timestamp"] = now_iso()
    evidence["probe_name"] = probe_name
    with open(evidence_file, 'w') as f:
        json.dump(evidence, f, indent=2, ensure_ascii=False)
    return evidence_file


class SummaryGenerationProbe:
    """Probe for summary generation functionality."""
    
    def __init__(self):
        self.checks = []
        self.evidence = {
            "probe_name": "probe-summary-generation",
            "verification_mode": "artifact_output_check",
            "checks": [],
            "passed": False,
            "failures": []
        }
    
    def check_tool_exists(self) -> Dict:
        """Check 1: agent-health-summary tool exists."""
        check = {
            "name": "tool_exists",
            "description": "Check agent-health-summary tool exists and is executable",
            "passed": False,
            "details": {}
        }
        
        if SUMMARY_TOOL.exists():
            check["passed"] = True
            check["details"]["path"] = str(SUMMARY_TOOL)
            check["details"]["executable"] = bool(SUMMARY_TOOL.stat().st_mode & 0o111)
            
            try:
                result = subprocess.run(
                    [str(SUMMARY_TOOL), "--health"],
                    capture_output=True,
                    text=True,
                    timeout=10
                )
                check["details"]["health_returncode"] = result.returncode
                if result.returncode == 0:
                    try:
                        health = json.loads(result.stdout)
                        check["details"]["health_status"] = health.get("status", "unknown")
                    except:
                        pass
            except Exception as e:
                check["details"]["health_error"] = str(e)
        else:
            check["details"]["error"] = f"Tool not found: {SUMMARY_TOOL}"
        
        self.checks.append(check)
        return check
    
    def check_summary_file_exists(self) -> Dict:
        """Check 2: Latest summary file exists."""
        check = {
            "name": "summary_file_exists",
            "description": "Check latest summary file exists",
            "passed": False,
            "details": {}
        }
        
        if CURRENT_HEALTH_FILE.exists():
            check["passed"] = True
            check["details"]["current_health_exists"] = True
            check["details"]["current_health_path"] = str(CURRENT_HEALTH_FILE)
            
            mtime = CURRENT_HEALTH_FILE.stat().st_mtime
            age_seconds = datetime.now().timestamp() - mtime
            check["details"]["file_age_hours"] = round(age_seconds / 3600, 2)
        else:
            check["details"]["current_health_exists"] = False
            check["details"]["error"] = f"Summary file not found: {CURRENT_HEALTH_FILE}"
        
        if HEALTH_HISTORY_FILE.exists():
            check["details"]["health_history_exists"] = True
            try:
                with open(HEALTH_HISTORY_FILE) as f:
                    line_count = sum(1 for _ in f)
                check["details"]["history_entries"] = line_count
            except:
                pass
        else:
            check["details"]["health_history_exists"] = False
        
        self.checks.append(check)
        return check
    
    def check_summary_format(self) -> Dict:
        """Check 3: Summary format is correct (valid JSON with structure)."""
        check = {
            "name": "summary_format",
            "description": "Check summary format is correct",
            "passed": False,
            "details": {}
        }
        
        if not CURRENT_HEALTH_FILE.exists():
            check["details"]["error"] = "Summary file does not exist"
            self.checks.append(check)
            return check
        
        try:
            with open(CURRENT_HEALTH_FILE) as f:
                summary = json.load(f)
            
            check["details"]["valid_json"] = True
            check["details"]["summary_type"] = type(summary).__name__
            
            if isinstance(summary, dict):
                check["details"]["is_object"] = True
                check["details"]["top_level_keys"] = list(summary.keys())[:10]
                
                if "components" in summary:
                    check["details"]["has_components"] = True
                    if isinstance(summary["components"], dict):
                        check["details"]["components_count"] = len(summary["components"])
                    elif isinstance(summary["components"], list):
                        check["details"]["components_count"] = len(summary["components"])
                
                check["passed"] = True
            else:
                check["details"]["is_object"] = False
                check["details"]["error"] = "Summary is not a JSON object"
                
        except json.JSONDecodeError as e:
            check["details"]["valid_json"] = False
            check["details"]["error"] = f"Invalid JSON: {e}"
        except Exception as e:
            check["details"]["error"] = str(e)
        
        self.checks.append(check)
        return check
    
    def check_required_fields(self) -> Dict:
        """Check 4: Required fields exist in summary."""
        check = {
            "name": "required_fields",
            "description": "Check required fields exist (overall_status, timestamp)",
            "passed": False,
            "details": {}
        }
        
        if not CURRENT_HEALTH_FILE.exists():
            check["details"]["error"] = "Summary file does not exist"
            self.checks.append(check)
            return check
        
        try:
            with open(CURRENT_HEALTH_FILE) as f:
                summary = json.load(f)
            
            if not isinstance(summary, dict):
                check["details"]["error"] = "Summary is not an object"
                self.checks.append(check)
                return check
            
            found_required = []
            missing_required = []
            
            for field in REQUIRED_FIELDS:
                if field in summary:
                    found_required.append(field)
                    check["details"][f"has_{field}"] = True
                    check["details"][f"{field}_value"] = str(summary[field])[:100]
                else:
                    missing_required.append(field)
                    check["details"][f"has_{field}"] = False
            
            found_optional = []
            for field in OPTIONAL_FIELDS:
                if field in summary:
                    found_optional.append(field)
                    check["details"][f"has_{field}"] = True
            
            check["details"]["found_required"] = found_required
            check["details"]["missing_required"] = missing_required
            check["details"]["found_optional"] = found_optional
            
            check["passed"] = len(missing_required) == 0
            
            if "overall_status" in summary:
                valid_statuses = ["GREEN", "YELLOW", "ORANGE", "RED", "OK", "WARN", "FAIL"]
                status = summary.get("overall_status", "").upper()
                check["details"]["status_is_valid"] = status in valid_statuses
            
        except Exception as e:
            check["details"]["error"] = str(e)
        
        self.checks.append(check)
        return check
    
    def check_tool_output(self) -> Dict:
        """Check 5: Tool produces valid output."""
        check = {
            "name": "tool_output",
            "description": "Check tool produces valid output",
            "passed": False,
            "details": {}
        }
        
        if not SUMMARY_TOOL.exists():
            check["details"]["error"] = "Tool does not exist"
            self.checks.append(check)
            return check
        
        try:
            result = subprocess.run(
                [str(SUMMARY_TOOL), "--json", "--hours", "24"],
                capture_output=True,
                text=True,
                timeout=TIMEOUT_SECONDS
            )
            
            check["details"]["returncode"] = result.returncode
            
            if result.returncode == 0 and result.stdout:
                try:
                    output = json.loads(result.stdout)
                    check["details"]["output_valid"] = True
                    check["details"]["output_keys"] = list(output.keys())[:10]
                    
                    if "current_level" in output or "overall_status" in output:
                        check["passed"] = True
                    elif "current_health" in output:
                        check["passed"] = True
                    else:
                        check["details"]["warning"] = "Output missing expected keys"
                        check["passed"] = True
                    
                except json.JSONDecodeError as e:
                    check["details"]["output_valid"] = False
                    check["details"]["parse_error"] = str(e)
            else:
                check["details"]["stderr"] = result.stderr[:200] if result.stderr else None
                
        except subprocess.TimeoutExpired:
            check["details"]["error"] = f"Timeout after {TIMEOUT_SECONDS}s"
        except Exception as e:
            check["details"]["error"] = str(e)
        
        self.checks.append(check)
        return check
    
    def run(self) -> Dict:
        """Run all checks and return result."""
        self.check_tool_exists()
        self.check_summary_file_exists()
        self.check_summary_format()
        self.check_required_fields()
        self.check_tool_output()
        
        all_passed = all(c["passed"] for c in self.checks)
        failures = [c for c in self.checks if not c["passed"]]
        
        self.evidence["checks"] = self.checks
        self.evidence["passed"] = all_passed
        self.evidence["status"] = "ok" if all_passed else "fail"
        self.evidence["message"] = "Summary generation system healthy" if all_passed else "Summary generation issues found"
        self.evidence["failures"] = [c["name"] for c in failures]
        self.evidence["check_count"] = len(self.checks)
        self.evidence["pass_count"] = len([c for c in self.checks if c["passed"]])
        
        evidence_file = write_evidence("probe-summary-generation", self.evidence)
        self.evidence["evidence_file"] = str(evidence_file)
        
        return self.evidence


def main():
    parser = argparse.ArgumentParser(description="Summary Generation Verification Probe")
    parser.add_argument("--json", action="store_true", help="Output JSON only")
    args = parser.parse_args()
    
    probe = SummaryGenerationProbe()
    result = probe.run()
    
    if args.json:
        print(json.dumps(result, indent=2, ensure_ascii=False))
    else:
        status = "PASS" if result["passed"] else "FAIL"
        print(f"[{status}] probe-summary-generation")
        for check in result["checks"]:
            check_status = "✓" if check["passed"] else "✗"
            print(f"  {check_status} {check['name']}: {check.get('description', '')}")
        
        if result["failures"]:
            print(f"\nFailed checks: {', '.join(result['failures'])}")
    
    sys.exit(0 if result["passed"] else 1)


if __name__ == "__main__":
    main()
