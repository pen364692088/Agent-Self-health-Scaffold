#!/usr/bin/env python3
"""
probe-telegram-notification - Telegram Notification System Verification

Verification Mode: recent_success_check

检查逻辑:
1. 检查 openclaw message send 命令可用
2. 检查 Telegram channel 配置
3. 检查最近发送成功记录
4. 检查消息队列状态

Usage:
  probe-telegram-notification
  probe-telegram-notification --json
  probe-telegram-notification --timeout 30

Exit codes:
  0 - PASS (all checks passed)
  1 - FAIL (one or more checks failed)
  2 - ERROR (unexpected error)
"""

import argparse
import json
import sys
import subprocess
import os
from pathlib import Path
from datetime import datetime, timezone
from typing import Dict, List, Any, Optional

WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
PROBES_DIR = WORKSPACE / "artifacts" / "self_health" / "probes"
DELIVERY_QUEUE = Path.home() / ".openclaw" / "delivery-queue"
OPENCLAW_CONFIG = Path.home() / ".openclaw" / "openclaw.json"

TIMEOUT_SECONDS = 30


def now_iso():
    return datetime.now(timezone.utc).isoformat()


def write_evidence(probe_name: str, evidence: Dict):
    """Write probe evidence to artifacts directory."""
    PROBES_DIR.mkdir(parents=True, exist_ok=True)
    evidence_file = PROBES_DIR / f"{probe_name}_evidence.json"
    evidence["timestamp"] = now_iso()
    evidence["probe_name"] = probe_name
    with open(evidence_file, 'w') as f:
        json.dump(evidence, f, indent=2, ensure_ascii=False)
    return evidence_file


class TelegramNotificationProbe:
    """Probe for Telegram notification functionality."""
    
    def __init__(self, timeout: int = TIMEOUT_SECONDS):
        self.timeout = timeout
        self.checks = []
        self.evidence = {
            "probe_name": "probe-telegram-notification",
            "verification_mode": "recent_success_check",
            "checks": [],
            "passed": False,
            "failures": []
        }
    
    def check_openclaw_message_available(self) -> Dict:
        """Check 1: openclaw message send 命令可用."""
        check = {
            "name": "openclaw_message_available",
            "description": "Check openclaw message send command available",
            "passed": False,
            "details": {}
        }
        
        try:
            result = subprocess.run(
                ["openclaw", "message", "--help"],
                capture_output=True,
                text=True,
                timeout=self.timeout
            )
            
            if result.returncode == 0:
                check["passed"] = True
                check["details"]["command_available"] = True
                # Check for send subcommand
                if "send" in result.stdout:
                    check["details"]["send_available"] = True
            else:
                check["details"]["returncode"] = result.returncode
                check["details"]["stderr"] = result.stderr[:200] if result.stderr else None
                
        except subprocess.TimeoutExpired:
            check["details"]["error"] = f"Timeout after {self.timeout}s"
        except FileNotFoundError:
            check["details"]["error"] = "openclaw command not found"
        except Exception as e:
            check["details"]["error"] = str(e)
        
        self.checks.append(check)
        return check
    
    def check_telegram_channel_config(self) -> Dict:
        """Check 2: Telegram channel 配置."""
        check = {
            "name": "telegram_channel_config",
            "description": "Check Telegram channel configuration",
            "passed": False,
            "details": {}
        }
        
        try:
            result = subprocess.run(
                ["openclaw", "channels", "list"],
                capture_output=True,
                text=True,
                timeout=self.timeout
            )
            
            if result.returncode == 0:
                check["details"]["channels_list_success"] = True
                
                # Parse output for Telegram channels
                output = result.stdout
                telegram_channels = []
                for line in output.split('\n'):
                    if 'Telegram' in line:
                        telegram_channels.append(line.strip())
                
                check["details"]["telegram_channels"] = telegram_channels
                check["details"]["telegram_channel_count"] = len(telegram_channels)
                
                if len(telegram_channels) > 0:
                    check["passed"] = True
                else:
                    check["details"]["warning"] = "No Telegram channels configured"
            else:
                check["details"]["returncode"] = result.returncode
                check["details"]["stderr"] = result.stderr[:200] if result.stderr else None
                
        except subprocess.TimeoutExpired:
            check["details"]["error"] = f"Timeout after {self.timeout}s"
        except Exception as e:
            check["details"]["error"] = str(e)
        
        self.checks.append(check)
        return check
    
    def check_recent_send_success(self) -> Dict:
        """Check 3: 最近发送成功记录."""
        check = {
            "name": "recent_send_success",
            "description": "Check recent successful send records",
            "passed": False,
            "details": {}
        }
        
        # Check delivery queue for recent deliveries
        if DELIVERY_QUEUE.exists():
            check["details"]["delivery_queue_exists"] = True
            
            # Check for sent items
            sent_dir = DELIVERY_QUEUE / "sent"
            if sent_dir.exists():
                sent_files = list(sent_dir.glob("*.json"))
                check["details"]["sent_count"] = len(sent_files)
                
                if sent_files:
                    # Get most recent
                    most_recent = max(sent_files, key=lambda f: f.stat().st_mtime)
                    mtime = most_recent.stat().st_mtime
                    age_seconds = datetime.now().timestamp() - mtime
                    check["details"]["most_recent_sent_file"] = most_recent.name
                    check["details"]["most_recent_sent_age_hours"] = round(age_seconds / 3600, 2)
                    
                    # Consider success if sent within last 24 hours
                    if age_seconds < 86400:  # 24 hours
                        check["passed"] = True
                        check["details"]["recent_activity"] = True
                    else:
                        check["details"]["warning"] = f"Last send was {round(age_seconds/3600, 1)} hours ago"
                        check["passed"] = True  # Non-blocking, just informational
            else:
                check["details"]["sent_dir_exists"] = False
                check["passed"] = True  # Non-blocking
        else:
            check["details"]["delivery_queue_exists"] = False
            check["passed"] = True  # Non-blocking
        
        self.checks.append(check)
        return check
    
    def check_message_queue_status(self) -> Dict:
        """Check 4: 消息队列状态."""
        check = {
            "name": "message_queue_status",
            "description": "Check message queue status",
            "passed": False,
            "details": {}
        }
        
        if DELIVERY_QUEUE.exists():
            check["details"]["delivery_queue_exists"] = True
            
            # Check for pending items
            pending_dir = DELIVERY_QUEUE / "pending"
            if pending_dir.exists():
                pending_files = list(pending_dir.glob("*.json"))
                check["details"]["pending_count"] = len(pending_files)
                
                if len(pending_files) == 0:
                    check["passed"] = True
                    check["details"]["queue_empty"] = True
                elif len(pending_files) < 10:
                    check["passed"] = True
                    check["details"]["queue_health"] = "normal"
                else:
                    check["passed"] = True  # Non-blocking but warning
                    check["details"]["queue_health"] = "backlogged"
            else:
                check["details"]["pending_dir_exists"] = False
                check["passed"] = True
            
            # Check for failed items
            failed_dir = DELIVERY_QUEUE / "failed"
            if failed_dir.exists():
                failed_files = list(failed_dir.glob("*.json"))
                check["details"]["failed_count"] = len(failed_files)
        else:
            check["details"]["delivery_queue_exists"] = False
            check["passed"] = True  # Non-blocking
        
        self.checks.append(check)
        return check
    
    def run(self) -> Dict:
        """Run all checks and return result."""
        self.check_openclaw_message_available()
        self.check_telegram_channel_config()
        self.check_recent_send_success()
        self.check_message_queue_status()
        
        # Determine overall result
        all_passed = all(c["passed"] for c in self.checks)
        failures = [c for c in self.checks if not c["passed"]]
        
        self.evidence["checks"] = self.checks
        self.evidence["passed"] = all_passed
        self.evidence["status"] = "ok" if all_passed else "fail"
        self.evidence["message"] = "Telegram notification system healthy" if all_passed else "Telegram notification system issues found"
        self.evidence["failures"] = [c["name"] for c in failures]
        self.evidence["check_count"] = len(self.checks)
        self.evidence["pass_count"] = len([c for c in self.checks if c["passed"]])
        
        # Write evidence
        evidence_file = write_evidence("probe-telegram-notification", self.evidence)
        self.evidence["evidence_file"] = str(evidence_file)
        
        return self.evidence


def main():
    parser = argparse.ArgumentParser(description="Telegram Notification Verification Probe")
    parser.add_argument("--json", action="store_true", help="Output JSON only")
    parser.add_argument("--timeout", type=int, default=TIMEOUT_SECONDS, help="Timeout in seconds")
    args = parser.parse_args()
    
    probe = TelegramNotificationProbe(timeout=args.timeout)
    result = probe.run()
    
    if args.json:
        print(json.dumps(result, indent=2, ensure_ascii=False))
    else:
        status = "PASS" if result["passed"] else "FAIL"
        print(f"[{status}] probe-telegram-notification")
        for check in result["checks"]:
            check_status = "✓" if check["passed"] else "✗"
            print(f"  {check_status} {check['name']}: {check.get('description', '')}")
        
        if result["failures"]:
            print(f"\nFailed checks: {', '.join(result['failures'])}")
    
    sys.exit(0 if result["passed"] else 1)


if __name__ == "__main__":
    main()
