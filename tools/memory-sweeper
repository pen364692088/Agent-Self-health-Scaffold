#!/usr/bin/env python3
"""
Memory Sweeper v2.0
新增:
- quarantine_reason 聚合
- 滚动窗口指标 (24h / last 200 events)
- test event 统计
- Canary 6-Point Check 自动判定
- CANARY_STATUS 输出 + rollback_recommended
- dry-run 模式支持
- 排除 sim source (模拟流量隔离)
- 诊断指标: revisit_rate, top_churn_entries, boundary_distance
- tier_change metrics 输出到 metrics/tier_changes.jsonl
"""

import os, sys, json, math, fcntl
from datetime import datetime, timedelta
from pathlib import Path
from collections import defaultdict

MEMORY_ROOT = Path.home() / ".openclaw/workspace/memory"
EVENTS_LOG = MEMORY_ROOT / "events.log"
LOCK_FILE = MEMORY_ROOT / ".locks" / "sweeper.lock"
CONFIG_FILE = MEMORY_ROOT / "sweeper_config.json"
STATS_FILE = MEMORY_ROOT / "sweeper_stats.json"
REVIEW_QUEUE = MEMORY_ROOT / "review_queue.json"
METRICS_DIR = MEMORY_ROOT / "metrics"
TIER_CHANGES_LOG = METRICS_DIR / "tier_changes.jsonl"
ENTRY_STATE_FILE = MEMORY_ROOT / "entry_state.json"

# Tier 阈值
TIER_THRESHOLDS = {
    "HOT": 7.0,
    "WARM": 3.0,
    "COLD": 0.0
}

# Hysteresis 阈值 (温和版)
HYSTERESIS_THRESHOLDS = {
    "HOT_UP": 7.2,
    "HOT_DOWN": 6.8,
    "WARM_UP": 3.2,
    "WARM_DOWN": 2.8
}

# Hysteresis 冷却期 (小时)
MIN_TIER_CHANGE_INTERVAL_HOURS = 12

# dry-run 模式
DRYRUN = os.environ.get("CANARY_DRYRUN", "0") == "1"

# 非生产 source (排除在 prod 指标之外)
NON_PROD_SOURCES = {"test", "sim"}

def with_lock(f):
    def w(*a,**kw):
        os.makedirs(LOCK_FILE.parent, exist_ok=True)
        with open(LOCK_FILE, "w") as lf:
            try:
                fcntl.flock(lf.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
                r = f(*a,**kw)
                fcntl.flock(lf.fileno(), fcntl.LOCK_UN)
                return r
            except BlockingIOError:
                print("ERROR: Another sweeper running"); sys.exit(1)
    return w

def load_config():
    D = {"half_life_days":14,"shadow_sources":["self_improving"],"score_scope_allowlist":["projects/openemotion","domains/infra"],"enable_shadow_proposals":True,"enable_self_improving_scoring":False}
    return {**D, **json.loads(CONFIG_FILE.read_text())} if CONFIG_FILE.exists() else D

def load_entry_state():
    """加载上次记录的 entry 状态 (last_score, last_tier)"""
    if ENTRY_STATE_FILE.exists():
        return json.loads(ENTRY_STATE_FILE.read_text())
    return {}

def save_entry_state(state):
    """保存 entry 状态"""
    ENTRY_STATE_FILE.write_text(json.dumps(state, indent=2))

def calculate_score(entry_data, cfg):
    """
    计算 entry 的 score
    score = use_term + recency_term + importance_term - conflict_term
    返回: (score, components_dict)
    """
    use_count = entry_data.get("use", 0)
    correction_count = entry_data.get("corr", 0)
    conflict_count = entry_data.get("conf", 0)
    last_ts = entry_data.get("last")
    
    # use_term: 随 use_count 对数增长
    use_term = math.log(1 + use_count) * 1.5
    
    # recency_term: 最近活跃度
    recency_term = 0.8  # 简化，实际应根据 last_ts 计算
    if last_ts:
        try:
            last_dt = datetime.fromisoformat(last_ts.replace("Z", ""))
            days_ago = (datetime.now() - last_dt).days
            recency_term = max(0.1, 1.0 - days_ago * 0.05)
        except:
            pass
    
    # importance_term: 基于 correction_count
    importance_term = min(1.5, correction_count * 0.3)
    
    # conflict_term: 冲突惩罚
    conflict_term = conflict_count * 0.5
    
    score = use_term + recency_term + importance_term - conflict_term
    
    components = {
        "use_term": round(use_term, 2),
        "recency_term": round(recency_term, 2),
        "importance_term": round(importance_term, 2),
        "conflict_term": round(conflict_term, 2)
    }
    
    return round(max(0, score), 2), components

def get_tier(score):
    """根据 score 确定 tier"""
    if score >= TIER_THRESHOLDS["HOT"]:
        return "HOT"
    elif score >= TIER_THRESHOLDS["WARM"]:
        return "WARM"
    else:
        return "COLD"

def get_threshold(tier):
    """获取 tier 对应的阈值"""
    if tier == "HOT":
        return TIER_THRESHOLDS["HOT"]
    elif tier == "WARM":
        return TIER_THRESHOLDS["WARM"]
    return 0.0

def write_tier_change(entry_id, scope, from_tier, to_tier, score, threshold, source_breakdown, decision_context):
    """写入 tier_change 记录到 metrics/tier_changes.jsonl"""
    METRICS_DIR.mkdir(parents=True, exist_ok=True)
    
    record = {
        "event": "tier_change",
        "timestamp": datetime.now().isoformat() + "Z",
        "memory_id": entry_id,
        "scope": scope,
        "source_breakdown_24h": source_breakdown,
        "from_tier": from_tier,
        "to_tier": to_tier,
        "score": score,
        "threshold": threshold,
        "boundary_distance": round(abs(score - threshold), 2),
        "decision_context": decision_context
    }
    
    with open(TIER_CHANGES_LOG, "a") as f:
        f.write(json.dumps(record) + "\n")
    
    return record

def parse_events(cfg):
    state = defaultdict(lambda: {"use":0,"last":None,"conf":0,"corr":0,"sessions":set(),"shadow":0})
    
    # 全量统计
    stats = {
        "total":0, "by_src":defaultdict(int), "dup":0, "miss_sess":0, "by_scope":defaultdict(int),
        "quar":0, "autofix":0, "test_events":0, "quar_reasons":defaultdict(int), "top":[],
        # tier_changes 统计
        "tier_changes_24h_prod": 0, "tier_changes_24h_total": 0,
        "tier_changes_by_source_24h": defaultdict(int),
        # 诊断指标
        "entry_changes_24h": defaultdict(lambda: {"count": 0, "scope": "", "sources": defaultdict(int)}),
        "corrections_by_entry_24h": defaultdict(int),
        # 口径自检
        "inclusion_audit": {
            "included_sources": set(),
            "excluded_by_reason": defaultdict(int)
        }
    }
    
    # 滚动窗口
    window_stats = {
        "total":0, "quar":0, "autofix":0, "by_src":defaultdict(int), "quar_reasons":defaultdict(int),
        "prod_total":0, "prod_quar":0
    }
    window_start = datetime.now() - timedelta(hours=24)
    recent_events = []
    
    allowlist = set(cfg.get("score_scope_allowlist", []))
    
    seen = set()
    if not EVENTS_LOG.exists(): return dict(state), stats, window_stats
    
    for line in EVENTS_LOG.read_text().strip().split("\n"):
        if not line.strip(): continue
        try:
            e = json.loads(line)
            stats["total"] += 1
            eid = e.get("event_id")
            if eid and eid in seen: stats["dup"] += 1; continue
            if eid: seen.add(eid)
            
            src = e.get("source","user")
            stats["by_src"][src] += 1
            
            # 滚动窗口
            ts_str = e.get("ts","")
            try:
                ts = datetime.fromisoformat(ts_str.replace("Z",""))
                is_recent = ts >= window_start
            except:
                is_recent = False
            
            recent_events.append(e)
            if len(recent_events) > 200: recent_events.pop(0)
            
            if is_recent:
                window_stats["total"] += 1
                window_stats["by_src"][src] += 1
                # prod 排除 test 和 sim
                if src not in NON_PROD_SOURCES:
                    window_stats["prod_total"] += 1
            
            # quarantine 统计
            if e.get("quarantined"):
                stats["quar"] += 1
                reason = e.get("quarantine_reason", "unknown")
                stats["quar_reasons"][reason] += 1
                if is_recent:
                    window_stats["quar"] += 1
                    window_stats["quar_reasons"][reason] += 1
                    if src not in NON_PROD_SOURCES:
                        window_stats["prod_quar"] += 1
            
            if e.get("scope_autofixed") or e.get("scope_was_autofixed"):
                stats["autofix"] += 1
                if is_recent: window_stats["autofix"] += 1
            
            if e.get("test_event") or src == "test":
                stats["test_events"] += 1
            
            scope = e.get("scope","")
            if scope: stats["by_scope"][scope] += 1
            if not e.get("session_id"): stats["miss_sess"] += 1
            
            # tier_changes 统计 (24h, 区分 prod vs total)
            if is_recent and e.get("event") == "correction":
                stats["tier_changes_24h_total"] += 1
                stats["tier_changes_by_source_24h"][src] += 1
                
                # 诊断: 按 entry 统计
                entry_id = e.get("memory_id", "unknown")
                stats["entry_changes_24h"][entry_id]["count"] += 1
                stats["entry_changes_24h"][entry_id]["scope"] = scope
                stats["entry_changes_24h"][entry_id]["sources"][src] += 1
                
                # prod 过滤 + 口径自检
                exclude_reason = None
                if src in NON_PROD_SOURCES:
                    exclude_reason = f"source={src}"
                elif e.get("quarantined"):
                    exclude_reason = "quarantined"
                elif e.get("eligible_for_scoring", True) == False:
                    exclude_reason = "not_eligible"
                elif scope not in allowlist and scope != "":
                    exclude_reason = f"scope_not_in_allowlist"
                
                if exclude_reason:
                    stats["inclusion_audit"]["excluded_by_reason"][exclude_reason] += 1
                else:
                    stats["tier_changes_24h_prod"] += 1
                    stats["inclusion_audit"]["included_sources"].add(src)
            
            # state 更新
            mid = e.get("memory_id")
            if not mid or e.get("quarantined"): continue
            
            et = e.get("event")
            ts2 = e.get("ts","")
            sess = e.get("session_id","")
            is_shad = src in cfg.get("shadow_sources",[])
            
            if et=="use":
                # v2 闸门: 只对 event_version=v2 的 use 计数 (adoption语义)
                # v1 或缺失 event_version 的 use 是历史数据，不计入 use_term
                event_version = e.get("event_version", "v1")
                if event_version == "v2" and not is_shad: 
                    state[mid]["use"] += 1
                state[mid]["sessions"].add(sess)
            elif et=="correction":
                if not is_shad: state[mid]["corr"] += 1
                else: state[mid]["shadow"] += 1
                state[mid]["sessions"].add(sess)
            elif et=="conflict": state[mid]["conf"] += 0.5
            if ts2 and (not state[mid]["last"] or ts2 > state[mid]["last"]): state[mid]["last"] = ts2
        except: continue
    
    for m in state: state[m]["sessions"] = len(state[m]["sessions"])
    stats["top"] = sorted(stats["by_scope"].items(), key=lambda x: x[1], reverse=True)[:10]
    
    return dict(state), stats, window_stats

def parse_review_queue():
    if not REVIEW_QUEUE.exists():
        return {"pending_total": 0, "pending_created_24h": 0, "resolved_24h": 0}
    
    data = json.loads(REVIEW_QUEUE.read_text())
    window_start = datetime.now() - timedelta(hours=24)
    
    pending_total = len(data.get("pending", []))
    pending_created_24h = 0
    
    for item in data.get("pending", []):
        added_at = item.get("added_at", "")
        try:
            ts = datetime.fromisoformat(added_at)
            if ts >= window_start:
                pending_created_24h += 1
        except:
            pass
    
    resolved_24h = 0
    for item in data.get("resolved", []):
        resolved_at = item.get("resolved_at", "")
        try:
            ts = datetime.fromisoformat(resolved_at)
            if ts >= window_start:
                resolved_24h += 1
        except:
            pass
    
    return {"pending_total": pending_total, "pending_created_24h": pending_created_24h, "resolved_24h": resolved_24h}

def check_allowlist_violation(stats, cfg):
    allowlist = set(cfg.get("score_scope_allowlist", []))
    violations = []
    ignored_scopes = {"global/quarantine", "test", "projects/test", "projects/myproject", ""}
    
    for scope, count in stats.get("by_scope", {}).items():
        if scope and scope not in allowlist and scope not in ignored_scopes:
            violations.append({"scope": scope, "count": count})
    
    return violations[:3]

def compute_diagnostics(stats, cfg):
    """计算诊断指标"""
    entry_changes = stats.get("entry_changes_24h", {})
    inclusion_audit = stats.get("inclusion_audit", {})
    
    if not entry_changes:
        return {
            "revisit_count": 0,
            "unique_entries": 0,
            "revisit_rate": 0.0,
            "max_changes_per_entry": 0,
            "top_churn_entries": [],
            "inclusion_audit": {
                "included_sources": [],
                "excluded_by_reason": {}
            }
        }
    
    # revisit: 被"修正 >= 2 次"的 entry 数量
    revisit_count = sum(1 for e in entry_changes.values() if e["count"] >= 2)
    unique_entries = len(entry_changes)
    revisit_rate = revisit_count / max(1, unique_entries)
    
    # max changes per entry
    max_changes = max(e["count"] for e in entry_changes.values())
    
    # top churn entries (被修正最多的前 5 个)
    allowlist = set(cfg.get("score_scope_allowlist", []))
    sorted_entries = sorted(entry_changes.items(), key=lambda x: x[1]["count"], reverse=True)
    
    # 只保留 prod+allowlist 的 entry
    top_churn = []
    for entry_id, data in sorted_entries[:10]:
        scope = data["scope"]
        # 过滤: 非 quarantine、非 test
        if scope and scope not in {"global/quarantine", "test", "projects/test"}:
            top_churn.append({
                "entry_id": entry_id,
                "scope": scope,
                "changes": data["count"],
                "sources": dict(data["sources"])
            })
        if len(top_churn) >= 5:
            break
    
    # 口径自检
    included_sources = sorted(list(inclusion_audit.get("included_sources", set())))
    excluded_by_reason = dict(inclusion_audit.get("excluded_by_reason", {}))
    
    return {
        "revisit_count": revisit_count,
        "unique_entries": unique_entries,
        "revisit_rate": round(revisit_rate * 100, 1),
        "max_changes_per_entry": max_changes,
        "top_churn_entries": top_churn,
        "inclusion_audit": {
            "included_sources": included_sources,
            "excluded_by_reason": excluded_by_reason
        }
    }

def generate_tuning_recommendations(diagnostics: dict, stats: dict, use_link_metrics: dict = None) -> list:
    """
    生成 tuning recommendations (启发式规则)
    只建议不自动改
    
    规则:
    1. 链路健康优先 (硬门)
    2. recency 占比过高
    3. importance 过低导致长期 COLD
    4. 疑似阈值抖动
    5. review 负载过高
    """
    recommendations = []
    
    # 加载 use_link_audit 结果
    use_link_file = MEMORY_ROOT / "use_link_audit.json"
    use_link = {}
    if use_link_file.exists():
        try:
            use_link = json.loads(use_link_file.read_text())
        except:
            pass
    
    use_coverage = use_link.get("metrics", {}).get("use_coverage", 1.0)
    use_attribution = use_link.get("metrics", {}).get("use_attribution", 1.0)
    
    # Rule 1: 链路健康优先 (硬门)
    if use_coverage < 0.95 or use_attribution < 0.99:
        recommendations.append({
            "id": "use_link_health",
            "severity": "HIGH",
            "signal": {
                "use_coverage": use_coverage,
                "use_attribution": use_attribution
            },
            "recommendation": "Fix use event chain before adjusting weights: ensure recall→use emission and memory_id attribution. Do not tune until coverage ≥95% and attribution ≥99%.",
            "action": "audit_use_chain"
        })
        # 硬门: 链路不健康时不输出其他建议
        return recommendations
    
    # Rule 2: recency 占比过高
    score_p50 = diagnostics.get("score_p50", 0)
    recency_p50 = diagnostics.get("recency_term_p50", 0)
    use_term_p50 = diagnostics.get("use_term_p50", 0)
    
    if score_p50 > 0 and recency_p50 / score_p50 > 0.7 and use_term_p50 < 0.5:
        recommendations.append({
            "id": "recency_dominant",
            "severity": "MEDIUM",
            "signal": {
                "recency_ratio": round(recency_p50 / score_p50, 2),
                "use_term_p50": use_term_p50
            },
            "recommendation": "Recency dominates score (>70%). Consider raising default importance (0.3→0.5) or reducing recency weight to balance learning.",
            "action": "adjust_importance_default"
        })
    
    # Rule 3: importance 过低导致长期 COLD
    near_boundary = diagnostics.get("near_boundary_distance_p50", 0)
    if score_p50 < 2.0 and near_boundary > 0.8 and use_term_p50 > 0:
        recommendations.append({
            "id": "importance_low_cold",
            "severity": "MEDIUM",
            "signal": {
                "score_p50": score_p50,
                "near_boundary_distance_p50": near_boundary,
                "use_term_p50": use_term_p50
            },
            "recommendation": "Score low with active use. Consider slightly raising importance default (0.3→0.4/0.5) to accelerate HOT/WARM promotion.",
            "action": "adjust_importance_default"
        })
    
    # Rule 4: 疑似阈值抖动
    crossing_p50 = diagnostics.get("crossing_distance_p50")
    tier_changes = stats.get("tier_changes_24h_prod", 0)
    
    if crossing_p50 is not None and crossing_p50 < 0.3 and tier_changes >= 10:
        recommendations.append({
            "id": "threshold_jitter",
            "severity": "HIGH",
            "signal": {
                "crossing_distance_p50": crossing_p50,
                "tier_changes_24h_prod": tier_changes
            },
            "recommendation": "Tier changes happening near threshold boundary. Enable hysteresis to prevent oscillation.",
            "action": "enable_hysteresis",
            "config": HYSTERESIS_THRESHOLDS
        })
    
    # Rule 5: review 负载过高
    # 从 review_queue 统计
    review_file = MEMORY_ROOT / "review_queue.json"
    if review_file.exists():
        try:
            review = json.loads(review_file.read_text())
            pending_growth = review.get("pending_created_24h", 0)
            if pending_growth > 20:
                recommendations.append({
                    "id": "review_overload",
                    "severity": "HIGH",
                    "signal": {
                        "pending_review_growth_24h": pending_growth
                    },
                    "recommendation": "Review queue growing fast (>20/day). Consider tightening proposal generation or raising review threshold to avoid human review avalanche.",
                    "action": "tighten_proposals"
                })
        except:
            pass
    
    return recommendations

def save_stats(s, w, canary_result, diagnostics, tuning_recommendations=None):
    STATS_FILE.write_text(json.dumps({
        "total": s["total"], "by_source": dict(s["by_src"]), "duplicates": s["dup"],
        "missing_session": s["miss_sess"], "quarantined": s["quar"], "autofixed": s["autofix"],
        "test_events": s["test_events"], "quarantine_reasons": dict(s["quar_reasons"]),
        "top_scopes": s["top"][:10],
        "tier_changes_24h_prod": s["tier_changes_24h_prod"],
        "tier_changes_24h_total": s["tier_changes_24h_total"],
        "tier_changes_by_source_24h": dict(s["tier_changes_by_source_24h"]),
        "diagnostics": diagnostics,
        "window_24h": {
            "total": w["total"], "quarantined": w["quar"], "autofixed": w["autofix"],
            "quarantined_rate": round(w["quar"]/max(1,w["total"])*100, 2),
            "by_source": dict(w["by_src"]), "quarantine_reasons": dict(w["quar_reasons"]),
            "prod_total": w["prod_total"],
            "prod_quarantined": w["prod_quar"],
            "prod_quarantined_rate": round(w["prod_quar"]/max(1,w["prod_total"])*100, 2)
        },
        "canary_status": canary_result["status"],
        "rollback_recommended": canary_result["rollback_recommended"],
        "rollback_reason": canary_result.get("rollback_reason"),
        "tuning_recommendations": tuning_recommendations or [],
        "dryrun": DRYRUN,
        "generated_at": datetime.now().isoformat()
    }, indent=2))

@with_lock
def sweep(cfg=None):
    if cfg is None: cfg = load_config()
    print("🧠 Memory Sweeper v2.0")
    if DRYRUN:
        print("⚠️  DRYRUN MODE (no auto-rollback)")
    print(f"Shadow-Proposals: {'ON' if cfg.get('enable_shadow_proposals') else 'OFF'}")
    print(f"SI scoring: {'ON' if cfg.get('enable_self_improving_scoring') else 'OFF'}\n")
    
    state, stats, window = parse_events(cfg)
    review = parse_review_queue()
    violations = check_allowlist_violation(stats, cfg)
    diagnostics = compute_diagnostics(stats, cfg)
    
    # ===== Tier Change 检测 =====
    entry_state = load_entry_state()
    allowlist = set(cfg.get("score_scope_allowlist", []))
    tier_changes_today = []
    crossing_distances = []  # tier_change 时的 boundary distance
    near_boundary_distances = []  # 所有 entry 到最近阈值的距离
    all_scores = []  # 所有 score
    score_components = {  # score 组件聚合
        "use_term": [],
        "recency_term": [],
        "importance_term": [],
        "conflict_term": []
    }
    
    for entry_id, entry_data in state.items():
        # 计算当前 score 和 tier
        score, components = calculate_score(entry_data, cfg)
        current_tier = get_tier(score)
        
        # 收集 score 和组件
        all_scores.append(score)
        for key in score_components:
            score_components[key].append(components[key])
        
        # 计算 near-boundary distance (所有 entry)
        nearest_threshold = TIER_THRESHOLDS["WARM"] if score < TIER_THRESHOLDS["WARM"] else TIER_THRESHOLDS["HOT"]
        near_distance = abs(score - nearest_threshold)
        near_boundary_distances.append(near_distance)
        
        # 检查是否变化
        prev_state = entry_state.get(entry_id, {})
        prev_tier = prev_state.get("tier", "COLD")
        
        if current_tier != prev_tier and entry_id in stats.get("entry_changes_24h", {}):
            # 获取 scope 和 source_breakdown
            entry_changes = stats["entry_changes_24h"].get(entry_id, {})
            scope = entry_changes.get("scope", "")
            source_breakdown = dict(entry_changes.get("sources", {}))
            
            # 检查是否 prod+allowlist
            is_prod = (
                scope in allowlist and
                all(src not in NON_PROD_SOURCES for src in source_breakdown.keys())
            )
            
            if is_prod:
                threshold = get_threshold(current_tier)
                crossing_distance = abs(score - threshold)
                crossing_distances.append(crossing_distance)
                
                # 写入 tier_change 记录
                decision_context = {
                    "allowlist": True,
                    "eligible": True,
                    "quarantined": False,
                    "dryrun": DRYRUN
                }
                
                record = write_tier_change(
                    entry_id, scope, prev_tier, current_tier,
                    score, threshold, source_breakdown, decision_context
                )
                tier_changes_today.append(record)
                
                # 更新 entry state
                entry_state[entry_id] = {
                    "tier": current_tier,
                    "score": score,
                    "last_tier_change_at": datetime.now().isoformat()
                }
        
        # 更新 score (即使 tier 未变)
        if entry_id not in entry_state:
            entry_state[entry_id] = {"tier": current_tier, "score": score}
        else:
            entry_state[entry_id]["score"] = score
    
    # 保存 entry state
    save_entry_state(entry_state)
    
    # 计算 score_p50
    if all_scores:
        sorted_scores = sorted(all_scores)
        diagnostics["score_p50"] = round(sorted_scores[len(sorted_scores)//2], 2)
        diagnostics["score_p90"] = round(sorted_scores[int(len(sorted_scores)*0.9)], 2) if len(sorted_scores) >= 10 else round(max(sorted_scores), 2)
    else:
        diagnostics["score_p50"] = None
        diagnostics["score_p90"] = None
    
    # 计算 score 组件分布
    for key in score_components:
        values = score_components[key]
        if values:
            sorted_values = sorted(values)
            diagnostics[f"{key}_p50"] = round(sorted_values[len(sorted_values)//2], 2)
    
    # 计算 revisit_rate_tier_changes (从 tier_changes.jsonl 统计)
    tier_change_revisit = 0
    tier_change_entries = defaultdict(int)
    if TIER_CHANGES_LOG.exists():
        window_start = datetime.now() - timedelta(hours=24)
        for line in TIER_CHANGES_LOG.read_text().strip().split("\n"):
            if not line.strip():
                continue
            try:
                tc = json.loads(line)
                ts_str = tc.get("timestamp", "")
                ts = datetime.fromisoformat(ts_str.replace("Z", ""))
                if ts >= window_start:
                    entry_id = tc.get("memory_id", "")
                    tier_change_entries[entry_id] += 1
            except:
                pass
        
        # 统计有多次 tier_change 的 entry
        tier_change_revisit = sum(1 for count in tier_change_entries.values() if count >= 2)
        unique_tier_change_entries = len(tier_change_entries)
        diagnostics["revisit_rate_tier_changes"] = round(tier_change_revisit / max(1, unique_tier_change_entries) * 100, 1)
        diagnostics["revisit_count_tier_changes"] = tier_change_revisit
    
    # 加载昨天的 near_boundary_distance (趋势对比)
    prev_stats_path = MEMORY_ROOT / "sweeper_stats_prev.json"
    if STATS_FILE.exists():
        try:
            prev_stats = json.loads(STATS_FILE.read_text())
            prev_near = prev_stats.get("diagnostics", {}).get("near_boundary_distance_p50")
            if prev_near is not None and diagnostics.get("near_boundary_distance_p50") is not None:
                diagnostics["near_boundary_distance_delta_24h"] = round(
                    diagnostics["near_boundary_distance_p50"] - prev_near, 2
                )
        except:
            pass
    
    # 计算 crossing boundary_distance 统计 (只有 tier_change 时)
    if crossing_distances:
        diagnostics["crossing_distance_p50"] = round(sorted(crossing_distances)[len(crossing_distances)//2], 2)
        diagnostics["crossing_distance_p90"] = round(sorted(crossing_distances)[int(len(crossing_distances)*0.9)], 2) if len(crossing_distances) >= 10 else round(max(crossing_distances), 2)
    else:
        diagnostics["crossing_distance_p50"] = None
        diagnostics["crossing_distance_p90"] = None
    
    # 计算 near-boundary distance 统计 (所有 entry)
    if near_boundary_distances:
        diagnostics["near_boundary_distance_p50"] = round(sorted(near_boundary_distances)[len(near_boundary_distances)//2], 2)
        diagnostics["near_boundary_distance_p90"] = round(sorted(near_boundary_distances)[int(len(near_boundary_distances)*0.9)], 2) if len(near_boundary_distances) >= 10 else round(max(near_boundary_distances), 2)
    else:
        diagnostics["near_boundary_distance_p50"] = None
        diagnostics["near_boundary_distance_p90"] = None
    
    # Hysteresis 推荐
    hysteresis_recommended = False
    hysteresis_reason = None
    
    # 触发条件 1: crossing P50 < 0.3 且 tier_changes >= 10
    if diagnostics.get("crossing_distance_p50") is not None:
        if diagnostics["crossing_distance_p50"] < 0.3 and stats["tier_changes_24h_prod"] >= 10:
            hysteresis_recommended = True
            hysteresis_reason = "crossing_distance_low"
    
    # 触发条件 2: revisit_rate_tier_changes > 20% (基于 tier_change 而非 events)
    if diagnostics.get("revisit_rate_tier_changes", 0) > 20:
        hysteresis_recommended = True
        hysteresis_reason = "high_tier_change_revisit"
    
    diagnostics["hysteresis_recommended"] = hysteresis_recommended
    diagnostics["hysteresis_reason"] = hysteresis_reason
    diagnostics["hysteresis_config"] = HYSTERESIS_THRESHOLDS if hysteresis_recommended else None
    
    if tier_changes_today:
        print(f"\n📊 Tier Changes Detected: {len(tier_changes_today)}")
        for tc in tier_changes_today[:3]:
            print(f"  - {tc['memory_id']}: {tc['from_tier']}→{tc['to_tier']} (score={tc['score']}, distance={tc['boundary_distance']})")
    
    print("📊 Health Metrics (All Time)")
    print(f"  Total: {stats['total']}")
    print(f"  Duplicates: {stats['dup']}")
    print(f"  Missing session: {stats['miss_sess']}")
    print(f"  Quarantined: {stats['quar']} ({stats['quar']/max(1,stats['total'])*100:.1f}%)")
    print(f"  Autofixed: {stats['autofix']}")
    print(f"  Test events: {stats['test_events']}")
    if stats['quar_reasons']:
        print(f"  Quarantine reasons: {dict(stats['quar_reasons'])}")
    
    print(f"\n📊 Rolling Window (24h / last 200)")
    print(f"  Total: {window['total']}")
    q_rate = window['quar']/max(1,window['total'])*100
    print(f"  Quarantined: {window['quar']} ({q_rate:.1f}%)")
    
    prod_q_rate = window['prod_quar']/max(1,window['prod_total'])*100
    print(f"\n📊 Prod Metrics (排除 test/sim)")
    print(f"  Prod Total: {window['prod_total']}")
    print(f"  Prod Quarantined: {window['prod_quar']} ({prod_q_rate:.1f}%)")
    
    print(f"\n📊 Tier Changes (24h)")
    print(f"  Prod: {stats['tier_changes_24h_prod']}")
    print(f"  Total: {stats['tier_changes_24h_total']}")
    if stats['tier_changes_by_source_24h']:
        print(f"  By Source: {dict(stats['tier_changes_by_source_24h'])}")
    
    # ===== 诊断指标 =====
    print(f"\n📈 Diagnostics (prod+allowlist, last 24h)")
    print(f"  Unique entries: {diagnostics['unique_entries']}")
    print(f"  Revisit rate (events): {diagnostics['revisit_rate']}%")
    if diagnostics.get('revisit_rate_tier_changes') is not None:
        print(f"  Revisit rate (tier_changes): {diagnostics['revisit_rate_tier_changes']}%")
    print(f"  Max changes per entry: {diagnostics['max_changes_per_entry']}")
    
    # Score 分布
    if diagnostics.get('score_p50') is not None:
        print(f"\n📊 Score Distribution")
        print(f"  Score P50: {diagnostics['score_p50']}")
        print(f"  Score P90: {diagnostics['score_p90']}")
        if diagnostics.get('use_term_p50') is not None:
            print(f"  Components P50: use={diagnostics.get('use_term_p50')}, recency={diagnostics.get('recency_term_p50')}, importance={diagnostics.get('importance_term_p50')}, conflict={diagnostics.get('conflict_term_p50')}")
    
    if diagnostics['top_churn_entries']:
        print(f"\n  Top churn entries:")
        for e in diagnostics['top_churn_entries'][:3]:
            print(f"    - {e['entry_id']}: {e['changes']} changes ({e['scope']})")
    
    # 口径自检
    audit = diagnostics.get('inclusion_audit', {})
    print(f"\n📊 Inclusion Audit")
    print(f"  Included sources: {audit.get('included_sources', [])}")
    excluded = audit.get('excluded_by_reason', {})
    if excluded:
        print(f"  Excluded by reason:")
        for reason, count in sorted(excluded.items(), key=lambda x: x[1], reverse=True):
            print(f"    - {reason}: {count}")
    
    # boundary_distance 输出
    if diagnostics.get('crossing_distance_p50') is not None:
        print(f"\n📊 Boundary Distance (crossings, tier_change 时)")
        print(f"  P50: {diagnostics['crossing_distance_p50']}")
        print(f"  P90: {diagnostics['crossing_distance_p90']}")
        if diagnostics['crossing_distance_p50'] < 0.3:
            print(f"  ⚠️  多数变化发生在阈值边缘 → 需要关注")
    
    if diagnostics.get('near_boundary_distance_p50') is not None:
        print(f"\n📊 Distance to Nearest Threshold (all entries)")
        print(f"  P50: {diagnostics['near_boundary_distance_p50']}")
        print(f"  P90: {diagnostics['near_boundary_distance_p90']}")
        delta = diagnostics.get('near_boundary_distance_delta_24h')
        if delta is not None:
            print(f"  Delta 24h: {delta}")
            if delta < -0.5:
                print(f"  ⚠️  快速接近阈值 → 提高观察频率")
        if diagnostics['near_boundary_distance_p50'] < 1.0:
            print(f"  ⚠️  多数 entry 接近 tier 边界 → 可能即将变化")
    
    # Hysteresis 推荐
    if diagnostics.get('hysteresis_recommended'):
        print(f"\n⚠️  Hysteresis Recommended: {diagnostics['hysteresis_reason']}")
        print(f"  Recommended config: {diagnostics['hysteresis_config']}")
    
    print(f"\n🎯 Go/No-Go Thresholds")
    print(f"  prod_quarantined_rate_24h ≤ 5%: {'✅' if prod_q_rate <= 5 else '⏳'} ({prod_q_rate:.1f}%)")
    print(f"  missing_session_rate ≤ 1%: {'✅' if stats['miss_sess']/max(1,stats['total'])*100 <= 1 else '⏳'}")
    
    # ===== Canary 6-Point Check =====
    print(f"\n🔍 Canary 6-Point Check")
    check_results = []
    rollback_reason = None
    
    rejected = stats['by_src'].get('rejected', 0)
    check1 = rejected == 0
    status1 = "✅" if check1 else "❌"
    if not check1: rollback_reason = "rejected_rate"
    print(f"  1. rejected_rate = 0%: {status1} ({rejected})")
    check_results.append(check1)
    
    miss_rate = stats['miss_sess']/max(1,stats['total'])*100
    check2 = miss_rate <= 1
    status2 = "✅" if check2 else "❌"
    if not check2 and not rollback_reason: rollback_reason = "missing_session_rate"
    print(f"  2. missing_session_rate ≤ 1%: {status2} ({miss_rate:.1f}%)")
    check_results.append(check2)
    
    check3 = prod_q_rate <= 5
    status3 = "✅" if check3 else "❌"
    if not check3 and not rollback_reason: rollback_reason = "prod_quarantined_rate"
    print(f"  3. prod_quarantined_rate ≤ 5%: {status3} ({prod_q_rate:.1f}%)")
    check_results.append(check3)
    
    pending_growth = review['pending_created_24h']
    check4 = pending_growth <= 20
    status4 = "✅" if check4 else "❌"
    if not check4 and not rollback_reason: rollback_reason = "pending_review_growth"
    print(f"  4. pending_review_growth ≤ 20/day: {status4} ({pending_growth})")
    check_results.append(check4)
    
    tier_prod = stats['tier_changes_24h_prod']
    if tier_prod <= 30:
        check5 = True
        status5 = "✅"
    elif tier_prod <= 60:
        check5 = "WARN"
        status5 = "⚠️ WARN"
    else:
        check5 = False
        status5 = "❌"
        if not rollback_reason: rollback_reason = "tier_changes_spike"
    print(f"  5. tier_changes_spike ≤ 30: {status5} ({tier_prod} prod)")
    check_results.append(check5 if check5 != "WARN" else True)
    
    check6 = len(violations) == 0
    if check6:
        status6 = "✅"
        print(f"  6. allowlist外影响 = 0: {status6} (0)")
    else:
        status6 = "❌"
        if not rollback_reason: rollback_reason = "allowlist_violation"
        print(f"  6. allowlist外影响 = 0: {status6} ({len(violations)} violations)")
    check_results.append(check6)
    
    # CANARY_STATUS
    has_fail = any(r is False for r in check_results)
    has_warn = check5 == "WARN"
    
    if has_fail:
        canary_status = "FAIL"
        rollback_recommended = True
    elif has_warn:
        canary_status = "WARN"
        rollback_recommended = False
    else:
        canary_status = "PASS"
        rollback_recommended = False
    
    print(f"\n🚦 CANARY_STATUS={canary_status}")
    if rollback_recommended:
        print(f"⚠️  ROLLBACK_RECOMMENDED=true")
        print(f"   Reason: {rollback_reason}")
        if DRYRUN:
            print("   (dryrun mode: no auto-rollback)")
    
    canary_result = {
        "status": canary_status,
        "rollback_recommended": rollback_recommended,
        "rollback_reason": rollback_reason
    }
    
    print(f"\n📊 Entries: {len(state)}")
    
    # 保存当前 stats 到 prev (用于趋势对比)
    if STATS_FILE.exists():
        prev_stats_path = MEMORY_ROOT / "sweeper_stats_prev.json"
        prev_stats_path.write_text(STATS_FILE.read_text())
    
    save_stats(stats, window, canary_result, diagnostics, tuning_recommendations=None)
    print("✓ Stats saved")

    # ===== Tuning Recommendations =====
    tuning_recommendations = generate_tuning_recommendations(diagnostics, stats)
    
    if tuning_recommendations:
        print(f"\n🔧 Tuning Recommendations")
        for rec in tuning_recommendations:
            severity = rec.get("severity", "INFO")
            icon = "⚠️" if severity == "HIGH" else "💡" if severity == "MEDIUM" else "ℹ️"
            print(f"  {icon} [{rec['id']}] {rec['recommendation'][:80]}...")
    
    # 保存 recommendations 到单独文件
    rec_file = MEMORY_ROOT / "tuning_recommendations.json"
    rec_file.write_text(json.dumps({
        "ts": datetime.now().isoformat(),
        "recommendations": tuning_recommendations
    }, indent=2))

