#!/usr/bin/env python3
import argparse, json
from datetime import datetime, timezone
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
CAP_DIR = REPO / 'artifacts' / 'self_health' / 'capabilities'
PROP_DIR = REPO / 'artifacts' / 'self_health' / 'proposals'
SCHEMAS_DIR = REPO / 'schemas'
POLICIES_DIR = REPO / 'POLICIES'
REPORTS_DIR = REPO / 'artifacts' / 'self_health' / 'gate_reports'


def check_gate_a():
    issues = []
    # Check capability registry exists
    registry = POLICIES_DIR / 'AGENT_CAPABILITY_REGISTRY.md'
    if not registry.exists():
        issues.append({'gate': 'A', 'severity': 'critical', 'issue': 'capability_registry_missing'})
    
    # Check schemas exist
    for schema in ['AGENT_CAPABILITY.schema.json', 'AGENT_PROPOSAL.schema.json']:
        if not (SCHEMAS_DIR / schema).exists():
            issues.append({'gate': 'A', 'severity': 'critical', 'issue': f'schema_missing:{schema}'})
    
    # Check capability states are valid
    if CAP_DIR.exists():
        for cap_file in CAP_DIR.glob('CAP-*.json'):
            try:
                data = json.loads(cap_file.read_text())
                if not data.get('capability_id'):
                    issues.append({'gate': 'A', 'severity': 'high', 'issue': f'missing_capability_id:{cap_file.name}'})
            except Exception as e:
                issues.append({'gate': 'A', 'severity': 'high', 'issue': f'invalid_json:{cap_file.name}'})
    
    # Check proposals are proposal_only
    if PROP_DIR.exists():
        for prop_file in PROP_DIR.glob('PROP-*.json'):
            try:
                data = json.loads(prop_file.read_text())
                if not data.get('proposal_only', True):
                    issues.append({'gate': 'A', 'severity': 'critical', 'issue': f'proposal_not_proposal_only:{prop_file.name}'})
            except Exception:
                pass
    
    return issues


def check_gate_b():
    issues = []
    summary = {'total': 0, 'healthy': 0, 'degraded': 0, 'missing': 0, 'unknown': 0}
    
    if CAP_DIR.exists():
        for cap_file in CAP_DIR.glob('CAP-*.json'):
            try:
                data = json.loads(cap_file.read_text())
                summary['total'] += 1
                status = data.get('status', 'unknown')
                if status in summary:
                    summary[status] += 1
                if status in {'degraded', 'missing'}:
                    issues.append({
                        'gate': 'B',
                        'severity': data.get('severity_if_missing', 'high'),
                        'issue': f'capability_{status}:{data.get("capability_id")}'
                    })
            except Exception:
                pass
    
    return issues, summary


def check_gate_c():
    issues = []
    
    # Check summary files exist
    summaries = [
        'VERIFIED_RECOVERY_SUMMARY.md',
        'CAPABILITY_SUMMARY.md',
        'PROPOSAL_SUMMARY.md'
    ]
    for s in summaries:
        if not (REPO / 'artifacts' / 'self_health' / s).exists():
            issues.append({'gate': 'C', 'severity': 'medium', 'issue': f'summary_missing:{s}'})
    
    # Check lock files not stale
    lock_dir = REPO / 'artifacts' / 'self_health' / 'locks'
    if lock_dir.exists():
        for lock_file in lock_dir.glob('*.lock'):
            try:
                data = json.loads(lock_file.read_text())
                started = datetime.fromisoformat(data['started_at'].replace('Z', '+00:00'))
                age = (datetime.now(timezone.utc) - started).total_seconds()
                if age > 600:
                    issues.append({'gate': 'C', 'severity': 'medium', 'issue': f'stale_lock:{lock_file.name}'})
            except Exception:
                pass
    
    return issues


parser = argparse.ArgumentParser()
parser.add_argument('--json', action='store_true')
parser.add_argument('--write', action='store_true')
args = parser.parse_args()

gate_a_issues = check_gate_a()
gate_b_issues, capability_summary = check_gate_b()
gate_c_issues = check_gate_c()

report = {
    'generated_at': datetime.now(timezone.utc).isoformat(),
    'gate_a': {
        'status': 'PASS' if not gate_a_issues else 'FAIL',
        'issues': gate_a_issues
    },
    'gate_b': {
        'status': 'PASS' if not gate_b_issues else 'PARTIAL' if capability_summary['healthy'] > 0 else 'FAIL',
        'issues': gate_b_issues,
        'summary': capability_summary
    },
    'gate_c': {
        'status': 'PASS' if not gate_c_issues else 'FAIL',
        'issues': gate_c_issues
    }
}

if args.write:
    REPORTS_DIR.mkdir(parents=True, exist_ok=True)
    report_file = REPORTS_DIR / f'gate_report_{datetime.now(timezone.utc).strftime("%Y%m%d-%H%M%S")}.json'
    report_file.write_text(json.dumps(report, ensure_ascii=False, indent=2))

if args.json:
    print(json.dumps(report, ensure_ascii=False, indent=2))
else:
    print(f"Gate A: {report['gate_a']['status']}")
    print(f"Gate B: {report['gate_b']['status']}")
    print(f"Gate C: {report['gate_c']['status']}")
    total_issues = len(gate_a_issues) + len(gate_b_issues) + len(gate_c_issues)
    print(f"Total issues: {total_issues}")
