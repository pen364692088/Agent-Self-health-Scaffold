#!/usr/bin/env python3
"""
Probe: Execution Policy System Health Check
Priority: P1 (High - Core Infrastructure)
Monitors: policy-doctor status, violation trends, rule coverage, effectiveness
"""
import argparse
import json
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

WORKSPACE = Path('/home/moonlight/.openclaw/workspace')
POLICY_DIR = WORKSPACE / 'artifacts' / 'execution_policy'
VIOLATIONS_DIR = POLICY_DIR / 'violations'
METRICS_DIR = POLICY_DIR / 'metrics'

def now_iso():
    return datetime.now(timezone.utc).isoformat()

def run_policy_doctor():
    try:
        result = subprocess.run(
            ['python3', str(WORKSPACE / 'tools' / 'policy-doctor'), '--json'],
            capture_output=True, text=True, timeout=30
        )
        return json.loads(result.stdout), result.returncode
    except Exception as e:
        return {'error': str(e)}, 1

def count_violations_today():
    if not VIOLATIONS_DIR.exists():
        return 0
    import time
    now = time.time()
    count = 0
    for f in VIOLATIONS_DIR.glob('*.jsonl'):
        if now - f.stat().st_mtime < 86400:
            try:
                with f.open('r') as fp:
                    count += sum(1 for _ in fp)
            except:
                pass
    return count

def check_critical_rules_active():
    rules_file = WORKSPACE / 'POLICIES' / 'EXECUTION_POLICY_RULES.yaml'
    if not rules_file.exists():
        return False, "Rules file missing"
    try:
        import yaml
        with rules_file.open('r') as f:
            rules = yaml.safe_load(f)
        active_critical = [r for r in rules.get('rules', []) 
                          if r.get('status') == 'active' and r.get('priority') in ('critical', 'P0')]
        if len(active_critical) < 1:
            return False, f"No critical rules active"
        return True, f"{len(active_critical)} critical rules active"
    except Exception as e:
        return False, f"Failed to parse rules: {e}"

def get_effectiveness_metrics():
    """Run effectiveness metrics collector and return summary."""
    try:
        result = subprocess.run(
            ['python3', str(WORKSPACE / 'tools' / 'policy-effectiveness-metrics'), 
             '--hours', '168', '--json'],
            capture_output=True, text=True, timeout=30
        )
        if result.returncode == 0:
            data = json.loads(result.stdout)
            return {
                'conclusion': data.get('conclusion', {}).get('conclusion', 'unknown'),
                'scores': data.get('effectiveness_scores', {}),
                'total_violations': data.get('metrics', {}).get('violations', {}).get('total_violations', 0)
            }
    except:
        pass
    return {'conclusion': 'unknown', 'scores': {}, 'total_violations': 0}

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument('--json', action='store_true')
    args = ap.parse_args()
    
    issues = []
    
    # Check 1: policy-doctor health
    doctor_result, rc = run_policy_doctor()
    if rc != 0 or not doctor_result.get('summary', {}).get('healthy', False):
        issues.append({
            'check': 'policy_doctor',
            'status': 'fail',
            'message': doctor_result.get('error', 'policy-doctor unhealthy')
        })
    
    # Check 2: critical rules active
    rules_ok, rules_msg = check_critical_rules_active()
    if not rules_ok:
        issues.append({
            'check': 'critical_rules',
            'status': 'fail',
            'message': rules_msg
        })
    
    # Check 3: violation trend (warning if > 50/day)
    violations_today = count_violations_today()
    if violations_today > 50:
        issues.append({
            'check': 'violation_trend',
            'status': 'warning',
            'message': f'High violation count: {violations_today} in last 24h'
        })
    
    # Check 4: effectiveness metrics
    eff = get_effectiveness_metrics()
    
    # Check for concerning effectiveness scores
    fallback_rate = eff.get('scores', {}).get('deny_then_success_via_fallback_rate')
    if fallback_rate is not None and fallback_rate < 80:
        issues.append({
            'check': 'effectiveness_fallback_rate',
            'status': 'warning',
            'message': f'Fallback success rate {fallback_rate:.1f}% < 80%'
        })
    
    false_positive = eff.get('scores', {}).get('false_positive_deny_count', 0)
    if false_positive > 1:
        issues.append({
            'check': 'effectiveness_false_positive',
            'status': 'warning',
            'message': f'False positive count: {false_positive}'
        })
    
    result = {
        'probe': 'probe-execution-policy',
        'timestamp': now_iso(),
        'status': 'pass' if not issues else ('warning' if any(i['status'] == 'warning' for i in issues) else 'fail'),
        'policy_doctor_healthy': doctor_result.get('summary', {}).get('healthy', False),
        'violations_today': violations_today,
        'effectiveness': eff,
        'issues': issues
    }
    
    if args.json:
        print(json.dumps(result, indent=2))
    else:
        status = result['status'].upper()
        print(f"[{status}] Execution Policy: {len(issues)} issues")
    
    return 0 if result['status'] == 'pass' else 1

if __name__ == '__main__':
    sys.exit(main())
