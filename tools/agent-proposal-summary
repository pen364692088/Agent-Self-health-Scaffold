#!/usr/bin/env python3
import argparse, json
from datetime import datetime, timezone
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
PROPOSAL_DIR = REPO / 'artifacts' / 'self_health' / 'proposals'
OUTPUT = REPO / 'artifacts' / 'self_health' / 'PROPOSAL_SUMMARY.md'


def load_proposals():
    proposals = []
    if PROPOSAL_DIR.exists():
        for f in sorted(PROPOSAL_DIR.glob('PROP-*.json')):
            try:
                proposals.append(json.loads(f.read_text()))
            except Exception:
                pass
    return proposals


def compute_summary(proposals):
    summary = {
        'total': len(proposals),
        'by_type': {},
        'by_status': {'pending': 0, 'in_review': 0, 'approved': 0, 'rejected': 0, 'shadow_running': 0, 'completed': 0},
        'pending_total': 0,
        'from_capability_degradation': 0,
    }
    
    for p in proposals:
        ptype = p.get('proposal_type', 'unknown')
        summary['by_type'][ptype] = summary['by_type'].get(ptype, 0) + 1
        
        status = p.get('status', 'pending')
        if status in summary['by_status']:
            summary['by_status'][status] += 1
        
        if status == 'pending':
            summary['pending_total'] += 1
        
        if p.get('target_capability'):
            summary['from_capability_degradation'] += 1
    
    return summary


def render_markdown(summary):
    lines = [
        '# Proposal Summary',
        '',
        f'**Generated**: {datetime.now(timezone.utc).isoformat()}',
        '',
        '## Overview',
        '',
        f'- **Total Proposals**: {summary["total"]}',
        f'- **Pending**: {summary["pending_total"]}',
        f'- **From Capability Degradation**: {summary["from_capability_degradation"]}',
        '',
        '## By Type',
        '',
    ]
    for ptype, count in sorted(summary['by_type'].items()):
        lines.append(f'- {ptype}: {count}')
    
    lines.extend([
        '',
        '## By Status',
        '',
    ])
    for status, count in summary['by_status'].items():
        if count > 0:
            lines.append(f'- {status}: {count}')
    
    lines.extend([
        '',
        '## Notes',
        '',
        '- All Level B proposals are proposal-only by default',
        '- No auto-execution allowed',
        '- Each proposal must have shadow plan and rollback',
    ])
    
    return '\n'.join(lines)


parser = argparse.ArgumentParser()
parser.add_argument('--json', action='store_true')
parser.add_argument('--write', action='store_true')
args = parser.parse_args()

proposals = load_proposals()
summary = compute_summary(proposals)

if args.json:
    print(json.dumps(summary, ensure_ascii=False, indent=2))
else:
    md = render_markdown(summary)
    if args.write:
        OUTPUT.parent.mkdir(parents=True, exist_ok=True)
        OUTPUT.write_text(md)
        print(f'Written to {OUTPUT}')
    else:
        print(md)
