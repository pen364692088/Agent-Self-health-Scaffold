#!/usr/bin/env python3
"""
context-compress v1.0 - Context Compression Executor (Shadow Mode)

Compression executor that runs in shadow mode (observe only, don't replace prompt)
or enforced mode (actually execute compression).

Usage:
  context-compress --session-id <id> --state <file> --history <file>
  context-compress --session-id <id> --state <file> --history <file> --mode enforced
  context-compress --session-id <id> --state <file> --history <file> --dry-run
  context-compress --health
  context-compress --test

Output: JSON with compression plan and results
"""

import argparse
import json
import sys
import subprocess
import time
from pathlib import Path
from datetime import datetime
from typing import Dict, List, Any, Optional, Tuple

WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
CAPSULE_BUILDER = WORKSPACE / "tools" / "capsule-builder"
BUDGET_CHECK = WORKSPACE / "tools" / "context-budget-check"
EVENTS_DIR = WORKSPACE / "artifacts" / "compression_events"
CAPSULES_DIR = WORKSPACE / "artifacts" / "capsules"

# Pressure thresholds
PRESSURE_THRESHOLDS = {
    "light": 0.70,
    "standard": 0.85,
    "strong": 0.92
}

# Turns to preserve from the end (recent context)
MIN_PRESERVE_TURNS = 5
MAX_EVICT_RATIO = 0.6  # Max 60% of turns can be evicted


def load_json_file(path: Path) -> Optional[Dict]:
    """Load JSON file safely."""
    if not path.exists():
        return None
    try:
        with open(path, 'r') as f:
            return json.load(f)
    except:
        return None


def load_jsonl_file(path: Path) -> List[Dict]:
    """Load JSONL file and return list of records."""
    records = []
    if not path.exists():
        return records
    with open(path, 'r') as f:
        for line in f:
            line = line.strip()
            if line:
                try:
                    records.append(json.loads(line))
                except json.JSONDecodeError:
                    continue
    return records


def count_turns(history_path: Path) -> int:
    """Count number of conversation turns in history file."""
    records = load_jsonl_file(history_path)
    turn_count = 0
    for record in records:
        if record.get("type") != "message":
            continue
        msg = record.get("message", {})
        if msg.get("role") in ("user", "assistant"):
            turn_count += 1
    return turn_count


def run_budget_check(state_path: Path, history_path: Path, max_tokens: int = 100000) -> Dict:
    """Run context-budget-check and return result."""
    try:
        result = subprocess.run(
            [str(BUDGET_CHECK), "--state", str(state_path), "--history", str(history_path), "--max-tokens", str(max_tokens), "--json"],
            capture_output=True,
            text=True,
            timeout=30
        )
        if result.returncode == 0:
            return json.loads(result.stdout)
        else:
            return {"error": result.stderr, "estimated_tokens": 0, "ratio": 0, "pressure_level": "normal"}
    except Exception as e:
        return {"error": str(e), "estimated_tokens": 0, "ratio": 0, "pressure_level": "normal"}


def determine_eviction_plan(
    turn_count: int,
    pressure_level: str,
    state: Optional[Dict]
) -> Dict:
    """
    Determine which turns to evict based on pressure level.
    
    Returns:
        - evict_turns: list of turn numbers to evict
        - preserve_turns: list of turn numbers to preserve
        - preserve_resident: list of resident state items to preserve
    """
    if turn_count <= MIN_PRESERVE_TURNS:
        return {
            "evict_turns": [],
            "preserve_turns": list(range(1, turn_count + 1)),
            "preserve_resident": ["task_goal", "open_loops", "hard_constraints", "response_contract"]
        }
    
    # Calculate number of turns to evict based on pressure
    if pressure_level == "strong":
        evict_ratio = 0.5
    elif pressure_level == "standard":
        evict_ratio = 0.4
    elif pressure_level == "light":
        evict_ratio = 0.25
    else:
        evict_ratio = 0
    
    evict_count = min(
        int(turn_count * evict_ratio),
        int(turn_count * MAX_EVICT_RATIO),
        turn_count - MIN_PRESERVE_TURNS
    )
    
    # Evict from the beginning, preserve recent turns
    evict_turns = list(range(1, evict_count + 1))
    preserve_turns = list(range(evict_count + 1, turn_count + 1))
    
    # Determine resident items to preserve
    preserve_resident = ["task_goal", "response_contract"]
    
    # Keep open_loops that are still open
    if state and "open_loops" in state:
        open_loops = [l for l in state.get("open_loops", []) if l.get("status") == "open"]
        if open_loops:
            preserve_resident.append("open_loops")
    
    # Keep hard_constraints
    if state and state.get("hard_constraints"):
        preserve_resident.append("hard_constraints")
    
    return {
        "evict_turns": evict_turns,
        "preserve_turns": preserve_turns,
        "preserve_resident": preserve_resident
    }


def build_capsule_for_range(
    session_id: str,
    start: int,
    end: int,
    history_path: Path,
    output_dir: Path
) -> Optional[Dict]:
    """Build a capsule for a turn range using capsule-builder."""
    try:
        result = subprocess.run(
            [
                str(CAPSULE_BUILDER),
                "--input", str(history_path),
                "--session-id", session_id,
                "--start", str(start),
                "--end", str(end),
                "--output", str(output_dir),
                "--no-llm"  # Use simple extraction for speed
            ],
            capture_output=True,
            text=True,
            timeout=60
        )
        
        if result.returncode == 0:
            output = json.loads(result.stdout)
            if output.get("status") == "success":
                capsule_path = Path(output["path"])
                with open(capsule_path, 'r') as f:
                    return json.load(f)
        return None
    except Exception as e:
        return None


def generate_event_id() -> str:
    """Generate unique event ID."""
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    return f"cmp_{ts}"


def create_compression_event(
    session_id: str,
    trigger: str,
    pressure_level: str,
    before: Dict,
    after: Dict,
    resident_kept: List[int],
    capsules_created: List[str],
    evicted_ranges: List[Dict],
    mode: str,
    duration_ms: int
) -> Dict:
    """Create a compression event record."""
    event_id = generate_event_id()
    
    event = {
        "event_id": event_id,
        "session_id": session_id,
        "trigger": trigger,
        "pressure_level": pressure_level,
        "before": {
            "estimated_tokens": before.get("estimated_tokens", 0),
            "turn_count": before.get("turn_count", 0),
            "ratio": before.get("ratio", 0)
        },
        "after": {
            "estimated_tokens": after.get("estimated_tokens", 0),
            "turn_count": after.get("turn_count", 0),
            "ratio": after.get("ratio", 0)
        },
        "resident_kept": resident_kept,
        "capsules_created": capsules_created,
        "evicted_turn_ranges": evicted_ranges,
        "vector_indexed": False,
        "mode": mode,
        "duration_ms": duration_ms,
        "created_at": datetime.now().isoformat()
    }
    
    return event


def save_event(event: Dict) -> Path:
    """Save compression event to file."""
    EVENTS_DIR.mkdir(parents=True, exist_ok=True)
    event_path = EVENTS_DIR / f"{event['event_id']}.json"
    with open(event_path, 'w') as f:
        json.dump(event, f, indent=2)
    return event_path


def append_to_events_log(event: Dict, events_path: Path):
    """Append event to compression_events.jsonl."""
    events_path.parent.mkdir(parents=True, exist_ok=True)
    with open(events_path, 'a') as f:
        f.write(json.dumps(event) + "\n")


def append_capsule_reference(capsule: Dict, capsules_path: Path):
    """Append capsule reference to capsules.jsonl."""
    capsules_path.parent.mkdir(parents=True, exist_ok=True)
    ref = {
        "capsule_id": capsule["capsule_id"],
        "session_id": capsule["session_id"],
        "source_turn_range": capsule["source_turn_range"],
        "topic": capsule["topic"],
        "created_at": capsule["created_at"]
    }
    with open(capsules_path, 'a') as f:
        f.write(json.dumps(ref) + "\n")


def estimate_tokens_after_eviction(
    original_tokens: int,
    evict_turns: List[int],
    total_turns: int
) -> int:
    """Estimate token count after eviction."""
    if total_turns == 0:
        return 0
    evict_ratio = len(evict_turns) / total_turns
    # Assume eviction reduces tokens proportionally, but with some overhead preserved
    return int(original_tokens * (1 - evict_ratio * 0.8))


def run_compression(
    session_id: str,
    state_path: Path,
    history_path: Path,
    capsules_path: Optional[Path],
    events_path: Optional[Path],
    mode: str = "shadow",
    dry_run: bool = False,
    max_tokens: int = 100000
) -> Dict:
    """Run compression analysis and optionally execute it."""
    start_time = time.time()
    
    # Load state
    state = load_json_file(state_path)
    
    # Count turns
    turn_count = count_turns(history_path)
    
    # Run budget check
    budget = run_budget_check(state_path, history_path, max_tokens)
    
    if "error" in budget and budget.get("estimated_tokens", 0) == 0:
        return {
            "error": {
                "type": "budget_check_failed",
                "message": budget.get("error", "Unknown error")
            }
        }
    
    pressure_level = budget.get("pressure_level", "normal")
    estimated_tokens = budget.get("estimated_tokens", 0)
    ratio = budget.get("ratio", 0)
    
    # Determine trigger
    if ratio >= PRESSURE_THRESHOLDS["strong"]:
        trigger = "threshold_92"
    elif ratio >= PRESSURE_THRESHOLDS["standard"]:
        trigger = "threshold_85"
    elif ratio >= PRESSURE_THRESHOLDS["light"]:
        trigger = "threshold_70"
    else:
        trigger = "manual"
    
    # Check if compression is needed
    compression_triggered = pressure_level in ("light", "standard", "strong")
    
    if not compression_triggered:
        return {
            "compression_triggered": False,
            "mode": mode,
            "pressure_level": pressure_level,
            "reason": "Context pressure is normal, no compression needed",
            "budget": budget
        }
    
    # Determine eviction plan
    plan = determine_eviction_plan(turn_count, pressure_level, state)
    evict_turns = plan["evict_turns"]
    preserve_turns = plan["preserve_turns"]
    
    if not evict_turns:
        return {
            "compression_triggered": False,
            "mode": mode,
            "pressure_level": pressure_level,
            "reason": "Not enough turns to evict while maintaining minimum context",
            "budget": budget
        }
    
    # Calculate after state
    after_tokens = estimate_tokens_after_eviction(estimated_tokens, evict_turns, turn_count)
    after_ratio = after_tokens / budget.get("max_tokens", 100000) if budget.get("max_tokens", 100000) > 0 else 0
    after_turn_count = len(preserve_turns)
    
    # Create eviction ranges (batch consecutive turns)
    evicted_ranges = []
    if evict_turns:
        # For simplicity, create a single range
        evicted_ranges = [{"start": evict_turns[0], "end": evict_turns[-1]}]
    
    # Build capsules (in both shadow and enforced modes for plan generation)
    capsules = []
    capsules_created = []
    
    CAPSULES_DIR.mkdir(parents=True, exist_ok=True)
    
    for evict_range in evicted_ranges:
        capsule = build_capsule_for_range(
            session_id,
            evict_range["start"],
            evict_range["end"],
            history_path,
            CAPSULES_DIR
        )
        if capsule:
            capsules.append(capsule)
            capsules_created.append(capsule["capsule_id"])
            
            # In enforced mode, append to capsules log
            if mode == "enforced" and capsules_path and not dry_run:
                append_capsule_reference(capsule, capsules_path)
    
    # Create compression event
    duration_ms = int((time.time() - start_time) * 1000)
    
    event = create_compression_event(
        session_id=session_id,
        trigger=trigger,
        pressure_level=pressure_level,
        before={
            "estimated_tokens": estimated_tokens,
            "turn_count": turn_count,
            "ratio": ratio
        },
        after={
            "estimated_tokens": after_tokens,
            "turn_count": after_turn_count,
            "ratio": after_ratio
        },
        resident_kept=preserve_turns[:10],  # Keep first 10 for event record
        capsules_created=capsules_created,
        evicted_ranges=evicted_ranges,
        mode=mode,
        duration_ms=duration_ms
    )
    
    # Save event (in both modes for audit trail)
    event_path = save_event(event)
    
    # Append to events log if path provided
    if events_path and not dry_run:
        append_to_events_log(event, events_path)
    
    # In enforced mode, we would update active_state.json here
    # For now, shadow mode just reports what would happen
    
    result = {
        "compression_triggered": True,
        "mode": mode,
        "pressure_level": pressure_level,
        "plan": {
            "evict_turns": evict_turns,
            "evicted_ranges": evicted_ranges,
            "create_capsules": capsules_created,
            "preserve_resident": plan["preserve_resident"]
        },
        "capsules": capsules,
        "event_id": event["event_id"],
        "event_path": str(event_path),
        "before": {
            "tokens": estimated_tokens,
            "turns": turn_count,
            "ratio": round(ratio, 4)
        },
        "after": {
            "tokens": after_tokens,
            "turns": after_turn_count,
            "ratio": round(after_ratio, 4)
        },
        "duration_ms": duration_ms
    }
    
    # Add shadow mode specific message
    if mode == "shadow":
        result["message"] = "Shadow mode: compression planned but not executed. Use --mode enforced to apply changes."
    
    return result


def health_check() -> Dict:
    """Perform health check."""
    issues = []
    checks = {}
    
    # Check dependencies
    checks["capsule_builder_exists"] = CAPSULE_BUILDER.exists()
    checks["budget_check_exists"] = BUDGET_CHECK.exists()
    
    if not CAPSULE_BUILDER.exists():
        issues.append(f"capsule-builder not found at {CAPSULE_BUILDER}")
    if not BUDGET_CHECK.exists():
        issues.append(f"context-budget-check not found at {BUDGET_CHECK}")
    
    # Check directories
    try:
        EVENTS_DIR.mkdir(parents=True, exist_ok=True)
        CAPSULES_DIR.mkdir(parents=True, exist_ok=True)
        checks["events_dir"] = True
        checks["capsules_dir"] = True
    except Exception as e:
        issues.append(f"Cannot create directories: {e}")
        checks["events_dir"] = False
        checks["capsules_dir"] = False
    
    # Test budget check
    try:
        result = subprocess.run(
            [str(BUDGET_CHECK), "--health"],
            capture_output=True,
            text=True,
            timeout=10
        )
        checks["budget_check_healthy"] = result.returncode == 0
    except Exception as e:
        checks["budget_check_healthy"] = False
        issues.append(f"Budget check failed: {e}")
    
    # Test capsule builder
    try:
        result = subprocess.run(
            [str(CAPSULE_BUILDER), "--health"],
            capture_output=True,
            text=True,
            timeout=10
        )
        checks["capsule_builder_healthy"] = result.returncode == 0
    except Exception as e:
        checks["capsule_builder_healthy"] = False
        issues.append(f"Capsule builder failed: {e}")
    
    return {
        "status": "healthy" if not issues else "degraded",
        "checks": checks,
        "issues": issues if issues else None,
        "timestamp": datetime.now().isoformat()
    }


def self_test() -> Dict:
    """Run self-test."""
    tests = []
    
    # Test 1: Budget check integration
    try:
        result = subprocess.run(
            [str(BUDGET_CHECK), "--test"],
            capture_output=True,
            text=True,
            timeout=30
        )
        budget_result = json.loads(result.stdout)
        tests.append({
            "name": "budget_check_integration",
            "status": "pass" if budget_result.get("status") == "pass" else "fail",
            "details": budget_result.get("tests", [])
        })
    except Exception as e:
        tests.append({"name": "budget_check_integration", "status": "fail", "details": str(e)})
    
    # Test 2: Eviction plan logic
    try:
        plan = determine_eviction_plan(100, "standard", {"open_loops": [{"status": "open"}]})
        assert len(plan["evict_turns"]) > 0
        assert len(plan["preserve_turns"]) >= MIN_PRESERVE_TURNS
        assert "task_goal" in plan["preserve_resident"]
        tests.append({"name": "eviction_plan_logic", "status": "pass"})
    except AssertionError as e:
        tests.append({"name": "eviction_plan_logic", "status": "fail", "details": str(e)})
    
    # Test 3: Eviction plan - low turn count
    try:
        plan = determine_eviction_plan(3, "strong", None)
        assert len(plan["evict_turns"]) == 0
        tests.append({"name": "eviction_plan_low_turns", "status": "pass"})
    except AssertionError as e:
        tests.append({"name": "eviction_plan_low_turns", "status": "fail", "details": str(e)})
    
    # Test 4: Event creation
    try:
        event = create_compression_event(
            session_id="test_session",
            trigger="threshold_85",
            pressure_level="standard",
            before={"estimated_tokens": 85000, "turn_count": 50, "ratio": 0.85},
            after={"estimated_tokens": 50000, "turn_count": 30, "ratio": 0.5},
            resident_kept=[1, 2, 3],
            capsules_created=["cap_001"],
            evicted_ranges=[{"start": 1, "end": 20}],
            mode="shadow",
            duration_ms=100
        )
        assert event["event_id"].startswith("cmp_")
        assert event["mode"] == "shadow"
        tests.append({"name": "event_creation", "status": "pass"})
    except AssertionError as e:
        tests.append({"name": "event_creation", "status": "fail", "details": str(e)})
    
    # Test 5: Token estimation after eviction
    try:
        after = estimate_tokens_after_eviction(100000, list(range(1, 41)), 100)
        assert after < 100000
        assert after > 0
        tests.append({"name": "token_estimation", "status": "pass"})
    except AssertionError as e:
        tests.append({"name": "token_estimation", "status": "fail", "details": str(e)})
    
    # Test 6: Capsule builder integration
    try:
        result = subprocess.run(
            [str(CAPSULE_BUILDER), "--test", "--json"],
            capture_output=True,
            text=True,
            timeout=30
        )
        capsule_result = json.loads(result.stdout)
        tests.append({
            "name": "capsule_builder_integration",
            "status": "pass" if capsule_result.get("status") == "passed" else "fail"
        })
    except Exception as e:
        tests.append({"name": "capsule_builder_integration", "status": "fail", "details": str(e)})
    
    passed = sum(1 for t in tests if t["status"] == "pass")
    failed = len(tests) - passed
    
    return {
        "status": "pass" if failed == 0 else "fail",
        "total": len(tests),
        "passed": passed,
        "failed": failed,
        "tests": tests,
        "timestamp": datetime.now().isoformat()
    }


def main():
    parser = argparse.ArgumentParser(
        description="context-compress v1.0 - Context Compression Executor (Shadow Mode)"
    )
    
    parser.add_argument(
        "--session-id", "-s",
        help="Session identifier"
    )
    
    parser.add_argument(
        "--state",
        type=Path,
        help="Path to active_state.json"
    )
    
    parser.add_argument(
        "--history",
        type=Path,
        help="Path to conversation history (raw.jsonl)"
    )
    
    parser.add_argument(
        "--capsules",
        type=Path,
        help="Path to capsules.jsonl (append)"
    )
    
    parser.add_argument(
        "--events",
        type=Path,
        help="Path to compression_events.jsonl (append)"
    )
    
    parser.add_argument(
        "--max-tokens", "-m",
        type=int,
        default=100000,
        help="Maximum token budget (default: 100000)"
    )
    
    parser.add_argument(
        "--mode",
        choices=["shadow", "enforced"],
        default="shadow",
        help="Compression mode (default: shadow)"
    )
    
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Generate plan only, don't write files"
    )
    
    parser.add_argument(
        "--json", "-j",
        action="store_true",
        help="Output as JSON"
    )
    
    parser.add_argument(
        "--health",
        action="store_true",
        help="Run health check"
    )
    
    parser.add_argument(
        "--test", "-t",
        action="store_true",
        help="Run self-test"
    )
    
    args = parser.parse_args()
    
    # Health check mode
    if args.health:
        result = health_check()
        print(json.dumps(result, indent=2))
        return 0 if result["status"] == "healthy" else 1
    
    # Self-test mode
    if args.test:
        result = self_test()
        print(json.dumps(result, indent=2))
        return 0 if result["status"] == "pass" else 1
    
    # Validate required args
    if not args.session_id:
        print(json.dumps({
            "error": {"type": "missing_arg", "message": "--session-id is required"}
        }, indent=2))
        return 1
    
    if not args.state:
        print(json.dumps({
            "error": {"type": "missing_arg", "message": "--state is required"}
        }, indent=2))
        return 1
    
    if not args.history:
        print(json.dumps({
            "error": {"type": "missing_arg", "message": "--history is required"}
        }, indent=2))
        return 1
    
    # Check file existence
    if not args.state.exists():
        print(json.dumps({
            "error": {"type": "file_not_found", "message": f"State file not found: {args.state}"}
        }, indent=2))
        return 1
    
    if not args.history.exists():
        print(json.dumps({
            "error": {"type": "file_not_found", "message": f"History file not found: {args.history}"}
        }, indent=2))
        return 1
    
    # Run compression
    try:
        result = run_compression(
            session_id=args.session_id,
            state_path=args.state,
            history_path=args.history,
            capsules_path=args.capsules,
            events_path=args.events,
            mode=args.mode,
            dry_run=args.dry_run,
            max_tokens=args.max_tokens
        )
        
        print(json.dumps(result, indent=2, ensure_ascii=False))
        return 0 if "error" not in result else 1
        
    except Exception as e:
        print(json.dumps({
            "error": {"type": "execution_error", "message": str(e)}
        }, indent=2))
        return 1


if __name__ == "__main__":
    sys.exit(main())
