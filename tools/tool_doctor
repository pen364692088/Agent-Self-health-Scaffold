#!/usr/bin/env python3
"""
tool_doctor v2.1 - Preflight Check Tool with Transport Modes

Performs preflight checks on tools before delivery:
- Configuration check
- Port/Endpoint connectivity
- Health check
- Sample call (real transport or local)

v2.0 增强:
- 两种 transport 模式: --transport http (真实请求) 或 --transport local (本地开发)
- 端口冲突自动换端口 (PORT=0)
- 详细的 error_code + 可行动 message
- report 中明确 mode 和 transport

v2.1 修复:
- --base-url 参数现在正确传递到 check_health 和 check_sample_call

Usage:
    tool_doctor <tool_path>
    tool_doctor <tool_path> --ci
    tool_doctor <tool_path> --transport http
    tool_doctor <tool_path> --base-url http://127.0.0.1:18080 --ci

Output: doctor_report.json
"""

import argparse
import json
import os
import subprocess
import sys
import time
import socket
import requests
from datetime import datetime
from pathlib import Path
from typing import Dict, List, Optional, Any

WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
REPORTS_DIR = WORKSPACE / "reports" / "tool_doctor"

# Check result statuses
STATUS_PASS = "pass"
STATUS_FAIL = "fail"
STATUS_WARN = "warn"

# Transport modes
TRANSPORT_HTTP = "http"
TRANSPORT_LOCAL = "local"


class CheckResult:
    def __init__(self, name: str, status: str, message: str, details: dict = None):
        self.name = name
        self.status = status
        self.message = message
        self.details = details or {}
        self.latency_ms = None
        self.response_time_ms = None
    
    def to_dict(self) -> dict:
        result = {
            "name": self.name,
            "status": self.status,
            "message": self.message
        }
        if self.details:
            result["details"] = self.details
        if self.latency_ms is not None:
            result["latency_ms"] = self.latency_ms
        if self.response_time_ms is not None:
            result["response_time_ms"] = self.response_time_ms
        return result


class ToolDoctor:
    def __init__(self, tool_path: str, ci_mode: bool = False, transport: str = TRANSPORT_LOCAL, base_url: str = None):
        self.tool_path = Path(tool_path)
        self.ci_mode = ci_mode
        self.transport = transport
        self.base_url = base_url  # v2.1: 支持自定义 base_url
        self.checks: List[CheckResult] = []
        self.chosen_port = None
        self.report = {
            "tool": str(tool_path),
            "timestamp": datetime.now().isoformat(),
            "mode": "ci" if ci_mode else "local",
            "transport": transport,
            "status": "healthy",
            "checks": [],
            "summary": {
                "passed": 0,
                "failed": 0,
                "warnings": 0
            }
        }
    
    def run_all_checks(self) -> dict:
        """Run all preflight checks."""
        self.check_config()
        self.check_port()
        self.check_health()
        self.check_sample_call()
        
        return self.generate_report()
    
    def check_config(self) -> CheckResult:
        """Check if tool configuration is valid."""
        result = CheckResult("config", STATUS_PASS, "Configuration check")
        
        try:
            # Check if tool exists
            if not self.tool_path.exists():
                result.status = STATUS_FAIL
                result.message = f"Tool not found: {self.tool_path}"
                result.details = {"error_code": "TOOL_NOT_FOUND"}
                self.checks.append(result)
                return result
            
            # Check if executable
            if not os.access(self.tool_path, os.X_OK):
                result.status = STATUS_WARN
                result.message = "Tool is not executable"
                result.details = {"suggestion": f"Run: chmod +x {self.tool_path}"}
            
            # Check for common config files
            config_files = []
            for ext in [".json", ".yaml", ".yml", ".toml", ".env"]:
                config_path = self.tool_path.with_suffix(ext)
                if config_path.exists():
                    config_files.append(str(config_path))
            
            if config_files:
                result.details = {"config_files": config_files}
            
            self.checks.append(result)
            return result
            
        except Exception as e:
            result.status = STATUS_FAIL
            result.message = f"Config check error: {e}"
            result.details = {"error_code": "CONFIG_CHECK_ERROR", "exception": str(e)}
            self.checks.append(result)
            return result
    
    def check_port(self, preferred_port: int = 0) -> CheckResult:
        """
        Check port availability, auto-switch if conflict (v2.0 增强)
        
        Args:
            preferred_port: 0 means auto-assign
        """
        result = CheckResult("port", STATUS_PASS, "Port check")
        
        # 如果 CI 模式且 PORT=0，跳过真实端口检查
        if self.ci_mode and preferred_port == 0:
            result.status = STATUS_WARN
            result.message = "CI mode: skipping real port check"
            result.details = {"mode": "ci", "suggestion": "Use --ci-port for CI testing"}
            self.checks.append(result)
            return result
        
        try:
            # 尝试绑定端口
            test_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            test_socket.settimeout(5)
            
            if preferred_port == 0:
                # 让系统分配端口
                test_socket.bind(('localhost', 0))
                self.chosen_port = test_socket.getsockname()[1]
                result.message = f"Auto-assigned port: {self.chosen_port}"
                result.details = {"chosen_port": self.chosen_port, "mode": "auto"}
            else:
                # 检查指定端口
                try:
                    test_socket.bind(('localhost', preferred_port))
                    self.chosen_port = preferred_port
                    result.message = f"Port {preferred_port} available"
                    result.details = {"chosen_port": preferred_port, "mode": "manual"}
                except OSError as e:
                    if e.errno == 98:  # EADDRINUSE
                        result.status = STATUS_FAIL
                        result.message = f"Port {preferred_port} already in use (EADDRINUSE)"
                        result.details = {
                            "error_code": "EADDRINUSE",
                            "port": preferred_port,
                            "suggestion": "Use PORT=0 for auto-assign or choose another port"
                        }
                    else:
                        raise
            
            test_socket.close()
            self.checks.append(result)
            return result
            
        except Exception as e:
            result.status = STATUS_FAIL
            result.message = f"Port check error: {e}"
            result.details = {"error_code": "PORT_CHECK_ERROR", "exception": str(e)}
            self.checks.append(result)
            return result
    
    def _supports_flag(self, flag: str) -> bool:
        """Best-effort check whether target tool advertises a CLI flag."""
        try:
            proc = subprocess.run(
                [str(self.tool_path), "--help"],
                capture_output=True,
                text=True,
                timeout=8
            )
            help_text = (proc.stdout or "") + "\n" + (proc.stderr or "")
            return flag in help_text
        except Exception:
            return False

    def _local_probe(self, args: list[str], timeout: int = 10, stdin_text: str = None):
        """Run local CLI probe and return subprocess.CompletedProcess."""
        return subprocess.run(
            [str(self.tool_path), *args],
            capture_output=True,
            text=True,
            timeout=timeout,
            input=stdin_text
        )

    def check_health(self) -> CheckResult:
        """
        Check health endpoint.
        
        v2.1: 优先使用 self.base_url，否则回退到 localhost:port
        """
        result = CheckResult("health", STATUS_PASS, "Health check")
        
        # v2.1: 优先级: self.base_url > localhost:chosen_port > localhost:8080
        if self.base_url:
            base_url = self.base_url
        elif self.chosen_port:
            base_url = f"http://localhost:{self.chosen_port}"
        else:
            base_url = "http://localhost:8080"
        
        health_url = f"{base_url}/health"
        
        try:
            if self.transport == TRANSPORT_HTTP:
                # 真实 HTTP 请求
                start_time = time.time()
                response = requests.get(health_url, timeout=10)
                latency = (time.time() - start_time) * 1000
                
                if response.status_code == 200:
                    result.message = "Health check passed"
                    result.details = {
                        "url": health_url,
                        "status_code": response.status_code,
                        "latency_ms": round(latency, 2)
                    }
                    result.latency_ms = latency
                else:
                    result.status = STATUS_FAIL
                    result.message = f"Health check failed: HTTP {response.status_code}"
                    result.details = {
                        "url": health_url,
                        "status_code": response.status_code,
                        "error_code": "HEALTH_CHECK_FAILED"
                    }
            
            else:  # TRANSPORT_LOCAL
                # 本地模式：检查进程或文件
                if self.ci_mode:
                    result.status = STATUS_WARN
                    result.message = "CI mode: skipping real health check"
                    result.details = {"mode": "ci", "transport": "local"}
                else:
                    # 本地探测优先级:
                    # 1) --health (若工具支持)
                    # 2) --help 作为降级健康探测
                    if self._supports_flag("--health"):
                        proc = self._local_probe(["--health"], timeout=10)
                        if proc.returncode == 0:
                            result.message = "Health check passed (local --health)"
                            result.details = {"output": (proc.stdout or "")[:200]}
                        else:
                            result.status = STATUS_FAIL
                            result.message = f"Health check failed: exit code {proc.returncode}"
                            result.details = {
                                "error_code": "HEALTH_CHECK_FAILED",
                                "stderr": (proc.stderr or "")[:200]
                            }
                    else:
                        proc = self._local_probe(["--help"], timeout=10)
                        if proc.returncode == 0:
                            result.status = STATUS_WARN
                            result.message = "No --health flag; fallback --help probe passed"
                            result.details = {
                                "fallback": "--help",
                                "recommendation": "Add --health for stronger preflight checks"
                            }
                        else:
                            result.status = STATUS_FAIL
                            result.message = f"Health fallback probe failed: exit code {proc.returncode}"
                            result.details = {
                                "error_code": "HEALTH_CHECK_FAILED",
                                "fallback": "--help",
                                "stderr": (proc.stderr or "")[:200]
                            }
            
            self.checks.append(result)
            return result
            
        except requests.exceptions.RequestException as e:
            result.status = STATUS_FAIL
            result.message = f"Health check failed: {e}"
            result.details = {
                "error_code": "HEALTH_CHECK_ERROR",
                "exception": str(e),
                "url": health_url
            }
            self.checks.append(result)
            return result
        
        except subprocess.TimeoutExpired:
            result.status = STATUS_FAIL
            result.message = "Health check timeout"
            result.details = {"error_code": "TIMEOUT", "timeout_seconds": 10}
            self.checks.append(result)
            return result
        
        except Exception as e:
            result.status = STATUS_FAIL
            result.message = f"Health check error: {e}"
            result.details = {"error_code": "HEALTH_CHECK_ERROR", "exception": str(e)}
            self.checks.append(result)
            return result
    
    def check_sample_call(self, endpoint: str = None, payload: dict = None) -> CheckResult:
        """
        Perform a sample call to verify the tool works.
        
        v2.1: 优先使用 self.base_url
        """
        result = CheckResult("sample_call", STATUS_PASS, "Sample call")
        
        # v2.1: 优先级: endpoint 参数 > self.base_url > localhost:port
        if not endpoint:
            if self.base_url:
                endpoint = f"{self.base_url}/api/v1/execute"
            else:
                endpoint = f"http://localhost:{self.chosen_port or 8080}/api/v1/execute"
        
        if not payload:
            payload = {"action": "ping"}  # 默认测试 payload
        
        try:
            if self.transport == TRANSPORT_HTTP:
                # 真实 HTTP 请求
                start_time = time.time()
                response = requests.post(
                    endpoint,
                    json=payload,
                    headers={"Content-Type": "application/json"},
                    timeout=30
                )
                latency = (time.time() - start_time) * 1000
                
                if response.status_code in [200, 201]:
                    result.message = "Sample call passed"
                    result.details = {
                        "endpoint": endpoint,
                        "payload": payload,
                        "status_code": response.status_code,
                        "latency_ms": round(latency, 2),
                        "response_preview": response.text[:200]
                    }
                    result.latency_ms = latency
                else:
                    result.status = STATUS_FAIL
                    result.message = f"Sample call failed: HTTP {response.status_code}"
                    result.details = {
                        "error_code": "SAMPLE_CALL_FAILED",
                        "status_code": response.status_code,
                        "response": response.text[:200]
                    }
            
            else:  # TRANSPORT_LOCAL
                # 本地模式：直接调用工具
                if self.ci_mode:
                    result.status = STATUS_WARN
                    result.message = "CI mode: mock sample call"
                    result.details = {"mode": "ci", "transport": "local", "mock": True}
                else:
                    # 本地样例调用优先级:
                    # 1) --sample (若工具支持)
                    # 2) --help 作为降级探测
                    if self._supports_flag("--sample"):
                        proc = self._local_probe(
                            ["--sample"],
                            timeout=30,
                            stdin_text=json.dumps(payload)
                        )
                        if proc.returncode == 0:
                            result.message = "Sample call passed (local --sample)"
                            result.details = {
                                "payload": payload,
                                "output": (proc.stdout or "")[:200]
                            }
                        else:
                            result.status = STATUS_FAIL
                            result.message = f"Sample call failed: exit code {proc.returncode}"
                            result.details = {
                                "error_code": "SAMPLE_CALL_FAILED",
                                "stderr": (proc.stderr or "")[:200]
                            }
                    else:
                        proc = self._local_probe(["--help"], timeout=10)
                        if proc.returncode == 0:
                            result.status = STATUS_WARN
                            result.message = "No --sample flag; fallback --help probe passed"
                            result.details = {
                                "fallback": "--help",
                                "recommendation": "Add --sample for stronger preflight checks"
                            }
                        else:
                            result.status = STATUS_FAIL
                            result.message = f"Sample fallback probe failed: exit code {proc.returncode}"
                            result.details = {
                                "error_code": "SAMPLE_CALL_FAILED",
                                "fallback": "--help",
                                "stderr": (proc.stderr or "")[:200]
                            }
            
            self.checks.append(result)
            return result
            
        except requests.exceptions.RequestException as e:
            result.status = STATUS_FAIL
            result.message = f"Sample call failed: {e}"
            result.details = {
                "error_code": "SAMPLE_CALL_ERROR",
                "exception": str(e),
                "endpoint": endpoint
            }
            self.checks.append(result)
            return result
        
        except subprocess.TimeoutExpired:
            result.status = STATUS_FAIL
            result.message = "Sample call timeout"
            result.details = {"error_code": "TIMEOUT", "timeout_seconds": 30}
            self.checks.append(result)
            return result
        
        except Exception as e:
            result.status = STATUS_FAIL
            result.message = f"Sample call error: {e}"
            result.details = {"error_code": "SAMPLE_CALL_ERROR", "exception": str(e)}
            self.checks.append(result)
            return result
    
    def generate_report(self) -> dict:
        """Generate the final doctor_report.json."""
        for check in self.checks:
            self.report["checks"].append(check.to_dict())
            
            if check.status == STATUS_PASS:
                self.report["summary"]["passed"] += 1
            elif check.status == STATUS_FAIL:
                self.report["summary"]["failed"] += 1
                self.report["status"] = "unhealthy"
            elif check.status == STATUS_WARN:
                self.report["summary"]["warnings"] += 1
        
        # Add key fields for done-guard validation
        self.report["chosen_port"] = self.chosen_port
        # local 模式下允许 WARN 作为可接受降级（例如工具未实现 --health/--sample）
        self.report["health_ok"] = any(
            c.name == "health" and (
                c.status == STATUS_PASS or
                (self.transport == TRANSPORT_LOCAL and c.status == STATUS_WARN)
            )
            for c in self.checks
        )
        self.report["sample_call_ok"] = any(
            c.name == "sample_call" and (
                c.status == STATUS_PASS or
                (self.transport == TRANSPORT_LOCAL and c.status == STATUS_WARN)
            )
            for c in self.checks
        )
        
        return self.report
    
    def save_report(self, output_path: str = None):
        """Save report to file."""
        if not output_path:
            REPORTS_DIR.mkdir(parents=True, exist_ok=True)
            output_path = REPORTS_DIR / f"doctor_report_{self.tool_path.stem}.json"
        
        with open(output_path, "w") as f:
            json.dump(self.report, f, indent=2)
        
        print(f"Report saved to: {output_path}")
        return output_path


def main():
    parser = argparse.ArgumentParser(description="tool_doctor - Preflight Check Tool")
    parser.add_argument("tool_path", nargs="?", help="Path to the tool to check")
    parser.add_argument("--ci", action="store_true", help="Run in CI mode (limited checks)")
    parser.add_argument("--transport", choices=["http", "local"], default="local",
                        help="Transport mode: http (real requests) or local (direct calls)")
    parser.add_argument("--port", type=int, default=0, help="Preferred port (0=auto)")
    parser.add_argument("--base-url", help="Base URL for health/sample checks")
    parser.add_argument("--output", help="Output file path for report")
    parser.add_argument("--json", action="store_true", help="Output only JSON")
    parser.add_argument("--health", action="store_true", help="Health check for tool_doctor itself")
    parser.add_argument("--sample", action="store_true", help="Sample call for tool_doctor itself")
    
    args = parser.parse_args()

    # Standard local interface for other preflight tools
    if args.health:
        payload = {"status": "healthy", "tool": "tool_doctor", "version": "v2.2"}
        print(json.dumps(payload) if args.json else "healthy")
        return 0

    if args.sample:
        payload = {"ok": True, "tool": "tool_doctor", "sample": "pong"}
        print(json.dumps(payload) if args.json else "sample_ok")
        return 0

    if not args.tool_path:
        parser.error("tool_path is required unless --health or --sample is used")
    
    # Run doctor
    doctor = ToolDoctor(
        args.tool_path,
        ci_mode=args.ci,
        transport=args.transport,
        base_url=args.base_url  # v2.1: 传递 base_url
    )
    
    if args.port:
        doctor.chosen_port = args.port
    
    report = doctor.run_all_checks()
    
    # Save report
    output_path = doctor.save_report(args.output)
    
    # Output
    if args.json:
        print(json.dumps(report, indent=2))
    else:
        print("=" * 60)
        print("TOOL DOCTOR REPORT")
        print("=" * 60)
        print(f"Tool: {args.tool_path}")
        print(f"Mode: {report['mode']}")
        print(f"Transport: {report['transport']}")
        print(f"Status: {report['status'].upper()}")
        print()
        
        for check in report["checks"]:
            status_icon = "✅" if check["status"] == "pass" else "❌" if check["status"] == "fail" else "⚠️"
            print(f"{status_icon} {check['name']}: {check['message']}")
            if check.get("details"):
                for key, value in check["details"].items():
                    if key not in ["config_files", "response_preview", "output"]:
                        print(f"   - {key}: {value}")
        
        print()
        print(f"Summary: {report['summary']['passed']} passed, {report['summary']['failed']} failed, {report['summary']['warnings']} warnings")
        print(f"Report: {output_path}")
    
    return 0 if report["status"] == "healthy" else 1


if __name__ == "__main__":
    sys.exit(main())
