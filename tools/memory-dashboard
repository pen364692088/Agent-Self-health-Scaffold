    ratio_status = "✅" if ratio >= ratio_threshold else ("⚠️ LOW_SAMPLE" if is_low_sample else "⚠️")
    print(f"   unique/raw ratio:  {ratio:.2%} / {ratio_threshold:.0%} {ratio_status}")
    print(f"   duplicate_id_rate: {metrics.get('duplicate_id_rate', 0):.2%}")
    
    # orphan 指标
    print("\n🔗 Link Quality (链路质量)")
    print(f"   orphan_use_count:   {metrics.get('orphan_use_count', 0)}")
    print(f"   orphan_use_rate:    {metrics.get('orphan_use_rate', 0):.1%}")
    # 拆分 orphan_recall_rate (v1.2.4)
    print(f"   unadopted_recall_rate: {metrics.get('unadopted_recall_rate', 0):.1%} (正常业务：窗口内未采用)")
    print(f"   broken_link_recall_rate: {metrics.get('broken_link_recall_rate', 0):.1%} (工程质量：链路缺失)")
    
    # 场景分桶 (v1.2.5)
    print("\n📊 Scenario Buckets (场景分桶)")
    bucket_a = metrics.get('recall_bucket_a', 0)
    bucket_b = metrics.get('recall_bucket_b', 0)
    print(f"   Bucket A (应该被采用): {bucket_a} 条")
    print(f"     unadopted_rate: {metrics.get('unadopted_rate_bucket_a', 0):.1%} (阈值 10%)")
    print(f"   Bucket B (未采用正常): {bucket_b} 条")
    print(f"     unadopted_rate: {metrics.get('unadopted_rate_bucket_b', 0):.1%} (宽松观测)")
    
    # 分版本计数
    print("\n🔢 Version Split (版本分区)")
    print(f"   v1_events: {metrics.get('v1_events', 0)} (recall={metrics.get('v1_recall_count', 0)}, use={metrics.get('v1_use_count', 0)})")
    print(f"   v2_events: {metrics.get('v2_events', 0)} (recall={metrics.get('v2_recall_count', 0)}, use={metrics.get('v2_use_count', 0)})")
    
    # 漂移检测指标 (v1.2.6)
    print("\n📉 Drift Detection (漂移检测)")
    bucket_a_ratio = metrics.get('bucket_a_ratio', 1.0)
    expected_ratio = metrics.get('expected_ratio', 1.0)
    print(f"   bucket_a_ratio:   {bucket_a_ratio:.1%} (A 桶占比)")
    print(f"   expected_ratio:   {expected_ratio:.1%} (expected link 占比)")
    
    # 历史趋势
    if show_history:
        history = load_history(hours=168)
        if history:
            print("\n📉 Trend (Last 7 Days)")
            print("-" * 40)
            
            # 按 6 小时聚合
            buckets = {}
            for record in history:
                ts = datetime.fromisoformat(record["ts"].replace("Z", ""))
                bucket_key = ts.strftime("%Y-%m-%d %H")[:13] + "h"
                if bucket_key not in buckets:
                    buckets[bucket_key] = []
                buckets[bucket_key].append(record)
            
            # 计算每个 bucket 的平均值
            for bucket_key in sorted(buckets.keys())[-12:]:  # 最近 12 个桶
                records = buckets[bucket_key]
                avg_adoption = sum(r["adoption_rate_any"] for r in records) / len(records)
                avg_use_term = sum(r["use_term_p50"] for r in records) / len(records)
                print(f" {bucket_key}: adoption={avg_adoption:.1%} use_term_p50={avg_use_term:.2f}")
    
    print("\n" + "=" * 60)

def health_check() -> Dict:
    """Standard health check for tool_doctor"""
    checks = {
        "events_log_readable": False,
        "metrics_dir_writable": False
    }
    
    # Check events log readable
    try:
        if EVENTS_LOG.exists():
            EVENTS_LOG.read_text()[:100]
        checks["events_log_readable"] = True
    except Exception:
        checks["events_log_readable"] = True  # OK if doesn't exist yet
    
    # Check metrics dir writable
    try:
        METRICS_DIR.mkdir(parents=True, exist_ok=True)
        test_file = METRICS_DIR / ".health_test"
        test_file.write_text("test")
        test_file.unlink()
        checks["metrics_dir_writable"] = True
    except Exception:
        pass
    
    all_healthy = all(checks.values())
    
    return {
        "status": "healthy" if all_healthy else "unhealthy",
        "version": "1.2.8",
        "checks": checks
    }


def sample_call() -> Dict:
    """Sample call for tool_doctor"""
    try:
        events = load_events(hours=24)
        metrics = compute_metrics(events)
        return {
            "status": "ok",
            "sample_result": {
                "ts": datetime.now().isoformat() + "Z",
                "config_hash": get_current_config_hash(),
                **metrics
            }
        }
    except Exception as e:
        return {
            "status": "error",
            "error": {
                "type": "sample_call_error",
                "message": str(e)
            }
        }


def main():
    import argparse
    parser = argparse.ArgumentParser(description="Memory Monitoring Dashboard")
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    parser.add_argument("--history", action="store_true", help="Show historical trends")
    parser.add_argument("--save", action="store_true", help="Save to history")
    parser.add_argument("--health", action="store_true", help="Health check for tool_doctor")
    parser.add_argument("--sample", action="store_true", help="Sample call for tool_doctor")
    args = parser.parse_args()
    
    # Standard interface for tool_doctor
    if args.health:
        result = health_check()
        print(json.dumps(result))
        sys.exit(0 if result["status"] == "healthy" else 1)
    
    if args.sample:
        result = sample_call()
        print(json.dumps(result))
        sys.exit(0 if result["status"] == "ok" else 1)
    
    events = load_events(hours=24)
    metrics = compute_metrics(events)
    
    if args.save:
        save_history(metrics)
    
    if args.json:
        output = {
            "ts": datetime.now().isoformat() + "Z",
            "config_hash": get_current_config_hash(),  # v1.2.8
            **metrics
        }
        print(json.dumps(output, indent=2))
    else:
        print_dashboard(metrics, show_history=args.history)

if __name__ == "__main__":
    main()
