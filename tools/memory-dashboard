    print("=" * 60)
    print("📊 Memory Monitoring Dashboard v1.2.8")
    print("=" * 60)
    print(f"Timestamp: {datetime.now().isoformat()}")
    
    # v1.2.8: config_hash
    config_hash = get_current_config_hash()
    print(f"\n🔧 Config Hash: {config_hash}")
    
    # 部署天数
    days = metrics.get("days_since_deploy", 1)
    phase = metrics.get("threshold_phase", "strict")
    print(f"📅 Deploy Status: Day {days} ({phase} phase)")
    
    # 样本量
    sample_size = metrics.get("sample_size", {})
    is_low_sample = metrics.get("is_low_sample", False)
    print(f"\n📐 Sample Size (样本量)")
    print(f"   events:   {sample_size.get('events', 0)} / {metrics.get('min_events_threshold', 200)}")
    print(f"   sessions: {sample_size.get('sessions', 0)} / {metrics.get('min_sessions_threshold', 20)}")
    
    if is_low_sample:
        print("   ⚠️ LOW_SAMPLE: 样本量不足，指标可能无统计意义")
    
    # 四件套
    print("\n🎯 Core Metrics (四件套)")
    print("-" * 40)
    
    # 1. use_attribution
    threshold = USE_ATTRIBUTION_THRESHOLD
    status = "✅" if metrics["use_attribution"] >= threshold else ("⚠️ LOW_SAMPLE" if is_low_sample else "❌")
    print(f"1. use_attribution:    {metrics['use_attribution']:.1%} {status}")
    print(f"   目标: ≥{threshold:.0%}")
    
    # 2. adoption_rate_any
    print(f"2. adoption_rate_any:  {metrics['adoption_rate_any']:.1%}")
    print(f"   含义: 这次检索最终是否真的用到了记忆")
    
    # 3. uses_per_recall 分布
    print(f"3. uses_per_recall:")
    print(f"   mean: {metrics['uses_per_recall']:.2f}")
    print(f"   p50:  {metrics['uses_per_recall_p50']:.2f}")
    print(f"   p90:  {metrics['uses_per_recall_p90']:.2f}")
    print(f"   含义: 每次检索用了几条记忆")
    
    # 4. use_term_p50
    print(f"4. use_term_p50:       {metrics['use_term_p50']:.2f}")
    print(f"   含义: 常用规则是否开始出现 (从 0 抬升)")
    
    # 辅助信息
    print("\n📈 Support Data")
    print(f"   recall_count:      {metrics['recall_count']}")
    print(f"   use_count:         {metrics['use_count']}")
    print(f"   total_recalls:     {metrics['total_recalls']}")
    print(f"   unique_memories:   {metrics['unique_memories_used']}")
    
    # 口径细化
    print("\n📊 Metric Calibration (口径细化)")
    print(f"   unique_use_count:  {metrics.get('unique_use_count', 0)}")
    print(f"   raw_mentions:      {metrics.get('raw_mentions', 0)}")
    ratio = metrics.get('unique_to_raw_ratio', 1.0)
