#!/usr/bin/env python3
"""
Auto Receipt v1.0 - 子代理完成时自动写入回执

当收到子代理完成消息时，从 WORKFLOW_STATE.json 找到 running 步骤，
自动写入回执。

Usage:
  auto-receipt [--session-key <key>] [--summary "<text>"]
"""

import json
import subprocess
import sys
from pathlib import Path
from datetime import datetime

WORKSPACE = Path.home() / ".openclaw" / "workspace"
WORKFLOW_FILE = WORKSPACE / "WORKFLOW_STATE.json"
INBOX_TOOL = WORKSPACE / "tools" / "subagent-inbox"


def find_running_step():
    """从 WORKFLOW_STATE.json 找到当前 running 的步骤"""
    if not WORKFLOW_FILE.exists():
        return None, None
    
    try:
        with open(WORKFLOW_FILE, 'r') as f:
            state = json.load(f)
        
        for step in state.get('steps', []):
            if step.get('status') == 'running':
                return step, state
        
        return None, state
    except Exception as e:
        print(f"Error reading workflow: {e}", file=sys.stderr)
        return None, None


def write_receipt(task_id, run_id, summary):
    """写入回执"""
    try:
        result = subprocess.run(
            [str(INBOX_TOOL), "write",
             "--task-id", task_id,
             "--run-id", run_id,
             "--status", "completed",
             "--summary", summary],
            capture_output=True, text=True
        )
        return result.returncode == 0
    except Exception as e:
        print(f"Error writing receipt: {e}", file=sys.stderr)
        return False


def main():
    step, state = find_running_step()
    
    if not step:
        print("No running step found", file=sys.stderr)
        sys.exit(0)  # 不是错误，只是没有 running 步骤
    
    task_id = step.get('task_id', '')
    run_id = step.get('run_id', '')
    
    if not task_id:
        # 生成 task_id
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        task_id = f"auto_{timestamp}_{run_id[:8] if run_id else 'unknown'}"
    
    if not run_id:
        run_id = f"auto_{datetime.now().strftime('%H%M%S')}"
    
    summary = "Auto-detected subagent completion"
    
    # 检查命令行参数
    if "--summary" in sys.argv:
        idx = sys.argv.index("--summary")
        if idx + 1 < len(sys.argv):
            summary = sys.argv[idx + 1]
    
    success = write_receipt(task_id, run_id, summary)
    
    result = {
        "action": "receipt_written" if success else "failed",
        "task_id": task_id,
        "run_id": run_id,
        "step_id": step.get('id')
    }
    
    print(json.dumps(result, indent=2))
    sys.exit(0 if success else 1)


if __name__ == "__main__":
    main()
