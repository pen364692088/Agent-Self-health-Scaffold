#!/usr/bin/env python3
"""
Session Archive Tool - 完整归档流程（强制执行所有步骤）

Usage:
    session-archive                    # 完整归档流程
    session-archive --check            # 检查归档状态
    session-archive --dry-run          # 预览将执行的操作

Exit codes:
    0 - 成功
    1 - 部分失败（继续执行）
    2 - 严重失败
"""
import argparse
import json
import os
import subprocess
import sys
from datetime import datetime
from pathlib import Path

WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
MEMORY_DIR = WORKSPACE / "memory"
ARCHIVE_DIR = Path.home() / ".openclaw" / "session-archives"

def run_cmd(cmd, check=True, capture=True):
    """Run shell command."""
    result = subprocess.run(
        cmd, shell=True, capture_output=capture, text=True
    )
    if check and result.returncode != 0:
        raise RuntimeError(f"Command failed: {cmd}\n{result.stderr}")
    return result

def get_today():
    """Get today's date string."""
    return datetime.now().strftime("%Y-%m-%d")

def step_1_check_daily_log(today):
    """Step 1: Ensure daily log exists and has content."""
    daily_log = MEMORY_DIR / f"{today}.md"
    
    if not daily_log.exists():
        return {"status": "missing", "path": str(daily_log), "size": 0}
    
    size = daily_log.stat().st_size
    if size < 100:
        return {"status": "empty", "path": str(daily_log), "size": size}
    
    return {"status": "ok", "path": str(daily_log), "size": size}

def step_2_check_memory_md():
    """Step 2: Check memory.md exists."""
    memory_md = WORKSPACE / "memory.md"  # In workspace root, not memory/
    
    if not memory_md.exists():
        return {"status": "missing", "path": str(memory_md)}
    
    return {"status": "ok", "path": str(memory_md), "size": memory_md.stat().st_size}

def step_3_run_session_indexer():
    """Step 3: Index session logs to SQLite."""
    indexer = WORKSPACE / "tools" / "session-indexer"
    
    if not indexer.exists():
        return {"status": "missing", "tool": str(indexer)}
    
    try:
        result = run_cmd(f"{indexer} --days 1", check=False)
        return {
            "status": "ok",
            "output": result.stdout[:500] if result.stdout else ""
        }
    except Exception as e:
        return {"status": "error", "error": str(e)}

def step_4_run_openviking_archive(today):
    """Step 4: Archive to OpenViking vector DB."""
    script = WORKSPACE / "scripts" / "openviking_archive_entry.py"
    daily_log = MEMORY_DIR / f"{today}.md"
    
    if not script.exists():
        return {"status": "missing", "tool": str(script)}
    
    if not daily_log.exists():
        return {"status": "skipped", "reason": "daily log not found"}
    
    try:
        result = run_cmd(
            f"python3 {script} --daily-log {daily_log} --include-memory-file --json",
            check=False
        )
        
        if result.returncode != 0:
            return {"status": "error", "error": result.stderr[:500]}
        
        # Parse JSON output
        try:
            data = json.loads(result.stdout)
            return {
                "status": "ok",
                "resources": sum(r.get("leaf_count", 0) for r in data.get("results", [])),
                "embed_calls": sum(
                    r.get("cost_estimate", {}).get("embed_calls_est", 0) 
                    for r in data.get("results", [])
                )
            }
        except:
            return {"status": "ok", "raw": result.stdout[:200]}
    except Exception as e:
        return {"status": "error", "error": str(e)}

def step_5_commit_changes(today):
    """Step 5: Commit and push to backup repo."""
    backup_repo = Path.home() / ".openclaw"
    
    try:
        os.chdir(backup_repo)
        
        # Check if there are changes
        result = run_cmd("git status --porcelain", check=False)
        if not result.stdout.strip():
            return {"status": "no_changes", "repo": str(backup_repo)}
        
        # Add and commit
        run_cmd("git add -A")
        commit_msg = f"archive: session {today}"
        run_cmd(f'git commit -m "{commit_msg}"')
        
        # Push
        push_result = run_cmd("git push", check=False)
        if push_result.returncode != 0:
            return {"status": "commit_ok_push_failed", "error": push_result.stderr[:200]}
        
        return {"status": "ok", "commit": commit_msg}
    except Exception as e:
        return {"status": "error", "error": str(e)}

def run_full_archive(dry_run=False):
    """Execute full archive workflow."""
    today = get_today()
    
    print(f"\n{'='*60}")
    print(f"Session Archive: {today}")
    print(f"{'='*60}\n")
    
    results = {}
    errors = []
    
    # Step 1: Check daily log
    print("Step 1: Check daily log...")
    r1 = step_1_check_daily_log(today)
    results["daily_log"] = r1
    if r1["status"] == "missing":
        print(f"  ⚠️  Daily log not found: {r1['path']}")
        errors.append("daily_log_missing")
    elif r1["status"] == "empty":
        print(f"  ⚠️  Daily log too small: {r1['size']} bytes")
        errors.append("daily_log_empty")
    else:
        print(f"  ✅ {r1['path']} ({r1['size']} bytes)")
    
    # Step 2: Check memory.md
    print("\nStep 2: Check memory.md...")
    r2 = step_2_check_memory_md()
    results["memory_md"] = r2
    if r2["status"] == "missing":
        print(f"  ⚠️  memory.md not found")
        errors.append("memory_md_missing")
    else:
        print(f"  ✅ {r2['path']} ({r2['size']} bytes)")
    
    if dry_run:
        print("\n[DRY RUN] Skipping remaining steps...")
        return results
    
    # Step 3: Session indexer
    print("\nStep 3: Index session logs to SQLite...")
    r3 = step_3_run_session_indexer()
    results["session_indexer"] = r3
    if r3["status"] != "ok":
        print(f"  ⚠️  Indexer failed: {r3.get('error', r3.get('status'))}")
        errors.append("session_indexer_failed")
    else:
        print(f"  ✅ Indexed recent sessions")
    
    # Step 4: OpenViking archive
    print("\nStep 4: Archive to OpenViking vector DB...")
    r4 = step_4_run_openviking_archive(today)
    results["openviking"] = r4
    if r4["status"] != "ok":
        print(f"  ⚠️  OpenViking archive: {r4.get('error', r4.get('status'))}")
        errors.append("openviking_failed")
    else:
        print(f"  ✅ Archived {r4.get('resources', '?')} resources")
    
    # Step 5: Git commit
    print("\nStep 5: Commit to backup repo...")
    r5 = step_5_commit_changes(today)
    results["git"] = r5
    if r5["status"] == "no_changes":
        print(f"  ✅ No changes to commit")
    elif r5["status"] != "ok":
        print(f"  ⚠️  Git: {r5.get('error', r5['status'])}")
        errors.append("git_failed")
    else:
        print(f"  ✅ {r5['commit']}")
    
    # Summary
    print(f"\n{'='*60}")
    if errors:
        print(f"Archive completed with warnings: {', '.join(errors)}")
        print(f"{'='*60}\n")
        return {"status": "partial", "errors": errors, "results": results}
    else:
        print("Archive completed successfully ✅")
        print(f"{'='*60}\n")
        return {"status": "ok", "results": results}

def check_archive_status():
    """Check current archive status."""
    today = get_today()
    
    print(f"\n{'='*60}")
    print(f"Archive Status Check: {today}")
    print(f"{'='*60}\n")
    
    # Check each component
    checks = [
        ("Daily Log", step_1_check_daily_log(today)),
        ("Memory.md", step_2_check_memory_md()),
        ("Session Index DB", {"status": "ok" if (WORKSPACE / ".session-index/sessions.db").exists() else "missing"}),
        ("OpenViking Service", {"status": "ok" if run_cmd("pgrep -f openviking", check=False).returncode == 0 else "stopped"}),
    ]
    
    all_ok = True
    for name, result in checks:
        status = "✅" if result.get("status") == "ok" else "⚠️ "
        print(f"  {status} {name}: {result.get('status', 'unknown')}")
        if result.get("status") != "ok":
            all_ok = False
    
    print(f"\n{'='*60}")
    if all_ok:
        print("All systems ready ✅")
    else:
        print("Some systems need attention ⚠️")
    print(f"{'='*60}\n")
    
    return all_ok

def main():
    parser = argparse.ArgumentParser(description="Session Archive Tool")
    parser.add_argument("--check", action="store_true", help="Check archive status only")
    parser.add_argument("--dry-run", action="store_true", help="Preview actions without executing")
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    args = parser.parse_args()
    
    if args.check:
        ok = check_archive_status()
        sys.exit(0 if ok else 1)
    
    result = run_full_archive(dry_run=args.dry_run)
    
    if args.json:
        print(json.dumps(result, indent=2, default=str))
    
    sys.exit(0 if result.get("status") == "ok" else 1)

if __name__ == "__main__":
    main()
