#!/bin/bash
# Session Archive - 使用提炼后的内容归档
# 
# 流程：提炼要点 → 存储到 OpenViking → 提交 git
#
# Usage: session-archive [--check] [--dry-run]

set -e

TOOL_DIR="$(dirname "$0")"
ARCHIVE_WITH_DISTILL="$TOOL_DIR/archive-with-distill"

# 检查参数
if [ "$1" = "--check" ]; then
    echo "Archive status: ready"
    echo "  Tool: $ARCHIVE_WITH_DISTILL"
    exit 0
fi

# 执行归档
if [ "$1" = "--dry-run" ]; then
    "$ARCHIVE_WITH_DISTILL" --dry-run
else
    "$ARCHIVE_WITH_DISTILL" --json
fi
