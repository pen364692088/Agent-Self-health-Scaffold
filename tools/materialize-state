#!/usr/bin/env python3
"""
materialize-state - CLI wrapper for StateMaterializerV0

Materializes state from SESSION-STATE.md and working-buffer.md.

Usage:
  materialize-state [--json] [--schema-validate]
  materialize-state --shadow-compare [--output-dir DIR]
  materialize-state --prompt-preview [--compare-with-main]
  materialize-state --fields
  materialize-state --health

v0 Constraints:
- Reads only SESSION-STATE.md and working-buffer.md (root level)
- No handoff/capsule/summary/distill integration
- No write-back to continuity sources
- No second live state

Phase 2.4:
- Shadow compare with canonical sources (read-only)
- Output compare artifacts
- Does NOT replace bridge state

Phase 2.5:
- Prompt preview from MaterializedState (shadow mode)
- Dual-run compare with main prompt-assemble
- Conflicts NOT silently included in prompt
- Missing blocker explicit warning
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from datetime import datetime
from pathlib import Path
from typing import Any, Dict, Optional

# Add workspace to path
WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
sys.path.insert(0, str(WORKSPACE))

from core.materialized_state_v0 import (
    StateMaterializerV0,
    MaterializedState,
    TRACKED_FIELDS,
)
from core.canonical_adapter import (
    CanonicalAdapter,
    create_shadow_report,
)
from core.prompt_preview import (
    MaterializedStatePromptAssembler,
    DualRunComparator,
    create_shadow_prompt_preview,
)


def get_current_branch() -> Optional[str]:
    """Get current git branch."""
    try:
        result = subprocess.run(
            ["git", "branch", "--show-current"],
            capture_output=True, text=True, cwd=WORKSPACE, timeout=5
        )
        return result.stdout.strip() if result.returncode == 0 else None
    except Exception:
        return None


def validate_against_schema(state_dict: Dict[str, Any]) -> tuple[bool, Optional[str]]:
    """Validate output against JSON schema."""
    try:
        import jsonschema
    except ImportError:
        return False, "jsonschema not installed"
    
    schema_path = WORKSPACE / "schemas" / "materialized_state.v0.schema.json"
    if not schema_path.exists():
        return False, f"Schema not found: {schema_path}"
    
    try:
        schema = json.loads(schema_path.read_text())
        jsonschema.validate(state_dict, schema)
        return True, None
    except jsonschema.ValidationError as e:
        return False, str(e.message)
    except Exception as e:
        return False, str(e)


def save_shadow_compare_artifact(report, output_dir: Path) -> Dict[str, Path]:
    """Save shadow compare report as artifacts."""
    output_dir.mkdir(parents=True, exist_ok=True)
    
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    artifacts = {}
    
    # Full JSON report
    json_path = output_dir / f"shadow_compare_{timestamp}.json"
    report_dict = {
        "generated_at": report.generated_at,
        "coverage": report.coverage,
        "conflicts": report.conflicts,
        "fallbacks": report.fallbacks,
        "warnings": report.warnings,
        "summary": report.summary,
        "field_comparisons": {
            name: {
                "field_name": comp.field_name,
                "bridge_value": comp.bridge_value,
                "canonical_value": comp.canonical_value,
                "bridge_source": comp.bridge_source,
                "canonical_source": comp.canonical_source,
                "match": comp.match,
                "conflict_type": comp.conflict_type
            }
            for name, comp in report.field_comparisons.items()
        },
        "sources": {
            name: {
                "name": s.name,
                "path": s.path,
                "exists": s.exists,
                "last_modified": s.last_modified,
                "record_count": s.record_count
            }
            for name, s in report.sources.items()
        }
    }
    json_path.write_text(json.dumps(report_dict, indent=2, ensure_ascii=False))
    artifacts["json_report"] = json_path
    
    # Human-readable summary
    summary_path = output_dir / f"shadow_compare_{timestamp}.md"
    md_lines = [
        "# Shadow Compare Report",
        "",
        f"**Generated**: {report.generated_at}",
        "",
        "## Summary",
        "",
        f"- **Total Fields Compared**: {report.summary['total_fields_compared']}",
        f"- **Matches**: {report.summary['matches']}",
        f"- **Conflicts**: {report.summary['conflicts']}",
        f"- **Fallbacks Available**: {report.summary['fallbacks_available']}",
        f"- **Bridge Coverage**: {report.summary['bridge_coverage']}/{report.summary['total_fields_compared']}",
        f"- **Canonical Coverage**: {report.summary['canonical_coverage']}/{report.summary['total_fields_compared']}",
        "",
        "## Coverage",
        "",
        f"- **Both sources**: {', '.join(report.coverage['both']) or 'None'}",
        f"- **Bridge only**: {', '.join(report.coverage['bridge_only']) or 'None'}",
        f"- **Canonical only**: {', '.join(report.coverage['canonical_only']) or 'None'}",
        f"- **Neither**: {', '.join(report.coverage['neither']) or 'None'}",
        "",
        "## Field Comparisons",
        "",
    ]
    
    for name, comp in report.field_comparisons.items():
        match_icon = "✅" if comp.match else "❌"
        md_lines.append(f"### {name}: {match_icon}")
        md_lines.append(f"- **Bridge**: {comp.bridge_value or 'N/A'} ({comp.bridge_source or 'N/A'})")
        md_lines.append(f"- **Canonical**: {comp.canonical_value or 'N/A'} ({comp.canonical_source or 'N/A'})")
        if comp.conflict_type:
            md_lines.append(f"- **Conflict Type**: {comp.conflict_type}")
        md_lines.append("")
    
    if report.conflicts:
        md_lines.append("## Conflicts")
        md_lines.append("")
        for c in report.conflicts:
            md_lines.append(f"- **{c['field']}**:")
            md_lines.append(f"  - Bridge: `{c['bridge_value']}` ({c['bridge_source']})")
            md_lines.append(f"  - Canonical: `{c['canonical_value']}` ({c['canonical_source']})")
        md_lines.append("")
    
    if report.fallbacks:
        md_lines.append("## Available Fallbacks")
        md_lines.append("")
        for f in report.fallbacks:
            md_lines.append(f"- **{f['field']}**: `{f['canonical_value']}` from {f['canonical_source']}")
        md_lines.append("")
    
    if report.warnings:
        md_lines.append("## Warnings")
        md_lines.append("")
        for w in report.warnings:
            md_lines.append(f"- {w}")
        md_lines.append("")
    
    summary_path.write_text("\n".join(md_lines))
    artifacts["md_summary"] = summary_path
    
    return artifacts


def run_main_prompt_assemble(session_id: str) -> Optional[Dict[str, Any]]:
    """Run main prompt-assemble chain."""
    prompt_assemble = WORKSPACE / "tools" / "prompt-assemble"
    active_state = WORKSPACE / "artifacts" / "active_state.json"
    raw_history = WORKSPACE / "artifacts" / "session_history" / f"{session_id}" / "raw.jsonl"
    
    if not prompt_assemble.exists():
        return None
    
    # Try with default paths
    try:
        result = subprocess.run(
            [str(prompt_assemble), "--session-id", session_id, "--dry-run", "--json"],
            capture_output=True, text=True, timeout=30
        )
        if result.returncode == 0:
            return json.loads(result.stdout)
    except Exception:
        pass
    
    return None


def save_prompt_preview_artifacts(preview_dict, compare_dict, output_dir: Path) -> Dict[str, Path]:
    """Save prompt preview artifacts."""
    output_dir.mkdir(parents=True, exist_ok=True)
    
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    artifacts = {}
    
    # Preview JSON
    preview_path = output_dir / f"prompt_preview_{timestamp}.json"
    preview_path.write_text(json.dumps(preview_dict, indent=2, ensure_ascii=False))
    artifacts["preview_json"] = preview_path
    
    # Compare JSON (if available)
    if compare_dict:
        compare_path = output_dir / f"dual_run_compare_{timestamp}.json"
        compare_path.write_text(json.dumps(compare_dict, indent=2, ensure_ascii=False))
        artifacts["compare_json"] = compare_path
    
    # Human-readable summary
    summary_path = output_dir / f"prompt_preview_{timestamp}.md"
    md_lines = [
        "# Prompt Preview (Shadow Mode)",
        "",
        f"**Generated**: {preview_dict['generated_at']}",
        f"**Prompt Tokens**: {preview_dict['prompt_tokens']}",
        "",
        "## ⚠️ Shadow Mode Notice",
        "",
        "This is a SHADOW preview. It does NOT replace the main prompt chain.",
        "Use for comparison and quality assessment only.",
        "",
        "## Layers",
        "",
    ]
    
    for name, layer in preview_dict.get("layers", {}).items():
        md_lines.append(f"### {name}")
        md_lines.append(f"- **Tokens**: {layer['tokens']}")
        md_lines.append(f"- **Components**: {', '.join(layer['components']) or 'None'}")
        md_lines.append("")
    
    if preview_dict.get("warnings"):
        md_lines.append("## ⚠️ Warnings")
        md_lines.append("")
        for w in preview_dict["warnings"]:
            md_lines.append(f"- {w}")
        md_lines.append("")
    
    if preview_dict.get("conflicts"):
        md_lines.append("## Conflicts Detected")
        md_lines.append("")
        md_lines.append("**Note**: Conflicts are NOT included in prompt by default.")
        md_lines.append("")
        for c in preview_dict["conflicts"]:
            md_lines.append(f"- **{c['field']}**: bridge=`{c['bridge_value']}` vs conflict=`{c['conflict_value']}`")
        md_lines.append("")
    
    if preview_dict.get("uncertainty_flag"):
        md_lines.append("## 🚨 Uncertainty Flag")
        md_lines.append("")
        md_lines.append("Critical fields are missing. Review materialized state.")
        md_lines.append("")
    
    # Add dual-run comparison if available
    if compare_dict:
        md_lines.append("---")
        md_lines.append("")
        md_lines.append("# Dual-Run Comparison")
        md_lines.append("")
        
        metrics = compare_dict.get("quality_metrics", {})
        md_lines.append("## Quality Metrics")
        md_lines.append("")
        completeness = metrics.get("completeness", {})
        md_lines.append(f"- **Completeness Score**: {completeness.get('score', 0):.1%}")
        md_lines.append(f"- **Present Fields**: {', '.join(completeness.get('present', [])) or 'None'}")
        md_lines.append(f"- **Missing Fields**: {', '.join(completeness.get('missing', [])) or 'None'}")
        md_lines.append("")
        
        consistency = metrics.get("consistency", {})
        md_lines.append(f"- **Consistency**: {'✅' if consistency.get('consistent') else '❌'}")
        md_lines.append(f"- **Token Ratio**: {consistency.get('token_ratio', 0):.2f}")
        md_lines.append("")
        
        if compare_dict.get("recommendations"):
            md_lines.append("## Recommendations")
            md_lines.append("")
            for r in compare_dict["recommendations"]:
                md_lines.append(f"- {r}")
            md_lines.append("")
    
    summary_path.write_text("\n".join(md_lines))
    artifacts["summary_md"] = summary_path
    
    return artifacts


def main():
    parser = argparse.ArgumentParser(
        description="Materialize state from continuity sources",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  materialize-state --json           # Output as JSON
  materialize-state --shadow-compare # Compare with canonical sources
  materialize-state --prompt-preview # Generate prompt preview (shadow mode)
  materialize-state --prompt-preview --compare-with-main  # Compare with main chain
  materialize-state --fields         # Show tracked fields
  materialize-state --health         # Health check
"""
    )
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    parser.add_argument("--schema-validate", action="store_true", help="Validate against JSON schema")
    parser.add_argument("--shadow-compare", action="store_true", help="Compare with canonical sources (shadow mode)")
    parser.add_argument("--prompt-preview", action="store_true", help="Generate prompt preview from MaterializedState")
    parser.add_argument("--compare-with-main", action="store_true", help="Compare with main prompt-assemble chain")
    parser.add_argument("--output-dir", type=str, help="Output directory for artifacts")
    parser.add_argument("--session-id", type=str, default="default", help="Session ID for prompt preview")
    parser.add_argument("--fields", action="store_true", help="Show tracked fields")
    parser.add_argument("--health", action="store_true", help="Health check")
    parser.add_argument("--workspace", type=str, help="Workspace path (default: ~/.openclaw/workspace)")
    
    args = parser.parse_args()
    
    # Override workspace if specified
    if args.workspace:
        global WORKSPACE
        WORKSPACE = Path(args.workspace).expanduser().resolve()
        sys.path.insert(0, str(WORKSPACE))
    
    # Health check
    if args.health:
        result = {
            "status": "healthy",
            "workspace": str(WORKSPACE),
            "session_state_exists": (WORKSPACE / "SESSION-STATE.md").exists(),
            "working_buffer_exists": (WORKSPACE / "working-buffer.md").exists(),
            "canonical_sources": {
                "run_state": (WORKSPACE / "state" / "durable_execution" / "RUN_STATE.json").exists(),
                "task_ledger": (WORKSPACE / "TASK_LEDGER.jsonl").exists(),
            },
            "prompt_assemble_exists": (WORKSPACE / "tools" / "prompt-assemble").exists()
        }
        print(json.dumps(result))
        return 0
    
    # Show tracked fields
    if args.fields:
        print("Tracked fields:")
        for f in TRACKED_FIELDS:
            print(f"  - {f}")
        return 0
    
    # Materialize state
    session_state_path = WORKSPACE / "SESSION-STATE.md"
    working_buffer_path = WORKSPACE / "working-buffer.md"
    
    materializer = StateMaterializerV0(
        session_state_path=session_state_path,
        working_buffer_path=working_buffer_path
    )
    
    branch = get_current_branch()
    state = materializer.materialize(branch=branch)
    state_dict = state.to_dict()
    
    # Prompt preview
    if args.prompt_preview:
        preview = create_shadow_prompt_preview(state_dict, session_id=args.session_id)
        preview_dict = preview.to_dict()
        
        compare_dict = None
        if args.compare_with_main:
            main_chain = run_main_prompt_assemble(args.session_id)
            if main_chain:
                comparator = DualRunComparator()
                compare = comparator.compare(main_chain, preview)
                compare_dict = compare.to_dict()
        
        output_dir = Path(args.output_dir) if args.output_dir else WORKSPACE / "artifacts" / "prompt_preview"
        artifacts = save_prompt_preview_artifacts(preview_dict, compare_dict, output_dir)
        
        result = {
            "prompt_preview": preview_dict,
            "artifacts": {k: str(v) for k, v in artifacts.items()}
        }
        
        if compare_dict:
            result["dual_run_compare"] = compare_dict
        
        print(json.dumps(result, indent=2, ensure_ascii=False))
        return 0
    
    # Shadow compare
    if args.shadow_compare:
        report = create_shadow_report(state_dict, workspace_path=WORKSPACE)
        
        output_dir = Path(args.output_dir) if args.output_dir else WORKSPACE / "artifacts" / "shadow_compare"
        artifacts = save_shadow_compare_artifact(report, output_dir)
        
        # Output summary
        result = {
            "shadow_compare": {
                "generated_at": report.generated_at,
                "summary": report.summary,
                "coverage": report.coverage,
                "conflicts_count": len(report.conflicts),
                "fallbacks_count": len(report.fallbacks),
                "warnings_count": len(report.warnings),
                "artifacts": {
                    "json_report": str(artifacts["json_report"]),
                    "md_summary": str(artifacts["md_summary"])
                }
            },
            "bridge_state": state_dict
        }
        
        print(json.dumps(result, indent=2, ensure_ascii=False))
        return 0
    
    # Schema validation
    if args.schema_validate:
        valid, error = validate_against_schema(state_dict)
        if not valid:
            print(f"Schema validation failed: {error}", file=sys.stderr)
            return 1
        state_dict["_schema_validated"] = True
    
    # Output
    if args.json or True:
        print(json.dumps(state_dict, indent=2, ensure_ascii=False))
    else:
        # Human-readable output
        print(f"Objective: {state.objective or 'N/A'}")
        print(f"Phase: {state.phase or 'N/A'}")
        print(f"Branch: {state.branch or 'N/A'}")
        print(f"Blocker: {state.blocker or 'None'}")
        print(f"Next Step: {state.next_step or 'N/A'}")
        print(f"Uncertainty: {state.uncertainty_flag}")
        print(f"Sources: {', '.join(state.sources_checked)}")
    
    return 0


if __name__ == "__main__":
    sys.exit(main())
