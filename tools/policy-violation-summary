#!/usr/bin/env python3
"""
Policy Violation Structure Summary
从计数转向分布分析
"""
import argparse
import json
import sys
from datetime import datetime, timezone, timedelta
from pathlib import Path
from collections import defaultdict

WORKSPACE = Path('/home/moonlight/.openclaw/workspace')
VIOLATIONS_DIR = WORKSPACE / 'artifacts' / 'execution_policy' / 'violations'

def now_iso():
    return datetime.now(timezone.utc).isoformat()

def parse_jsonl(path):
    if not path.exists():
        return []
    records = []
    try:
        with path.open('r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if line:
                    try:
                        records.append(json.loads(line))
                    except:
                        pass
    except:
        pass
    return records

def generate_summary(hours=24):
    """Generate structured violation summary."""
    cutoff = datetime.now(timezone.utc) - timedelta(hours=hours)
    
    # Structure data
    by_rule = defaultdict(int)
    by_decision = defaultdict(int)
    by_path = defaultdict(int)
    by_task = defaultdict(int)
    
    deny_count = 0
    warn_count = 0
    reroute_count = 0
    allow_count = 0
    
    fallback_success = 0
    fallback_failed = 0
    false_positive_count = 0
    repeat_offenders = defaultdict(int)
    
    all_records = []
    
    if VIOLATIONS_DIR.exists():
        for jsonl_file in VIOLATIONS_DIR.glob('*.jsonl'):
            for record in parse_jsonl(jsonl_file):
                try:
                    ts_str = record.get('timestamp', '')
                    if ts_str:
                        ts = datetime.fromisoformat(ts_str.replace('Z', '+00:00'))
                        if ts < cutoff:
                            continue
                    
                    all_records.append(record)
                    
                    rule_id = record.get('rule_id', 'unknown')
                    decision = record.get('decision', 'unknown')
                    path = record.get('path', 'unknown')
                    task_id = record.get('task_id', 'unknown')
                    
                    by_rule[rule_id] += 1
                    by_decision[decision] += 1
                    
                    if path != 'unknown':
                        by_path[path] += 1
                    if task_id != 'unknown':
                        by_task[task_id] += 1
                    
                    if decision == 'deny':
                        deny_count += 1
                        if record.get('fallback_used'):
                            if record.get('fallback_success'):
                                fallback_success += 1
                            else:
                                fallback_failed += 1
                    elif decision == 'warn':
                        warn_count += 1
                    elif decision == 'reroute':
                        reroute_count += 1
                    elif decision == 'allow':
                        allow_count += 1
                    
                    if record.get('false_positive'):
                        false_positive_count += 1
                    
                    # Track repeat offenders
                    key = f"{rule_id}:{path}"
                    repeat_offenders[key] += 1
                    
                except Exception as e:
                    pass
    
    # Sort and limit
    top_rules = sorted(by_rule.items(), key=lambda x: -x[1])[:10]
    top_paths = sorted(by_path.items(), key=lambda x: -x[1])[:10]
    top_tasks = sorted(by_task.items(), key=lambda x: -x[1])[:5]
    top_repeat = sorted(repeat_offenders.items(), key=lambda x: -x[1])[:10]
    
    # Calculate rates
    total_deny_with_fallback = fallback_success + fallback_failed
    fallback_success_rate = (
        fallback_success / total_deny_with_fallback * 100 
        if total_deny_with_fallback > 0 else None
    )
    
    warn_followed = sum(1 for r in all_records 
                       if r.get('decision') == 'warn' and r.get('warn_followed'))
    warn_total = warn_count
    warn_follow_rate = warn_followed / warn_total * 100 if warn_total > 0 else None
    
    return {
        'timestamp': now_iso(),
        'window_hours': hours,
        'summary': {
            'total_violations': len(all_records),
            'by_decision': {
                'deny': deny_count,
                'warn': warn_count,
                'reroute': reroute_count,
                'allow': allow_count
            }
        },
        'distribution': {
            'top_rule_ids': [{'rule_id': r, 'count': c} for r, c in top_rules],
            'top_paths': [{'path': p, 'count': c} for p, c in top_paths],
            'top_tasks': [{'task_id': t, 'count': c} for t, c in top_tasks],
            'repeat_offenders': [{'key': k, 'count': c} for k, c in top_repeat if c > 1]
        },
        'effectiveness': {
            'fallback_success_count': fallback_success,
            'fallback_failed_count': fallback_failed,
            'fallback_success_rate': fallback_success_rate,
            'warn_followed_count': warn_followed,
            'warn_follow_rate': warn_follow_rate,
            'suspected_false_positive_count': false_positive_count
        },
        'sample_maturity': {
            'deny_samples': deny_count,
            'warn_samples': warn_count,
            'fallback_samples': total_deny_with_fallback,
            'has_minimum_samples': deny_count >= 5 and warn_count >= 10
        }
    }

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument('--hours', type=int, default=24)
    ap.add_argument('--json', action='store_true')
    args = ap.parse_args()
    
    summary = generate_summary(args.hours)
    
    if args.json:
        print(json.dumps(summary, indent=2, ensure_ascii=False))
    else:
        print(f"=== Violation Structure Summary ({args.hours}h) ===\n")
        
        s = summary['summary']
        print(f"Total: {s['total_violations']}")
        print(f"  Deny: {s['by_decision']['deny']}")
        print(f"  Warn: {s['by_decision']['warn']}")
        print(f"  Reroute: {s['by_decision']['reroute']}")
        print(f"  Allow: {s['by_decision']['allow']}")
        
        print(f"\nTop Rules:")
        for r in summary['distribution']['top_rule_ids'][:5]:
            print(f"  {r['rule_id']}: {r['count']}")
        
        print(f"\nTop Paths:")
        for p in summary['distribution']['top_paths'][:5]:
            print(f"  {p['path']}: {p['count']}")
        
        eff = summary['effectiveness']
        print(f"\nEffectiveness:")
        print(f"  Fallback success: {eff['fallback_success_count']}")
        print(f"  Fallback success rate: {eff['fallback_success_rate']:.1f}%" if eff['fallback_success_rate'] else "  Fallback success rate: N/A")
        print(f"  False positives: {eff['suspected_false_positive_count']}")
        
        mat = summary['sample_maturity']
        print(f"\nSample Maturity:")
        print(f"  Minimum samples met: {'✅' if mat['has_minimum_samples'] else '❌'}")
        print(f"  Deny samples: {mat['deny_samples']} (need 5)")
        print(f"  Warn samples: {mat['warn_samples']} (need 10)")
    
    return 0

if __name__ == '__main__':
    sys.exit(main())
