runner.test("citation_enforcement", test_citation_enforcement)

# ========== 工程测试 ==========

def test_idempotency_sweeper():
    events = [{"m": "m1"} for _ in range(5)]
    state = {}
    for e in events:
        state[e["m"]] = state.get(e["m"], 0) + 1
    assert state["m1"] == 5

runner.test("idempotency_sweeper", test_idempotency_sweeper)

def test_lock_contention():
    import tempfile, fcntl
    lock = Path(tempfile.mktemp(suffix=".lock"))
    ok = False
    try:
        with open(lock, "w") as f:
            fcntl.flock(f.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
            ok = True
            fcntl.flock(f.fileno(), fcntl.LOCK_UN)
    except:
        pass
    assert ok
    lock.unlink(missing_ok=True)

runner.test("lock_contention", test_lock_contention)

def test_schema_backward_compat():
    old = {"event": "use"}
    new = {"schema_version": "1.1", "event": "use"}
    assert old.get("schema_version", "1.0") == "1.0"
    assert new.get("schema_version") == "1.1"

runner.test("schema_backward_compat", test_schema_backward_compat)

