runner.test("scope_leak_prevention", test_scope_leak_prevention)

# ========== E2E 测试 ==========

def test_e2e_event_id_includes_session():
    """验证 event_id 包含 session, 不同 session 同句纠正不误判为重复"""
    def gen_id(e):
        canonical = json.dumps({
            "event": e.get("event"),
            "session_id": e.get("session_id"),
            "task_id": e.get("task_id"),
            "text": e.get("text", "").lower(),
        }, sort_keys=True)
        return hashlib.sha256(canonical.encode()).hexdigest()[:16]
    
    e1 = {"event": "correction", "session_id": "s1", "task_id": "t1", "text": "Use X"}
    e2 = {"event": "correction", "session_id": "s2", "task_id": "t2", "text": "Use X"}
    e3 = {"event": "correction", "session_id": "s1", "task_id": "t1", "text": "Use X"}  # 重复
    
    id1, id2, id3 = gen_id(e1), gen_id(e2), gen_id(e3)
    
    assert id1 != id2, "不同 session 应该生成不同 id"
    assert id1 == id3, "相同 session/task 应该生成相同 id"

runner.test("e2e_event_id_includes_session", test_e2e_event_id_includes_session)

def test_e2e_shadow_mode():
    normal = [{"source": "user"}]
    shadow = [{"source": "self_improving"}]
    use_count = len(normal)
    shadow_count = len(shadow)
    assert use_count == 1
    assert shadow_count == 1

runner.test("e2e_shadow_mode", test_e2e_shadow_mode)

def test_e2e_canary_scope():
    """验证 canary: 只对白名单 scope 评分"""
    config = {
        "score_scope_allowlist": ["projects/openemotion"],
    }
    
    def should_score(scope):
        allowlist = config.get("score_scope_allowlist", [])
        if not allowlist:
            return True
        return any(scope.startswith(allowed) for allowed in allowlist)
    
    # 白名单内的 scope 参与评分
    assert should_score("projects/openemotion")
    assert should_score("projects/openemotion/submodule")
    
    # 白名单外的 scope 不参与评分
    assert not should_score("projects/other")
    assert not should_score("test")

runner.test("e2e_canary_scope", test_e2e_canary_scope)

def test_e2e_daily_cap():
    """验证每日上限"""
    config = {"max_corrections_per_entry_per_day": 3}
    
    daily_corrections = {"m1": 3}  # 已达上限
    
    def can_add(entry_id):
        current = daily_corrections.get(entry_id, 0)
        return current < config["max_corrections_per_entry_per_day"]
    
    assert not can_add("m1"), "超过每日上限应拒绝"
    assert can_add("m2"), "未达上限应允许"

runner.test("e2e_daily_cap", test_e2e_daily_cap)

