#!/usr/bin/env python3
"""
Memory Governance Test Suite v1.3
包含: 基础测试 + 工程测试 + E2E测试 + Canary测试
"""

import math
import json
import hashlib
from pathlib import Path

class TestRunner:
    def __init__(self):
        self.passed = 0
        self.failed = 0
    
    def test(self, name: str, func):
        try:
            func()
            self.passed += 1
            print(f"✓ {name}")
        except AssertionError as e:
            self.failed += 1
            print(f"✗ {name}: {e}")
    
    def summary(self):
        total = self.passed + self.failed
        print(f"\n{'='*50}")
        print(f"Tests: {self.passed}/{total} passed")
        print(f"{'='*50}")
        return self.failed == 0

runner = TestRunner()

# ========== 基础测试 ==========

def test_promotion_score():
    def score(u, d, i, c):
        HALF_LIFE = 14
        recency = math.exp(-d / HALF_LIFE) if d >= 0 else 1
        return round(2*math.log(u+1) + 1.5*recency + 3*i - 2*c, 2)
    assert score(50, 0, 0.9, 0) >= 7
    s = score(3, 5, 0.5, 0)
    assert 3 <= s < 7
    assert score(0, 90, 0.3, 1) < 3

runner.test("promotion_score", test_promotion_score)

def test_correction_to_rule():
    corrections = [{"session_id": f"s{i}"} for i in range(3)]
    assert len(set(c["session_id"] for c in corrections)) >= 3

runner.test("correction_to_rule", test_correction_to_rule)

def test_privacy_filter():
    import re
    patterns = [r"password[:\s]+"]
    assert any(re.search(p, "password: x", re.I) for p in patterns)

runner.test("privacy_filter", test_privacy_filter)

def test_citation_enforcement():
