#!/bin/bash
# Session Continuity v1.1.1a Daily Observation Check
# Dual-layer metrics: Raw events + Unique coverage

set -e

WORKSPACE="$HOME/.openclaw/workspace"
EVENTS_FILE="$WORKSPACE/state/session_continuity_events.jsonl"
HEALTH_FILE="$WORKSPACE/artifacts/session_continuity/v1_1_1/HEALTH_SUMMARY.md"
LAST_CHECK="$WORKSPACE/state/continuity_last_check"
WAL_FILE="$WORKSPACE/state/wal/session_state_wal.jsonl"
METRICS_FILE="$WORKSPACE/state/daily_metrics.json"

# Check if daily check needed
TODAY=$(date +%Y-%m-%d)
if [ -f "$LAST_CHECK" ]; then
    LAST_DATE=$(cat "$LAST_CHECK")
    if [ "$LAST_DATE" = "$TODAY" ]; then
        exit 0
    fi
fi

# Parse events
~/.openclaw/workspace/tools/parse-continuity-events

# Read metrics
if [ -f "$METRICS_FILE" ]; then
    RAW_RECOVERY=$(jq -r '.raw.recovery_success // 0' "$METRICS_FILE")
    RAW_HANDOFF=$(jq -r '.raw.handoff_created // 0' "$METRICS_FILE")
    RAW_HIGH_CTX=$(jq -r '.raw.high_context_trigger // 0' "$METRICS_FILE")
    RAW_INTERRUPTION=$(jq -r '.raw.interruption_recovery // 0' "$METRICS_FILE")
    RAW_UNCERTAINTY=$(jq -r '.raw.recovery_uncertainty // 0' "$METRICS_FILE")
    RAW_CONFLICT=$(jq -r '.raw.conflict_resolution_applied // 0' "$METRICS_FILE")
    RAW_FAILURE=$(jq -r '.raw.recovery_failure // 0' "$METRICS_FILE")
    RAW_GATE=$(jq -r '.raw.gate_completed // 0' "$METRICS_FILE")
    RAW_TASK_CLOSE=$(jq -r '.raw.task_ready_to_close // 0' "$METRICS_FILE")
    
    UNIQUE_SESSIONS_RECOVERED=$(jq -r '.unique_sessions.recovery_success // 0' "$METRICS_FILE")
    UNIQUE_SESSIONS_HANDOFF=$(jq -r '.unique_sessions.handoff_created // 0' "$METRICS_FILE")
    UNIQUE_SESSIONS_HIGH_CTX=$(jq -r '.unique_sessions.high_context_trigger // 0' "$METRICS_FILE")
    UNIQUE_SESSIONS_INTERRUPTION=$(jq -r '.unique_sessions.interruption_recovery // 0' "$METRICS_FILE")
    
    UNIQUE_HANDOFF_IDS=$(jq -r '.unique_handoff_ids // 0' "$METRICS_FILE")
    UNIQUE_CONFLICT_IDS=$(jq -r '.unique_conflict_ids // 0' "$METRICS_FILE")
    UNIQUE_GATE_IDS=$(jq -r '.unique_gate_ids // 0' "$METRICS_FILE")
    TOTAL_EVENTS=$(jq -r '.total_events // 0' "$METRICS_FILE")
    
    SEMANTICS_VERSION=$(jq -r '.by_semantics_version | keys[0] // "unknown"' "$METRICS_FILE")
else
    RAW_RECOVERY=0
    RAW_HANDOFF=0
    RAW_HIGH_CTX=0
    RAW_INTERRUPTION=0
    RAW_UNCERTAINTY=0
    RAW_CONFLICT=0
    RAW_FAILURE=0
    RAW_GATE=0
    RAW_TASK_CLOSE=0
    UNIQUE_SESSIONS_RECOVERED=0
    UNIQUE_SESSIONS_HANDOFF=0
    UNIQUE_SESSIONS_HIGH_CTX=0
    UNIQUE_SESSIONS_INTERRUPTION=0
    UNIQUE_HANDOFF_IDS=0
    UNIQUE_CONFLICT_IDS=0
    UNIQUE_GATE_IDS=0
    TOTAL_EVENTS=0
    SEMANTICS_VERSION="unknown"
fi

# WAL status
WAL_ENTRIES=0
if [ -f "$WAL_FILE" ]; then
    WAL_ENTRIES=$(wc -l < "$WAL_FILE" | tr -d ' ')
fi

# Calculate rates
TOTAL_RECOVERY_ATTEMPTS=$((RAW_RECOVERY + RAW_FAILURE))
if [ $TOTAL_RECOVERY_ATTEMPTS -gt 0 ]; then
    SUCCESS_RATE=$(awk "BEGIN {printf \"%.1f\", $RAW_RECOVERY * 100 / $TOTAL_RECOVERY_ATTEMPTS}")
else
    SUCCESS_RATE="N/A"
fi

if [ $RAW_RECOVERY -gt 0 ]; then
    UNCERTAINTY_RATE=$(awk "BEGIN {printf \"%.1f\", $RAW_UNCERTAINTY * 100 / $RAW_RECOVERY}")
else
    UNCERTAINTY_RATE="N/A"
fi

# Determine risk level
if [ $RAW_FAILURE -gt 0 ]; then
    RISK_LEVEL="🔴 High"
elif [ $RAW_UNCERTAINTY -gt 2 ]; then
    RISK_LEVEL="🟡 Medium"
else
    RISK_LEVEL="🟢 Low"
fi

# Update HEALTH_SUMMARY.md
cat > "$HEALTH_FILE" << EOF
# Session Continuity v1.1.1a Health Summary

**Version**: v1.1.1a  
**Mode**: GUARDED STABLE  
**Updated**: $(date -Iseconds)  
**Semantics**: $SEMANTICS_VERSION

---

## Wiring Status

**Overall**: ✅ OPERATIONAL

| Module | Status |
|--------|--------|
| Main agent | ✅ PASS |
| cc-godmode | ✅ PASS |
| handoff | ✅ PASS |
| compaction | ✅ PASS |
| Gate A/B/C | ✅ PASS |
| heartbeat/daily | ✅ PASS |

---

## Current Status

| Dimension | Status | Details |
|-----------|--------|---------|
| **Overall** | ✅ HEALTHY | All modules operational |
| Recovery | ✅ Working | ${RAW_RECOVERY} recoveries |
| WAL | ✅ Active | ${WAL_ENTRIES} entries |
| Event Log | ✅ Active | ${TOTAL_EVENTS} events |

---

## Raw Event Metrics

| Event Type | Count |
|------------|-------|
| recovery_success | ${RAW_RECOVERY} |
| handoff_created | ${RAW_HANDOFF} |
| high_context_trigger | ${RAW_HIGH_CTX} |
| interruption_recovery | ${RAW_INTERRUPTION} |
| recovery_uncertainty | ${RAW_UNCERTAINTY} |
| conflict_resolution_applied | ${RAW_CONFLICT} |
| recovery_failure | ${RAW_FAILURE} |
| gate_completed | ${RAW_GATE} |
| task_ready_to_close | ${RAW_TASK_CLOSE} |

---

## Unique / Coverage Metrics

| Metric | Count |
|--------|-------|
| unique_sessions_recovered | ${UNIQUE_SESSIONS_RECOVERED} |
| unique_sessions_with_handoff | ${UNIQUE_SESSIONS_HANDOFF} |
| unique_sessions_high_context | ${UNIQUE_SESSIONS_HIGH_CTX} |
| unique_sessions_interruption_recovered | ${UNIQUE_SESSIONS_INTERRUPTION} |
| unique_handoff_ids | ${UNIQUE_HANDOFF_IDS} |
| unique_conflict_cases | ${UNIQUE_CONFLICT_IDS} |
| unique_gate_ids | ${UNIQUE_GATE_IDS} |

---

## Derived Rates

| Rate | Value | Target |
|------|-------|--------|
| Recovery Success Rate | ${SUCCESS_RATE}% | > 95% |
| Uncertainty Rate | ${UNCERTAINTY_RATE}% | < 10% |

---

## Rollout Coverage Progress

| Target | Metric | Current | Status |
|--------|--------|---------|--------|
| ≥10 session recoveries | unique_sessions_recovered | ${UNIQUE_SESSIONS_RECOVERED} | $([ ${UNIQUE_SESSIONS_RECOVERED} -ge 10 ] && echo "✅" || echo "⏳") |
| ≥5 handoffs | raw_handoff_created | ${RAW_HANDOFF} | $([ ${RAW_HANDOFF} -ge 5 ] && echo "✅" || echo "⏳") |
| ≥3 high-context | unique_sessions_high_context | ${UNIQUE_SESSIONS_HIGH_CTX} | $([ ${UNIQUE_SESSIONS_HIGH_CTX} -ge 3 ] && echo "✅" || echo "⏳") |
| ≥2 interruptions | raw_interruption_recovery | ${RAW_INTERRUPTION} | $([ ${RAW_INTERRUPTION} -ge 2 ] && echo "✅" || echo "⏳") |

---

## WAL Status

\`\`\`
Location: state/wal/session_state_wal.jsonl
Entries: ${WAL_ENTRIES}
Status: ✅ Normal
\`\`\`

---

## Risk Assessment

**Current Risk Level**: ${RISK_LEVEL}

---

## Next Review

**Date**: $(date -d "+1 day" +%Y-%m-%d 2>/dev/null || date -v+1d +%Y-%m-%d)

---

*Auto-updated by heartbeat daily check (v1.1.1a).*
EOF

# Mark check done
echo "$TODAY" > "$LAST_CHECK"

echo "Daily check: recovery=${RAW_RECOVERY}, handoff=${RAW_HANDOFF}, gate=${RAW_GATE}, total=${TOTAL_EVENTS}"
