    print(f"  事件 1: run_id={event1.get('run_id')}, workflow={event1.get('workflow_id')}")
    print(f"  事件 2: run_id={event2.get('run_id')}, workflow={event2.get('workflow_id')}")
    
    # 验证：两个事件都是独立的
    if (event1.get('run_id') and event2.get('run_id') and
        event1.get('run_id') != event2.get('run_id')):
        print("  ✅ 测试通过：多 workflow 并行推进互不干扰")
        result = True
    else:
        print("  ❌ 测试失败：事件处理异常")
        result = False
    
    # 清理
    wf1_file.unlink(missing_ok=True)
    wf2_file.unlink(missing_ok=True)
    
    return result


def main():
    print("=" * 60)
    print("Path B 验收测试")
    print("=" * 60)
    
    backup()
    
    try:
        tests = [
            ("事件先到、state 后到", test_event_before_state),
            ("事件丢失", test_event_lost),
            ("事件风暴", test_event_storm),
            ("多 workflow 并行", test_multi_workflow),
        ]
        
        passed = 0
        failed = 0
        
        for name, test_fn in tests:
            try:
                if test_fn():
                    passed += 1
                else:
                    failed += 1
            except Exception as e:
                print(f"❌ {name}: Exception - {e}")
                import traceback
                traceback.print_exc()
                failed += 1
            
            # 每个测试后清理
            restore()
        
        print("\n" + "=" * 60)
        print(f"结果: {passed} passed, {failed} failed")
        print("=" * 60)
        
        return 0 if failed == 0 else 1
    
    finally:
        restore()


if __name__ == "__main__":
    sys.exit(main())
