#!/usr/bin/env python3
"""
Project Check Phase Worker

Executes a single phase and produces artifacts:
- status.json
- summary.md  
- raw.log

Usage:
  project-check-phase <check_id> <phase_id>
  project-check-phase repo-snapshot    # Standalone phase
  project-check-phase --health
"""

import sys
import json
import subprocess
import argparse
from datetime import datetime
from pathlib import Path

ARTIFACTS_BASE = Path.home() / ".openclaw" / "workspace" / "artifacts" / "project_check"


def run_command(cmd, cwd=None, timeout=300):
    """Run command and capture output."""
    result = {
        "returncode": None,
        "stdout": "",
        "stderr": "",
        "timed_out": False
    }
    
    try:
        proc = subprocess.run(
            cmd,
            cwd=cwd,
            capture_output=True,
            text=True,
            timeout=timeout
        )
        result["returncode"] = proc.returncode
        result["stdout"] = proc.stdout
        result["stderr"] = proc.stderr
    except subprocess.TimeoutExpired:
        result["timed_out"] = True
    
    return result


def phase_repo_snapshot(phase_dir, repo_path, timeout=60):
    """Phase A: Repo Snapshot."""
    started = datetime.utcnow()
    raw_log = []
    metrics = {}
    
    # Check git status
    raw_log.append("=== Git Status ===")
    result = run_command(["git", "status", "--short"], cwd=repo_path, timeout=30)
    raw_log.append(result["stdout"])
    raw_log.append(result["stderr"])
    metrics["dirty_files"] = len([l for l in result["stdout"].strip().split("\n") if l])
    
    # Check branch/commit
    raw_log.append("\n=== Branch/Commit ===")
    result = run_command(["git", "rev-parse", "--abbrev-ref", "HEAD"], cwd=repo_path)
    branch = result["stdout"].strip()
    raw_log.append(f"Branch: {branch}")
    
    result = run_command(["git", "rev-parse", "HEAD"], cwd=repo_path)
    commit = result["stdout"].strip()[:12]
    raw_log.append(f"Commit: {commit}")
    
    # Check critical paths
    raw_log.append("\n=== Critical Paths ===")
    critical_paths = [".github/workflows", "tests", "scripts"]
    missing = []
    for p in critical_paths:
        path = Path(repo_path) / p
        exists = path.exists()
        raw_log.append(f"{p}: {'✅' if exists else '❌'}")
        if not exists:
            missing.append(p)
    metrics["missing_paths"] = missing
    
    # Determine OK
    ok = len(missing) == 0 and metrics["dirty_files"] < 100  # Allow some dirty files
    
    # Write artifacts
    finished = datetime.utcnow()
    
    status = {
        "phase": "phase_a_repo",
        "state": "done",
        "ok": ok,
        "started_at": started.isoformat() + "Z",
        "finished_at": finished.isoformat() + "Z",
        "inputs": {"repo_path": repo_path},
        "metrics": metrics,
        "artifacts": {"summary": "summary.md", "raw_log": "raw.log"},
        "next_action": "phase_b_tests" if ok else "STOP: repo issues"
    }
    
    if not ok:
        status["error"] = {
            "code": "REPO_ISSUES",
            "message": f"Missing paths: {missing}, dirty files: {metrics['dirty_files']}"
        }
    
    summary = f"""# Repo Snapshot

**Status**: {'✅ OK' if ok else '❌ ISSUES FOUND'}

## Details

- Branch: `{branch}`
- Commit: `{commit}`
- Dirty files: {metrics['dirty_files']}
- Missing paths: {missing or 'None'}

## Raw Log

See `raw.log`
"""
    
    with open(phase_dir / "raw.log", "w") as f:
        f.write("\n".join(raw_log))
    
    with open(phase_dir / "summary.md", "w") as f:
        f.write(summary)
    
    with open(phase_dir / "status.json", "w") as f:
        json.dump(status, f, indent=2)
    
    return status


def phase_fast_tests(phase_dir, repo_path, timeout=300):
    """Phase B: Fast Tests."""
    started = datetime.utcnow()
    raw_log = []
    metrics = {}
    
    # Run pytest
    raw_log.append("=== Fast Tests ===")
    result = run_command(
        ["pytest", "-q", "tests/mvp11", "tests/testbot", "--tb=no", "-q"],
        cwd=repo_path,
        timeout=timeout
    )
    raw_log.append(result["stdout"])
    raw_log.append(result["stderr"])
    
    # Parse results
    stdout = result["stdout"]
    if "passed" in stdout:
        # Extract counts
        import re
        match = re.search(r"(\d+) passed", stdout)
        metrics["tests_passed"] = int(match.group(1)) if match else 0
        match = re.search(r"(\d+) failed", stdout)
        metrics["tests_failed"] = int(match.group(1)) if match else 0
        match = re.search(r"(\d+) error", stdout)
        metrics["tests_error"] = int(match.group(1)) if match else 0
    else:
        metrics["tests_passed"] = 0
        metrics["tests_failed"] = 0
        metrics["tests_error"] = 0 if result["returncode"] == 0 else 1
    
    ok = metrics["tests_failed"] == 0 and metrics["tests_error"] == 0 and result["returncode"] == 0
    
    finished = datetime.utcnow()
    
    status = {
        "phase": "phase_b_tests",
        "state": "done",
        "ok": ok,
        "started_at": started.isoformat() + "Z",
        "finished_at": finished.isoformat() + "Z",
        "inputs": {"repo_path": repo_path},
        "metrics": metrics,
        "artifacts": {"summary": "summary.md", "raw_log": "raw.log"},
        "next_action": "phase_c_testbot" if ok else "STOP: tests failed"
    }
    
    if not ok:
        status["error"] = {
            "code": "TEST_FAILURE",
            "message": f"Failed: {metrics['tests_failed']}, Errors: {metrics['tests_error']}"
        }
    
    summary = f"""# Fast Tests

**Status**: {'✅ PASS' if ok else '❌ FAIL'}

## Results

- Passed: {metrics.get('tests_passed', 0)}
- Failed: {metrics.get('tests_failed', 0)}
- Errors: {metrics.get('tests_error', 0)}

## Raw Log

See `raw.log`
"""
    
    with open(phase_dir / "raw.log", "w") as f:
        f.write("\n".join(raw_log))
    
    with open(phase_dir / "summary.md", "w") as f:
        f.write(summary)
    
    with open(phase_dir / "status.json", "w") as f:
        json.dump(status, f, indent=2)
    
    return status


