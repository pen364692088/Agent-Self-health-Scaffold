def phase_aggregate(phase_dir, artifacts_dir, repo_path, timeout=60):
    """Phase E: Final Aggregation."""
    import json
    from pathlib import Path
    
    started = datetime.utcnow()
    raw_log = []
    
    # Read all phase statuses
    manifest_path = artifacts_dir / "manifest.json"
    with open(manifest_path) as f:
        manifest = json.load(f)
    
    phase_statuses = {}
    for phase in manifest["phases"]:
        phase_id = phase["id"]
        status_path = artifacts_dir / phase_id / "status.json"
        if status_path.exists():
            with open(status_path) as f:
                phase_statuses[phase_id] = json.load(f)
    
    raw_log.append("=== Phase Statuses ===")
    raw_log.append(json.dumps(phase_statuses, indent=2))
    
    # Determine overall OK
    all_ok = all(s.get("ok", False) for s in phase_statuses.values())
    
    # Generate final report
    final_dir = artifacts_dir / "final"
    final_dir.mkdir(parents=True, exist_ok=True)
    
    final_status = {
        "check_id": manifest["check_id"],
        "ok": all_ok,
        "repo": manifest["repo"],
        "phases": phase_statuses,
        "started_at": started.isoformat() + "Z",
        "finished_at": datetime.utcnow().isoformat() + "Z"
    }
    
    one_liner = "✅ ALL CHECKS PASSED" if all_ok else "❌ CHECKS FAILED"
    
    report = f"""# Project Check Report

**Status**: {one_liner}

**Check ID**: {manifest['check_id']}

**Repo**: {manifest['repo'].get('path', 'N/A')}
**Branch**: {manifest['repo'].get('branch', 'N/A')}
**Commit**: {manifest['repo'].get('commit', 'N/A')}

## Phase Results

"""
    for phase_id, status in phase_statuses.items():
        icon = "✅" if status.get("ok") else "❌"
        report += f"- {icon} **{phase_id}**: {status.get('state', 'unknown')}\n"
    
    # Write final artifacts
    with open(final_dir / "FINAL_CHECK_STATUS.json", "w") as f:
        json.dump(final_status, f, indent=2)
    
    with open(final_dir / "FINAL_CHECK_REPORT.md", "w") as f:
        f.write(report)
    
    with open(final_dir / "one_liner.txt", "w") as f:
        f.write(one_liner)
    
    with open(phase_dir / "raw.log", "w") as f:
        f.write("\n".join(raw_log))
    
    with open(phase_dir / "summary.md", "w") as f:
        f.write(report)
    
    status = {
        "phase": "phase_e_final",
        "state": "done",
        "ok": True,
        "started_at": started.isoformat() + "Z",
        "finished_at": datetime.utcnow().isoformat() + "Z",
        "artifacts": {
            "final_status": "final/FINAL_CHECK_STATUS.json",
            "report": "final/FINAL_CHECK_REPORT.md",
            "one_liner": "final/one_liner.txt"
        }
    }
    
    with open(phase_dir / "status.json", "w") as f:
        json.dump(status, f, indent=2)
    
    return status


def cmd_health(args):
    """Health check."""
    print(json.dumps({"status": "healthy", "version": "1.0.0"}))


def main():
    parser = argparse.ArgumentParser(description="Project Check Phase Worker")
    parser.add_argument("--health", action="store_true", help="Health check")
    parser.add_argument("check_id", nargs="?", help="Check ID")
    parser.add_argument("phase_id", nargs="?", help="Phase ID")
    
    args = parser.parse_args()
    
    if args.health:
        cmd_health(args)
        return
    
    if not args.check_id or not args.phase_id:
        print("ERROR: check_id and phase_id required", file=sys.stderr)
        sys.exit(1)
    
    # Load manifest
    manifest_path = ARTIFACTS_BASE / args.check_id / "manifest.json"
    if not manifest_path.exists():
        print(f"ERROR: Check not found: {args.check_id}", file=sys.stderr)
        sys.exit(1)
    
    with open(manifest_path) as f:
        manifest = json.load(f)
    
    artifacts_dir = Path(manifest["artifacts_dir"])
    phase_dir = artifacts_dir / args.phase_id
    phase_dir.mkdir(parents=True, exist_ok=True)
    repo_path = manifest["repo"]["path"]
    
    # Execute phase
    phase_handlers = {
        "phase_a_repo": lambda: phase_repo_snapshot(phase_dir, repo_path),
        "phase_b_tests": lambda: phase_fast_tests(phase_dir, repo_path),
        "phase_c_testbot": lambda: phase_testbot_e2e(phase_dir, repo_path),
        "phase_d_gate": lambda: phase_hard_gate(phase_dir, repo_path),
        "phase_e_final": lambda: phase_aggregate(phase_dir, artifacts_dir, repo_path),
    }
    
    handler = phase_handlers.get(args.phase_id)
    if not handler:
        print(f"ERROR: Unknown phase: {args.phase_id}", file=sys.stderr)
        sys.exit(1)
    
    print(f"Running phase: {args.phase_id}")
    status = handler()
    
    print(f"Phase complete: {status['state']}")
    print(f"OK: {status['ok']}")
    
    if not status["ok"]:
        sys.exit(1)

if __name__ == "__main__":
    main()
