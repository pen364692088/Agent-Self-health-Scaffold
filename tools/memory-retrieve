DAILY_SUMMARY_FILE = MEMORY_ROOT / "daily_summaries.jsonl"

# ============== CONSTANTS ==============
STAGE2_MAX_DOCS = 5
STAGE2_MIN_SCORE = 0.4  # 降低阈值以适应实际向量相似度分布
SAMPLING_RATE = 0.1  # 10% sampling for normal queries
LATENCY_THRESHOLD_MS = 1000  # ms, for anomaly detection

# Match type weights for sorting
MATCH_TYPE_PRIORITY = {
    "exact": 3,
    "phrase": 2,
    "keyword": 1
}

# ============== Helper Functions ==============

def load_tombstones() -> Set[str]:
    tombstones = set()
    if TOMBSTONES_FILE.exists():
        for line in TOMBSTONES_FILE.read_text().strip().split("\n"):
            if not line.strip() or line.startswith("#"):
                continue
            try:
                entry = json.loads(line)
                if "doc_id" in entry:
                    tombstones.add(entry["doc_id"])
                if "sha256" in entry:
                    tombstones.add(entry["sha256"])
            except:
                pass
    return tombstones


def load_doc_metadata() -> Dict[str, Dict]:
    metadata = {}
    if METADATA_FILE.exists():
        for line in METADATA_FILE.read_text().strip().split("\n"):
            if not line.strip() or line.startswith("#"):
                continue
            try:
                entry = json.loads(line)
                if "doc_id" in entry:
                    metadata[entry["doc_id"]] = entry
            except:
                pass
    return metadata


