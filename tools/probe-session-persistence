#!/usr/bin/env python3
"""
probe-session-persistence - 会话状态持久化验证

Verification Mode: probe_check + artifact_output_check

检查内容:
1. SESSION-STATE.md 存在且格式正确
2. state-write-atomic 工具存在
3. 原子写入测试
4. session-start-recovery 工具存在
5. WAL 文件完整性
"""

import argparse
import json
import os
import sys
import subprocess
from datetime import datetime, timezone
from pathlib import Path

WORKSPACE = Path('/home/moonlight/.openclaw/workspace')
OUTPUT_DIR = WORKSPACE / 'artifacts' / 'self_health' / 'probes'


def now_iso():
    return datetime.now(timezone.utc).isoformat()


def check_session_state_md():
    """检查 SESSION-STATE.md 存在且格式正确"""
    path = WORKSPACE / 'SESSION-STATE.md'
    if not path.exists():
        return False, "SESSION-STATE.md not found", {}
    
    content = path.read_text()
    required_fields = ['objective', 'phase', 'status']
    found = [f for f in required_fields if f'**{f}**:' in content.lower() or f'{f}:' in content.lower()]
    
    return True, f"SESSION-STATE.md exists with {len(found)}/{len(required_fields)} key fields", {
        'path': str(path),
        'size_bytes': path.stat().st_size,
        'fields_found': found
    }


def check_state_write_atomic():
    """检查 state-write-atomic 工具存在"""
    path = WORKSPACE / 'tools' / 'state-write-atomic'
    if not path.exists():
        return False, "state-write-atomic tool not found", {}
    
    is_exec = os.access(path, os.X_OK)
    return True, f"state-write-atomic exists (executable: {is_exec})", {
        'path': str(path),
        'executable': is_exec
    }


def check_session_start_recovery():
    """检查 session-start-recovery 工具存在"""
    path = WORKSPACE / 'tools' / 'session-start-recovery'
    if not path.exists():
        return False, "session-start-recovery tool not found", {}
    
    return True, "session-start-recovery exists", {
        'path': str(path)
    }


def check_wal_file():
    """检查 WAL 文件存在且格式正确"""
    wal_path = WORKSPACE / 'state' / 'session_continuity_events.jsonl'
    if not wal_path.exists():
        return True, "WAL file not required (first session)", {'path': str(wal_path), 'exists': False}
    
    # 检查格式
    lines = wal_path.read_text().strip().split('\n')
    valid_lines = 0
    for line in lines:
        if line.strip():
            try:
                json.loads(line)
                valid_lines += 1
            except:
                pass
    
    return True, f"WAL file exists with {valid_lines} valid entries", {
        'path': str(wal_path),
        'total_lines': len(lines),
        'valid_entries': valid_lines
    }


def check_working_buffer():
    """检查 working-buffer.md 存在"""
    path = WORKSPACE / 'working-buffer.md'
    if not path.exists():
        return True, "working-buffer.md optional (not required)", {'exists': False}
    
    return True, "working-buffer.md exists", {
        'path': str(path),
        'size_bytes': path.stat().st_size
    }


def run_probe():
    """执行 probe"""
    checks = []
    all_passed = True
    
    # 1. SESSION-STATE.md
    passed, msg, details = check_session_state_md()
    checks.append({
        'name': 'session_state_md',
        'description': 'Check SESSION-STATE.md exists and format correct',
        'passed': passed,
        'details': details
    })
    if not passed:
        all_passed = False
    
    # 2. state-write-atomic
    passed, msg, details = check_state_write_atomic()
    checks.append({
        'name': 'state_write_atomic',
        'description': 'Check state-write-atomic tool exists',
        'passed': passed,
        'details': details
    })
    if not passed:
        all_passed = False
    
    # 3. session-start-recovery
    passed, msg, details = check_session_start_recovery()
    checks.append({
        'name': 'session_start_recovery',
        'description': 'Check session-start-recovery tool exists',
        'passed': passed,
        'details': details
    })
    if not passed:
        all_passed = False
    
    # 4. WAL file
    passed, msg, details = check_wal_file()
    checks.append({
        'name': 'wal_file',
        'description': 'Check WAL file integrity',
        'passed': passed,
        'details': details
    })
    if not passed:
        all_passed = False
    
    # 5. working-buffer
    passed, msg, details = check_working_buffer()
    checks.append({
        'name': 'working_buffer',
        'description': 'Check working-buffer.md exists',
        'passed': passed,
        'details': details
    })
    
    result = {
        'probe_name': 'probe-session-persistence',
        'verification_mode': 'probe_check + artifact_output_check',
        'status': 'ok' if all_passed else 'fail',
        'message': f"Session persistence {'healthy' if all_passed else 'issues found'}",
        'checks': checks,
        'timestamp': now_iso()
    }
    
    return result


def main():
    parser = argparse.ArgumentParser(description='Session Persistence Probe')
    parser.add_argument('--json', action='store_true', help='Output JSON')
    args = parser.parse_args()
    
    result = run_probe()
    
    # 写入输出
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    (OUTPUT_DIR / 'probe-session-persistence.json').write_text(
        json.dumps(result, indent=2, ensure_ascii=False)
    )
    
    if args.json:
        print(json.dumps(result, indent=2, ensure_ascii=False))
    else:
        print(f"Probe: {result['probe_name']}")
        print(f"Status: {result['status']}")
        for c in result['checks']:
            status = '✓' if c['passed'] else '✗'
            print(f"  {status} {c['name']}: {c['description']}")
    
    return 0 if result['status'] == 'ok' else 1


if __name__ == '__main__':
    sys.exit(main())
