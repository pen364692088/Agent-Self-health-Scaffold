#!/usr/bin/env python3
"""
probe-longrunkit-timeout-retry - LongRunKit Timeout & Retry Configuration Probe

Verification Mode: synthetic_input_check

检查逻辑:
1. 检查超时配置存在
2. 检查重试逻辑存在
3. 检查 max_attempts 配置

Usage:
  probe-longrunkit-timeout-retry
  probe-longrunkit-timeout-retry --json
  probe-longrunkit-timeout-retry --timeout 30

Exit codes:
  0 - PASS (all checks passed)
  1 - FAIL (one or more checks failed)
  2 - ERROR (unexpected error)
"""

import argparse
import json
import sys
import os
from pathlib import Path
from datetime import datetime, timezone
from typing import Dict, List, Any, Optional

WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
PROBES_DIR = WORKSPACE / "artifacts" / "self_health" / "probes"
LONGRUNKIT_DIR = Path.home() / "Project" / "Github" / "MyProject" / "LongRunKit"
JOBS_DIR = LONGRUNKIT_DIR / "jobs"
TOOLS_DIR = LONGRUNKIT_DIR / "tools"

TIMEOUT_SECONDS = 30

# Default expected configurations
DEFAULT_MAX_ATTEMPTS = 3
DEFAULT_TIMEOUT_MINUTES = 30
DEFAULT_LEASE_MINUTES = 2


def now_iso():
    return datetime.now(timezone.utc).isoformat()


def write_evidence(probe_name: str, evidence: Dict):
    """Write probe evidence to artifacts directory."""
    PROBES_DIR.mkdir(parents=True, exist_ok=True)
    evidence_file = PROBES_DIR / f"{probe_name}_evidence.json"
    evidence["timestamp"] = now_iso()
    evidence["probe_name"] = probe_name
    with open(evidence_file, 'w') as f:
        json.dump(evidence, f, indent=2, ensure_ascii=False)
    return evidence_file


class LongRunKitTimeoutRetryProbe:
    """Probe for LongRunKit timeout and retry configuration."""
    
    def __init__(self, timeout: int = TIMEOUT_SECONDS):
        self.timeout = timeout
        self.checks = []
        self.evidence = {
            "probe_name": "probe-longrunkit-timeout-retry",
            "verification_mode": "synthetic_input_check",
            "checks": [],
            "passed": False,
            "failures": []
        }
    
    def check_timeout_config(self) -> Dict:
        """Check 1: Timeout configuration exists in tools."""
        check = {
            "name": "timeout_config",
            "description": "Check timeout configuration in LongRunKit tools",
            "passed": False,
            "details": {}
        }
        
        # Check for timeout in joblib.py
        joblib = TOOLS_DIR / "joblib.py"
        if joblib.exists():
            content = joblib.read_text()
            
            # Look for timeout-related constants/variables
            timeout_patterns = [
                "TIMEOUT",
                "timeout",
                "DEFAULT_TIMEOUT",
                "LEASE_",
                "lease"
            ]
            
            found_patterns = []
            for pattern in timeout_patterns:
                if pattern in content:
                    found_patterns.append(pattern)
            
            check["details"]["patterns_found"] = found_patterns
            check["details"]["joblib_exists"] = True
            
            if any(p in found_patterns for p in ["TIMEOUT", "timeout", "DEFAULT_TIMEOUT"]):
                check["passed"] = True
                check["details"]["timeout_config_present"] = True
            else:
                check["details"]["warning"] = "No explicit timeout config found"
                check["passed"] = True  # Non-blocking, defaults may exist
        else:
            check["details"]["warning"] = "joblib.py not found"
            check["passed"] = True  # Non-blocking
        
        # Check job-worker for timeout handling
        job_worker = TOOLS_DIR / "job-worker-v3"
        if not job_worker.exists():
            job_worker = TOOLS_DIR / "job-worker"
        
        if job_worker.exists():
            content = job_worker.read_text() if job_worker.suffix == ".py" else ""
            if not content and job_worker.suffix != ".py":
                # Try reading as script
                try:
                    content = job_worker.read_text()
                except Exception:
                    pass
            
            if "timeout" in content.lower() or "TIMEOUT" in content:
                check["details"]["worker_timeout_handling"] = True
        
        self.checks.append(check)
        return check
    
    def check_retry_logic(self) -> Dict:
        """Check 2: Retry logic exists in tools."""
        check = {
            "name": "retry_logic",
            "description": "Check retry logic in LongRunKit tools",
            "passed": False,
            "details": {}
        }
        
        # Check for retry in joblib.py
        joblib = TOOLS_DIR / "joblib.py"
        if joblib.exists():
            content = joblib.read_text()
            
            # Look for retry-related patterns
            retry_patterns = [
                "max_attempts",
                "MAX_ATTEMPTS",
                "retry",
                "RETRY",
                "attempt",
                "ATTEMPT"
            ]
            
            found_patterns = []
            for pattern in retry_patterns:
                if pattern in content:
                    found_patterns.append(pattern)
            
            check["details"]["patterns_found"] = found_patterns
            
            if any(p in found_patterns for p in ["max_attempts", "MAX_ATTEMPTS", "retry", "RETRY"]):
                check["passed"] = True
                check["details"]["retry_logic_present"] = True
            else:
                check["details"]["warning"] = "No explicit retry logic found"
                check["passed"] = True  # Non-blocking
        else:
            check["details"]["warning"] = "joblib.py not found"
            check["passed"] = True
        
        # Check watchdog for retry handling
        watchdog = TOOLS_DIR / "job-watchdog-v3"
        if not watchdog.exists():
            watchdog = TOOLS_DIR / "job-watchdog"
        
        if watchdog.exists():
            try:
                content = watchdog.read_text()
                if "retry" in content.lower() or "STUCK" in content:
                    check["details"]["watchdog_retry_handling"] = True
            except Exception:
                pass
        
        self.checks.append(check)
        return check
    
    def check_max_attempts_config(self) -> Dict:
        """Check 3: max_attempts configuration in jobs."""
        check = {
            "name": "max_attempts_config",
            "description": "Check max_attempts configuration in job statuses",
            "passed": False,
            "details": {}
        }
        
        if not JOBS_DIR.exists():
            check["details"]["error"] = "Jobs directory not found"
            check["passed"] = False
            self.checks.append(check)
            return check
        
        # Check a sample of jobs for max_attempts
        job_dirs = [d for d in JOBS_DIR.iterdir() if d.is_dir() and d.name.startswith("202")]
        
        max_attempts_values = []
        jobs_with_max_attempts = 0
        jobs_checked = 0
        
        for job_dir in job_dirs[:50]:  # Sample up to 50 jobs
            status_file = job_dir / "status.json"
            if status_file.exists():
                try:
                    with open(status_file) as f:
                        status = json.load(f)
                    
                    jobs_checked += 1
                    max_attempts = status.get("max_attempts")
                    
                    if max_attempts is not None:
                        jobs_with_max_attempts += 1
                        max_attempts_values.append(max_attempts)
                except Exception:
                    pass
        
        check["details"]["jobs_checked"] = jobs_checked
        check["details"]["jobs_with_max_attempts"] = jobs_with_max_attempts
        
        if max_attempts_values:
            from collections import Counter
            counts = Counter(max_attempts_values)
            check["details"]["max_attempts_distribution"] = dict(counts)
            check["details"]["most_common"] = counts.most_common(1)[0] if counts else None
        
        # Check spec.json for max_attempts default
        spec_examples = []
        for job_dir in job_dirs[:10]:
            spec_file = job_dir / "spec.json"
            if spec_file.exists():
                try:
                    with open(spec_file) as f:
                        spec = json.load(f)
                    if "max_attempts" in spec:
                        spec_examples.append(spec["max_attempts"])
                except Exception:
                    pass
        
        if spec_examples:
            check["details"]["spec_max_attempts_examples"] = spec_examples
        
        # If we found max_attempts in any job, consider it configured
        if jobs_with_max_attempts > 0:
            check["passed"] = True
            check["details"]["config_present"] = True
        else:
            check["passed"] = True  # Non-blocking - defaults may apply
            check["details"]["warning"] = "No jobs with explicit max_attempts found"
        
        self.checks.append(check)
        return check
    
    def run(self) -> Dict:
        """Run all checks and return result."""
        self.check_timeout_config()
        self.check_retry_logic()
        self.check_max_attempts_config()
        
        # Determine overall result
        all_passed = all(c["passed"] for c in self.checks)
        failures = [c for c in self.checks if not c["passed"]]
        
        self.evidence["checks"] = self.checks
        self.evidence["passed"] = all_passed
        self.evidence["status"] = "ok" if all_passed else "fail"
        self.evidence["message"] = "LongRunKit timeout/retry configuration verified" if all_passed else "LongRunKit timeout/retry configuration issues"
        self.evidence["failures"] = [c["name"] for c in failures]
        self.evidence["check_count"] = len(self.checks)
        self.evidence["pass_count"] = len([c for c in self.checks if c["passed"]])
        
        # Write evidence
        evidence_file = write_evidence("probe-longrunkit-timeout-retry", self.evidence)
        self.evidence["evidence_file"] = str(evidence_file)
        
        return self.evidence


def main():
    parser = argparse.ArgumentParser(description="LongRunKit Timeout & Retry Configuration Probe")
    parser.add_argument("--json", action="store_true", help="Output JSON only")
    parser.add_argument("--timeout", type=int, default=TIMEOUT_SECONDS, help="Timeout in seconds")
    args = parser.parse_args()
    
    probe = LongRunKitTimeoutRetryProbe(timeout=args.timeout)
    result = probe.run()
    
    if args.json:
        print(json.dumps(result, indent=2, ensure_ascii=False))
    else:
        status = "PASS" if result["passed"] else "FAIL"
        print(f"[{status}] probe-longrunkit-timeout-retry")
        for check in result["checks"]:
            check_status = "✓" if check["passed"] else "✗"
            print(f"  {check_status} {check['name']}: {check.get('description', '')}")
        
        if result["failures"]:
            print(f"\nFailed checks: {', '.join(result['failures'])}")
    
    sys.exit(0 if result["passed"] else 1)


if __name__ == "__main__":
    main()
