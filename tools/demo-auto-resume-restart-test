#!/usr/bin/env python3
from __future__ import annotations
import json, os, subprocess, sys, time
from datetime import datetime
from pathlib import Path

W = Path('/home/moonlight/.openclaw/workspace')
ART = W / 'artifacts' / 'auto_resume_demo'
TRACE = ART / 'trace.jsonl'
WF = W / 'WORKFLOW_STATE.json'
RUN_STATE = W / 'state' / 'durable_execution' / 'RUN_STATE.json'
CFG = W / 'state' / 'durable_execution' / 'AUTO_RESUME_CONFIG.json'
AUTO_LOG = W / 'artifacts' / 'auto_resume' / 'recovery_log.jsonl'
RUNTIME = W / 'state' / 'durable_execution' / 'AUTO_RESUME_RUNTIME.json'
RESTART_UNIT = 'openclaw-demo-restart-gateway.service'

ART.mkdir(parents=True, exist_ok=True)


def log(event, **kw):
    row = {'ts': datetime.now().isoformat(), 'event': event, **kw}
    with TRACE.open('a', encoding='utf-8') as f:
        f.write(json.dumps(row, ensure_ascii=False) + '\n')
    print(json.dumps(row, ensure_ascii=False), flush=True)


def write_json(p: Path, data):
    p.parent.mkdir(parents=True, exist_ok=True)
    tmp = p.with_suffix(p.suffix + '.tmp')
    tmp.write_text(json.dumps(data, ensure_ascii=False, indent=2))
    tmp.replace(p)


def schedule_restart(delay_s: int = 60):
    cmd = [
        'systemd-run', '--user', '--unit', RESTART_UNIT,
        '--on-active', f'{delay_s}s',
        '/bin/bash', '-lc', 'systemctl --user restart openclaw-gateway'
    ]
    r = subprocess.run(cmd, capture_output=True, text=True)
    log('restart_scheduled', delay_s=delay_s, rc=r.returncode, stdout=r.stdout.strip(), stderr=r.stderr.strip())
    if r.returncode != 0:
        raise SystemExit(f'failed scheduling restart: {r.stderr}')


def main():
    log('test_start')
    # ensure auto-resume enabled
    cfg = {
        'enabled': True,
        'cooldown_seconds': 15,
        'lease_ttl_seconds': 180,
        'max_recovery_attempts_per_target': 3,
        'task_overrides': {}
    }
    write_json(CFG, cfg)
    log('config_written', path=str(CFG))

    # phase 1: active work before restart
    wf = {
        'active': True,
        'workflow_type': 'serial',
        'workflow_id': 'auto_resume_demo_3min',
        'steps': [
            {'id': 'phase1', 'task': 'demo phase1', 'model': 'gpt', 'status': 'done'},
            {'id': 'phase2', 'task': 'demo phase2 after restart', 'model': 'gpt', 'status': 'pending'},
            {'id': 'phase3', 'task': 'demo phase3 final', 'model': 'gpt', 'status': 'pending', 'auto_resume': True},
        ],
        'notify_on_done': 'auto resume demo done',
        'created_at': datetime.now().isoformat(),
        'updated_at': datetime.now().isoformat(),
    }
    write_json(WF, wf)
    write_json(RUN_STATE, {
        'version': 1,
        'updated_at': datetime.now().isoformat(),
        'status': 'running',
        'hard_block': False,
        'hard_block_reason': None,
        'resume_action': 'spawn_pending',
        'next_step': {'id': 'phase2'},
        'last_checkpoint': {
            'label': 'demo_pre_restart_checkpoint',
            'summary': 'phase1 done; phase2 pending before planned restart',
            'next_step': 'phase2',
            'status': 'running',
            'hard_block': False,
            'error_type': None,
            'ts': datetime.now().isoformat(),
        },
        'workflow': {
            'exists': True,
            'active': True,
            'workflow_type': 'serial',
            'pending_steps': [{'id': 'phase2'}, {'id': 'phase3'}],
            'running_steps': [],
            'done_steps': [{'id': 'phase1'}],
            'failed_steps': [],
            'notify_on_done': 'auto resume demo done',
            'updated_at': datetime.now().isoformat(),
        },
        'orchestrator': {'exists': True, 'pending_count': 0, 'completed_count': 0, 'pending_tasks': []},
        'unfinished_tasks': {'workflow_pending': [{'id': 'phase2'}, {'id': 'phase3'}], 'workflow_running': [], 'ledger': [], 'orchestrator_pending': []},
        'recovery_hint': {'should_auto_continue': True, 'requires_user_input': False},
    })
    log('durable_state_written', workflow=str(WF), run_state=str(RUN_STATE))

    schedule_restart(60)

    # 3-minute observation loop
    for i in range(6):
        time.sleep(30)
        auto_tail = []
        if AUTO_LOG.exists():
            auto_tail = AUTO_LOG.read_text().splitlines()[-5:]
        runtime = {}
        if RUNTIME.exists():
            try:
                runtime = json.loads(RUNTIME.read_text())
            except Exception:
                runtime = {'parse_error': True}
        log('tick', minute_mark=(i+1)*0.5, auto_log_tail=auto_tail, runtime=runtime)

    log('test_end')

if __name__ == '__main__':
    main()
