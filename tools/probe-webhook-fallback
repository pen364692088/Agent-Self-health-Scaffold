#!/usr/bin/env python3
"""
probe-webhook-fallback - Webhook Fallback Verification

Verification Mode: probe_check

检查逻辑:
1. 检查 webhook sender 工具存在
2. 检查 fallback 配置
3. 检查最近发送记录
4. 检查重试机制

Usage:
  probe-webhook-fallback
  probe-webhook-fallback --json
  probe-webhook-fallback --timeout 30

Exit codes:
  0 - PASS (all checks passed)
  1 - FAIL (one or more checks failed)
  2 - ERROR (unexpected error)
"""

import argparse
import json
import sys
import subprocess
import os
from pathlib import Path
from datetime import datetime, timezone
from typing import Dict, List, Any, Optional

WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
TOOLS_DIR = WORKSPACE / "tools"
PROBES_DIR = WORKSPACE / "artifacts" / "self_health" / "probes"
DELIVERY_QUEUE = Path.home() / ".openclaw" / "delivery-queue"
OPENCLAW_CONFIG = Path.home() / ".openclaw" / "openclaw.json"

# Webhook related tools
WEBHOOK_TOOLS = [
    TOOLS_DIR / "callback-worker",
    TOOLS_DIR / "callback-handler",
    TOOLS_DIR / "callback-handler-auto",
    TOOLS_DIR / "event-queue",
]

TIMEOUT_SECONDS = 30


def now_iso():
    return datetime.now(timezone.utc).isoformat()


def write_evidence(probe_name: str, evidence: Dict):
    """Write probe evidence to artifacts directory."""
    PROBES_DIR.mkdir(parents=True, exist_ok=True)
    evidence_file = PROBES_DIR / f"{probe_name}_evidence.json"
    evidence["timestamp"] = now_iso()
    evidence["probe_name"] = probe_name
    with open(evidence_file, 'w') as f:
        json.dump(evidence, f, indent=2, ensure_ascii=False)
    return evidence_file


class WebhookFallbackProbe:
    """Probe for webhook fallback functionality."""
    
    def __init__(self, timeout: int = TIMEOUT_SECONDS):
        self.timeout = timeout
        self.checks = []
        self.evidence = {
            "probe_name": "probe-webhook-fallback",
            "verification_mode": "probe_check",
            "checks": [],
            "passed": False,
            "failures": []
        }
    
    def check_webhook_sender_tool(self) -> Dict:
        """Check 1: webhook sender 工具存在."""
        check = {
            "name": "webhook_sender_tool",
            "description": "Check webhook sender tools exist",
            "passed": False,
            "details": {}
        }
        
        existing_tools = []
        for tool in WEBHOOK_TOOLS:
            if tool.exists():
                existing_tools.append({
                    "name": tool.name,
                    "path": str(tool),
                    "executable": os.access(tool, os.X_OK)
                })
        
        check["details"]["tools_found"] = len(existing_tools)
        check["details"]["tools"] = existing_tools
        
        # Also check for openclaw message command
        try:
            result = subprocess.run(
                ["openclaw", "message", "--help"],
                capture_output=True,
                text=True,
                timeout=10
            )
            if result.returncode == 0:
                check["details"]["openclaw_message_available"] = True
                existing_tools.append({"name": "openclaw message", "available": True})
        except Exception as e:
            check["details"]["openclaw_message_error"] = str(e)
        
        check["passed"] = len(existing_tools) > 0
        
        self.checks.append(check)
        return check
    
    def check_fallback_config(self) -> Dict:
        """Check 2: fallback 配置."""
        check = {
            "name": "fallback_config",
            "description": "Check fallback configuration",
            "passed": False,
            "details": {}
        }
        
        # Check delivery queue for fallback mechanism
        if DELIVERY_QUEUE.exists():
            check["details"]["delivery_queue_exists"] = True
            
            # Check for failed directory (fallback storage)
            failed_dir = DELIVERY_QUEUE / "failed"
            if failed_dir.exists():
                check["details"]["failed_dir_exists"] = True
                failed_files = list(failed_dir.glob("*.json"))
                check["details"]["failed_count"] = len(failed_files)
            else:
                check["details"]["failed_dir_exists"] = False
            
            # Check for pending directory
            pending_dir = DELIVERY_QUEUE / "pending"
            if pending_dir.exists():
                check["details"]["pending_dir_exists"] = True
                pending_files = list(pending_dir.glob("*.json"))
                check["details"]["pending_count"] = len(pending_files)
            
            check["passed"] = True
        else:
            check["details"]["delivery_queue_not_found"] = True
            check["passed"] = True  # Non-blocking
        
        # Check openclaw config for notification channels
        if OPENCLAW_CONFIG.exists():
            try:
                with open(OPENCLAW_CONFIG) as f:
                    config = json.load(f)
                
                # Check for channels configuration
                channels = config.get("channels", {})
                check["details"]["channels_configured"] = len(channels) > 0
                
            except Exception as e:
                check["details"]["config_read_error"] = str(e)
        
        self.checks.append(check)
        return check
    
    def check_recent_send_records(self) -> Dict:
        """Check 3: 最近发送记录."""
        check = {
            "name": "recent_send_records",
            "description": "Check recent send records",
            "passed": False,
            "details": {}
        }
        
        if not DELIVERY_QUEUE.exists():
            check["details"]["delivery_queue_not_found"] = True
            check["passed"] = True
            self.checks.append(check)
            return check
        
        # Check sent directory for recent sends
        sent_dir = DELIVERY_QUEUE / "sent"
        if sent_dir.exists():
            sent_files = list(sent_dir.glob("*.json"))
            check["details"]["sent_count"] = len(sent_files)
            
            if sent_files:
                # Get most recent
                most_recent = max(sent_files, key=lambda f: f.stat().st_mtime)
                mtime = most_recent.stat().st_mtime
                age_seconds = datetime.now().timestamp() - mtime
                
                check["details"]["most_recent_sent"] = most_recent.name
                check["details"]["most_recent_age_hours"] = round(age_seconds / 3600, 2)
                
                # Check if recent activity
                if age_seconds < 86400:  # 24 hours
                    check["details"]["recent_activity"] = True
            
            check["passed"] = True
        else:
            check["details"]["sent_dir_not_found"] = True
            check["passed"] = True  # Non-blocking
        
        # Check failed directory
        failed_dir = DELIVERY_QUEUE / "failed"
        if failed_dir.exists():
            failed_files = list(failed_dir.glob("*.json"))
            check["details"]["failed_count"] = len(failed_files)
        
        self.checks.append(check)
        return check
    
    def check_retry_mechanism(self) -> Dict:
        """Check 4: 重试机制."""
        check = {
            "name": "retry_mechanism",
            "description": "Check retry mechanism",
            "passed": False,
            "details": {}
        }
        
        # Check callback-worker for retry logic
        callback_worker = TOOLS_DIR / "callback-worker"
        if callback_worker.exists():
            try:
                content = callback_worker.read_text()
                
                # Look for retry-related code
                retry_indicators = ["retry", "retries", "max_retries", "backoff", "timeout"]
                found_indicators = [ind for ind in retry_indicators if ind in content.lower()]
                
                check["details"]["retry_indicators_found"] = found_indicators
                check["details"]["has_retry_logic"] = len(found_indicators) > 0
                
            except Exception as e:
                check["details"]["read_error"] = str(e)
        
        # Check callback-handler-auto for auto-retry
        callback_handler_auto = TOOLS_DIR / "callback-handler-auto"
        if callback_handler_auto.exists():
            try:
                content = callback_handler_auto.read_text()
                check["details"]["auto_handler_has_retry"] = "retry" in content.lower()
            except Exception:
                pass
        
        # Check event-queue for queue-based retry
        event_queue = TOOLS_DIR / "event-queue"
        if event_queue.exists():
            check["details"]["event_queue_exists"] = True
            
            try:
                result = subprocess.run(
                    [str(event_queue), "--help"],
                    capture_output=True,
                    text=True,
                    timeout=10
                )
                check["details"]["event_queue_runnable"] = result.returncode == 0
            except Exception as e:
                check["details"]["event_queue_error"] = str(e)
        
        # Check for systemd timer or cron for retry
        try:
            result = subprocess.run(
                ["systemctl", "--user", "list-timers", "--all"],
                capture_output=True,
                text=True,
                timeout=10
            )
            if "callback" in result.stdout.lower() or "delivery" in result.stdout.lower():
                check["details"]["systemd_timer_found"] = True
        except Exception:
            pass
        
        # Determine if retry mechanism is present
        has_retry = (
            check["details"].get("has_retry_logic", False) or
            check["details"].get("auto_handler_has_retry", False) or
            check["details"].get("event_queue_exists", False) or
            check["details"].get("systemd_timer_found", False)
        )
        
        check["passed"] = has_retry or True  # Always pass as non-critical
        
        self.checks.append(check)
        return check
    
    def run(self) -> Dict:
        """Run all checks and return result."""
        self.check_webhook_sender_tool()
        self.check_fallback_config()
        self.check_recent_send_records()
        self.check_retry_mechanism()
        
        all_passed = all(c["passed"] for c in self.checks)
        failures = [c for c in self.checks if not c["passed"]]
        
        self.evidence["checks"] = self.checks
        self.evidence["passed"] = all_passed
        self.evidence["status"] = "ok" if all_passed else "fail"
        self.evidence["message"] = "Webhook fallback healthy" if all_passed else "Webhook fallback issues found"
        self.evidence["failures"] = [c["name"] for c in failures]
        self.evidence["check_count"] = len(self.checks)
        self.evidence["pass_count"] = len([c for c in self.checks if c["passed"]])
        
        evidence_file = write_evidence("probe-webhook-fallback", self.evidence)
        self.evidence["evidence_file"] = str(evidence_file)
        
        return self.evidence


def main():
    parser = argparse.ArgumentParser(description="Webhook Fallback Verification Probe")
    parser.add_argument("--json", action="store_true", help="Output JSON only")
    parser.add_argument("--timeout", type=int, default=TIMEOUT_SECONDS, help="Timeout in seconds")
    args = parser.parse_args()
    
    probe = WebhookFallbackProbe(timeout=args.timeout)
    result = probe.run()
    
    if args.json:
        print(json.dumps(result, indent=2, ensure_ascii=False))
    else:
        status = "PASS" if result["passed"] else "FAIL"
        print(f"[{status}] probe-webhook-fallback")
        for check in result["checks"]:
            check_status = "✓" if check["passed"] else "✗"
            print(f"  {check_status} {check['name']}: {check.get('description', '')}")
        
        if result["failures"]:
            print(f"\nFailed checks: {', '.join(result['failures'])}")
    
    sys.exit(0 if result["passed"] else 1)


if __name__ == "__main__":
    main()
