#!/usr/bin/env python3
"""
probe-daily-rollup - Daily Rollup Verification

Verification Mode: artifact_output_check

检查逻辑:
1. 检查 daily rollup 工具/脚本存在
2. 检查最新 rollup 文件存在
3. 检查 rollup 格式正确
4. 检查聚合数据完整性

Usage:
  probe-daily-rollup
  probe-daily-rollup --json
  probe-daily-rollup --timeout 30

Exit codes:
  0 - PASS (all checks passed)
  1 - FAIL (one or more checks failed)
  2 - ERROR (unexpected error)
"""

import argparse
import json
import sys
import os
from pathlib import Path
from datetime import datetime, timezone, timedelta
from typing import Dict, List, Any, Optional

WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
TOOLS_DIR = WORKSPACE / "tools"
PROBES_DIR = WORKSPACE / "artifacts" / "self_health" / "probes"
MEMORY_DIR = WORKSPACE / "memory"
ARTIFACTS_DIR = WORKSPACE / "artifacts"

# Daily rollup related tools
DAILY_ROLLUP_TOOLS = [
    TOOLS_DIR / "callback-daily-summary",
    TOOLS_DIR / "memory-daily-obs",
    TOOLS_DIR / "s1-daily-report",
    TOOLS_DIR / "session-daily-audit",
    TOOLS_DIR / "session-continuity-daily-check",
    TOOLS_DIR / "srap-daily-report",
]

TIMEOUT_SECONDS = 30


def now_iso():
    return datetime.now(timezone.utc).isoformat()


def write_evidence(probe_name: str, evidence: Dict):
    """Write probe evidence to artifacts directory."""
    PROBES_DIR.mkdir(parents=True, exist_ok=True)
    evidence_file = PROBES_DIR / f"{probe_name}_evidence.json"
    evidence["timestamp"] = now_iso()
    evidence["probe_name"] = probe_name
    with open(evidence_file, 'w') as f:
        json.dump(evidence, f, indent=2, ensure_ascii=False)
    return evidence_file


class DailyRollupProbe:
    """Probe for daily rollup functionality."""
    
    def __init__(self, timeout: int = TIMEOUT_SECONDS):
        self.timeout = timeout
        self.checks = []
        self.evidence = {
            "probe_name": "probe-daily-rollup",
            "verification_mode": "artifact_output_check",
            "checks": [],
            "passed": False,
            "failures": []
        }
    
    def check_daily_rollup_tools(self) -> Dict:
        """Check 1: daily rollup 工具/脚本存在."""
        check = {
            "name": "daily_rollup_tools",
            "description": "Check daily rollup tools exist",
            "passed": False,
            "details": {}
        }
        
        existing_tools = []
        for tool in DAILY_ROLLUP_TOOLS:
            if tool.exists():
                existing_tools.append({
                    "name": tool.name,
                    "path": str(tool),
                    "executable": os.access(tool, os.X_OK)
                })
        
        check["details"]["tools_found"] = len(existing_tools)
        check["details"]["tools"] = existing_tools
        
        # Pass if at least one daily tool exists
        check["passed"] = len(existing_tools) > 0
        
        self.checks.append(check)
        return check
    
    def check_latest_rollup_file(self) -> Dict:
        """Check 2: 最新 rollup 文件存在."""
        check = {
            "name": "latest_rollup_file",
            "description": "Check latest rollup file exists",
            "passed": False,
            "details": {}
        }
        
        # Look for rollup files in various locations
        rollup_patterns = [
            (MEMORY_DIR, "daily_summaries.jsonl"),
            (ARTIFACTS_DIR / "self_health", "daily_*.json"),
            (ARTIFACTS_DIR / "self_report", "daily_*.json"),
        ]
        
        rollup_files = []
        for base_dir, pattern in rollup_patterns:
            if base_dir.exists():
                matches = list(base_dir.glob(pattern))
                for f in matches:
                    rollup_files.append({
                        "path": str(f),
                        "name": f.name,
                        "mtime": f.stat().st_mtime
                    })
        
        if rollup_files:
            # Sort by modification time
            rollup_files.sort(key=lambda x: x["mtime"], reverse=True)
            latest = rollup_files[0]
            
            check["details"]["rollup_files_count"] = len(rollup_files)
            check["details"]["latest_file"] = latest["name"]
            check["details"]["latest_path"] = latest["path"]
            
            # Calculate age
            age_hours = (datetime.now().timestamp() - latest["mtime"]) / 3600
            check["details"]["latest_age_hours"] = round(age_hours, 2)
            
            # Pass if file is within reasonable age (7 days)
            check["passed"] = age_hours < 168
        else:
            check["details"]["warning"] = "No rollup files found"
            check["passed"] = True  # Non-blocking - may not have run yet
        
        self.checks.append(check)
        return check
    
    def check_rollup_format(self) -> Dict:
        """Check 3: rollup 格式正确."""
        check = {
            "name": "rollup_format",
            "description": "Check rollup format correctness",
            "passed": False,
            "details": {}
        }
        
        # Check daily_summaries.jsonl format
        daily_summaries = MEMORY_DIR / "daily_summaries.jsonl"
        
        if daily_summaries.exists():
            check["details"]["daily_summaries_exists"] = True
            
            try:
                lines = daily_summaries.read_text().strip().split('\n')
                check["details"]["lines_count"] = len(lines)
                
                # Validate JSONL format
                valid_lines = 0
                for line in lines:
                    if line.strip():
                        try:
                            json.loads(line)
                            valid_lines += 1
                        except json.JSONDecodeError:
                            pass
                
                check["details"]["valid_json_lines"] = valid_lines
                check["passed"] = valid_lines > 0
                
            except Exception as e:
                check["details"]["read_error"] = str(e)
        else:
            check["details"]["daily_summaries_not_found"] = True
            check["passed"] = True  # Non-blocking
        
        self.checks.append(check)
        return check
    
    def check_aggregated_data_integrity(self) -> Dict:
        """Check 4: 聚合数据完整性."""
        check = {
            "name": "aggregated_data_integrity",
            "description": "Check aggregated data integrity",
            "passed": False,
            "details": {}
        }
        
        # Check memory directory for recent entries
        if MEMORY_DIR.exists():
            md_files = list(MEMORY_DIR.glob("*.md"))
            
            # Check for today's or recent files
            today = datetime.now().strftime("%Y-%m-%d")
            yesterday = (datetime.now() - timedelta(days=1)).strftime("%Y-%m-%d")
            
            recent_files = [f for f in md_files 
                           if today in f.name or yesterday in f.name]
            
            check["details"]["total_md_files"] = len(md_files)
            check["details"]["recent_md_files"] = len(recent_files)
            
            # Check for events log
            events_log = MEMORY_DIR / "events.log"
            if events_log.exists():
                check["details"]["events_log_exists"] = True
                check["details"]["events_log_size"] = events_log.stat().st_size
            
            # Check INDEX.yaml
            index_file = MEMORY_DIR / "INDEX.yaml"
            if index_file.exists():
                check["details"]["index_exists"] = True
            
            check["passed"] = len(md_files) > 0
        else:
            check["details"]["memory_dir_not_found"] = True
        
        self.checks.append(check)
        return check
    
    def run(self) -> Dict:
        """Run all checks and return result."""
        self.check_daily_rollup_tools()
        self.check_latest_rollup_file()
        self.check_rollup_format()
        self.check_aggregated_data_integrity()
        
        all_passed = all(c["passed"] for c in self.checks)
        failures = [c for c in self.checks if not c["passed"]]
        
        self.evidence["checks"] = self.checks
        self.evidence["passed"] = all_passed
        self.evidence["status"] = "ok" if all_passed else "fail"
        self.evidence["message"] = "Daily rollup healthy" if all_passed else "Daily rollup issues found"
        self.evidence["failures"] = [c["name"] for c in failures]
        self.evidence["check_count"] = len(self.checks)
        self.evidence["pass_count"] = len([c for c in self.checks if c["passed"]])
        
        evidence_file = write_evidence("probe-daily-rollup", self.evidence)
        self.evidence["evidence_file"] = str(evidence_file)
        
        return self.evidence


def main():
    parser = argparse.ArgumentParser(description="Daily Rollup Verification Probe")
    parser.add_argument("--json", action="store_true", help="Output JSON only")
    parser.add_argument("--timeout", type=int, default=TIMEOUT_SECONDS, help="Timeout in seconds")
    args = parser.parse_args()
    
    probe = DailyRollupProbe(timeout=args.timeout)
    result = probe.run()
    
    if args.json:
        print(json.dumps(result, indent=2, ensure_ascii=False))
    else:
        status = "PASS" if result["passed"] else "FAIL"
        print(f"[{status}] probe-daily-rollup")
        for check in result["checks"]:
            check_status = "✓" if check["passed"] else "✗"
            print(f"  {check_status} {check['name']}: {check.get('description', '')}")
        
        if result["failures"]:
            print(f"\nFailed checks: {', '.join(result['failures'])}")
    
    sys.exit(0 if result["passed"] else 1)


if __name__ == "__main__":
    main()
