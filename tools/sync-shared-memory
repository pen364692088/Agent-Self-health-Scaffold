#!/bin/bash
# sync-shared-memory - 同步共享知识到所有 agent workspace
#
# Usage:
#   sync-shared-memory [--dry-run] [--agent main|ceo|all]
#
# 功能:
#   1. 扫描 ~/.openclaw/shared/**/*.md
#   2. 为每个 agent workspace 创建符号链接
#   3. 删除失效链接
#   4. 执行 memory index
#   5. 输出统计报告

set -e

# Configuration
SHARED_DIR="$HOME/.openclaw/shared"
WORKSPACES=("main:$HOME/.openclaw/workspace" "ceo:$HOME/.openclaw/workspace-ceo")
DRY_RUN=false
TARGET_AGENT="all"

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --agent)
            TARGET_AGENT="$2"
            shift 2
            ;;
        -h|--help)
            echo "Usage: sync-shared-memory [--dry-run] [--agent main|ceo|all]"
            echo ""
            echo "Synchronize shared knowledge to all agent workspaces."
            echo ""
            echo "Options:"
            echo "  --dry-run    Show what would be done without making changes"
            echo "  --agent      Target specific agent (main, ceo, or all)"
            echo "  -h, --help   Show this help message"
            exit 0
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Statistics
STATS_ADDED=0
STATS_UPDATED=0
STATS_REMOVED=0
STATS_UNCHANGED=0

echo "=== Shared Memory Sync ==="
echo "Mode: $([ "$DRY_RUN" = true ] && echo "DRY RUN" || echo "LIVE")"
echo "Target: $TARGET_AGENT"
echo ""

# Function to sync a single workspace
sync_workspace() {
    local agent_name="$1"
    local workspace="$2"
    local memory_shared="$workspace/memory/shared"
    
    echo "Processing agent: $agent_name"
    echo "  Workspace: $workspace"
    
    # Create memory/shared directory if not exists
    if [ ! -d "$memory_shared" ]; then
        if [ "$DRY_RUN" = true ]; then
            echo "  [DRY-RUN] Would create: $memory_shared"
        else
            mkdir -p "$memory_shared"
            echo "  Created: $memory_shared"
        fi
    fi
    
    # Find all .md files in shared directory
    local shared_files=()
    while IFS= read -r -d '' file; do
        shared_files+=("$file")
    done < <(find "$SHARED_DIR" -name "*.md" -type f -print0 2>/dev/null)
    
    echo "  Found ${#shared_files[@]} shared files"
    
    # Create/update symlinks
    for shared_file in "${shared_files[@]}"; do
        local rel_path="${shared_file#$SHARED_DIR/}"
        local link_name="$memory_shared/$(basename "$rel_path")"
        
        # Skip if basename would conflict (prefer first found)
        if [ -L "$link_name" ] || [ -e "$link_name" ]; then
            local current_target
            current_target=$(readlink -f "$link_name" 2>/dev/null || echo "")
            if [ "$current_target" = "$shared_file" ]; then
                echo "    [UNCHANGED] $rel_path"
                ((STATS_UNCHANGED++)) || true
            elif [ -L "$link_name" ]; then
                # Different target - this is an update
                if [ "$DRY_RUN" = true ]; then
                    echo "    [DRY-RUN] Would update: $rel_path"
                else
                    ln -sf "$shared_file" "$link_name"
                    echo "    [UPDATED] $rel_path"
                fi
                ((STATS_UPDATED++))
            else
                echo "    [SKIP] $rel_path - link name collision with existing file"
                ((STATS_UNCHANGED++)) || true
            fi
        else
            if [ "$DRY_RUN" = true ]; then
                echo "    [DRY-RUN] Would add: $rel_path"
            else
                ln -sf "$shared_file" "$link_name"
                echo "    [ADDED] $rel_path"
            fi
            ((STATS_ADDED++)) || true
        fi
    done
    
    # Remove dead symlinks
    for link in "$memory_shared"/*; do
        [ -L "$link" ] || continue
        local target
        target=$(readlink "$link")
        if [[ "$target" == "$SHARED_DIR"* ]] && [ ! -e "$target" ]; then
            if [ "$DRY_RUN" = true ]; then
                echo "    [DRY-RUN] Would remove dead link: $(basename "$link")"
            else
                rm "$link"
                echo "    [REMOVED] dead link: $(basename "$link")"
            fi
            ((STATS_REMOVED++)) || true
        fi
    done
    
    echo ""
}

# Process workspaces
for workspace_spec in "${WORKSPACES[@]}"; do
    IFS=':' read -r agent_name workspace <<< "$workspace_spec"
    
    if [ "$TARGET_AGENT" = "all" ] || [ "$TARGET_AGENT" = "$agent_name" ]; then
        sync_workspace "$agent_name" "$workspace"
    fi
done

# Run memory index
if [ "$DRY_RUN" = false ]; then
    echo "Reindexing memory..."
    for workspace_spec in "${WORKSPACES[@]}"; do
        IFS=':' read -r agent_name workspace <<< "$workspace_spec"
        if [ "$TARGET_AGENT" = "all" ] || [ "$TARGET_AGENT" = "$agent_name" ]; then
            echo "  Indexing $agent_name..."
            openclaw memory index --agent "$agent_name" 2>&1 | grep -E "Indexed|files" || true
        fi
    done
else
    echo "[DRY-RUN] Would run: openclaw memory index --agent <each>"
fi

# Summary
echo ""
echo "=== Summary ==="
echo "Added: $STATS_ADDED"
echo "Updated: $STATS_UPDATED"
echo "Removed: $STATS_REMOVED"
echo "Unchanged: $STATS_UNCHANGED"
echo ""

if [ "$DRY_RUN" = true ]; then
    echo "This was a dry run. Run without --dry-run to apply changes."
fi

echo "Done."
