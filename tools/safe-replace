#!/usr/bin/env python3
"""
Safe Replace Tool

Safe content replacement in files with verification.
Usage: safe-replace <path> <old_string> <new_string>
       safe-replace --path <path> --old <old> --new <new>
"""

import argparse
import hashlib
import json
import os
import re
import sys
import tempfile
import shutil
from datetime import datetime
from pathlib import Path
from typing import Optional, Tuple


def compute_hash(content: str) -> str:
    """Compute SHA256 hash of content."""
    return hashlib.sha256(content.encode()).hexdigest()[:16]


def find_and_replace(content: str, old: str, new: str, regex: bool = False) -> Tuple[str, int]:
    """Find and replace in content. Returns (new_content, count)."""
    if regex:
        new_content, count = re.subn(old, new, content)
    else:
        count = content.count(old)
        new_content = content.replace(old, new)
    
    return new_content, count


def safe_replace(path: str, old: str, new: str, regex: bool = False, all_occurrences: bool = True) -> dict:
    """Perform safe replace with verification."""
    target_path = Path(path).expanduser().resolve()
    
    if not target_path.exists():
        return {
            "success": False,
            "error": f"File not found: {target_path}"
        }
    
    try:
        # Read original content
        with open(target_path) as f:
            original_content = f.read()
        
        original_hash = compute_hash(original_content)
        
        # Check if old string exists
        if not regex and old not in original_content:
            return {
                "success": False,
                "error": "Old string not found in file",
                "path": str(target_path)
            }
        
        # Perform replacement
        new_content, count = find_and_replace(original_content, old, new, regex)
        
        if count == 0:
            return {
                "success": False,
                "error": "No matches found for replacement",
                "path": str(target_path)
            }
        
        new_hash = compute_hash(new_content)
        
        # Write to temp file first
        with tempfile.NamedTemporaryFile(mode='w', delete=False, suffix='.tmp') as tmp:
            tmp.write(new_content)
            tmp_path = tmp.name
        
        # Atomic move
        shutil.move(tmp_path, str(target_path))
        
        # Verify
        with open(target_path) as f:
            verified_content = f.read()
        
        verified_hash = compute_hash(verified_content)
        
        if verified_hash != new_hash:
            # Attempt rollback
            with open(target_path, 'w') as f:
                f.write(original_content)
            return {
                "success": False,
                "error": "Hash verification failed after write",
                "expected": new_hash,
                "actual": verified_hash,
                "rolled_back": True
            }
        
        return {
            "success": True,
            "path": str(target_path),
            "replacements": count,
            "original_hash": original_hash,
            "new_hash": new_hash,
            "size_change": len(new_content) - len(original_content)
        }
        
    except Exception as e:
        return {
            "success": False,
            "error": str(e)
        }


def main():
    parser = argparse.ArgumentParser(description="Safe content replacement")
    parser.add_argument("path", nargs="?", help="Target file path")
    parser.add_argument("old", nargs="?", help="String to replace")
    parser.add_argument("new", nargs="?", help="Replacement string")
    parser.add_argument("--path", dest="path_opt", help="Target file path")
    parser.add_argument("--old", dest="old_opt", help="String to replace")
    parser.add_argument("--new", dest="new_opt", help="Replacement string")
    parser.add_argument("--regex", action="store_true", help="Treat old as regex pattern")
    parser.add_argument("--first", action="store_true", help="Replace first occurrence only")
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    
    args = parser.parse_args()
    
    # Determine path
    path = args.path or args.path_opt
    old = args.old or args.old_opt
    new = args.new or args.new_opt
    
    if not path:
        print("Error: Path is required", file=sys.stderr)
        sys.exit(1)
    
    if old is None:
        print("Error: Old string is required", file=sys.stderr)
        sys.exit(1)
    
    if new is None:
        print("Error: New string is required", file=sys.stderr)
        sys.exit(1)
    
    # Check if reading new from stdin
    if new == "-":
        new = sys.stdin.read()
    
    result = safe_replace(path, old, new, args.regex, not args.first)
    
    if args.json:
        print(json.dumps(result, indent=2))
    else:
        if result["success"]:
            print(f"✓ Replaced {result['replacements']} occurrence(s) in {result['path']}")
            print(f"  Original hash: {result['original_hash']}")
            print(f"  New hash: {result['new_hash']}")
            if result['size_change'] != 0:
                print(f"  Size change: {'+' if result['size_change'] > 0 else ''}{result['size_change']} bytes")
        else:
            print(f"✗ Replace failed: {result['error']}", file=sys.stderr)
    
    sys.exit(0 if result["success"] else 1)


if __name__ == "__main__":
    main()
