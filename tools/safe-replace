#!/usr/bin/env python3
"""
safe-replace - 安全替换 ~/.openclaw/ 下文件的内容

禁止使用 edit 工具直接修改 ~/.openclaw/ 下的文件。
此工具用于精确替换，比 sed 更可靠。

Usage:
  safe-replace <file> <old> <new>
  safe-replace --path <file> --old <old> --new <new>

Example:
  safe-replace ~/.openclaw/workspace/TOOLS.md "| old |" "| new |"
"""

import sys
import os
from pathlib import Path

OPENCLAW_ROOT = Path.home() / ".openclaw"

def is_protected_path(path: Path) -> bool:
    """检查是否是受保护路径"""
    try:
        resolved = path.resolve()
        return str(resolved).startswith(str(OPENCLAW_ROOT.resolve()))
    except:
        return False

def main():
    if len(sys.argv) < 2 or "--help" in sys.argv or "-h" in sys.argv:
        print(__doc__)
        sys.exit(0)
    
    # 解析参数
    path = None
    old_text = None
    new_text = None
    
    i = 1
    while i < len(sys.argv):
        arg = sys.argv[i]
        if arg == "--path":
            path = Path(sys.argv[i + 1])
            i += 2
        elif arg == "--old":
            old_text = sys.argv[i + 1]
            i += 2
        elif arg == "--new":
            new_text = sys.argv[i + 1]
            i += 2
        elif arg.startswith("-"):
            print(f"Unknown option: {arg}", file=sys.stderr)
            sys.exit(1)
        else:
            if path is None:
                path = Path(arg)
            elif old_text is None:
                old_text = arg
            elif new_text is None:
                new_text = arg
            i += 1
    
    if path is None or old_text is None or new_text is None:
        print("Error: path, old, and new are all required", file=sys.stderr)
        sys.exit(1)
    
    path = path.expanduser().resolve()
    
    if not path.exists():
        print(f"❌ File not found: {path}", file=sys.stderr)
        sys.exit(1)
    
    if not is_protected_path(path):
        print(f"⚠️  Warning: {path} is not under ~/.openclaw/")
    
    # 读取文件
    with open(path, 'r') as f:
        content = f.read()
    
    # 检查旧文本是否存在
    if old_text not in content:
        print(f"❌ Old text not found in {path}", file=sys.stderr)
        print(f"   Searched for: {old_text[:50]}..." if len(old_text) > 50 else f"   Searched for: {old_text}")
        sys.exit(1)
    
    # 统计出现次数
    count = content.count(old_text)
    if count > 1:
        print(f"⚠️  Warning: Old text appears {count} times, all will be replaced")
    
    # 替换
    new_content = content.replace(old_text, new_text)
    
    # 原子写入
    tmp_path = path.with_suffix(path.suffix + ".tmp")
    try:
        with open(tmp_path, 'w') as f:
            f.write(new_content)
            f.flush()
            os.fsync(f.fileno())
        os.rename(str(tmp_path), str(path))
        print(f"✅ Replaced in {path} ({count} occurrence(s))")
    except Exception as e:
        print(f"❌ Write failed: {e}", file=sys.stderr)
        if tmp_path.exists():
            tmp_path.unlink()
        sys.exit(1)

if __name__ == "__main__":
    main()
