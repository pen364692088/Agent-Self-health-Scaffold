#!/usr/bin/env python3
"""
project-check-report v1.0 - Generate final project check reports

Reads all phase status.json files and generates consolidated reports:
- FINAL_CHECK_STATUS.json - Machine-readable overall status
- FINAL_CHECK_REPORT.md - Human-readable summary
- one_liner.txt - Single-line result summary

Usage:
    project-check-report <check_id> [--format md|json|html]
    project-check-report --health
    project-check-report --e2e-test

Options:
    --format <fmt>   Output format (md, json, html) - default: md
    --json           Shortcut for --format json
    --health         Health check endpoint
    --e2e-test       Run E2E self-test

Tool Delivery Gates:
    Gate A: Schema validation
    Gate B: E2E testing (--e2e-test flag)
    Gate C: Health check (--health flag)
"""

import argparse
import json
import os
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Dict, List, Optional, Any, Tuple

# Workspace paths
WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
ARTIFACT_ROOT = WORKSPACE / "artifacts" / "project_check"
MANIFEST_SCHEMA_FILE = WORKSPACE / "schemas" / "project_check_manifest.v1.schema.json"
STATUS_SCHEMA_FILE = WORKSPACE / "schemas" / "project_check_status.v1.schema.json"

# Phase states
STATE_PENDING = "pending"
STATE_RUNNING = "running"
STATE_DONE = "done"
STATE_FAILED = "failed"
STATE_SKIPPED = "skipped"

# Error codes
ERROR_NOT_FOUND = "NOT_FOUND"
ERROR_VALIDATION = "VALIDATION_ERROR"
ERROR_INTERNAL = "INTERNAL_ERROR"


def error_response(code: str, message: str, details: dict = None) -> dict:
    """Standardized error format per Tool Delivery Gates."""
    return {
        "error": {
            "type": code.lower().replace("_", " ").title(),
            "message": message,
            "code": code,
            "details": details or {}
        }
    }


def find_phase_dirs(check_dir: Path) -> List[Path]:
    """Find all phase directories in a check run."""
    phase_dirs = []
    for item in check_dir.iterdir():
        if item.is_dir() and item.name.startswith("phase_"):
            phase_dirs.append(item)
    return sorted(phase_dirs)


def load_json_file(path: Path) -> Tuple[Optional[dict], Optional[dict]]:
    """Load JSON file with error handling."""
    if not path.exists():
        return None, error_response(ERROR_NOT_FOUND, f"File not found: {path}")
    
    try:
        with open(path, 'r') as f:
            return json.load(f), None
    except json.JSONDecodeError as e:
        return None, error_response(ERROR_VALIDATION, f"Invalid JSON in {path}: {e}")


def load_manifest(check_id: str, check_dir: Path) -> Tuple[Optional[dict], Optional[dict]]:
    """Load manifest.json for a check run."""
    manifest_path = check_dir / "manifest.json"
    return load_json_file(manifest_path)


def load_phase_status(phase_dir: Path) -> Tuple[Optional[dict], Optional[dict]]:
    """Load status.json from a phase directory."""
    status_path = phase_dir / "status.json"
    return load_json_file(status_path)


def aggregate_status(phases: List[dict]) -> dict:
    """Aggregate status across all phases."""
    total = len(phases)
    completed = 0
    failed = 0
    skipped = 0
    running = 0
    pending = 0
    total_issues = 0
    total_warnings = 0
    
    for phase in phases:
        state = phase.get("state", "pending")
        ok = phase.get("ok", False)
        
        if state == STATE_DONE:
            completed += 1
        elif state == STATE_FAILED:
            failed += 1
        elif state == STATE_SKIPPED:
            skipped += 1
        elif state == STATE_RUNNING:
            running += 1
        else:
            pending += 1
        
        # Accumulate metrics
        metrics = phase.get("metrics", {})
        total_issues += metrics.get("issues_found", 0)
        total_issues += metrics.get("errors_count", 0)
        total_warnings += metrics.get("warnings_count", 0)
        total_warnings += len(phase.get("warnings", []))
    
    # Determine overall status
    if failed > 0:
        overall_status = "failed"
    elif running > 0:
        overall_status = "running"
    elif pending > 0:
        overall_status = "incomplete"
    elif skipped == total:
        overall_status = "skipped"
    else:
        overall_status = "success"
    
    return {
        "total_phases": total,
        "completed": completed,
        "failed": failed,
        "skipped": skipped,
        "running": running,
        "pending": pending,
        "total_issues": total_issues,
        "total_warnings": total_warnings,
        "overall_status": overall_status,
        "all_passed": failed == 0 and completed == total
    }


def generate_final_status(check_id: str, manifest: dict, phases: List[dict], summary: dict) -> dict:
    """Generate FINAL_CHECK_STATUS.json content."""
    now = datetime.now(timezone.utc)
    
    # Calculate total duration
    total_duration = 0.0
    for phase in phases:
        duration = phase.get("duration_seconds")
        if duration:
            total_duration += duration
    
    final_status = {
        "check_id": check_id,
        "generated_at": now.strftime("%Y-%m-%dT%H:%M:%SZ"),
        "project_path": manifest.get("project_path") if manifest else None,
        "created_at": manifest.get("created_at") if manifest else None,
        "overall_status": summary["overall_status"],
        "all_passed": summary["all_passed"],
        "summary": {
            "total_phases": summary["total_phases"],
            "completed": summary["completed"],
            "failed": summary["failed"],
            "skipped": summary["skipped"],
            "total_issues": summary["total_issues"],
            "total_warnings": summary["total_warnings"],
            "total_duration_seconds": round(total_duration, 2)
        },
        "phases": phases,
        "recommendation": get_recommendation(summary, phases)
    }
    
    return final_status


def get_recommendation(summary: dict, phases: List[dict]) -> str:
    """Generate recommendation based on results."""
    if summary["all_passed"]:
        return "All checks passed. Project is healthy."
    
    if summary["failed"] > 0:
        failed_phases = [p for p in phases if p.get("state") == STATE_FAILED]
        if failed_phases:
            first_failure = failed_phases[0]
            error = first_failure.get("error", {})
            return f"Fix {first_failure.get('phase', 'unknown')}: {error.get('message', 'Unknown error')}"
        return f"{summary['failed']} phase(s) failed. Review errors above."
    
    if summary["pending"] > 0:
        return "Check is incomplete. Run remaining phases."
    
    if summary["running"] > 0:
        return "Check is still running. Wait for completion."
    
    return "Review warnings and proceed with caution."


def generate_markdown_report(check_id: str, manifest: dict, phases: List[dict], summary: dict) -> str:
    """Generate FINAL_CHECK_REPORT.md content."""
    lines = []
    
    # Header
    lines.append(f"# Project Check Report")
    lines.append("")
    lines.append(f"**Check ID:** `{check_id}`")
    
    if manifest:
        if manifest.get("project_path"):
            lines.append(f"**Project:** `{manifest['project_path']}`")
        if manifest.get("created_at"):
            lines.append(f"**Created:** {manifest['created_at']}")
    
    lines.append(f"**Generated:** {datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M:%S UTC')}")
    lines.append("")
    
    # Summary section
    lines.append("## Summary")
    lines.append("")
    
    status_emoji = {
        "success": "✅",
        "failed": "❌",
        "running": "🔄",
        "incomplete": "⏳",
        "skipped": "⏭️"
    }.get(summary["overall_status"], "❓")
    
    lines.append(f"**Overall Status:** {status_emoji} **{summary['overall_status'].upper()}**")
    lines.append("")
    
    lines.append("| Metric | Value |")
    lines.append("|--------|-------|")
    lines.append(f"| Total Phases | {summary['total_phases']} |")
    lines.append(f"| Completed | {summary['completed']} |")
    if summary['failed'] > 0:
        lines.append(f"| Failed | **{summary['failed']}** |")
    if summary['skipped'] > 0:
        lines.append(f"| Skipped | {summary['skipped']} |")
    if summary['total_issues'] > 0:
        lines.append(f"| Issues Found | **{summary['total_issues']}** |")
    if summary['total_warnings'] > 0:
        lines.append(f"| Warnings | {summary['total_warnings']} |")
    lines.append("")
    
    # Phase details
    lines.append("## Phase Details")
    lines.append("")
    
    for phase in phases:
        phase_id = phase.get("phase", "unknown")
        state = phase.get("state", "unknown")
        ok = phase.get("ok", False)
        
        state_emoji = {
            STATE_DONE: "✅" if ok else "❌",
            STATE_FAILED: "❌",
            STATE_RUNNING: "🔄",
            STATE_PENDING: "⏳",
            STATE_SKIPPED: "⏭️"
        }.get(state, "❓")
        
        lines.append(f"### {state_emoji} {phase_id}")
        lines.append("")
        lines.append(f"- **State:** `{state}`")
        lines.append(f"- **Passed:** {'Yes' if ok else 'No'}")
        
        if phase.get("duration_seconds"):
            lines.append(f"- **Duration:** {phase['duration_seconds']:.2f}s")
        
        if phase.get("started_at"):
            lines.append(f"- **Started:** {phase['started_at']}")
        if phase.get("finished_at"):
            lines.append(f"- **Finished:** {phase['finished_at']}")
        
        # Metrics
        metrics = phase.get("metrics", {})
        if metrics:
            lines.append("")
            lines.append("**Metrics:**")
            lines.append("")
            for k, v in metrics.items():
                if isinstance(v, float):
                    lines.append(f"- {k}: {v:.2f}")
                else:
                    lines.append(f"- {k}: {v}")
        
        # Error
        if state == STATE_FAILED and phase.get("error"):
            error = phase["error"]
            lines.append("")
            lines.append("**Error:**")
            lines.append("")
            lines.append(f"- **Code:** `{error.get('code', 'UNKNOWN')}`")
            lines.append(f"- **Message:** {error.get('message', 'Unknown error')}")
            if error.get("details"):
                lines.append(f"- **Details:** `{json.dumps(error['details'])}`")
        
        # Warnings
        warnings = phase.get("warnings", [])
        if warnings:
            lines.append("")
            lines.append("**Warnings:**")
            lines.append("")
            for w in warnings:
                lines.append(f"- [{w.get('code', 'WARN')}] {w.get('message', 'Unknown warning')}")
        
        lines.append("")
    
    # Recommendation
    lines.append("## Recommendation")
    lines.append("")
    lines.append(get_recommendation(summary, phases))
    lines.append("")
    
    # Footer
    lines.append("---")
    lines.append(f"*Generated by project-check-report v1.0*")
    
    return "\n".join(lines)


