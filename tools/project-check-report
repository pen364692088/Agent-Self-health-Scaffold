def generate_one_liner(summary: dict) -> str:
    """Generate one_liner.txt content."""
    if summary["all_passed"]:
        return "✅ PASS - All checks successful"
    
    if summary["overall_status"] == "failed":
        return f"❌ FAIL - {summary['failed']} phase(s) failed, {summary['total_issues']} issue(s)"
    
    if summary["overall_status"] == "incomplete":
        return f"⏳ INCOMPLETE - {summary['pending']} phase(s) pending"
    
    if summary["overall_status"] == "running":
        return f"🔄 RUNNING - {summary['running']} phase(s) in progress"
    
    if summary["overall_status"] == "skipped":
        return f"⏭️ SKIPPED - {summary['skipped']} phase(s) skipped"
    
    return f"⚠️ {summary['overall_status'].upper()} - Review details"


def generate_report(check_id: str, output_format: str = "md") -> Tuple[Optional[dict], Optional[dict]]:
    """Generate final report for a check run."""
    check_dir = ARTIFACT_ROOT / check_id
    
    if not check_dir.exists():
        return None, error_response(
            ERROR_NOT_FOUND,
            f"Check not found: {check_id}",
            {"check_id": check_id, "expected_path": str(check_dir)}
        )
    
    # Load manifest
    manifest, err = load_manifest(check_id, check_dir)
    if err:
        return None, err
    
    # Find all phase directories
    phase_dirs = find_phase_dirs(check_dir)
    
    if not phase_dirs:
        return None, error_response(
            ERROR_NOT_FOUND,
            f"No phase status files found for check: {check_id}",
            {"check_id": check_id, "check_dir": str(check_dir)}
        )
    
    # Load phase statuses
    phases = []
    for phase_dir in phase_dirs:
        status, err = load_phase_status(phase_dir)
        if err:
            phases.append({
                "phase": phase_dir.name,
                "state": STATE_FAILED,
                "ok": False,
                "error": {
                    "code": ERROR_INTERNAL,
                    "message": f"Failed to load status: {err.get('error', {}).get('message', 'Unknown error')}"
                }
            })
        else:
            phases.append(status)
    
    # Aggregate status
    summary = aggregate_status(phases)
    
    # Generate output
    final_dir = check_dir / "final"
    final_dir.mkdir(parents=True, exist_ok=True)
    
    result = {
        "check_id": check_id,
        "overall_status": summary["overall_status"],
        "artifacts": {}
    }
    
    # Always generate FINAL_CHECK_STATUS.json
    final_status = generate_final_status(check_id, manifest, phases, summary)
    status_path = final_dir / "FINAL_CHECK_STATUS.json"
    with open(status_path, "w") as f:
        json.dump(final_status, f, indent=2)
    result["artifacts"]["status_json"] = str(status_path)
    
    # Generate FINAL_CHECK_REPORT.md
    md_report = generate_markdown_report(check_id, manifest, phases, summary)
    md_path = final_dir / "FINAL_CHECK_REPORT.md"
    with open(md_path, "w") as f:
        f.write(md_report)
    result["artifacts"]["report_md"] = str(md_path)
    
    # Generate one_liner.txt
    one_liner = generate_one_liner(summary)
    one_liner_path = final_dir / "one_liner.txt"
    with open(one_liner_path, "w") as f:
        f.write(one_liner)
    result["artifacts"]["one_liner"] = str(one_liner_path)
    
    # Generate HTML if requested
    if output_format == "html":
        html_report = generate_html_report(check_id, manifest, phases, summary)
        html_path = final_dir / "FINAL_CHECK_REPORT.html"
        with open(html_path, "w") as f:
            f.write(html_report)
        result["artifacts"]["report_html"] = str(html_path)
    
    # Include summary
    result["summary"] = summary
    
    # Set output based on format
    if output_format == "json":
        result["output"] = final_status
    elif output_format == "html":
        result["output"] = html_report
    else:
        result["output"] = md_report
    
    return result, None


def health_check() -> dict:
    """Health check endpoint for Gate C."""
    checks = []
    
    # Check artifact root exists
    artifact_exists = ARTIFACT_ROOT.exists()
    checks.append({
        "name": "artifact_root",
        "status": "pass" if artifact_exists else "fail",
        "message": f"Artifact root {'exists' if artifact_exists else 'not found'}: {ARTIFACT_ROOT}"
    })
    
    # Check schema files exist
    manifest_schema_exists = MANIFEST_SCHEMA_FILE.exists()
    checks.append({
        "name": "manifest_schema",
        "status": "pass" if manifest_schema_exists else "warn",
        "message": f"Manifest schema {'found' if manifest_schema_exists else 'not found'}"
    })
    
    status_schema_exists = STATUS_SCHEMA_FILE.exists()
    checks.append({
        "name": "status_schema",
        "status": "pass" if status_schema_exists else "warn",
        "message": f"Status schema {'found' if status_schema_exists else 'not found'}"
    })
    
    # Sample call - try to generate report for an existing check
    try:
        existing_checks = [d.name for d in ARTIFACT_ROOT.iterdir() if d.is_dir() and d.name.startswith("check_")]
        if existing_checks:
            # Try a quick status read (not full report generation)
            test_check = existing_checks[0]
            test_dir = ARTIFACT_ROOT / test_check
            manifest_exists = (test_dir / "manifest.json").exists()
            checks.append({
                "name": "sample_call",
                "status": "pass" if manifest_exists else "warn",
                "message": f"Sample check '{test_check}' {'has manifest' if manifest_exists else 'missing manifest'}"
            })
        else:
            checks.append({
                "name": "sample_call",
                "status": "warn",
                "message": "No existing check runs to sample"
            })
    except Exception as e:
        checks.append({
            "name": "sample_call",
            "status": "fail",
            "message": f"Failed to list checks: {e}"
        })
    
    # Determine overall status
    failed = sum(1 for c in checks if c["status"] == "fail")
    warnings = sum(1 for c in checks if c["status"] == "warn")
    
    overall_status = "healthy" if failed == 0 else ("degraded" if warnings > 0 else "unhealthy")
    
    return {
        "tool": "project-check-report",
        "version": "1.0.0",
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "status": overall_status,
        "checks": checks,
        "summary": {
            "passed": sum(1 for c in checks if c["status"] == "pass"),
            "failed": failed,
            "warnings": warnings
        }
    }


def find_check_with_phases() -> Optional[str]:
    """Find a check ID that has phase status files."""
    for check_dir in ARTIFACT_ROOT.iterdir():
        if check_dir.is_dir() and check_dir.name.startswith("check_"):
            # Check if any phase_* directory has status.json
            for phase_dir in check_dir.iterdir():
                if phase_dir.is_dir() and phase_dir.name.startswith("phase_"):
                    if (phase_dir / "status.json").exists():
                        return check_dir.name
    return None


def e2e_test() -> dict:
    """E2E self-test for Gate B."""
    results = {
        "tool": "project-check-report",
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "tests": []
    }
    
    # Find a check with phase status files
    test_check_id = find_check_with_phases()
    
    if test_check_id:
        
        # Test happy path - generate report (md format)
        result1, err1 = generate_report(test_check_id, "md")
        test1 = {
            "name": "happy_path_generate_md",
            "status": "pass" if result1 and not err1 else "fail",
            "check_id": test_check_id
        }
        if result1:
            test1["overall_status"] = result1.get("overall_status")
            test1["artifacts"] = list(result1.get("artifacts", {}).keys())
        if err1:
            test1["error"] = err1
        results["tests"].append(test1)
        
        # Test happy path - generate json format
        result2, err2 = generate_report(test_check_id, "json")
        test2 = {
            "name": "happy_path_generate_json",
            "status": "pass" if result2 and not err2 else "fail",
            "check_id": test_check_id
        }
        if err2:
            test2["error"] = err2
        results["tests"].append(test2)
        
        # Test happy path - generate html format
        result3, err3 = generate_report(test_check_id, "html")
        test3 = {
            "name": "happy_path_generate_html",
            "status": "pass" if result3 and not err3 else "fail",
            "check_id": test_check_id
        }
        if result3:
            test3["has_html_artifact"] = "report_html" in result3.get("artifacts", {})
        if err3:
            test3["error"] = err3
        results["tests"].append(test3)
        
        # Verify artifacts exist
        check_dir = ARTIFACT_ROOT / test_check_id
        final_dir = check_dir / "final"
        
        artifacts_exist = (
            (final_dir / "FINAL_CHECK_STATUS.json").exists() and
            (final_dir / "FINAL_CHECK_REPORT.md").exists() and
            (final_dir / "one_liner.txt").exists()
        )
        
        test4 = {
            "name": "artifacts_created",
            "status": "pass" if artifacts_exist else "fail",
            "expected_files": [
                "FINAL_CHECK_STATUS.json",
                "FINAL_CHECK_REPORT.md", 
                "one_liner.txt"
            ]
        }
        results["tests"].append(test4)
    else:
        results["tests"].append({
            "name": "happy_path_generate_report",
            "status": "skip",
            "reason": "No existing check runs found"
        })
    
    # Test bad args - non-existent check
    result5, err5 = generate_report("check_99999999_999999_nonexist")
    test5 = {
        "name": "bad_args_nonexistent_check",
        "status": "pass" if err5 and not result5 else "fail",
        "expected": "error response for non-existent check"
    }
    if err5:
        test5["error_code"] = err5.get("error", {}).get("code")
    results["tests"].append(test5)
    
    # Summary
    passed = sum(1 for t in results["tests"] if t["status"] == "pass")
    failed = sum(1 for t in results["tests"] if t["status"] == "fail")
    skipped = sum(1 for t in results["tests"] if t["status"] == "skip")
    
    results["summary"] = {
        "passed": passed,
        "failed": failed,
        "skipped": skipped,
        "total": len(results["tests"])
    }
    
    return results


def main():
    parser = argparse.ArgumentParser(
        description="Generate final project check reports",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__
    )
    
    parser.add_argument("check_id", nargs="?", help="Check ID to generate report for")
    parser.add_argument("--format", "-f", choices=["md", "json", "html"], default="md",
                        help="Output format (default: md)")
    parser.add_argument("--json", "-j", action="store_true", help="Shortcut for --format json")
    parser.add_argument("--health", action="store_true", help="Health check endpoint")
    parser.add_argument("--e2e-test", action="store_true", help="Run E2E self-test")
    
    args = parser.parse_args()
    
    # Gate C: Health check
    if args.health:
        result = health_check()
        print(json.dumps(result, indent=2))
        return 0 if result["status"] != "unhealthy" else 1
    
    # Gate B: E2E test
    if args.e2e_test:
        result = e2e_test()
        print(json.dumps(result, indent=2))
        return 0 if result["summary"]["failed"] == 0 else 1
    
    # Validate required arguments
    if not args.check_id:
        print("Error: check_id is required", file=sys.stderr)
        parser.print_help()
        return 1
    
    # Handle --json shortcut
    output_format = "json" if args.json else args.format
    
    # Generate report
    result, err = generate_report(args.check_id, output_format)
    
    if err:
        print(json.dumps(err, indent=2))
        return 1
    
    # Output
    if output_format == "json":
        print(json.dumps(result["output"], indent=2))
    else:
        print(result["output"])
    
    # Print artifact paths to stderr
    print("\n# Artifacts generated:", file=sys.stderr)
    for name, path in result.get("artifacts", {}).items():
        print(f"#   {name}: {path}", file=sys.stderr)
    
    return 0 if result.get("overall_status") != "failed" else 1


if __name__ == "__main__":
    sys.exit(main())
