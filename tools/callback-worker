#!/usr/bin/env python3
"""
Callback Worker v9.0 - trigger only

唯一职责：
- 发现新回执
- 调用唯一正式入口 `subtask-orchestrate resume`
- 如需用户通知，仅转发该入口的结果

不再自行决定 spawn / flag / workflow 推进。
"""

import json
import subprocess
import sys
from pathlib import Path

WORKSPACE = Path.home() / ".openclaw" / "workspace"
ORCH_TOOL = WORKSPACE / "tools" / "subtask-orchestrate"


def run_resume():
    result = subprocess.run([str(ORCH_TOOL), 'resume'], capture_output=True, text=True, timeout=60)
    if result.returncode != 0:
        return {'status': 'error', 'error': result.stderr[:200] if result.stderr else 'resume_failed'}
    try:
        return json.loads(result.stdout or '{}')
    except Exception:
        return {'status': 'error', 'error': 'invalid_resume_json', 'raw': result.stdout[:200]}


def send_notification(message):
    openclaw_path = Path.home() / ".npm-global" / "bin" / "openclaw"
    try:
        result = subprocess.run([str(openclaw_path), 'message', 'send', '--account', 'manager', '--channel', 'telegram', '--target', '8420019401', '--message', message], capture_output=True, text=True, timeout=30)
        return {'success': result.returncode == 0, 'output': result.stdout[:100] if result.stdout else '', 'error': result.stderr[:200] if result.stderr else None}
    except Exception as e:
        return {'success': False, 'error': str(e)}


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)
    if sys.argv[1] == '--health':
        print(json.dumps({'status': 'healthy', 'version': '9.0', 'entrypoint': 'subtask-orchestrate resume'}))
        sys.exit(0)
    if sys.argv[1] == '--once':
        result = run_resume()
        if result.get('action') == 'notify_user' and result.get('message'):
            result['send_result'] = send_notification(result['message'])
        print(json.dumps(result, indent=2, ensure_ascii=False))
        sys.exit(0)
    print(__doc__)
    sys.exit(1)


if __name__ == '__main__':
    main()
