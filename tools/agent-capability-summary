#!/usr/bin/env python3
import argparse, json
from datetime import datetime, timezone
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
CAP_DIR = REPO / 'artifacts' / 'self_health' / 'capabilities'
OUTPUT = REPO / 'artifacts' / 'self_health' / 'CAPABILITY_SUMMARY.md'


def load_capability_results():
    results = []
    if CAP_DIR.exists():
        for f in CAP_DIR.glob('CAP-*.json'):
            try:
                results.append(json.loads(f.read_text()))
            except Exception:
                pass
    return results


def compute_summary(results):
    summary = {
        'total': len(results),
        'by_status': {'healthy': 0, 'stale': 0, 'degraded': 0, 'missing': 0, 'unknown': 0},
        'by_severity': {'critical': 0, 'high': 0, 'medium': 0, 'low': 0},
        'by_category': {},
        'degraded_capabilities': [],
        'compaction_summary': None,
    }
    
    # 提取 compaction 能力组
    compaction_caps = {
        'CAP-COMPACTION_EXECUTION': None,
        'CAP-CONTEXT_OVERFLOW_HANDLING': None,
        'CAP-COMPACTION_EFFECTIVENESS': None,
    }
    
    for r in results:
        status = r.get('status', 'unknown')
        if status in summary['by_status']:
            summary['by_status'][status] += 1
        
        severity = r.get('severity_if_missing', 'medium')
        if severity in summary['by_severity']:
            summary['by_severity'][severity] += 1
        
        category = r.get('category', 'unknown')
        summary['by_category'][category] = summary['by_category'].get(category, 0) + 1
        
        if status in {'degraded', 'missing'}:
            summary['degraded_capabilities'].append({
                'capability_id': r['capability_id'],
                'name': r['name'],
                'status': status,
                'severity': severity,
            })
        
        # 收集 compaction 能力
        cap_id = r.get('capability_id')
        if cap_id in compaction_caps:
            compaction_caps[cap_id] = r
    
    # 计算 compaction summary
    if all(v is not None for v in compaction_caps.values()):
        statuses = [r.get('status', 'unknown') for r in compaction_caps.values()]
        
        if all(s == 'healthy' for s in statuses):
            overall = '✅ HEALTHY'
        elif statuses[0] != 'healthy' or statuses[1] != 'healthy':  # 前两项 critical
            overall = '🚨 CRITICAL_DEGRADATION'
        elif 'degraded' in statuses:
            overall = '⚠️ DEGRADED'
        else:
            overall = '❓ UNKNOWN'
        
        exec_cap = compaction_caps['CAP-COMPACTION_EXECUTION']
        overflow_cap = compaction_caps['CAP-CONTEXT_OVERFLOW_HANDLING']
        effect_cap = compaction_caps['CAP-COMPACTION_EFFECTIVENESS']
        
        summary['compaction_summary'] = {
            'overall_status': overall,
            'capabilities': [
                {'name': 'Execution', 'status': exec_cap.get('status'), 'priority': 'critical'},
                {'name': 'Overflow Handling', 'status': overflow_cap.get('status'), 'priority': 'critical'},
                {'name': 'Effectiveness', 'status': effect_cap.get('status'), 'priority': 'high'},
            ],
            'restored_status': exec_cap.get('evidence', {}).get('restored_status', 'N/A'),
            'high_pressure_count': overflow_cap.get('evidence', {}).get('high_pressure_count', 'N/A'),
            'openviking_retrieval': effect_cap.get('evidence', {}).get('openviking_retrieval', 'N/A'),
        }
    
    return summary


def render_markdown(summary):
    lines = [
        '# Capability Summary',
        '',
        f'**Generated**: {datetime.now(timezone.utc).isoformat()}',
        '',
        '## Overview',
        '',
        f'- **Total Capabilities**: {summary["total"]}',
        f'- **Healthy**: {summary["by_status"]["healthy"]}',
        f'- **Stale**: {summary["by_status"]["stale"]}',
        f'- **Degraded**: {summary["by_status"]["degraded"]}',
        f'- **Missing**: {summary["by_status"]["missing"]}',
        f'- **Unknown**: {summary["by_status"]["unknown"]}',
        '',
        '## By Severity',
        '',
    ]
    for sev in ['critical', 'high', 'medium', 'low']:
        lines.append(f'- {sev}: {summary["by_severity"][sev]}')
    
    lines.extend([
        '',
        '## By Category',
        '',
    ])
    for cat, count in sorted(summary['by_category'].items()):
        lines.append(f'- {cat}: {count}')
    
    # Compaction 独立小节
    if 'compaction_summary' in summary:
        cs = summary['compaction_summary']
        lines.extend([
            '',
            '## Compaction Chain (Critical Path)',
            '',
            f'**Overall Status**: {cs["overall_status"]}',
            '',
            '| Capability | Status | Priority |',
            '|------------|--------|----------|',
        ])
        for cap in cs['capabilities']:
            status_icon = '✅' if cap['status'] == 'healthy' else '⚠️' if cap['status'] == 'degraded' else '❌'
            lines.append(f"| {cap['name']} | {status_icon} {cap['status']} | {cap['priority']} |")
        
        lines.extend([
            '',
            '### Key Metrics',
            '',
            f'- Restored Status: {cs.get("restored_status", "N/A")}',
            f'- High Pressure Sessions: {cs.get("high_pressure_count", "N/A")}',
            f'- OpenViking Retrieval: {cs.get("openviking_retrieval", "N/A")}',
        ])
    
    if summary['degraded_capabilities']:
        lines.extend([
            '',
            '## Degraded Capabilities',
            '',
            '| Capability | Status | Severity |',
            '|------------|--------|----------|',
        ])
        for cap in summary['degraded_capabilities']:
            lines.append(f"| {cap['name']} | {cap['status']} | {cap['severity']} |")
    
    return '\n'.join(lines)


parser = argparse.ArgumentParser()
parser.add_argument('--json', action='store_true')
parser.add_argument('--write', action='store_true')
args = parser.parse_args()

results = load_capability_results()
summary = compute_summary(results)

if args.json:
    print(json.dumps(summary, ensure_ascii=False, indent=2))
else:
    md = render_markdown(summary)
    if args.write:
        OUTPUT.parent.mkdir(parents=True, exist_ok=True)
        OUTPUT.write_text(md)
        print(f'Written to {OUTPUT}')
    else:
        print(md)
