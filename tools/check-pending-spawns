#!/usr/bin/env python3
"""
Check Pending Spawns v2.0 - 检查待执行的 spawn 任务 + 自动执行

如果检测到待 spawn 任务，并且是主代理调用，直接返回 spawn 信息。
如果是 cron 调用，写入触发文件并通知主代理。

Usage:
  check-pending-spawns [--consume] [--auto-spawn]
"""

import json
import sys
from pathlib import Path
from datetime import datetime

WORKSPACE = Path.home() / ".openclaw" / "workspace"
TRIGGER_FILE = WORKSPACE / "reports" / "pending_spawns.jsonl"
WORKFLOW_FILE = WORKSPACE / "WORKFLOW_STATE.json"
NOTIFY_FILE = WORKSPACE / "reports" / "spawn_notify.flag"


def get_pending_from_workflow():
    """从 WORKFLOW_STATE.json 获取 running 步骤"""
    if not WORKFLOW_FILE.exists():
        return []
    
    try:
        with open(WORKFLOW_FILE) as f:
            state = json.load(f)
        
        if not state.get('active'):
            return []
        
        # 找 running 状态的步骤
        for step in state.get('steps', []):
            if step.get('status') == 'running':
                return [{
                    "step_id": step.get('id'),
                    "task": step.get('task', ''),
                    "model": step.get('model', 'iflow/glm-4.6'),
                    "run_id": step.get('run_id', '')
                }]
        
        return []
    except:
        return []


def check_spawns(consume=False, auto_spawn=False):
    """检查待 spawn 任务"""
    pending = []
    
    # 1. 从触发文件读取
    if TRIGGER_FILE.exists():
        lines = []
        with open(TRIGGER_FILE, 'r') as f:
            lines = f.readlines()
        
        for line in lines:
            line = line.strip()
            if line:
                try:
                    task = json.loads(line)
                    pending.append(task)
                except:
                    pass
    
    # 2. 从 WORKFLOW_STATE 读取
    workflow_pending = get_pending_from_workflow()
    for task in workflow_pending:
        # 检查是否已经在 pending 列表中
        if not any(p.get('step_id') == task.get('step_id') for p in pending):
            pending.append(task)
    
    if consume and pending:
        # 清空触发文件
        with open(TRIGGER_FILE, 'w') as f:
            pass
    
    result = {"pending": pending, "count": len(pending)}
    
    # 如果有待 spawn 任务且不是 auto_spawn 模式，写入通知文件
    if pending and not auto_spawn:
        with open(NOTIFY_FILE, 'w') as f:
            json.dump({
                "count": len(pending),
                "steps": [p.get('step_id') for p in pending],
                "timestamp": datetime.now().isoformat()
            }, f)
    
    return result


def main():
    consume = "--consume" in sys.argv
    auto_spawn = "--auto-spawn" in sys.argv
    
    result = check_spawns(consume=consume, auto_spawn=auto_spawn)
    
    if result["count"] > 0:
        print(json.dumps(result, indent=2))
    else:
        # 检查是否有通知文件
        if NOTIFY_FILE.exists():
            print(json.dumps({"has_notification": True, "file": str(NOTIFY_FILE)}))
        else:
            print(json.dumps({"pending": [], "count": 0}))


if __name__ == "__main__":
    main()
