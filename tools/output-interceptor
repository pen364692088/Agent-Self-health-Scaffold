#!/usr/bin/env python3
"""
output-interceptor v1.1 - 统一输出拦截层

用途：
- 在所有对外输出前检查 finalize-response
- 防止旁路泄露伪完成

v1.1: 支持环境变量配置工作区路径（CI 兼容）

集成点：
- Telegram message
- GitHub comment
- callback-worker 自动推进
- subagent mailbox 回执
- 任何"任务完成"类输出

Usage:
  output-interceptor --task-id <id> --channel <channel> --message "..."
  output-interceptor --task-id <id> --check-only
  
Exit codes:
  0 - ALLOW: safe to output
  1 - BLOCK: must repair first
  2 - ERROR: invalid usage
"""

import argparse
import json
import sys
import os
import subprocess
from pathlib import Path
from datetime import datetime
from typing import Dict, Optional

# 动态检测工作区路径
def _detect_workspace() -> Path:
    """Detect workspace path from environment or script location."""
    env_workspace = os.environ.get("OPENCLAW_WORKSPACE")
    if env_workspace:
        return Path(env_workspace)
    
    script_path = Path(__file__).resolve()
    possible_workspace = script_path.parent.parent
    if (possible_workspace / "tools").exists():
        return possible_workspace
    
    cwd = Path.cwd()
    if (cwd / "tools").exists():
        return cwd
    
    default = Path("/home/moonlight/.openclaw/workspace")
    if default.exists():
        return default
    
    return possible_workspace

WORKSPACE = _detect_workspace()
FINALIZE_RESPONSE = WORKSPACE / "tools" / "finalize-response"
INTERCEPTOR_LOG = WORKSPACE / "reports" / "interceptor_log.jsonl"

# 需要拦截的输出通道
PROTECTED_CHANNELS = [
    "telegram",
    "discord", 
    "github_comment",
    "github_pr",
    "slack",
    "email",
    "callback_auto_reply",
    "subagent_mailbox",
    "cli_summary"
]


def log_intercept(
    task_id: str,
    channel: str,
    allowed: bool,
    reason: str,
    details: dict = None
):
    """记录拦截日志"""
    try:
        INTERCEPTOR_LOG.parent.mkdir(parents=True, exist_ok=True)
        
        entry = {
            "timestamp": datetime.now().isoformat(),
            "task_id": task_id,
            "channel": channel,
            "allowed": allowed,
            "reason": reason
        }
        if details:
            entry["details"] = details
        
        with open(INTERCEPTOR_LOG, "a") as f:
            f.write(json.dumps(entry) + "\n")
    except Exception:
        pass


def check_receipts_exist(task_id: str) -> bool:
    """检查四类 receipt 是否存在"""
    receipts_dir = WORKSPACE / "artifacts" / "receipts"
    if not receipts_dir.exists():
        return False
    
    for rtype in ["contract", "e2e", "preflight", "final"]:
        path = receipts_dir / f"{task_id}_{rtype}_receipt.json"
        if not path.exists():
            return False
    
    return True


def check_fake_completion(message: str) -> bool:
    """检查是否包含伪完成文本"""
    import re
    patterns = [
        r"已完成", r"全部完成", r"可以交付", r"已可合并",
        r"已准备好关闭", r"所有阶段通过"
    ]
    for pattern in patterns:
        if re.search(pattern, message):
            return True
    return False


def main():
    parser = argparse.ArgumentParser(description="output-interceptor v1.1")
    parser.add_argument("--task-id", required=True, help="Task identifier")
    parser.add_argument("--channel", default="unknown", help="Output channel")
    parser.add_argument("--message", help="Message to check")
    parser.add_argument("--check-only", action="store_true", help="Only check, no message")
    parser.add_argument("--json", action="store_true", help="JSON output")
    
    args = parser.parse_args()
    
    result = {
        "task_id": args.task_id,
        "channel": args.channel,
        "action": "ALLOW"
    }
    
    # 检查 receipts
    has_receipts = check_receipts_exist(args.task_id)
    result["has_receipts"] = has_receipts
    
    # 检查伪完成文本
    if args.message and check_fake_completion(args.message):
        result["action"] = "BLOCK"
        result["reason"] = "fake_completion_detected"
        result["message_hint"] = "Message contains fake completion text"
    
    # 如果没有 receipts，阻断
    if not has_receipts:
        result["action"] = "BLOCK"
        result["reason"] = "missing_receipts"
    
    # 记录日志
    log_intercept(
        args.task_id,
        args.channel,
        result["action"] == "ALLOW",
        result.get("reason", "passed"),
        {"has_receipts": has_receipts}
    )
    
    if args.json:
        print(json.dumps(result, indent=2))
    else:
        if result["action"] == "ALLOW":
            print(f"✅ ALLOW: {args.task_id}")
        else:
            print(f"❌ BLOCK: {result.get('reason', 'unknown')}")
    
    return 0 if result["action"] == "ALLOW" else 1


if __name__ == "__main__":
    sys.exit(main())
