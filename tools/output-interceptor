#!/usr/bin/env python3
"""
output-interceptor v1.0 - 统一输出拦截层

用途：
- 在所有对外输出前检查 finalize-response
- 防止旁路泄露伪完成

集成点：
- Telegram message
- GitHub comment
- callback-worker 自动推进
- subagent mailbox 回执
- 任何"任务完成"类输出

Usage:
  output-interceptor --task-id <id> --channel <channel> --message "..."
  output-interceptor --task-id <id> --check-only
  
Exit codes:
  0 - ALLOW: safe to output
  1 - BLOCK: must repair first
  2 - ERROR: invalid usage
"""

import argparse
import json
import sys
import subprocess
from pathlib import Path
from datetime import datetime
from typing import Dict, Optional

WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
FINALIZE_RESPONSE = WORKSPACE / "tools" / "finalize-response"
INTERCEPTOR_LOG = WORKSPACE / "reports" / "interceptor_log.jsonl"

# 需要拦截的输出通道
PROTECTED_CHANNELS = [
    "telegram",
    "discord", 
    "github_comment",
    "github_pr",
    "slack",
    "email",
    "callback_auto_reply",
    "subagent_mailbox",
    "cli_summary"
]


def log_intercept(
    task_id: str,
    channel: str,
    allowed: bool,
    reason: str,
    details: dict = None
):
    """记录拦截日志"""
    INTERCEPTOR_LOG.parent.mkdir(parents=True, exist_ok=True)
    
    entry = {
        "timestamp": datetime.now().isoformat(),
        "task_id": task_id,
        "channel": channel,
        "allowed": allowed,
        "reason": reason
    }
    if details:
        entry["details"] = details
    
    with open(INTERCEPTOR_LOG, "a") as f:
        f.write(json.dumps(entry) + "\n")


def check_finalize_response(task_id: str, message: str = None) -> tuple:
    """
    调用 finalize-response 检查
    
    Returns:
        (allowed: bool, result: dict)
    """
    args = [str(FINALIZE_RESPONSE), "--task-id", task_id, "--json"]
    
    if message:
        args.extend(["--summary", message])
    
    result = subprocess.run(
        args,
        capture_output=True,
        text=True
    )
    
    try:
        data = json.loads(result.stdout)
        return data.get("action") == "ALLOW", data
    except:
        return False, {"error": "parse_error", "raw": result.stdout}


def main():
    parser = argparse.ArgumentParser(description="output-interceptor v1.0")
    parser.add_argument("--task-id", required=True, help="Task identifier")
    parser.add_argument("--channel", help="Output channel")
    parser.add_argument("--message", help="Message to check")
    parser.add_argument("--check-only", action="store_true", help="Only check, no message")
    parser.add_argument("--json", action="store_true", help="JSON output")
    parser.add_argument("--bypass", action="store_true", help="Bypass check (dangerous, log only)")
    
    args = parser.parse_args()
    
    task_id = args.task_id
    channel = args.channel or "unknown"
    
    # Bypass 模式：只记录，不阻断
    if args.bypass:
        log_intercept(task_id, channel, True, "bypass_mode")
        result = {
            "action": "BYPASS",
            "reason": "bypass_mode",
            "warning": "Bypass mode should only be used in emergencies"
        }
        if args.json:
            print(json.dumps(result, indent=2))
        return 0
    
    # 检查是否是保护通道
    is_protected = channel in PROTECTED_CHANNELS
    
    if not is_protected:
        # 非保护通道，允许通过
        log_intercept(task_id, channel, True, "unprotected_channel")
        result = {
            "action": "ALLOW",
            "reason": "unprotected_channel",
            "channel": channel
        }
        if args.json:
            print(json.dumps(result, indent=2))
        return 0
    
    # 保护通道：必须检查
    allowed, check_result = check_finalize_response(task_id, args.message)
    
    if allowed:
        log_intercept(task_id, channel, True, "check_passed")
        result = {
            "action": "ALLOW",
            "reason": "check_passed",
            "channel": channel
        }
    else:
        log_intercept(task_id, channel, False, check_result.get("reason", "unknown"), check_result)
        result = {
            "action": "BLOCK",
            "reason": check_result.get("reason", "unknown"),
            "channel": channel,
            "required_action": check_result.get("required_action", f"verify-and-close --task-id {task_id}"),
            "message": check_result.get("message", "Output blocked. Run verify-and-close first.")
        }
    
    if args.json:
        print(json.dumps(result, indent=2))
    else:
        if allowed:
            print(f"✅ ALLOW [{channel}]")
        else:
            print(f"❌ BLOCK [{channel}]: {result['reason']}")
            print(f"Required: {result['required_action']}")
    
    return 0 if allowed else 1


if __name__ == "__main__":
    sys.exit(main())
