#!/bin/bash
# capsule-builder - Wrapper for Capsule Builder (Production Default: V3)
#
# Version History:
#   V1 (deprecated): capsule-builder-v1.py
#   V2 (2026-03-09): Gate-based scoring, 92% agreement
#   V3 (2026-03-09): Decision context enhanced, 100% DC coverage
#
# Current Default: V3
# Rollback: Use --v2 flag to use previous version

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Default to V3
VERSION="v3"

# Parse arguments
ARGS=()
while [[ $# -gt 0 ]]; do
    case $1 in
        --v2)
            VERSION="v2"
            shift
            ;;
        --v1)
            VERSION="v1"
            shift
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

# Select version
case $VERSION in
    v3)
        EXECUTABLE="$SCRIPT_DIR/capsule-builder-v3.py"
        VERSION_TAG="2.1-decision-context-enhanced"
        ;;
    v2)
        EXECUTABLE="$SCRIPT_DIR/capsule-builder-v2.py"
        VERSION_TAG="2.0-gate-based"
        ;;
    v1)
        EXECUTABLE="$SCRIPT_DIR/capsule-builder-v1.py"
        VERSION_TAG="1.0"
        ;;
esac

# Check if executable exists
if [[ ! -x "$EXECUTABLE" ]]; then
    echo "ERROR: Capsule builder $VERSION not found: $EXECUTABLE" >&2
    exit 1
fi

# Log version
echo "[capsule-builder] Using version: $VERSION_TAG" >&2

# Execute
exec python3 "$EXECUTABLE" "${ARGS[@]}"
