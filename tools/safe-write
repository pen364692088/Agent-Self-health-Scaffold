"""
Safe Write Tool

Atomic file write with verification for sensitive paths.
Usage: safe-write <path> <content>
       safe-write --path <path> --content <content>
       safe-write --path <path> --file <source_file>
"""

import argparse
import hashlib
import json
import os
import shutil
import sys
import tempfile
from datetime import datetime
from pathlib import Path
from typing import Optional

# Import policy evaluator
SCRIPT_DIR = Path(__file__).parent
sys.path.insert(0, str(SCRIPT_DIR))


def compute_hash(content: str) -> str:
    """Compute SHA256 hash of content."""
    return hashlib.sha256(content.encode()).hexdigest()[:16]


def atomic_write(path: str, content: str) -> dict:
    """Perform atomic write with verification."""
    target_path = Path(path).expanduser().resolve()
    
    # Create parent directories
    target_path.parent.mkdir(parents=True, exist_ok=True)
    
    # Write to temp file first
    with tempfile.NamedTemporaryFile(mode='w', delete=False, suffix='.tmp') as tmp:
        tmp.write(content)
        tmp_path = tmp.name
    
    try:
        # Atomic move
        shutil.move(tmp_path, str(target_path))
        
        # Verify
        with open(target_path) as f:
            written_content = f.read()
        
        written_hash = compute_hash(written_content)
        expected_hash = compute_hash(content)
        
        if written_hash != expected_hash:
            return {
                "success": False,
                "error": "Hash verification failed",
                "expected": expected_hash,
                "actual": written_hash
            }
        
        return {
            "success": True,
            "path": str(target_path),
            "hash": written_hash,
            "size": len(content)
        }
    except Exception as e:
        # Clean up temp file on error
        if os.path.exists(tmp_path):
            os.unlink(tmp_path)
        return {
            "success": False,
            "error": str(e)
        }


def main():
    parser = argparse.ArgumentParser(description="Safe atomic file write")
    parser.add_argument("path", nargs="?", help="Target file path")
    parser.add_argument("content", nargs="?", help="Content to write")
    parser.add_argument("--path", dest="path_opt", help="Target file path")
    parser.add_argument("--content", dest="content_opt", help="Content to write")
    parser.add_argument("--file", dest="source_file", help="Source file to read content from")
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    
    args = parser.parse_args()
    
    # Determine path
    path = args.path or args.path_opt
    if not path:
        print("Error: Path is required", file=sys.stderr)
        sys.exit(1)
    
    # Determine content
    if args.source_file:
        with open(args.source_file) as f:
            content = f.read()
    else:
        content = args.content or args.content_opt or ""
    
    # Check if reading from stdin
    if not content and not sys.stdin.isatty():
        content = sys.stdin.read()
    
    if content is None:
        print("Error: Content is required", file=sys.stderr)
        sys.exit(1)
    
    result = atomic_write(path, content)
    
    if args.json:
        print(json.dumps(result, indent=2))
    else:
        if result["success"]:
            print(f"✓ Written to {result['path']}")
            print(f"  Size: {result['size']} bytes")
            print(f"  Hash: {result['hash']}")
        else:
            print(f"✗ Write failed: {result['error']}", file=sys.stderr)
    
    sys.exit(0 if result["success"] else 1)


if __name__ == "__main__":
    main()
