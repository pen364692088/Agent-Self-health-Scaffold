#!/usr/bin/env python3
"""
safe-write - 安全写入 ~/.openclaw/ 下的文件

禁止使用 edit 工具直接修改 ~/.openclaw/ 下的文件。
必须通过此工具进行写入。

Usage:
  safe-write <file> <content>
  safe-write --path <file> --content <content>
  echo "content" | safe-write --path <file>

Example:
  safe-write ~/.openclaw/workspace/SOUL.md "new content"
  safe-write --path /home/user/.openclaw/config.json --content '{"key": "value"}'
"""

import sys
import os
from pathlib import Path

OPENCLAW_ROOT = Path.home() / ".openclaw"

def is_protected_path(path: Path) -> bool:
    """检查是否是受保护路径"""
    try:
        resolved = path.resolve()
        return str(resolved).startswith(str(OPENCLAW_ROOT.resolve()))
    except:
        return False

def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(0)
    
    # 解析参数
    path = None
    content = None
    
    i = 1
    while i < len(sys.argv):
        arg = sys.argv[i]
        if arg == "--path":
            path = Path(sys.argv[i + 1])
            i += 2
        elif arg == "--content":
            content = sys.argv[i + 1]
            i += 2
        elif arg.startswith("-"):
            print(f"Unknown option: {arg}", file=sys.stderr)
            sys.exit(1)
        else:
            if path is None:
                path = Path(arg)
            elif content is None:
                content = arg
            i += 1
    
    # 从 stdin 读取内容
    if content is None and not sys.stdin.isatty():
        content = sys.stdin.read()
    
    if path is None:
        print("Error: --path required", file=sys.stderr)
        sys.exit(1)
    
    if content is None:
        print("Error: --content required or pipe via stdin", file=sys.stderr)
        sys.exit(1)
    
    # 检查路径
    path = path.expanduser().resolve()
    
    if not is_protected_path(path):
        print(f"⚠️  Warning: {path} is not under ~/.openclaw/")
        print("   For non-protected paths, you can use write/edit directly.")
    
    # 确保父目录存在
    path.parent.mkdir(parents=True, exist_ok=True)
    
    # 原子写入
    tmp_path = path.with_suffix(path.suffix + ".tmp")
    try:
        with open(tmp_path, 'w') as f:
            f.write(content)
            f.flush()
            os.fsync(f.fileno())
        os.rename(str(tmp_path), str(path))
        print(f"✅ Written to {path}")
    except Exception as e:
        print(f"❌ Write failed: {e}", file=sys.stderr)
        if tmp_path.exists():
            tmp_path.unlink()
        sys.exit(1)

if __name__ == "__main__":
    main()
