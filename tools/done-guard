import argparse
import json
import re
import sys
import hashlib
from pathlib import Path
from typing import List, Tuple, Dict, Any
from datetime import datetime

WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
GATES_CONFIG = WORKSPACE / "POLICIES" / "GATES_CONFIG.json"
DOCTOR_SCHEMA = WORKSPACE / "schemas" / "doctor_report.v1.schema.json"
VALIDATION_SUMMARY_DIR = WORKSPACE / "reports" / "schema_validation"
AUDIT_LOG = WORKSPACE / "reports" / "gates_audit.log"


def compute_file_hash(file_path: str) -> str:
    """Compute SHA256 hash of a file."""
    path = Path(file_path)
    if not path.exists():
        return "file_not_found"
    
    with open(path, "rb") as f:
        return hashlib.sha256(f.read()).hexdigest()[:16]


def load_config() -> dict:
    """Load gates configuration."""
    if GATES_CONFIG.exists():
        with open(GATES_CONFIG) as f:
            return json.load(f)
    return {}


def validate_json_schema(data: dict, schema_path: str = None) -> Tuple[bool, List[str]]:
    """Validate JSON data against schema."""
    issues = []
    
    schema_file = Path(schema_path) if schema_path else DOCTOR_SCHEMA
    if not schema_file.exists():
        return False, [f"Schema file not found: {schema_file}"]
    
    try:
        with open(schema_file) as f:
            schema = json.load(f)
    except json.JSONDecodeError as e:
        return False, [f"Invalid schema JSON: {e}"]
    
    required_fields = schema.get("required", [])
    properties = schema.get("properties", {})
    
    # Check required fields
    for field in required_fields:
        if field not in data:
            issues.append(f"Missing required field: {field}")
    
    # Check field types
    for field, field_schema in properties.items():
        if field not in data:
            continue
        
        value = data[field]
        expected_type = field_schema.get("type")
        
        if expected_type:
            if isinstance(expected_type, list):
                valid = any(_check_type(value, t) for t in expected_type)
            else:
                valid = _check_type(value, expected_type)
            
            if not valid:
                issues.append(f"Field '{field}' has wrong type: expected {expected_type}, got {type(value).__name__}")
        
        if "enum" in field_schema and value not in field_schema["enum"]:
            issues.append(f"Field '{field}' value '{value}' not in enum: {field_schema['enum']}")
    
    return len(issues) == 0, issues


def _check_type(value: Any, expected_type: str) -> bool:
    """Check if value matches expected JSON schema type."""
    type_map = {
        "string": str,
        "integer": int,
        "number": (int, float),
        "boolean": bool,
        "array": list,
        "object": dict,
        "null": type(None)
    }
    
    expected = type_map.get(expected_type)
    if expected is None:
        return True
    
    if expected_type == "integer":
        return isinstance(value, int) and not isinstance(value, bool)
    
    return isinstance(value, expected)


def write_validation_summary(
    report_path: str,
    schema_id: str,
    validated: bool,
    errors: List[str],
    report_hash: str
):
    """
    Write validation summary to artifact.
    
    v2.2 补丁: 验证结果摘要
    """
    VALIDATION_SUMMARY_DIR.mkdir(parents=True, exist_ok=True)
    
    summary = {
        "timestamp": datetime.now().isoformat(),
        "report_path": report_path,
        "report_hash": report_hash,
        "schema_id": schema_id,
        "schema_hash": compute_file_hash(DOCTOR_SCHEMA),
        "validated": validated,
        "errors_count": len(errors),
        "errors": errors if errors else []
    }
    
    # 写入摘要文件
    summary_file = VALIDATION_SUMMARY_DIR / f"validation_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
    with open(summary_file, "w") as f:
        json.dump(summary, f, indent=2)
    
    print(f"📝 Validation summary written to: {summary_file}")
    
    return summary


def validate_doctor_report(report_path: str) -> Tuple[bool, List[str]]:
    """Validate doctor_report.json against schema."""
    issues = []
    path = Path(report_path)
    
    if not path.exists():
        return False, [f"File does not exist: {report_path}"]
    
    try:
        with open(path) as f:
            data = json.load(f)
    except json.JSONDecodeError as e:
        return False, [f"Invalid JSON: {e}"]
    
    # Schema validation
    valid, schema_issues = validate_json_schema(data, str(DOCTOR_SCHEMA))
    issues.extend(schema_issues)
    
    # Semantic validation
    if data.get("status") == "healthy":
        if not data.get("health_ok"):
            issues.append("Status is 'healthy' but health_ok is false")
        if not data.get("sample_call_ok") and data.get("transport") == "http":
            issues.append("Status is 'healthy' but sample_call_ok is false (http mode)")
    
    # v2.2: 写入验证摘要
    schema_id = "doctor.v1"
    report_hash = compute_file_hash(report_path)
    
    summary = write_validation_summary(
        report_path=report_path,
        schema_id=schema_id,
        validated=len(issues) == 0,
        errors=issues,
        report_hash=report_hash
    )
    
    # 输出摘要
    print()
    print("=" * 60)
    print("SCHEMA VALIDATION SUMMARY")
    print("=" * 60)
    print(f"Schema ID:     {schema_id}")
    print(f"Schema Hash:   {summary['schema_hash']}")
    print(f"Report Hash:   {report_hash}")
    print(f"Validated:     {'✅ YES' if summary['validated'] else '❌ NO'}")
    print(f"Errors:        {summary['errors_count']}")
    if issues:
        for issue in issues:
            print(f"  - {issue}")
    print("=" * 60)
    
    return len(issues) == 0, issues


def check_evidence_block(text: str, gate: str) -> Tuple[bool, List[str]]:
    """Check evidence block."""
    issues = []
    
    patterns = {
        "gate_a": r"##\s*EVIDENCE_GATE_A",
        "gate_b": r"##\s*EVIDENCE_GATE_B",
        "gate_c": r"##\s*EVIDENCE_GATE_C"
    }
    
    pattern = patterns.get(gate)
    if not pattern:
        return False, [f"Unknown gate: {gate}"]
    
    match = re.search(pattern, text, re.IGNORECASE)
    if not match:
        return False, [f"Missing {gate.upper()} evidence block"]
    
    start = match.start()
    next_header = re.search(r'\n##\s+', text[start + 10:])
    if next_header:
        block = text[start:start + 10 + next_header.start()]
    else:
        block = text[start:]
    
    keywords = {
        "gate_a": ["schema", "drift"],
        "gate_b": ["e2e", "happy"],
        "gate_c": ["tool_doctor", "doctor_report"]
    }
    
    block_lower = block.lower()
    for kw in keywords.get(gate, []):
        if kw not in block_lower:
            issues.append(f"Missing keyword: {kw}")
    
    if gate == "gate_c":
        file_pattern = r'([/\.\w-]+doctor_report[\.\w-]*)'
        file_matches = re.findall(file_pattern, block)
        
        for file_path in file_matches:
            valid, file_issues = validate_doctor_report(file_path)
            if not valid:
                issues.extend(file_issues)
    
    if "pass" not in block_lower and "✅" not in block:
        issues.append("No pass/success indicator")
    
    return len(issues) == 0, issues


def check_all_gates(text: str) -> Dict:
    """Check all three gates."""
    results = {
        "all_passed": True,
        "gates": {}
    }
    
    for gate in ["gate_a", "gate_b", "gate_c"]:
        passed, issues = check_evidence_block(text, gate)
        results["gates"][gate] = {
            "passed": passed,
            "issues": issues
        }
        if not passed:
            results["all_passed"] = False
    
    return results


def main():
    parser = argparse.ArgumentParser(description="Done Guard v2.2")
    parser.add_argument("input", nargs="?", help="Input file")
    parser.add_argument("--validate-schema", nargs=2, metavar=("JSON", "SCHEMA"))
    parser.add_argument("--validate-doctor", metavar="REPORT")
    parser.add_argument("--json", action="store_true")
    
    args = parser.parse_args()
    
    if args.validate_schema:
        json_file, schema_file = args.validate_schema
        with open(json_file) as f:
            data = json.load(f)
        
        valid, issues = validate_json_schema(data, schema_file)
        
        if args.json:
            print(json.dumps({"valid": valid, "issues": issues}, indent=2))
        else:
            print(f"Valid: {valid}")
            for issue in issues:
                print(f"  - {issue}")
        
        return 0 if valid else 1
    
    if args.validate_doctor:
        valid, issues = validate_doctor_report(args.validate_doctor)
        
        if args.json:
            print(json.dumps({"valid": valid, "issues": issues}, indent=2))
        
        return 0 if valid else 1
    
    if args.input:
        text = Path(args.input).read_text()
        results = check_all_gates(text)
        
        if args.json:
            print(json.dumps(results, indent=2))
        else:
            for gate, result in results["gates"].items():
                status = "✅" if result["passed"] else "❌"
                print(f"{status} {gate}: {result['issues'] or ['PASS']}")
        
        return 0 if results["all_passed"] else 1
    
    return 2


if __name__ == "__main__":
    sys.exit(main())
