#!/usr/bin/env python3
"""
Done Guard v3.1 - Evidence Gate Checker + Receipt Validator + State Machine

遵循 OPENCLAW_EXECUTION_POLICY.md:
- 拦截"已完成"类文本输出
- 检查四类 receipt 存在性
- 状态机校验
- human_failed 检查

v3.1: 支持环境变量配置工作区路径（CI 兼容）

Usage:
  done-guard --task-id <id> --all              # 完整检查
  done-guard --check-text <file>               # 拦截伪完成文本
  done-guard --validate-state current:target   # 状态机校验
  done-guard --validate-doctor <report.json>   # doctor report 验证
"""

import argparse
import json
import re
import sys
import os
import hashlib
from pathlib import Path
from typing import List, Tuple, Dict, Any, Optional
from datetime import datetime

# 动态检测工作区路径
def _detect_workspace() -> Path:
    """Detect workspace path from environment or script location."""
    env_workspace = os.environ.get("OPENCLAW_WORKSPACE")
    if env_workspace:
        return Path(env_workspace)
    
    script_path = Path(__file__).resolve()
    possible_workspace = script_path.parent.parent
    if (possible_workspace / "tools").exists():
        return possible_workspace
    
    cwd = Path.cwd()
    if (cwd / "tools").exists():
        return cwd
    
    default = Path("/home/moonlight/.openclaw/workspace")
    if default.exists():
        return default
    
    return possible_workspace

WORKSPACE = _detect_workspace()
GATES_CONFIG = WORKSPACE / "POLICIES" / "GATES_CONFIG.json"
DOCTOR_SCHEMA = WORKSPACE / "schemas" / "doctor_report.v1.schema.json"
RECEIPT_SCHEMA = WORKSPACE / "schemas" / "task_receipt.v1.schema.json"
ARTIFACTS_DIR = WORKSPACE / "artifacts" / "receipts"
WORKFLOW_STATE = WORKSPACE / "WORKFLOW_STATE.json"
VALIDATION_SUMMARY_DIR = WORKSPACE / "reports" / "schema_validation"

# 伪完成文本模式
FAKE_COMPLETION_PATTERNS = [
    r"已完成", r"全部完成", r"可以交付", r"已可合并",
    r"已准备好关闭", r"所有阶段通过", r"基本完成",
    r"大体完成", r"核心已完成", r"主要功能完成"
]

# 状态机定义
VALID_STATES = [
    "planned", "implementing", "self_verify",
    "await_human_test", "human_failed", "repairing",
    "reverify", "ready_to_close", "closed", "blocked"
]

STATE_TRANSITIONS = {
    "planned": ["implementing", "blocked"],
    "implementing": ["self_verify", "blocked"],
    "self_verify": ["await_human_test", "repairing", "blocked"],
    "await_human_test": ["human_failed", "ready_to_close", "blocked"],
    "human_failed": ["repairing", "blocked"],
    "repairing": ["reverify", "blocked"],
    "reverify": ["await_human_test", "ready_to_close", "blocked"],
    "ready_to_close": ["closed", "blocked"],
    "blocked": ["implementing", "repairing"],
    "closed": []
}


def compute_file_hash(file_path: str) -> str:
    path = Path(file_path)
    if not path.exists():
        return "file_not_found"
    with open(path, "rb") as f:
        return hashlib.sha256(f.read()).hexdigest()[:16]


def load_workflow_state() -> Dict:
    if WORKFLOW_STATE.exists():
        with open(WORKFLOW_STATE) as f:
            return json.load(f)
    return {}


def get_task_info(task_id: str) -> Dict:
    wf = load_workflow_state()
    for task in wf.get("completed", []):
        if task.get("id") == task_id:
            return {"status": task.get("status", "done"), "source": "completed"}
    for task in wf.get("pending", []):
        if task.get("id") == task_id:
            return {"status": task.get("status", "pending"), "source": "pending"}
    return {"status": "standalone", "source": "none"}


def check_receipts_exist(task_id: str) -> Tuple[bool, List[str], Dict]:
    """检查四类 receipt 是否存在"""
    missing = []
    found = {}
    
    for rtype in ["contract", "e2e", "preflight", "final"]:
        path = ARTIFACTS_DIR / f"{task_id}_{rtype}_receipt.json"
        if path.exists():
            found[rtype] = str(path)
        else:
            missing.append(rtype)
    
    return len(missing) == 0, missing, found


def check_fake_completion(text: str) -> Tuple[bool, List[str]]:
    """检查文本中是否包含伪完成词"""
    matches = []
    for pattern in FAKE_COMPLETION_PATTERNS:
        if re.search(pattern, text):
            matches.append(pattern)
    return len(matches) > 0, matches


def validate_state_transition(current: str, target: str) -> Tuple[bool, str]:
    """验证状态转换是否合法"""
    if current not in VALID_STATES:
        return False, f"Invalid current state: {current}"
    if target not in VALID_STATES:
        return False, f"Invalid target state: {target}"
    
    allowed = STATE_TRANSITIONS.get(current, [])
    if target in allowed:
        return True, "valid"
    
    return False, f"Invalid transition: {current} -> {target}"


def check_human_failed(task_id: str) -> bool:
    """检查是否处于 human_failed 状态"""
    info = get_task_info(task_id)
    return info.get("status") == "human_failed"


def run_all_checks(task_id: str) -> Dict:
    """运行所有检查"""
    results = {
        "task_id": task_id,
        "can_close": True,
        "blockers": [],
        "checks": []
    }
    
    # 1. Receipt 检查
    receipts_ok, missing, found = check_receipts_exist(task_id)
    results["checks"].append({
        "name": "receipts",
        "status": "pass" if receipts_ok else "fail",
        "missing": missing,
        "found": found
    })
    if not receipts_ok:
        results["can_close"] = False
        results["blockers"].append(f"Missing receipts: {', '.join(missing)}")
    
    # 2. 状态检查
    info = get_task_info(task_id)
    results["checks"].append({
        "name": "task_state",
        "status": "pass",
        "state": info.get("status"),
        "source": info.get("source")
    })
    
    # 3. human_failed 检查
    if check_human_failed(task_id):
        results["can_close"] = False
        results["blockers"].append("Task in human_failed state - must repair first")
        results["checks"].append({
            "name": "human_failed",
            "status": "fail",
            "message": "Task marked as failed by human"
        })
    else:
        results["checks"].append({
            "name": "human_failed",
            "status": "pass"
        })
    
    return results


def main():
    parser = argparse.ArgumentParser(description="done-guard v3.1")
    parser.add_argument("--task-id", help="Task identifier")
    parser.add_argument("--all", action="store_true", help="Run all checks")
    parser.add_argument("--check-text", help="Check text file for fake completion")
    parser.add_argument("--validate-state", help="Validate state transition (current:target)")
    parser.add_argument("--validate-doctor", help="Validate doctor report JSON")
    parser.add_argument("--json", action="store_true", help="JSON output")
    
    args = parser.parse_args()
    
    if not any([args.task_id, args.check_text, args.validate_state, args.validate_doctor]):
        parser.print_help()
        return 2
    
    result = {"action": "none"}
    
    if args.check_text:
        path = Path(args.check_text)
        if not path.exists():
            result = {"action": "error", "message": f"File not found: {args.check_text}"}
        else:
            text = path.read_text()
            has_fake, matches = check_fake_completion(text)
            if has_fake:
                result = {
                    "action": "BLOCK",
                    "reason": "fake_completion_detected",
                    "has_fake_completion": True,
                    "patterns": matches
                }
            else:
                result = {"action": "ALLOW", "has_fake_completion": False}
    
    elif args.validate_state:
        parts = args.validate_state.split(":")
        if len(parts) != 2:
            result = {"action": "error", "message": "Invalid format. Use current:target"}
        else:
            valid, msg = validate_state_transition(parts[0], parts[1])
            result = {
                "action": "ALLOW" if valid else "BLOCK",
                "valid": valid,
                "message": msg
            }
    
    elif args.validate_doctor:
        path = Path(args.validate_doctor)
        if not path.exists():
            result = {"action": "error", "message": f"File not found: {args.validate_doctor}"}
        else:
            try:
                data = json.loads(path.read_text())
                if data.get("status") == "healthy":
                    result = {"action": "ALLOW", "status": "healthy"}
                else:
                    result = {"action": "BLOCK", "status": data.get("status", "unknown")}
            except Exception as e:
                result = {"action": "error", "message": str(e)}
    
    elif args.task_id and args.all:
        result = run_all_checks(args.task_id)
    
    elif args.task_id:
        # 只检查 receipts
        receipts_ok, missing, found = check_receipts_exist(args.task_id)
        result = {
            "task_id": args.task_id,
            "can_close": receipts_ok,
            "missing": missing,
            "found": found
        }
    
    if args.json:
        print(json.dumps(result, indent=2))
    else:
        if result.get("can_close") or result.get("action") == "ALLOW":
            print(f"✅ ALLOW: {result.get('task_id', 'check')}")
        elif result.get("action") == "BLOCK":
            print(f"❌ BLOCK: {result.get('reason', result.get('message', 'unknown'))}")
        else:
            print(json.dumps(result, indent=2))
    
    return 0 if result.get("can_close") or result.get("action") == "ALLOW" else 1


if __name__ == "__main__":
    sys.exit(main())
