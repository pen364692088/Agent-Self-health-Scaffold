#!/usr/bin/env python3
import sys
"""
state-authority v2.1 - 状态迁移权威机构

Receipt 只能证明事实，状态迁移只能由 state authority 执行。
"""
import argparse
import json
import hashlib
import hmac
import subprocess
from pathlib import Path
from datetime import datetime

WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
WORKFLOW_STATE = WORKSPACE / "WORKFLOW_STATE.json"
STATE_LOG = WORKSPACE / "reports" / "state_transitions.jsonl"
ARTIFACTS_DIR = WORKSPACE / "artifacts" / "receipts"

# 签名密钥
DEFAULT_SECRET = "openclaw-execution-policy-secret-key-v2.1"

# 状态机
VALID_STATES = [
    "planned", "implementing", "self_verify",
    "await_human_test", "human_failed", "repairing",
    "reverify", "ready_to_close", "closed", "blocked"
]

STATE_TRANSITIONS = {
    "planned": ["implementing", "blocked"],
    "implementing": ["self_verify", "blocked"],
    "self_verify": ["await_human_test", "repairing", "blocked"],
    "await_human_test": ["human_failed", "ready_to_close", "blocked"],
    "human_failed": ["repairing", "blocked"],
    "repairing": ["reverify", "blocked"],
    "reverify": ["await_human_test", "ready_to_close", "blocked"],
    "ready_to_close": ["closed", "blocked"],
    "blocked": ["implementing", "repairing"],
    "closed": []
}


def get_signer_key(signer_id: str) -> str:
    return DEFAULT_SECRET


def verify_receipt_signature(receipt: dict) -> tuple:
    """验证 receipt 签名"""
    signature = receipt.get("signature")
    if not signature:
        return False, "Missing signature"
    
    signer_id = receipt.get("signer_id")
    if not signer_id:
        return False, "Missing signer_id"
    
    # 只验证核心字段
    core_fields = ["task_id", "run_id", "commit", "workspace_hash",
                   "gate_name", "started_at", "finished_at", "result",
                   "parent_receipt_hash", "signer_id", "receipt_version", "content_hash"]
    
    core_data = {k: receipt[k] for k in core_fields if k in receipt}
    message = json.dumps(core_data, sort_keys=True)
    secret = get_signer_key(signer_id)
    expected = hmac.new(secret.encode(), message.encode(), hashlib.sha256).hexdigest()
    
    if hmac.compare_digest(signature, expected):
        return True, "Valid"
    return False, "Signature mismatch"


def load_workflow_state() -> dict:
    if WORKFLOW_STATE.exists():
        try:
            return json.loads(WORKFLOW_STATE.read_text())
        except:
            pass
    return {}


def get_task_state(state: dict, task_id: str) -> tuple:
    for task in state.get("completed", []):
        if task.get("id") == task_id:
            return task.get("status", "done"), "completed"
    for task in state.get("pending", []):
        if task.get("id") == task_id:
            return task.get("status", "pending"), "pending"
    return "standalone", "none"


def validate_transition(current: str, target: str) -> tuple:
    if current not in VALID_STATES:
        return False, f"Invalid current: {current}"
    if target not in VALID_STATES:
        return False, f"Invalid target: {target}"
    if target not in STATE_TRANSITIONS.get(current, []):
        return False, f"Illegal: {current} -> {target}"
    return True, "Valid"


def verify_final_receipt(task_id: str) -> tuple:
    path = ARTIFACTS_DIR / f"{task_id}_final_receipt.json"
    if not path.exists():
        return False, {"error": "Final receipt not found"}
    
    receipt = json.loads(path.read_text())
    valid, msg = verify_receipt_signature(receipt)
    if not valid:
        return False, {"error": f"Invalid signature: {msg}"}
    if receipt.get("result") != "pass":
        return False, {"error": "Receipt result not pass"}
    return True, receipt


def log_transition(task_id, from_state, to_state, receipt_hash):
    STATE_LOG.parent.mkdir(parents=True, exist_ok=True)
    entry = {
        "timestamp": datetime.now().isoformat(),
        "task_id": task_id,
        "from": from_state,
        "to": to_state,
        "receipt_hash": receipt_hash
    }
    with open(STATE_LOG, "a") as f:
        f.write(json.dumps(entry) + "\n")


def advance_state(task_id, target, require_receipt=True):
    state = load_workflow_state()
    current, source = get_task_state(state, task_id)
    
    valid, msg = validate_transition(current, target)
    if not valid:
        return False, msg, {"current": current}
    
    receipt_hash = None
    if require_receipt and target in ["ready_to_close", "closed"]:
        valid_receipt, result = verify_final_receipt(task_id)
        if not valid_receipt:
            return False, f"Receipt failed: {result.get('error')}", result
        receipt_hash = result.get("content_hash")
    
    if receipt_hash:
        log_transition(task_id, current, target, receipt_hash)
    
    return True, f"Advanced: {current} -> {target}", {"receipt_hash": receipt_hash}


def main():
    parser = argparse.ArgumentParser(description="state-authority")
    parser.add_argument("--advance", nargs=2, metavar=("TASK_ID", "TARGET"))
    parser.add_argument("--check", metavar="TASK_ID")
    parser.add_argument("--validate", nargs=2, metavar=("CURRENT", "TARGET"))
    parser.add_argument("--verify-receipt", metavar="TASK_ID")
    parser.add_argument("--json", action="store_true")
    
    args = parser.parse_args()
    
    if args.validate:
        valid, msg = validate_transition(args.validate[0], args.validate[1])
        result = {"valid": valid, "message": msg}
        print(json.dumps(result, indent=2) if args.json else f"{'✅' if valid else '❌'} {msg}")
        return 0 if valid else 1
    
    if args.check:
        state = load_workflow_state()
        status, source = get_task_state(state, args.check)
        result = {"task_id": args.check, "status": status, "source": source}
        print(json.dumps(result, indent=2) if args.json else f"Status: {status}")
        return 0
    
    if args.verify_receipt:
        valid, result = verify_final_receipt(args.verify_receipt)
        output = {"valid": valid, "result": result}
        print(json.dumps(output, indent=2) if args.json else f"{'✅' if valid else '❌'} {result.get('error', 'Valid')}")
        return 0 if valid else 1
    
    if args.advance:
        success, msg, details = advance_state(args.advance[0], args.advance[1])
        result = {"success": success, "message": msg, "details": details}
        print(json.dumps(result, indent=2) if args.json else f"{'✅' if success else '❌'} {msg}")
        return 0 if success else 1
    
    parser.print_help()
    return 2


if __name__ == "__main__":
    sys.exit(main())
