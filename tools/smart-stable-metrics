#!/usr/bin/env python3
import argparse
import json
import re
from datetime import datetime, timedelta, timezone
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple


def parse_iso(ts: str) -> Optional[datetime]:
    if not ts:
        return None
    try:
        if ts.endswith('Z'):
            ts = ts[:-1] + '+00:00'
        dt = datetime.fromisoformat(ts)
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=timezone.utc)
        return dt.astimezone(timezone.utc)
    except Exception:
        return None


def extract_text_content(content: Any) -> str:
    if isinstance(content, list):
        parts = []
        for item in content:
            if isinstance(item, dict) and item.get('type') == 'text':
                parts.append(str(item.get('text', '')))
        return '\n'.join(parts)
    return ''


def parse_possible_json(text: str) -> Optional[Dict[str, Any]]:
    text = (text or '').strip()
    if not text.startswith('{'):
        return None
    try:
        return json.loads(text)
    except Exception:
        return None


def is_cron_marker(text: str) -> bool:
    t = (text or '').lower()
    return '[cron:' in t or 'heartbeat check mode' in t or 'cron:' in t


AVOIDABLE_PATTERNS = {
    'command_not_found': re.compile(r'command not found', re.I),
    'enoent': re.compile(r'enoent|no such file or directory', re.I),
    'unknown_session': re.compile(r'unknown session(id| key)?', re.I),
    'timeout': re.compile(r'timeout|timed out', re.I),
}


def detect_tool_error(msg: Dict[str, Any]) -> Tuple[bool, str]:
    # msg is envelope['message'] with role=toolResult
    if msg.get('isError') is True:
        txt = extract_text_content(msg.get('content'))
        return True, txt or 'isError=true'

    details = msg.get('details')
    if isinstance(details, dict):
        if details.get('status') == 'error':
            return True, str(details.get('error') or details)
        if details.get('tool') and details.get('error'):
            return True, str(details.get('error'))

    txt = extract_text_content(msg.get('content'))
    parsed = parse_possible_json(txt)
    if isinstance(parsed, dict) and parsed.get('status') == 'error':
        return True, str(parsed.get('error') or parsed)

    # exec failures sometimes only appear in plain text but exitCode present in details
    if isinstance(details, dict) and isinstance(details.get('exitCode'), int) and details.get('exitCode') != 0:
        return True, txt or f"exitCode={details.get('exitCode')}"

    low = txt.lower()
    if 'error' in low and ('enoent' in low or 'command not found' in low or 'unknown session' in low or 'timed out' in low):
        return True, txt

    return False, ''


def collect_metrics(session_dir: Path, hours: int, include_cron: bool) -> Dict[str, Any]:
    now = datetime.now(timezone.utc)
    start = now - timedelta(hours=hours)

    totals = {
        'assistant_turns': 0,
        'tool_call_turns': 0,
        'tool_calls': 0,
        'tool_calls_resolved': 0,
        'tool_calls_success': 0,
        'tool_calls_failed': 0,
        'tool_results': 0,
        'tool_results_success': 0,
        'tool_results_failed': 0,
        'avoidable_failure_count': 0,
    }

    durations: List[float] = []
    error_events: List[Dict[str, Any]] = []
    success_events: List[Dict[str, Any]] = []
    all_tool_events: List[Dict[str, Any]] = []
    avoidable_buckets = {k: 0 for k in AVOIDABLE_PATTERNS.keys()}

    total_files = 0
    included_files = 0
    excluded_cron_files = 0

    jsonl_files = sorted(session_dir.glob('*.jsonl'))
    for fp in jsonl_files:
        if fp.name.startswith('sessions.json'):
            continue

        total_files += 1
        session_is_cron = False
        file_events: List[Tuple[datetime, Dict[str, Any]]] = []

        try:
            with fp.open('r', encoding='utf-8') as f:
                for line in f:
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        ev = json.loads(line)
                    except Exception:
                        continue

                    ts = parse_iso(ev.get('timestamp', ''))
                    if not ts or ts < start:
                        continue

                    if ev.get('type') != 'message':
                        continue

                    msg = ev.get('message', {})
                    role = msg.get('role')
                    if role == 'user':
                        text = extract_text_content(msg.get('content'))
                        if is_cron_marker(text):
                            session_is_cron = True

                    file_events.append((ts, ev))
        except Exception:
            continue

        if not file_events:
            continue

        if session_is_cron and not include_cron:
            excluded_cron_files += 1
            continue

        included_files += 1

        # per-session pass
        for ts, ev in file_events:
            msg = ev.get('message', {})
            role = msg.get('role')

            if role == 'assistant':
                totals['assistant_turns'] += 1
                content = msg.get('content', [])
                tool_calls = [c for c in content if isinstance(c, dict) and c.get('type') == 'toolCall']
                if tool_calls:
                    totals['tool_call_turns'] += 1
                    totals['tool_calls'] += len(tool_calls)

            elif role == 'toolResult':
                totals['tool_results'] += 1
                call_id = msg.get('toolCallId')
                is_err, err_text = detect_tool_error(msg)

                details = msg.get('details')
                if isinstance(details, dict):
                    d = details.get('durationMs')
                    if isinstance(d, (int, float)):
                        durations.append(float(d))

                event_rec = {
                    'session': fp.name,
                    'timestamp': ts,
                    'toolCallId': call_id,
                    'is_error': is_err,
                    'error_text': err_text,
                }
                all_tool_events.append(event_rec)

                if is_err:
                    totals['tool_results_failed'] += 1
                    error_events.append(event_rec)
                    low = (err_text or '').lower()
                    for key, pat in AVOIDABLE_PATTERNS.items():
                        if pat.search(low):
                            avoidable_buckets[key] += 1
                            totals['avoidable_failure_count'] += 1
                            break
                else:
                    totals['tool_results_success'] += 1
                    success_events.append(event_rec)

    # Resolve per call-id first-pass status from toolResult events
    # We only count toolResults with a call id as resolved calls
    call_status: Dict[str, bool] = {}
    for ev in all_tool_events:
        cid = ev.get('toolCallId')
        if not cid:
            continue
        # False=success, True=failed ; prefer failure if any failure exists for same id
        prev = call_status.get(cid)
        cur = bool(ev.get('is_error'))
        if prev is None:
            call_status[cid] = cur
        else:
            call_status[cid] = prev or cur

    totals['tool_calls_resolved'] = len(call_status)
    totals['tool_calls_failed'] = sum(1 for v in call_status.values() if v)
    totals['tool_calls_success'] = sum(1 for v in call_status.values() if not v)

    # Recovery: error followed by success in next 5 tool events in same session
    recovered = 0
    if all_tool_events:
        all_tool_events.sort(key=lambda x: x['timestamp'])
        for i, ev in enumerate(all_tool_events):
            if not ev['is_error']:
                continue
            sess = ev['session']
            for j in range(i + 1, min(i + 6, len(all_tool_events))):
                nxt = all_tool_events[j]
                if nxt['session'] != sess:
                    continue
                if not nxt['is_error']:
                    recovered += 1
                    break

    def pct(num: float, den: float) -> float:
        return round((num / den) * 100.0, 2) if den else 0.0

    metrics = {
        'first_pass_success_rate': pct(totals['tool_calls_success'], totals['tool_calls_resolved']),
        'retry_recovery_rate': pct(recovered, totals['tool_results_failed']),
        'avg_turn_latency_ms': round(sum(durations) / len(durations), 2) if durations else 0.0,
        'avoidable_failure_count': totals['avoidable_failure_count'],
        'tool_error_rate': pct(totals['tool_results_failed'], totals['tool_results']),
    }

    return {
        'generated_at': now.isoformat(),
        'window_hours': hours,
        'scope': {
            'session_dir': str(session_dir),
            'include_cron': include_cron,
            'total_files_scanned': total_files,
            'included_files': included_files,
            'excluded_cron_files': excluded_cron_files,
        },
        'totals': totals,
        'metrics': metrics,
        'avoidable_breakdown': avoidable_buckets,
    }


def diff_metrics(base: Dict[str, Any], current: Dict[str, Any]) -> Dict[str, Any]:
    keys = [
        'first_pass_success_rate',
        'retry_recovery_rate',
        'avg_turn_latency_ms',
        'avoidable_failure_count',
        'tool_error_rate',
    ]
    out = {}
    for k in keys:
        b = float(base.get('metrics', {}).get(k, 0.0))
        c = float(current.get('metrics', {}).get(k, 0.0))
        out[k] = {
            'baseline': b,
            'current': c,
            'delta': round(c - b, 2),
        }
    return out


def write_json(path: Path, data: Dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding='utf-8')


def main() -> int:
    workspace = Path('/home/moonlight/.openclaw/workspace')
    default_session_dir = Path('/home/moonlight/.openclaw/agents/main/sessions')
    default_report_dir = workspace / 'reports' / 'smart_stable'
    default_baseline = default_report_dir / 'baseline.json'

    p = argparse.ArgumentParser(description='Smart+Stable metrics collector (24h baseline/compare).')
    sub = p.add_subparsers(dest='cmd', required=True)

    def add_common(sp):
        sp.add_argument('--hours', type=int, default=24)
        sp.add_argument('--session-dir', type=Path, default=default_session_dir)
        sp.add_argument('--include-cron', action='store_true')

    s1 = sub.add_parser('snapshot', help='Collect a metrics snapshot')
    add_common(s1)
    s1.add_argument('--out', type=Path, default=None)

    s2 = sub.add_parser('baseline', help='Set baseline snapshot')
    add_common(s2)
    s2.add_argument('--baseline', type=Path, default=default_baseline)

    s3 = sub.add_parser('compare', help='Compare current snapshot vs baseline')
    add_common(s3)
    s3.add_argument('--baseline', type=Path, default=default_baseline)
    s3.add_argument('--out', type=Path, default=None)

    args = p.parse_args()

    if args.cmd == 'snapshot':
        snap = collect_metrics(args.session_dir, args.hours, args.include_cron)
        out = args.out or (default_report_dir / f"snapshot-{datetime.now().strftime('%Y%m%d-%H%M%S')}.json")
        write_json(out, snap)
        print(json.dumps({'status': 'ok', 'snapshot': str(out), 'metrics': snap['metrics']}, ensure_ascii=False, indent=2))
        return 0

    if args.cmd == 'baseline':
        snap = collect_metrics(args.session_dir, args.hours, args.include_cron)
        write_json(args.baseline, snap)
        print(json.dumps({'status': 'ok', 'baseline': str(args.baseline), 'metrics': snap['metrics']}, ensure_ascii=False, indent=2))
        return 0

    if args.cmd == 'compare':
        if not args.baseline.exists():
            print(json.dumps({'status': 'error', 'error': f'baseline not found: {args.baseline}'}, ensure_ascii=False, indent=2))
            return 2
        baseline = json.loads(args.baseline.read_text(encoding='utf-8'))
        current = collect_metrics(args.session_dir, args.hours, args.include_cron)
        report = {
            'generated_at': datetime.now(timezone.utc).isoformat(),
            'baseline_path': str(args.baseline),
            'baseline_generated_at': baseline.get('generated_at'),
            'current': current,
            'diff': diff_metrics(baseline, current),
        }
        out = args.out or (default_report_dir / f"compare-{datetime.now().strftime('%Y%m%d-%H%M%S')}.json")
        write_json(out, report)
        print(json.dumps({'status': 'ok', 'compare': str(out), 'diff': report['diff']}, ensure_ascii=False, indent=2))
        return 0

    return 1


if __name__ == '__main__':
    raise SystemExit(main())
