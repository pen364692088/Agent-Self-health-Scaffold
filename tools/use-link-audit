#!/usr/bin/env python3
""" Use Link Audit Tool v1.2
验证 recall→use 事件链路健康度
区分两种事件:
- recall: 检索阶段（不计入 use_term）
- use: adoption 阶段（计入 use_term，只有被引用时发射）
通过标准:
- recall_coverage: recall 完整性
- use_adoption_rate: use / recall（合理区间）
- use_attribution: use 事件 memory_id 正确率

Adoption 指标定义 (v1.2 新增):
1. adoption_rate_any (主指标)
   - 公式：recalls_with_any_use / recall_count
   - 取值：0-100%
   - 含义："这次检索最终是否真的用到了记忆"

2. uses_per_recall
   - 公式：use_count / recall_count (允许 >1)
   - 含义："平均每次检索用了几条记忆"

3. candidate_adoption_rate
   - 公式：use_count / recalled_candidates_total
   - 含义：检索结果的"命中质量"
"""

import json
import sys
from pathlib import Path
from datetime import datetime, timedelta
from collections import defaultdict

MEMORY_ROOT = Path.home() / ".openclaw/workspace/memory"
EVENTS_LOG = MEMORY_ROOT / "events.log"
USE_LINK_FILE = MEMORY_ROOT / "use_link_audit.json"
COVERAGE_THRESHOLD = 0.95
ATTRIBUTION_THRESHOLD = 0.99

def load_events(hours=24):
    events = []
    if not EVENTS_LOG.exists():
        return events
    cutoff = datetime.now() - timedelta(hours=hours)
    for line in EVENTS_LOG.read_text().strip().split("\n"):
        if not line.strip() or line.startswith("#"):
            continue
        try:
            event = json.loads(line)
            ts_str = event.get("ts", "")
            if ts_str:
                ts = datetime.fromisoformat(ts_str.replace("Z", ""))
                if ts >= cutoff:
                    events.append(event)
        except:
            pass
    return events

def analyze_events(events):
    """
    分析 recall 和 use 事件链路
    
    新增 Adoption 指标 (v1.2):
    - adoption_rate_any: recalls_with_any_use / recall_count
    - uses_per_recall: use_count / recall_count
    - candidate_adoption_rate: use_count / recalled_candidates_total
    
    v1.2.1 新增:
    - event_version 过滤: 只统计 v2 事件
    - 分位数输出: uses_per_recall_p50/p90
    """
    recall_count = 0
    use_count = 0
    use_attributed_count = 0
    recalled_candidates_total = 0
    
    # 按 recall_id 追踪
    recalls = {}  # recall_id -> {used: [...], has_use: bool, use_count: int}
    uses_by_memory = defaultdict(list)
    uses_per_recall_values = []  # 用于计算分位数
    
    for event in events:
        event_type = event.get("event", "")
        recall_id = event.get("recall_id")
        event_version = event.get("event_version", "v1")
        
        if event_type == "recall":
            # v2 闸门: 只统计 v2 的 recall
            if event_version != "v2":
                continue
            used = event.get("used", [])
            recall_count += len(used)
            recalled_candidates_total += len(used)  # 累加检索到的候选总数
            if recall_id:
                recalls[recall_id] = {
                    "used": used,
                    "has_use": False,
                    "use_count": 0
                }
        elif event_type == "use":
            # v2 闸门: 只统计 v2 的 use
            if event_version != "v2":
                continue
            use_count += 1
            memory_id = event.get("memory_id")
            if memory_id:
                use_attributed_count += 1
                uses_by_memory[memory_id].append(recall_id)
            
            # 标记对应的 recall 有 use
            if recall_id and recall_id in recalls:
                recalls[recall_id]["has_use"] = True
                recalls[recall_id]["use_count"] += 1
    
    # 计算有使用的 recall 数量 (用于 adoption_rate_any)
    recalls_with_any_use = sum(1 for data in recalls.values() if data["has_use"])
    total_recalls = len(recalls) if len(recalls) > 0 else 1
    
    # 计算每个 recall 的 uses 数量（用于分位数）
    uses_per_recall_values = [data["use_count"] for data in recalls.values()]
    
    # 计算分位数
    def percentile(values, p):
        if not values:
            return 0.0
        sorted_vals = sorted(values)
        k = (len(sorted_vals) - 1) * p / 100
        f = int(k)
        c = f + 1 if f + 1 < len(sorted_vals) else f
        return sorted_vals[f] + (k - f) * (sorted_vals[c] - sorted_vals[f]) if c != f else sorted_vals[f]
    
    uses_per_recall_p50 = percentile(uses_per_recall_values, 50)
    uses_per_recall_p90 = percentile(uses_per_recall_values, 90)
    
    # ========== 新增 Adoption 指标 (v1.2) ==========
    # 1. adoption_rate_any: 有使用的 recall 比例
    adoption_rate_any = recalls_with_any_use / total_recalls if total_recalls > 0 else 0.0
    
    # 2. uses_per_recall: 平均每次检索用了几条记忆 (允许 >1)
    uses_per_recall = use_count / total_recalls if total_recalls > 0 else 0.0
    
    # 3. candidate_adoption_rate: 检索结果的命中质量
    candidate_adoption_rate = use_count / recalled_candidates_total if recalled_candidates_total > 0 else 0.0
    # ===============================================
    
    # 计算旧的 adoption rate (向后兼容)
    adoption_rate = use_count / recall_count if recall_count > 0 else 0.0
    
    # 计算 attribution
    attribution = use_attributed_count / use_count if use_count > 0 else 0.0
    
    # 找出 recall_without_use
    recall_without_use = []
    for rid, data in list(recalls.items())[-20:]:
        if not data["has_use"]:
            for mem_id in data["used"]:
                recall_without_use.append({
                    "recall_id": rid,
                    "memory_id": mem_id
                })
    
    # 计算 recall coverage（有对应 recall 事件的 retrieval）
    retrieval_count = sum(1 for e in events if e.get("event") == "retrieval")
    recall_coverage = recall_count / (recall_count + retrieval_count) if (recall_count + retrieval_count) > 0 else 1.0
    
    return {
        "recall_count_24h": recall_count,
        "use_count_24h": use_count,
        "use_attributed_count_24h": use_attributed_count,
        "adoption_rate": round(adoption_rate, 4),
        "use_attribution": round(attribution, 4),
        "recall_coverage": round(recall_coverage, 4),
        "recall_without_use_samples": recall_without_use[-10:],
        "unique_memory_ids_used": len(uses_by_memory),
        # v1.2 新增 Adoption 指标
        "adoption_rate_any": round(adoption_rate_any, 4),
        "uses_per_recall": round(uses_per_recall, 4),
        "candidate_adoption_rate": round(candidate_adoption_rate, 4),
        # v1.2.1 新增分位数
        "uses_per_recall_p50": round(uses_per_recall_p50, 2),
        "uses_per_recall_p90": round(uses_per_recall_p90, 2),
        # 辅助数据
        "recalls_with_any_use": recalls_with_any_use,
        "total_recalls": total_recalls,
        "recalled_candidates_total": recalled_candidates_total,
        "event_version_filter": "v2",
    }

def generate_report():
    print("=" * 60)
    print("Use Link Audit Report v1.2")
    print("=" * 60)
    events = load_events(hours=24)
    print(f"\n📊 Events analyzed (24h): {len(events)}")
    metrics = analyze_events(events)
    
    print("\n📊 Recall → Use Chain")
    print(f" recall_count_24h: {metrics['recall_count_24h']}")
    print(f" use_count_24h: {metrics['use_count_24h']}")
    print(f" adoption_rate: {metrics['adoption_rate']:.1%}")
    print(f" recall_coverage: {metrics['recall_coverage']:.1%}")
    
    print("\n📊 Use Event Quality")
    print(f" use_attribution: {metrics['use_attribution']:.1%}")
    print(f" unique_memory_ids: {metrics['unique_memory_ids_used']}")
    
    # ========== v1.2 新增 Adoption 指标 ==========
    print("\n📊 Adoption Metrics (v1.2)")
    print(f" adoption_rate_any: {metrics['adoption_rate_any']:.1%}")
    print(f"   公式：recalls_with_any_use / recall_count = {metrics['recalls_with_any_use']} / {metrics['total_recalls']}")
    print(f"   含义：这次检索最终是否真的用到了记忆")
    
    print(f" uses_per_recall: {metrics['uses_per_recall']:.2f}")
    print(f"   公式：use_count / recall_count = {metrics['use_count_24h']} / {metrics['total_recalls']}")
    print(f"   含义：平均每次检索用了几条记忆 (允许 >1)")
    
    print(f" candidate_adoption_rate: {metrics['candidate_adoption_rate']:.1%}")
    print(f"   公式：use_count / recalled_candidates_total = {metrics['use_count_24h']} / {metrics['recalled_candidates_total']}")
    print(f"   含义：检索结果的命中质量")
    
    # ========== v1.2.1 新增分位数 ==========
    print("\n📊 Distribution Metrics (v1.2.1)")
    print(f" uses_per_recall_p50: {metrics['uses_per_recall_p50']:.2f}")
    print(f" uses_per_recall_p90: {metrics['uses_per_recall_p90']:.2f}")
    print(f" event_version_filter: {metrics.get('event_version_filter', 'v2')}")
    # ===============================================
    
    # Gap analysis
    recall_without_use = metrics.get("recall_without_use_samples", [])
    print("\n📊 Gap Analysis")
    print(f" recall_without_use: {len(recall_without_use)} samples")
    if len(recall_without_use) > 0:
        print(f" ⚠️ 这些 recall 没有对应的 use 事件（可能未被实际引用）")
        for sample in recall_without_use[:3]:
            print(f" - {sample['memory_id']}")
    
    # Gates
    print("\n🚦 Gates")
    gates_pass = True
    if metrics["recall_coverage"] < COVERAGE_THRESHOLD:
        print(f" recall_coverage: {metrics['recall_coverage']:.1%} < {COVERAGE_THRESHOLD:.0%} ❌")
        gates_pass = False
    else:
        print(f" recall_coverage: {metrics['recall_coverage']:.1%} ≥ {COVERAGE_THRESHOLD:.0%} ✅")
    
    if metrics["use_attribution"] < ATTRIBUTION_THRESHOLD:
        print(f" use_attribution: {metrics['use_attribution']:.1%} < {ATTRIBUTION_THRESHOLD:.0%} ❌")
        gates_pass = False
    else:
        print(f" use_attribution: {metrics['use_attribution']:.1%} ≥ {ATTRIBUTION_THRESHOLD:.0%} ✅")
    
    # Adoption rate 警告
    if metrics["adoption_rate"] > 0.95:
        print(f" adoption_rate: {metrics['adoption_rate']:.1%} ⚠️ WARN (接近 100%，可能语义偏移)")
        print(f" 检查 use 事件是否只在 adoption 时发射")
    elif metrics["adoption_rate"] < 0.1:
        print(f" adoption_rate: {metrics['adoption_rate']:.1%} ⚠️ WARN (过低，大部分检索未被引用)")
    else:
        print(f" adoption_rate: {metrics['adoption_rate']:.1%} ✅ (合理区间)")
    
    print("\n" + "=" * 60)
    print(f"RESULT: {'✅ GATES PASS' if gates_pass else '❌ GATES FAILED'}")
    print("=" * 60)
    
    # Save report
    report = {
        "ts": datetime.now().isoformat() + "Z",
        "metrics": metrics,
        "gates_pass": gates_pass
    }
    USE_LINK_FILE.parent.mkdir(parents=True, exist_ok=True)
    USE_LINK_FILE.write_text(json.dumps(report, indent=2))
    print(f"\nReport saved: {USE_LINK_FILE}")
    
    return gates_pass

if __name__ == "__main__":
    all_pass = generate_report()
    sys.exit(0 if all_pass else 1)
