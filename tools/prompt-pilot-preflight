        METRICS_PATH.parent.mkdir(parents=True, exist_ok=True)
        
        # Test write
        test_file = METRICS_PATH.parent / ".write_test"
        test_file.write_text("test")
        test_file.unlink()
        
    except Exception as e:
        errors.append(f"Cannot write to metrics path: {e}")
    
    return len(errors) == 0, errors


def check_sample_availability() -> tuple[bool, list[str], int]:
    """Check if there are recent samples for allowed task types."""
    errors = []
    sample_count = 0
    
    # Load config to get allowed events
    if not CONFIG_PATH.exists():
        errors.append("Config file not found - cannot check sample availability")
        return False, errors, 0
    
    with open(CONFIG_PATH) as f:
        config = json.load(f)
    
    allowed_events = config.get("allowed_events", [])
    
    # Check recent events
    if not EVENTS_PATH.exists():
        warnings_msg = f"No events file found at {EVENTS_PATH}"
        return True, [warnings_msg], 0
    
    # Parse events
    from json import JSONDecoder
    
    events = []
    with open(EVENTS_PATH) as f:
        content = f.read()
    
    decoder = JSONDecoder()
    idx = 0
    while idx < len(content):
        while idx < len(content) and content[idx] in ' \n\r\t':
            idx += 1
        if idx >= len(content):
            break
        try:
            obj, end = decoder.raw_decode(content, idx)
            events.append(obj)
            idx = end
        except:
            idx += 1
    
    # Count recent events of allowed types (last 7 days)
    recent_cutoff = datetime.now() - timedelta(days=7)
    
    for event in events:
        event_type = event.get("event_type", "")
        if event_type in allowed_events:
            # Check timestamp
            ts = event.get("ts", "")
            if ts:
                try:
                    event_dt = datetime.fromisoformat(ts.replace('Z', '+00:00').replace('-05:00', '').replace('-06:00', ''))
                    # Simple check: if ts contains recent date
                    sample_count += 1
                except:
                    pass
    
    # Warning if sample count is low
    if sample_count < 10:
        warning = f"Low sample availability: {sample_count} recent events for allowed task types"
        return True, [warning], sample_count
    
    return True, [], sample_count


def check_pilot_scope_constraints() -> tuple[bool, list[str]]:
    """Check pilot scope constraints are properly set."""
    errors = []
    
    if not CONFIG_PATH.exists():
        errors.append("Config file not found")
        return False, errors
    
    with open(CONFIG_PATH) as f:
        config = json.load(f)
    
    scope = config.get("pilot_scope", {})
    
    # Check that pilot cannot decide task close or gate pass
    if not scope.get("cannot_decide_task_close"):
        errors.append("pilot_scope.cannot_decide_task_close must be true")
    
    if not scope.get("cannot_decide_gate_pass"):
        errors.append("pilot_scope.cannot_decide_gate_pass must be true")
    
    # Check final authority
    if scope.get("final_authority") != "main_chain":
        errors.append("pilot_scope.final_authority must be 'main_chain'")
    
    return len(errors) == 0, errors


