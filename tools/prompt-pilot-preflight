    return len(errors) == 0, errors


def check_config() -> tuple[bool, list[str], dict]:
    """Check pilot configuration completeness."""
    errors = []
    warnings = []
    
    if not CONFIG_PATH.exists():
        errors.append(f"Config file not found: {CONFIG_PATH}")
        return False, errors, {}
    
    with open(CONFIG_PATH) as f:
        config = json.load(f)
    
    # Required keys
    required_keys = [
        "pilot_enabled",
        "pilot_mode",
        "allowed_events",
        "authority_chain",
        "stop_conditions",
        "dual_gate"
    ]
    
    for key in required_keys:
        if key not in config:
            errors.append(f"Missing config key: {key}")
    
    # Check authority chain is main_chain
    if config.get("authority_chain", {}).get("prompt") != "main_chain":
        errors.append("Authority chain must be 'main_chain' for safety")
    
    # Check stop conditions completeness
    stop = config.get("stop_conditions", {})
    required_stop_keys = [
        "max_conflict_rate",
        "max_missing_rate",
        "min_match_rate",
        "max_token_overhead",
        "max_fallback_rate",
        "max_manual_override_rate",
        "min_provenance_completeness"
    ]
    
    for key in required_stop_keys:
        if key not in stop:
            warnings.append(f"Stop condition missing: {key}")
    
    # Check dual gate configuration
    dual_gate = config.get("dual_gate", {})
    if "shadow_to_pilot" not in dual_gate:
        errors.append("Missing dual_gate.shadow_to_pilot configuration")
    else:
        stp = dual_gate["shadow_to_pilot"]
        if "min_samples" not in stp:
            errors.append("Missing shadow_to_pilot.min_samples")
        if "max_days" not in stp:
            errors.append("Missing shadow_to_pilot.max_days")
    
    if "pilot_to_decision" not in dual_gate:
        warnings.append("Missing dual_gate.pilot_to_decision configuration")
    
    return len(errors) == 0, errors + warnings, config


def check_rollback_switch() -> tuple[bool, list[str]]:
    """Check if rollback switch is available and functional."""
    errors = []
    
    if not CONFIG_PATH.exists():
        errors.append("Config file not found - cannot verify rollback switch")
        return False, errors
    
    with open(CONFIG_PATH) as f:
        config = json.load(f)
    
    # Check rollback triggers
    rollback = config.get("rollback_trigger", {})
    
    if not rollback.get("manual"):
        errors.append("Manual rollback not enabled in config")
    
    # Test rollback by toggling pilot_enabled
    original = config.get("pilot_enabled", False)
    
    try:
        # Try to set pilot_enabled to false
        config["pilot_enabled"] = False
        CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
        with open(CONFIG_PATH, 'w') as f:
            json.dump(config, f, indent=2)
        
        # Verify
        with open(CONFIG_PATH) as f:
            verify = json.load(f)
        
        if verify.get("pilot_enabled") != False:
            errors.append("Rollback switch verification failed")
        
        # Restore
        config["pilot_enabled"] = original
        with open(CONFIG_PATH, 'w') as f:
            json.dump(config, f, indent=2)
            
    except Exception as e:
        errors.append(f"Rollback switch test failed: {e}")
    
    return len(errors) == 0, errors


