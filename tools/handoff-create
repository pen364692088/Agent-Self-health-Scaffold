#!/usr/bin/env python3
"""
handoff-create v1.1.1a - Create handoff summary with proper identity

Creates handoff.md with essential context for session recovery.
Logs handoff_created event with handoff_id for proper deduplication.

Usage:
    handoff-create
    handoff-create --summary "text"
    handoff-create --json
"""

import argparse
import hashlib
import json
import os
import subprocess
from datetime import datetime
from pathlib import Path

WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
SESSION_STATE = WORKSPACE / "SESSION-STATE.md"
WORKING_BUFFER = WORKSPACE / "working-buffer.md"
HANDOFF = WORKSPACE / "handoff.md"


def get_session_id() -> str:
    return os.environ.get("OPENCLAW_SESSION_ID",
                          os.environ.get("TELEGRAM_CHAT_ID", "unknown"))


def generate_handoff_id(file_content: str, session_id: str, ts: str) -> str:
    """Generate deterministic handoff_id."""
    content_hash = hashlib.sha256(file_content.encode()).hexdigest()[:8]
    ts_short = ts.replace(":", "").replace("-", "").replace(".", "")[:15]
    return f"{content_hash}:{ts_short}"


def extract_field(content: str, field_name: str) -> str:
    """Extract a field value from markdown content."""
    if not content:
        return "N/A"
    
    lines = content.split("\n")
    in_field = False
    value_lines = []
    
    for line in lines:
        if line.strip().startswith(f"## {field_name}") or \
           line.strip().startswith(f"## Current {field_name}"):
            in_field = True
            continue
        if in_field:
            if line.strip().startswith("##"):
                break
            value_lines.append(line)
    
    value = "\n".join(value_lines).strip()
    return value if value else "N/A"


def create_handoff(summary: str = None) -> dict:
    """Create handoff.md from current state."""
    timestamp = datetime.now().isoformat()
    session_id = get_session_id()
    
    # Read current state
    session_state = SESSION_STATE.read_text() if SESSION_STATE.exists() else ""
    working_buffer = WORKING_BUFFER.read_text() if WORKING_BUFFER.exists() else ""
    
    # Extract fields
    objective = extract_field(session_state, "Objective")
    phase = extract_field(session_state, "Phase")
    branch = extract_field(session_state, "Branch")
    next_actions = extract_field(session_state, "Next Actions")
    blockers = extract_field(session_state, "Blockers")
    focus = extract_field(working_buffer, "Focus")
    
    # Build handoff content
    handoff_content = f"""# Handoff Summary

**Created**: {timestamp}
**Session ID**: {session_id}

---

## Current Objective
{objective}

## Current Phase
{phase}

## Current Branch / Workspace
{branch}

## Next Actions
{next_actions}

## Blockers
{blockers}

## Active Focus
{focus}

---

## Quick Resume

When resuming:
1. Read SESSION-STATE.md
2. Read working-buffer.md
3. Check current git branch
4. Continue from Next Actions

---

*Auto-generated by handoff-create v1.1.1a*
"""
    
    if summary:
        handoff_content += f"\n\n## Summary\n{summary}\n"
    
    # Generate handoff_id based on content
    handoff_id = generate_handoff_id(handoff_content, session_id, timestamp)
    
    # Write handoff
    HANDOFF.write_text(handoff_content)
    
    # Log event with handoff_id
    log_handoff_event(session_id, handoff_id)
    
    return {
        "created": True,
        "path": str(HANDOFF),
        "timestamp": timestamp,
        "session_id": session_id,
        "handoff_id": handoff_id
    }


def log_handoff_event(session_id: str, handoff_id: str):
    """Log handoff_created event with proper identity (v1.1.1a)."""
    try:
        cmd = [
            str(WORKSPACE / "tools" / "continuity-event-log"),
            "handoff_created",
            "--session-id", session_id,
            "--handoff-id", handoff_id
        ]
        env = os.environ.copy()
        env["CONTINUITY_SOURCE_TOOL"] = "handoff-create"
        subprocess.run(cmd, capture_output=True, timeout=5, env=env)
    except Exception:
        pass


def main():
    parser = argparse.ArgumentParser(description="Create handoff summary v1.1.1a")
    parser.add_argument("--summary", type=str, help="Additional summary text")
    parser.add_argument("--json", action="store_true", help="JSON output")
    args = parser.parse_args()
    
    result = create_handoff(summary=args.summary)
    
    if args.json:
        print(json.dumps(result, indent=2))
    else:
        print(f"✅ Handoff created: {result['path']}")
        print(f"   handoff_id: {result['handoff_id']}")


if __name__ == "__main__":
    main()
