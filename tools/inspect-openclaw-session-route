from __future__ import annotations

from pathlib import Path

DIST = Path('/home/moonlight/.npm-global/lib/node_modules/openclaw/dist')
FILES = [
    DIST / 'pi-embedded-DoQsYfIY.js',
    DIST / 'reply-C5LKjXcC.js',
]
NEEDLES = [
    'function resolveInboundLastRouteSessionKey(params) {',
    'function buildAgentSessionKey(params) {',
    'function resolveAgentRoute(input) {',
    'async function recordInboundSession(params) {',
]

for file in FILES:
