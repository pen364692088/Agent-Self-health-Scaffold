#!/usr/bin/env python3
"""
context-retrieve v2.0 - Two-tier retrieval with explicit source labels

Architecture:
  L1: Capsule/Keyword/Entity fallback (always available)
  L2: OpenViking vector enhancement (optional, degraded if unavailable)

Output includes explicit source labels:
  - source: capsule | vector_index | session_index | recent_active
  - confidence: 0.0-1.0 (quality estimate)
  - tier: L1 | L2

Usage:
  context-retrieve --query <text> --session-id <id>
  context-retrieve --query <text> --capsule-only  # L1 only
  context-retrieve --health
  context-retrieve --test
"""

import argparse
import json
import sys
import subprocess
import re
from pathlib import Path
from datetime import datetime
from typing import Dict, List, Any, Optional, Tuple

WORKSPACE = Path("/home/moonlight/.openclaw/workspace")
CAPSULES_DIR = WORKSPACE / "artifacts" / "capsules"
SESSIONS_DIR = Path.home() / ".openclaw" / "agents" / "main" / "sessions"
DB_PATH = WORKSPACE / ".session-index" / "sessions.db"

DEFAULT_MAX_SNIPPETS = 4
MAX_SNIPPET_CHARS = 500


class TwoTierRetriever:
    """Two-tier retrieval system with explicit source labels."""
    
    def __init__(self, use_vector: bool = True):
        self.use_vector = use_vector
        self.openviking_available = self._check_openviking()
    
    def _check_openviking(self) -> bool:
        """Check if OpenViking is available and responding."""
        if not self.use_vector:
            return False
        try:
            result = subprocess.run(['openviking', 'health'], 
                                   capture_output=True, text=True, timeout=5)
            # OpenViking health may return non-zero when healthy=false
            # but we only care if it's responding (ok=true)
            if result.stdout:
                data = json.loads(result.stdout)
                return data.get('ok', False)
            return False
        except:
            return False
    
    # === L1: Capsule Fallback (Always Available) ===
    
    def search_capsules_l1(self, capsules: List[Dict], query: str, 
                           session_id: Optional[str] = None) -> List[Dict]:
        """L1: Keyword-based capsule search (always available)."""
        results = []
        
        for capsule in capsules:
            if session_id and capsule.get('session_id') != session_id:
                continue
            
            # Build searchable text
            search_fields = [
                capsule.get('topic', ''),
                capsule.get('summary', ''),
                ' '.join(capsule.get('retrieval_keys', [])),
                ' '.join([str(d) for d in capsule.get('decisions', [])]),
                ' '.join(capsule.get('hard_constraints', [])),
                ' '.join([str(e.get('name', '')) for e in capsule.get('entities', [])])
            ]
            search_text = ' '.join(search_fields)
            
            # Keyword matching
            score = self._keyword_match(query, search_text)
            
            if score > 0:
                confidence = self._estimate_confidence(score, 'capsule')
                results.append({
                    'source': 'capsule',
                    'tier': 'L1',
                    'capsule_id': capsule.get('capsule_id', 'unknown'),
                    'session_id': capsule.get('session_id', ''),
                    'relevance': round(score, 2),
                    'confidence': round(confidence, 2),
                    'content': self._truncate_content({
                        'topic': capsule.get('topic', ''),
                        'summary': capsule.get('summary', ''),
                        'decisions': capsule.get('decisions', [])[:3],
                        'hard_constraints': capsule.get('hard_constraints', [])[:3],
                        'open_loops': capsule.get('open_loops', [])[:2],
                        'entities': capsule.get('entities', [])[:3]
                    })
                })
        
        results.sort(key=lambda x: x['confidence'], reverse=True)
        return results
    
    def search_session_index_l1(self, query: str, session_id: Optional[str] = None, 
                                limit: int = 5) -> List[Dict]:
        """L1: SQLite FTS search (always available)."""
        if not DB_PATH.exists():
            return []
        
        import sqlite3
        
        try:
            conn = sqlite3.connect(DB_PATH)
            conn.row_factory = sqlite3.Row
            cursor = conn.cursor()
            
            sql = '''
                SELECT session_id, event_id, ts, role, event_type,
                       tool_name, content_preview, source_path, source_line
                FROM events e
                WHERE e.id IN (
                    SELECT rowid FROM events_fts WHERE events_fts MATCH ?
                )
            '''
            params = [query]
            
            if session_id:
                sql += ' AND e.session_id = ?'
                params.append(session_id)
            
            sql += f' ORDER BY e.ts DESC LIMIT {limit}'
            
            results = []
            try:
                cursor.execute(sql, params)
                for row in cursor.fetchall():
                    confidence = self._estimate_confidence(0.7, 'session_index')
                    results.append({
                        'source': 'session_index',
                        'tier': 'L1',
                        'session_id': row['session_id'],
                        'event_id': row['event_id'],
                        'relevance': 0.7,
                        'confidence': round(confidence, 2),
                        'content': self._truncate_content({
                            'event_type': row['event_type'],
                            'tool_name': row['tool_name'],
                            'content_preview': row['content_preview'],
                            'ts': row['ts']
                        })
                    })
            except:
                pass
            
            conn.close()
            return results
        except:
            return []
    
    # === L2: Vector Enhancement (Optional) ===
    
    def search_openviking_l2(self, query: str, limit: int = 5, 
                               uri_scope: str = 'viking://resources/user/memory/') -> List[Dict]:
        """L2: OpenViking semantic search (optional, degraded if unavailable).
        
        Args:
            query: Search query string
            limit: Maximum number of results
            uri_scope: URI prefix for search scope (default: user memory)
        """
        if not self.openviking_available:
            return []
        
        # Health check before L2 call
        try:
            health_result = subprocess.run(
                ['openviking', 'health'],
                capture_output=True, text=True, timeout=5
            )
            
            health_data = json.loads(health_result.stdout)
            # Note: OpenViking may report unhealthy but still work
            # We proceed anyway and let the actual search fail if needed
            if not health_data.get('ok', False):
                return []
        except:
            return []
        
        # L2 search with proper URI scope and retry
        max_retries = 2
        for attempt in range(max_retries + 1):
            try:
                result = subprocess.run(
                    ['openviking', 'find', query, 
                     '-u', uri_scope,
                     '-n', str(limit)],
                    capture_output=True, text=True, timeout=15
                )
                
                if result.returncode != 0:
                    if attempt < max_retries:
                        continue  # Retry
                    return []
                
                break  # Success
            except subprocess.TimeoutExpired:
                if attempt < max_retries:
                    continue  # Retry
                return []
            except:
                return []
        
        try:
            data = json.loads(result.stdout)
            items = data.get('result', {}).get('resources', []) or data.get('resources', []) or data.get('memories', []) or data.get('results', [])
            
            results = []
            for item in items:
                if isinstance(item, dict):
                    score = item.get('score', 0.75)
                    confidence = self._estimate_confidence(score, 'vector_index')
                    results.append({
                        'source': 'vector_index',
                        'tier': 'L2',
                        'uri': item.get('uri', ''),
                        'relevance': round(score, 2),
                        'confidence': round(confidence, 2),
                        'content': self._truncate_content({
                            'abstract': item.get('abstract', ''),
                            'overview': item.get('overview', ''),
                            'metadata': item.get('metadata', {})
                        })
                    })
            
            results.sort(key=lambda x: x['confidence'], reverse=True)
            return results
        except:
            return []
    
    # === Helper Methods ===
    
    def _keyword_match(self, query: str, text: str) -> float:
        """Calculate keyword match score."""
        if not query or not text:
            return 0.0
        
        query_lower = query.lower()
        text_lower = text.lower()
        
        # Extract keywords (Chinese + English 3+ chars)
        query_keywords = set(re.findall(r'\b[\u4e00-\u9fff]+\b|[a-zA-Z]{3,}\b', query_lower))
        
        if not query_keywords:
            return 0.0
        
        matches = sum(1 for kw in query_keywords if kw in text_lower)
        return matches / len(query_keywords)
    
    def _estimate_confidence(self, relevance: float, source: str) -> float:
        """Estimate confidence based on source and relevance.
        
        Confidence reflects quality/authority of the source:
        - capsule: High (structured, curated)
        - session_index: Medium (raw but indexed)
        - vector_index: Variable (depends on embedding quality)
        """
        base_confidence = {
            'capsule': 0.85,
            'session_index': 0.70,
            'vector_index': 0.65,
            'recent_active': 0.80
        }
        
        base = base_confidence.get(source, 0.5)
        # Adjust by relevance
        return min(1.0, base * relevance + 0.1)
    
    def _truncate_content(self, content: Any, max_chars: int = MAX_SNIPPET_CHARS) -> Any:
        """Truncate content to max characters."""
        if isinstance(content, str):
            return content[:max_chars] + "..." if len(content) > max_chars else content
        elif isinstance(content, dict):
            return {k: (v[:max_chars] + "..." if isinstance(v, str) and len(v) > max_chars 
                       else v[:5] if isinstance(v, list) else v)
                    for k, v in content.items()}
        return content
    
    # === Main Retrieval Interface ===
    
    def retrieve(self, query: str, session_id: Optional[str] = None,
                 capsules_path: Optional[Path] = None, max_snippets: int = DEFAULT_MAX_SNIPPETS,
                 capsule_only: bool = False) -> Dict:
        """Run two-tier retrieval with explicit source labels."""
        
        all_snippets = []
        sources_used = []
        
        # === L1: Always Run ===
        
        # Load capsules
        capsules = self._load_capsules(capsules_path)
        
        # L1a: Current session capsules (highest priority)
        if capsules:
            session_capsules = self.search_capsules_l1(capsules, query, session_id)
            for s in session_capsules[:max_snippets]:
                all_snippets.append(s)
                sources_used.append('capsule')
        
        # L1b: Cross-session capsules (if room)
        if len(all_snippets) < max_snippets and capsules:
            cross_capsules = self.search_capsules_l1(capsules, query, None)
            seen_ids = {s.get('capsule_id') for s in all_snippets}
            for s in cross_capsules:
                if s.get('capsule_id') not in seen_ids:
                    s['confidence'] = round(s['confidence'] * 0.9, 2)  # Lower confidence
                    all_snippets.append(s)
                    sources_used.append('capsule_cross_session')
                    if len(all_snippets) >= max_snippets:
                        break
        
        # L1c: Session index (if room)
        if len(all_snippets) < max_snippets:
            index_results = self.search_session_index_l1(query, session_id, limit=3)
            for s in index_results:
                all_snippets.append(s)
                sources_used.append('session_index')
        
        # === L2: Optional Enhancement ===
        
        if not capsule_only and self.openviking_available and len(all_snippets) < max_snippets:
            vector_results = self.search_openviking_l2(query, limit=3)
            for s in vector_results:
                all_snippets.append(s)
                sources_used.append('vector_index')
        
        # Sort by confidence
        all_snippets.sort(key=lambda x: x.get('confidence', 0), reverse=True)
        
        # Limit
        returned = all_snippets[:max_snippets]
        
        return {
            'query': query,
            'session_id': session_id,
            'snippets': returned,
            'total_found': len(all_snippets),
            'returned': len(returned),
            'sources': list(set(sources_used)),
            'tiers': {
                'L1_available': True,
                'L2_available': self.openviking_available and not capsule_only,
                'mode': 'capsule_only' if capsule_only else 'full'
            },
            'metrics': {
                'avg_confidence': round(sum(s.get('confidence', 0) for s in returned) / len(returned), 2) if returned else 0,
                'capsule_count': sum(1 for s in returned if s.get('source') == 'capsule'),
                'vector_count': sum(1 for s in returned if s.get('source') == 'vector_index')
            }
        }
    
    def _load_capsules(self, capsules_path: Optional[Path] = None) -> List[Dict]:
        """Load capsules from file or directory."""
        capsules = []
        
        if capsules_path and capsules_path.exists():
            if capsules_path.is_dir():
                for f in capsules_path.glob("*.json"):
                    try:
                        with open(f, 'r') as fp:
                            capsule = json.load(fp)
                            capsule['_source_file'] = str(f)
                            capsules.append(capsule)
                    except:
                        pass
                for f in capsules_path.glob("*.jsonl"):
                    try:
                        with open(f, 'r') as fp:
                            for line in fp:
                                line = line.strip()
                                if line:
                                    capsule = json.loads(line)
                                    capsule['_source_file'] = str(f)
                                    capsules.append(capsule)
                    except:
                        pass
            else:
                if capsules_path.suffix == '.jsonl':
                    with open(capsules_path, 'r') as fp:
                        for line in fp:
                            line = line.strip()
                            if line:
                                try:
                                    capsule = json.loads(line)
                                    capsule['_source_file'] = str(capsules_path)
                                    capsules.append(capsule)
                                except:
                                    pass
                else:
                    with open(capsules_path, 'r') as fp:
                        capsule = json.load(fp)
                        capsule['_source_file'] = str(capsules_path)
                        capsules.append(capsule)
        
        # Also check default directory
        if CAPSULES_DIR.exists():
            for f in CAPSULES_DIR.glob("*.json"):
                try:
                    with open(f, 'r') as fp:
                        capsule = json.load(fp)
                        capsule['_source_file'] = str(f)
                        if capsule not in capsules:
                            capsules.append(capsule)
                except:
                    pass
        
        return capsules


def run_health_check() -> Dict:
    """Run health check with tier status."""
    checks = {
        'workspace_exists': WORKSPACE.exists(),
        'capsules_dir_exists': CAPSULES_DIR.exists(),
        'sessions_dir_exists': SESSIONS_DIR.exists(),
        'db_exists': DB_PATH.exists(),
        'python_version': sys.version.split()[0]
    }
    
    # Check OpenViking
    try:
        result = subprocess.run(['openviking', 'health'], capture_output=True, text=True, timeout=5)
        # OpenViking health may return non-zero when healthy=false
        # but we only care if it's responding (ok=true)
        if result.stdout:
            data = json.loads(result.stdout)
            checks['openviking_available'] = data.get('ok', False)
        else:
            checks['openviking_available'] = False
    except:
        checks['openviking_available'] = False
    
    # Determine status
    # L1 always available, so "degraded but functional" if only L2 missing
    l1_ok = checks['workspace_exists'] and checks['capsules_dir_exists']
    l2_ok = checks['openviking_available']
    
    if l1_ok and l2_ok:
        status = 'healthy'
    elif l1_ok:
        status = 'degraded_but_functional'  # Can still operate on L1
    else:
        status = 'unhealthy'
    
    return {
        'status': status,
        'tiers': {
            'L1_capsule_fallback': l1_ok,
            'L2_vector_enhancement': l2_ok
        },
        'checks': checks
    }


def run_self_test() -> Dict:
    """Run self-contained test."""
    test_capsule = {
        'capsule_id': 'cap_test_001',
        'session_id': 'test_session_123',
        'topic': 'Context compression design',
        'summary': 'Discussion about implementing context compression.',
        'decisions': [{'decision': 'Use two-tier retrieval', 'rationale': 'Better resilience'}],
        'hard_constraints': ['Must preserve response plan'],
        'open_loops': [],
        'retrieval_keys': ['compression', 'capsule', 'retrieval', 'two-tier'],
        'entities': [{'name': 'OpenClaw', 'type': 'project'}],
        'created_at': datetime.now().isoformat()
    }
    
    test_dir = WORKSPACE / 'test_context_retrieve_temp'
    test_dir.mkdir(exist_ok=True)
    test_file = test_dir / 'test_capsules.jsonl'
    
    with open(test_file, 'w') as f:
        f.write(json.dumps(test_capsule) + '\n')
    
    try:
        retriever = TwoTierRetriever(use_vector=False)
        result = retriever.retrieve(
            query='context compression retrieval',
            session_id='test_session_123',
            capsules_path=test_file,
            max_snippets=2,
            capsule_only=True
        )
        
        checks = {
            'found_snippets': len(result['snippets']) > 0,
            'correct_source': any(s['source'] == 'capsule' for s in result['snippets']),
            'has_confidence': all('confidence' in s for s in result['snippets']),
            'has_tier': all('tier' in s for s in result['snippets']),
            'tier_is_L1': all(s.get('tier') == 'L1' for s in result['snippets']),
            'capsule_only_works': result['tiers']['mode'] == 'capsule_only'
        }
        
        return {
            'status': 'passed' if all(checks.values()) else 'failed',
            'checks': checks,
            'sample_result': {
                'total_found': result['total_found'],
                'returned': result['returned'],
                'sources': result['sources'],
                'avg_confidence': result['metrics']['avg_confidence']
            }
        }
    except Exception as e:
        return {'status': 'failed', 'error': str(e)}
    finally:
        import shutil
        if test_dir.exists():
            shutil.rmtree(test_dir)


def main():
    parser = argparse.ArgumentParser(
        description='context-retrieve v2.0 - Two-tier retrieval with explicit source labels'
    )
    parser.add_argument('--query', '-q', help='Search query')
    parser.add_argument('--session-id', '-s', help='Session ID filter')
    parser.add_argument('--capsules', '-c', help='Path to capsules file or directory')
    parser.add_argument('--max-snippets', '-n', type=int, default=DEFAULT_MAX_SNIPPETS)
    parser.add_argument('--capsule-only', action='store_true',
                        help='L1 only, skip vector search')
    parser.add_argument('--format', '-f', choices=['json', 'markdown'], default='json')
    parser.add_argument('--health', action='store_true', help='Run health check')
    parser.add_argument('--test', action='store_true', help='Run self-test')
    parser.add_argument('--json', action='store_true', help='Force JSON output')
    
    args = parser.parse_args()
    
    if args.health:
        result = run_health_check()
        if args.json:
            print(json.dumps(result, indent=2))
        else:
            print(f"Status: {result['status']}")
            print(f"  L1 (Capsule Fallback): {'✅' if result['tiers']['L1_capsule_fallback'] else '❌'}")
            print(f"  L2 (Vector Enhancement): {'✅' if result['tiers']['L2_vector_enhancement'] else '❌'}")
            for k, v in result['checks'].items():
                if isinstance(v, bool):
                    print(f"  {k}: {'✅' if v else '❌'}")
                else:
                    print(f"  {k}: {v}")
        sys.exit(0 if result['status'] in ['healthy', 'degraded_but_functional'] else 1)
    
    if args.test:
        result = run_self_test()
        print(json.dumps(result, indent=2))
        sys.exit(0 if result['status'] == 'passed' else 1)
    
    if not args.query:
        print(json.dumps({'error': {'type': 'missing_arg', 'message': '--query is required'}}))
        sys.exit(1)
    
    capsules_path = Path(args.capsules) if args.capsules else None
    
    retriever = TwoTierRetriever(use_vector=not args.capsule_only)
    result = retriever.retrieve(
        query=args.query,
        session_id=args.session_id,
        capsules_path=capsules_path,
        max_snippets=args.max_snippets,
        capsule_only=args.capsule_only
    )
    
    if args.format == 'markdown':
        md = f"""# Context Retrieval Results (v2.0)

**Query**: {result['query']}
**Session**: {result.get('session_id', 'N/A')}
**Mode**: {result['tiers']['mode']}
**L1 Available**: {'✅' if result['tiers']['L1_available'] else '❌'}
**L2 Available**: {'✅' if result['tiers']['L2_available'] else '❌'}

## Metrics
- **Avg Confidence**: {result['metrics']['avg_confidence']}
- **Capsule Count**: {result['metrics']['capsule_count']}
- **Vector Count**: {result['metrics']['vector_count']}

## Snippets ({result['returned']}/{result['total_found']})

"""
        for i, snippet in enumerate(result['snippets'], 1):
            md += f"### [{i}] {snippet['source']} (Tier: {snippet['tier']})\n\n"
            md += f"**Confidence**: {snippet.get('confidence', 0):.2f}\n\n"
            content = snippet.get('content', {})
            if isinstance(content, dict):
                for k, v in content.items():
                    if v:
                        md += f"**{k}**: {v}\n"
            else:
                md += str(content)
            md += "\n\n"
        
        print(md)
    else:
        print(json.dumps(result, indent=2, ensure_ascii=False))


if __name__ == '__main__':
    main()
