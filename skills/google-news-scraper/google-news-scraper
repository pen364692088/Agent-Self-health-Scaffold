#!/bin/bash

# Google News Automation Scraper
# Usage: google-news-scraper [command] [options]

set -e

# Configuration
API_KEY="${GOOGLE_NEWS_API_KEY:-}"
CONFIG_FILE="$HOME/.config/google-news-scraper/config"
BASE_URL="https://newsapi.org/v2"
DEFAULT_LIMIT="10"
DEFAULT_COUNTRY="us"
DEFAULT_LANGUAGE="en"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Load configuration
load_config() {
    if [ -z "$API_KEY" ] && [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    fi
    
    # Also try to load from skill config directory
    if [ -z "$API_KEY" ] && [ -f "$(dirname "$0")/config" ]; then
        source "$(dirname "$0")/config"
    fi
    
    if [ -z "$API_KEY" ]; then
        echo -e "${RED}Error: Google News API key not found${NC}"
        echo "Please set GOOGLE_NEWS_API_KEY environment variable or create $CONFIG_FILE"
        echo "Example: echo 'GOOGLE_NEWS_API_KEY=\"your-api-key\"' > $CONFIG_FILE"
        exit 1
    fi
}

# Make API request
make_request() {
    local endpoint="$1"
    local params="$2"
    
    local url="${BASE_URL}/${endpoint}?apiKey=${API_KEY}&${params}"
    
    # Rate limiting: wait if we're making too many requests
    if [ -n "$LAST_REQUEST_TIME" ]; then
        local current_time=$(date +%s)
        local time_diff=$((current_time - LAST_REQUEST_TIME))
        if [ $time_diff -lt 1 ]; then
            sleep 1
        fi
    fi
    
    LAST_REQUEST_TIME=$(date +%s)
    
    # Make request with retry logic
    local max_retries=3
    local retry_count=0
    
    while [ $retry_count -lt $max_retries ]; do
        local response=$(curl -s -w "HTTPSTATUS:%{http_code}" "$url")
        local status_code=$(echo "$response" | grep -o 'HTTPSTATUS:[0-9]*' | cut -d: -f2)
        local body=$(echo "$response" | sed -E 's/HTTPSTATUS:[0-9]*$//')
        
        if [ "$status_code" = "200" ]; then
            echo "$body"
            return 0
        elif [ "$status_code" = "429" ]; then
            echo -e "${YELLOW}Rate limit hit, waiting...${NC}"
            sleep 5
            ((retry_count++))
        elif [ "$status_code" = "401" ]; then
            echo -e "${RED}Error: Invalid API key${NC}"
            exit 1
        else
            echo -e "${RED}Error: HTTP $status_code${NC}"
            if [ -n "$body" ]; then
                echo "$body" | jq -r '.message // .error // "Unknown error"' 2>/dev/null || echo "$body"
            fi
            ((retry_count++))
            sleep 2
        fi
    done
    
    echo -e "${RED}Failed after $max_retries retries${NC}"
    exit 1
}

# Format output
format_output() {
    local format="$1"
    local data="$2"
    
    case "$format" in
        "json")
            echo "$data" | jq .
            ;;
        "csv")
            echo "$data" | jq -r '.articles[] | [.source.name, .title, .description, .publishedAt, .url] | @csv'
            ;;
        *)
            # Human readable format
            echo "$data" | jq -r '
                if .articles then
                    .articles[] | 
                    "📰 [" + .source.name + "] " + .title + "\n" +
                    "   📅 Published: " + (.publishedAt | fromdateiso8601 | strftime("%Y-%m-%d %H:%M:%S")) + "\n" +
                    "   📝 " + (.description // "No description") + "\n" +
                    "   🔗 " + .url + "\n"
                else
                    "No articles found"
                end
            '
            ;;
    esac
}

# Top headlines
top_headlines() {
    local country="$1"
    local category="$2"
    local sources="$3"
    local q="$4"
    local limit="$5"
    
    local params="pageSize=${limit}"
    
    [ -n "$country" ] && params="${params}&country=${country}"
    [ -n "$category" ] && params="${params}&category=${category}"
    [ -n "$sources" ] && params="${params}&sources=${sources}"
    [ -n "$q" ] && params="${params}&q=${q}"
    
    make_request "top-headlines" "$params"
}

# Search everything
search_news() {
    local q="$1"
    local sources="$2"
    local domains="$3"
    local from="$4"
    local to="$5"
    local language="$6"
    local sort_by="$7"
    local limit="$8"
    
    local params="q=${q}&pageSize=${limit}"
    
    [ -n "$sources" ] && params="${params}&sources=${sources}"
    [ -n "$domains" ] && params="${params}&domains=${domains}"
    [ -n "$from" ] && params="${params}&from=${from}"
    [ -n "$to" ] && params="${params}&to=${to}"
    [ -n "$language" ] && params="${params}&language=${language}"
    [ -n "$sort_by" ] && params="${params}&sortBy=${sort_by}"
    
    make_request "everything" "$params"
}

# Get sources
get_sources() {
    local category="$1"
    local language="$2"
    local country="$3"
    
    local params=""
    
    [ -n "$category" ] && params="${params}&category=${category}"
    [ -n "$language" ] && params="${params}&language=${language}"
    [ -n "$country" ] && params="${params}&country=${country}"
    
    make_request "sources" "$params"
}

# Show help
show_help() {
    cat << EOF
Google News Automation Scraper

USAGE:
    google-news-scraper [COMMAND] [OPTIONS]

COMMANDS:
    top                 Get top headlines
    topic <category>    Get news by category
    search <query>      Search news by keyword
    sources             List available sources
    help                Show this help

CATEGORIES:
    business, entertainment, general, health, science, sports, technology

OPTIONS:
    --country <code>    Country code (default: us)
    --language <code>   Language code (default: en)
    --sources <list>    Comma-separated source list
    --limit <number>    Number of articles (default: 10)
    --sort <field>      Sort by: publishedAt, relevancy, popularity
    --format <type>     Output format: default, json, csv
    --from <date>       From date (YYYY-MM-DD)
    --to <date>         To date (YYYY-MM-DD)
    --domains <list>    Comma-separated domain list

EXAMPLES:
    google-news-scraper top
    google-news-scraper topic technology --limit 5
    google-news-scraper search "artificial intelligence" --sort publishedAt
    google-news-scraper topic business --country gb --language en
    google-news-scraper sources --category technology

CONFIGURATION:
    Set API key: export GOOGLE_NEWS_API_KEY="your-api-key"
    Or create: ~/.config/google-news-scraper/config

EOF
}

# Main script
main() {
    local command="$1"
    shift
    
    # Default values
    local country="$DEFAULT_COUNTRY"
    local language="$DEFAULT_LANGUAGE"
    local sources=""
    local domains=""
    local category=""
    local query=""
    local sort_by="publishedAt"
    local limit="$DEFAULT_LIMIT"
    local format="default"
    local from_date=""
    local to_date=""
    
    # Parse arguments
    while [ $# -gt 0 ]; do
        case $1 in
            --country)
                country="$2"
                shift 2
                ;;
            --language)
                language="$2"
                shift 2
                ;;
            --sources)
                sources="$2"
                shift 2
                ;;
            --domains)
                domains="$2"
                shift 2
                ;;
            --limit)
                limit="$2"
                shift 2
                ;;
            --sort)
                sort_by="$2"
                shift 2
                ;;
            --format)
                format="$2"
                shift 2
                ;;
            --from)
                from_date="$2"
                shift 2
                ;;
            --to)
                to_date="$2"
                shift 2
                ;;
            *)
                if [ -z "$query" ] && [ "$command" = "search" ]; then
                    query="$1"
                elif [ -z "$category" ] && [ "$command" = "topic" ]; then
                    category="$1"
                fi
                shift
                ;;
        esac
    done
    
    # Load configuration
    load_config
    
    # Execute command
    case "$command" in
        "top")
            echo -e "${BLUE}📰 Top Headlines (${country^^})${NC}"
            echo "====================="
            echo ""
            result=$(top_headlines "$country" "$category" "$sources" "$query" "$limit")
            format_output "$format" "$result"
            ;;
        "topic")
            if [ -z "$category" ]; then
                echo -e "${RED}Error: Category required for topic command${NC}"
                echo "Available categories: business, entertainment, general, health, science, sports, technology"
                exit 1
            fi
            echo -e "${BLUE}📰 ${category^} News${NC}"
            echo "==================="
            echo ""
            result=$(top_headlines "$country" "$category" "$sources" "$query" "$limit")
            format_output "$format" "$result"
            ;;
        "search")
            if [ -z "$query" ]; then
                echo -e "${RED}Error: Search query required${NC}"
                exit 1
            fi
            echo -e "${BLUE}🔍 Search Results: $query${NC}"
            echo "========================="
            echo ""
            result=$(search_news "$query" "$sources" "$domains" "$from_date" "$to_date" "$language" "$sort_by" "$limit")
            format_output "$format" "$result"
            ;;
        "sources")
            echo -e "${BLUE}📡 Available Sources${NC}"
            echo "===================="
            echo ""
            result=$(get_sources "$category" "$language" "$country")
            echo "$result" | jq -r '.sources[] | "• " + .name + " (" + .category + ") - " + .description'
            ;;
        "help"|"--help"|"-h")
            show_help
            ;;
        *)
            echo -e "${RED}Error: Unknown command '$command'${NC}"
            echo "Use 'google-news-scraper help' for usage information"
            exit 1
            ;;
    esac
}

# Check dependencies
if ! command -v curl &> /dev/null; then
    echo -e "${RED}Error: curl is required but not installed${NC}"
    exit 1
fi

if ! command -v jq &> /dev/null; then
    echo -e "${RED}Error: jq is required but not installed${NC}"
    echo "Install with: sudo apt-get install jq (Ubuntu/Debian) or brew install jq (macOS)"
    exit 1
fi

# Run main function
main "$@"