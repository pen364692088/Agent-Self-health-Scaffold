  "kill_switch": {
    "enabled": true,
    "file": "artifacts/context_compression/mainline_shadow/KILL_SWITCH.md",
    "trigger_on": ["manual", "error_rate_high", "replay_regression"],
    "log_file": "logs/compression_kill_switch.log"
  },
  
  "scoping": {
    "allowed_sessions": [
      "single_topic_daily_chat",
      "non_critical_task",
      "simple_tool_context"
    ],
    "excluded_sessions": [
      "multi_file_debug",
      "high_commitment_task",
      "critical_execution",
      "multi_agent_collaboration",
      "high_risk_scenario"
    ]
  },
  
  "integration_points": {
    "pre_prompt_assemble": {
      "action": "context-budget-check",
      "shadow_only": true
    },
    "on_threshold_reached": {
      "action": "context-compress --mode shadow",
      "shadow_only": true,
      "no_write_to_active_session": true
    },
    "recall_path": {
      "action": "anchor-aware-retrieve",
      "shadow_only": true
    },
    "artifact_output": {
      "path": "artifacts/context_compression/shadow_sessions/",
      "separate_from_main": true
    }
  },
  
  "constraints": {
    "do_not_modify_real_reply": true,
    "do_not_enter_enforced": true,
    "do_not_pollute_active_session": true,
    "do_not_expand_patch_set": true,
    "do_not_add_prompt_assemble": true,
    "do_not_cover_high_risk_sessions": true,
    "do_not_modify_old_S1_baseline": true
  },
  
  "observation": {
    "separate_reporting": true,
    "layers": ["total", "real_admissible", "historical_replay"],
    "replay_guardrail": true,
    "metrics": [
      "avg_score",
      ">=0.75_count",
      "correct_topic_wrong_anchor",
      "replay_average",
      "anchor_coverage",
      "shadow_trigger_count",
      "admissible_stats"
    ]
  }
