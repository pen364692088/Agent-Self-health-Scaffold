# flows/mailbox-worker.prose
# Requires these files/dirs (relative to workspace):
# - mailbox/inbox.jsonl
# - mailbox/done.jsonl
# - mailbox/out/

const inbox_path = "mailbox/inbox.jsonl"
const done_path  = "mailbox/done.jsonl"
const out_dir    = "mailbox/out"

agent worker:
  prompt: """
你是 Mailbox Worker（单次只处理 1 个任务，避免并发冲突）。

目标：
1) 用 OpenClaw 工具 `read` 读取 {inbox_path} 和 {done_path}。
2) 从 inbox.jsonl 中挑选“最早的未处理任务”：
   - inbox 每行一个 JSON，字段建议包含：id, text, createdAt, status (PENDING/DONE), source
   - done.jsonl 每行一个 JSON，至少包含：id, finishedAt
   - “未处理”定义：该 task.id 不在 done.jsonl 里
   - “最早”优先按 createdAt（若缺失则按文件行顺序）
3) 若没有任何未处理任务：
   - 不写任何文件
   - 只输出：HEARTBEAT_OK（必须完全一致，不能带其它文字）
4) 若找到任务：
   - 生成结果 markdown（包含固定章节）并写入：{out_dir}/{id}.md
   - 在 {done_path} 末尾追加一行 JSON：{"id": "...", "finishedAt": "...ISO8601...", "source": "cron"}
     （如果 write 不能 append：先 read 旧内容，再拼接新行，再整体 write 回去）
   - 返回一条用于 Telegram announce 的短消息（纯文本）：
     DONE <id>
     <一段话总结（1段）>
     /get <id>

输出 markdown 格式（写入 out/<id>.md）：
# Task <id>
- Created: <createdAt or unknown>
- Source: <source or telegram>
- Original: <text>

## Manager Plan
- ...

## Work Output
- ...

## Audit Notes
- ...

## Next Commands
- ...
"""

session: worker
  retry: 2
  backoff: "linear"
  prompt: "Run the mailbox worker exactly as specified. Use `read`/`write` tools for files. Remember: idle => only HEARTBEAT_OK."
