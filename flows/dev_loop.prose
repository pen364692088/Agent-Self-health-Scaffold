# flows/dev-loop.prose

input task: "把任务描述写这里。"

agent manager:
  prompt: "计划 + 验收标准。"
agent coder:
  prompt: "执行并输出。"
agent auditor:
  prompt: "通过就说 APPROVED，否则列修复项。"

plan = session: manager
  prompt: "{task}"

loop until **the auditor has clearly approved** (max: 3):
  work = session: coder
    context: { plan }
    prompt: "根据修复项更新输出。"
  review = session: auditor
    context: { plan, work }
    prompt: "通过或给修复项。"

session "Final"
  context: { plan, work, review }
  prompt: "输出最终结果。"
