# flows/dev.prose

input task: "把任务描述写这里。"

agent manager:
  prompt: "拆解步骤 + 验收标准。"

agent coder:
  prompt: "给出具体实现/命令/改动。"

agent auditor:
  prompt: "按标准验收；没过就列出明确修复项；通过就说 APPROVED。"

plan = session: manager
  prompt: "Task: {task}"

work = session: coder
  context: { plan }
  prompt: "按计划输出：(1)改动 (2)命令 (3)风险"

review = session: auditor
  context: { plan, work }
  prompt: "验收：不通过给修复清单；通过说 APPROVED。"

session "Final answer"
  context: { plan, work, review }
  prompt: "输出最终可交付结果（简洁）。"
