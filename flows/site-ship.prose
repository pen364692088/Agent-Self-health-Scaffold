# flows/site-ship.prose
# Goal: one-run closed-loop: SPEC -> implement -> verify -> audit -> iterate (<=4) -> morning report.

input project_path: "/home/moonlight/Project/Github/MyProject/PersonWebsite/CVWebsite"
input repo_url: "https://github.com/pen364692088/CVWebsite"
input reference_url: "https://www.guillaumenicollet.com/"
input pages_url: "https://pen364692088.github.io/CVWebsite/"  # expected default

const evidence_dir = "evidence"
const rounds_max = 4

agent manager:
  prompt: """
Write SPEC.md for a static personal website (Astro) with:
- Scope, assumptions, acceptance criteria
- Architecture decisions (Astro, minimal JS animations)
- Content modules: Home/About/Projects(cards)/Resume(link)/Contact
- Security constraints: no secrets, no destructive commands
- Deployment plan: GitHub Pages first, Cloudflare Pages only if blocked
Write SPEC.md in the repo root (project_path). Also update README.md outline (deployment steps placeholder).
"""

agent coder:
  prompt: """
You are the implementer. You MUST create real files in {project_path}.

Hard constraints:
- Static site only.
- Simple, professional, fast, responsive.
- No secrets in repo. No destructive commands. No sudo.

Implementation plan (execute via safe shell commands + file edits):
A) If repo is empty/no package.json:
   - Scaffold Astro using create-astro non-interactively:
     npm create astro@latest . -- --template minimal --yes --install --no-git --skip-houston
   (If '.' fails, scaffold into a temp folder then move contents.)
B) Build site structure:
   - src/pages/index.astro (Home)
   - src/pages/about.astro
   - src/pages/projects.astro
   - src/pages/resume.astro (link to CV)
   - src/pages/contact.astro
   - shared layout/components: src/layouts/BaseLayout.astro, src/components/Nav.astro, Footer.astro, ProjectCard.astro
   - fast CSS: src/styles/global.css (or inline minimal)
   - minimal JS animation (prefer pure CSS/IntersectionObserver; add GSAP/Lenis only if truly needed)
C) Add content inspired by reference_url style: clean typography, generous spacing, subtle motion.
D) Add GitHub Pages workflow using Astro official action:
   - .github/workflows/deploy.yml
E) Configure astro.config.mjs for GitHub Pages:
   - site: https://pen364692088.github.io
   - base: /CVWebsite
F) Ensure README.md has: local dev, build, deploy (GitHub Pages), link-check command.

Each round: apply fixes from previous_audit if any.
Commit changes with a clear message (no pushing secrets).
"""

agent verifier:
  prompt: """
You verify with EVIDENCE. Create folder {evidence_dir}/ if missing.

Must produce:
1) Build log:
   - Run npm install (or npm ci if lockfile) then npm run build
   - Save full output to {evidence_dir}/build.log
2) Link check output:
   - Run: npx linkinator ./dist --recurse
   - Save to {evidence_dir}/linkcheck.txt
3) Deployment evidence:
   - Ensure workflow exists, git remote is {repo_url}, push to main.
   - After push, poll pages_url with:
     curl -I -L {pages_url}
     until you see HTTP 200 (retry with backoff; stop after reasonable attempts).
   - Save final headers to {evidence_dir}/online-check.txt
4) Responsive check evidence (best-effort):
   - At minimum, write {evidence_dir}/responsive-notes.md explaining breakpoints and what was checked.
   - If Playwright is feasible quickly, generate 2 screenshots and save into {evidence_dir}/.

Return a concise PASS/FAIL table against acceptance criteria.
If any step is blocked (permissions/settings), continue with defaults and add “Questions for user”.
"""

agent auditor:
  prompt: """
Audit the current repo state against SPEC.md and acceptance criteria.
Output issues as:
- P0: must fix to ship
- P1: should fix soon
- P2: nice to have
For each issue: minimal fix suggestion (1-3 bullets).
If everything passes, say clearly: APPROVED.
"""

# --- Stage 1: SPEC (always once)
let spec = session: manager
  prompt: "Write SPEC.md + update README.md outline. Repo path: {project_path}"

# --- Stage 2-5: Iterate (<=4)
const previous_audit = "NONE"

loop until **the verifier reports ALL acceptance criteria PASS and the auditor says APPROVED** (max: 4) as round:
  let impl = session: coder
    context: { spec, previous_audit }
    prompt: """
Round {round}/{rounds_max}.
Repo path: {project_path}
Reference: {reference_url}
Do fixes requested in previous_audit (if not NONE), otherwise implement from scratch.
"""

  let verify = session: verifier
    context: { spec, impl }
    prompt: """
Verify with evidence. Repo path: {project_path}
Git remote: {repo_url}
Expected Pages URL: {pages_url}
"""

  let audit = session: auditor
    context: { spec, impl, verify }
    prompt: "Audit and output P0/P1/P2. If clean: APPROVED."

  previous_audit = audit

# --- Final: morning report
session "Morning report"
  context: { spec, previous_audit }
  prompt: """
Write MORNING_REPORT.md in repo root with:
- What was done
- Final Pages URL
- Evidence files list under {evidence_dir}/
- Remaining P1/P2 (if any)
- Questions for user (if any)
Also reply in chat with the report summary.
"""
