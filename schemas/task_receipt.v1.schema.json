{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "task_receipt.v1",
  "title": "Task Receipt Schema",
  "description": "Receipt for task completion verification",
  "type": "object",
  "required": ["task_id", "receipt_type", "status", "generated_at"],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "Unique task identifier"
    },
    "receipt_type": {
      "type": "string",
      "enum": ["contract", "e2e", "preflight", "final"],
      "description": "Type of receipt"
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "blocked"],
      "description": "Receipt status"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": {"type": "string"},
          "status": {"type": "string", "enum": ["pass", "fail", "skip"]},
          "details": {"type": "string"}
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Paths to generated artifacts"
    },
    "gate_results": {
      "type": "object",
      "properties": {
        "gate_a": {"type": "string", "enum": ["pass", "fail", "skip"]},
        "gate_b": {"type": "string", "enum": ["pass", "fail", "skip"]},
        "gate_c": {"type": "string", "enum": ["pass", "fail", "skip"]}
      }
    },
    "state_before": {
      "type": "string",
      "description": "Task state before this receipt"
    },
    "state_after": {
      "type": "string",
      "description": "Task state after this receipt"
    },
    "error": {
      "type": "object",
      "properties": {
        "type": {"type": "string"},
        "message": {"type": "string"}
      }
    }
  }
}
