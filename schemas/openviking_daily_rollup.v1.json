    "date": {"type": "string"},
    "run_count": {"type": "integer", "minimum": 0},
    "coverage_pct": {"type": "object"},
    "skipped_chunks_count": {"type": "object"},
    "fallback_trigger_count": {"type": "object"},
    "dual_guard_trim_count": {"type": "object"},
    "offenders_topN": {"type": "array"},
    "policy_level_distribution": {"type": "object"}
  },
  "additionalProperties": true
}
